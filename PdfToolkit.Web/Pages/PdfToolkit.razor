@page "/delete-pdf-pages"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService

<PageTitle>Delete PDF Pages Free Online — Remove Pages from PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Delete pages from your PDF free online.
                   Remove one or multiple pages instantly.
                   No signup required." />
    <meta name="keywords"
          content="delete pdf pages, remove pages from pdf,
                   pdf page remover free" />
    <link rel="canonical"
          href="https://pdftoolstack.com/delete-pdf-pages" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />

    <div class="tool-container">
        <h1>Delete PDF Pages</h1>
        <p class="tool-subtitle">
            Remove one or multiple pages from your PDF for free.
            No signup required. Files deleted within 1 hour.
        </p>

        @if (CurrentState == PageState.Upload)
        {
            <FileUpload OnFileSelected="HandleFileSelected"
                        OnFileRemoved="HandleFileRemoved" />

            @if (SelectedFile != null && TotalPages > 0)
            {
                <div class="page-selector">
                    <h3>Select pages to delete</h3>
                    <p class="page-selector-hint">
                        Your PDF has @TotalPages pages.
                        Click pages to mark for deletion.
                    </p>

                    <div class="page-grid">
                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var pageNum = i;
                            var isSelected = SelectedPages
                            .Contains(pageNum);
                            <button class="page-tile @(isSelected
                                                                    ? "page-tile-selected" : "")"
                        @onclick="() =>
                                                                TogglePage(pageNum)">
                    @pageNum
                    @if (isSelected)
                                {
                                    <span class="page-delete-x">
                                        ✕
                                    </span>
                                }
                            </button>
                        }
                    </div>

                    @if (SelectedPages.Any())
                    {
                        <p class="selected-summary">
                            @SelectedPages.Count page(s)
                            selected for deletion:
                            @string.Join(", ",
                            SelectedPages.OrderBy(p => p))
            </p>

            <button class="process-button"
                    @onclick="ProcessFile">
                Delete @SelectedPages.Count Page(s)
            </button>
                        }
                </div>
            }
            else if (SelectedFile != null && TotalPages == 0)
            {
                <div class="processing-container">
                    <div class="spinner"></div>
                    <p>Loading page count...</p>
                </div>
            }
        }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                              FileName="@(SelectedFile?.Name ?? "")"
                              ToolType="DeletePdfPages"
                              OnCancel="Reset" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Deleting pages from your PDF...</p>
            </div>
        }

        @if (CurrentState == PageState.Complete
                && ResultBytes != null)
        {
            <AdSlot Size="rectangle" />
            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>Pages Deleted!</h2>
                <p style="color: var(--gray);
                               margin-bottom: 1.5rem;">
                    Successfully removed
                    @DeletedPageCount page(s)
                    from your PDF.
                </p>
                <button class="download-button"
                        @onclick="DownloadFile">
                    Download PDF
                </button>
                <button class="reset-button"
                        @onclick="Reset">
                    Delete More Pages
                </button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button" @onclick="Reset">
                    Try Again
                </button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>Can I delete multiple pages at once?</h3>
            <p>
                Yes — select as many pages as you want to
                remove and they will all be deleted in
                one click.
            </p>
        </div>
        <div class="faq-item">
            <h3>Will the remaining pages be renumbered?</h3>
            <p>
                Yes — the remaining pages will be
                automatically renumbered after deletion.
            </p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>
                Yes — completely free up to 25MB with no
                signup required.
            </p>
        </div>
        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>
                Your file is automatically deleted within
                1 hour. We never store your documents
                permanently.
            </p>
        </div>
    </div>
</div>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private int TotalPages = 0;
    private int DeletedPageCount = 0;
    private HashSet<int> SelectedPages = new();

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = file;
        ErrorMessage = null;
        SelectedPages.Clear();
        TotalPages = 0;

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            if (PaymentService.IsFileTooLargeForFree(
                file.Size))
            {
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            TotalPages = await ApiService
                .GetPageCountAsync(
                    UploadedBytes, file.Name);
        }
        catch (Exception ex)
        {
            ErrorMessage =
                $"Could not read file: {ex.Message}";
            SelectedFile = null;
            UploadedBytes = null;
        }

        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        SelectedPages.Clear();
        TotalPages = 0;
    }

    private void TogglePage(int pageNum)
    {
        if (SelectedPages.Contains(pageNum))
            SelectedPages.Remove(pageNum);
        else
            SelectedPages.Add(pageNum);
        StateHasChanged();
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null ||
            !SelectedPages.Any()) return;

        DeletedPageCount = SelectedPages.Count;
        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            ResultBytes = await ApiService.DeletePagesAsync(
                UploadedBytes,
                SelectedFile!.Name,
                SelectedPages);

            if (ResultBytes != null)
                CurrentState = PageState.Complete;
            else
            {
                ErrorMessage =
                    "Failed to delete pages. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "document")
            + "_pages_deleted.pdf";
        await JS.InvokeVoidAsync("downloadFile",
            fileName,
            Convert.ToBase64String(ResultBytes));
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        TotalPages = 0;
        DeletedPageCount = 0;
        SelectedPages.Clear();
    }
}
