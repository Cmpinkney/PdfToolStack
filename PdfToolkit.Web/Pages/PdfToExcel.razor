@page "/pdf-to-excel"

<PageTitle>PDF to Excel Converter Free Online</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert PDF to Excel spreadsheet free online.
                   Extract tables from PDF to XLSX.
                   No signup required." />
    <meta name="keywords"
          content="pdf to excel, convert pdf to xlsx,
                   pdf table extractor free" />
    <link rel="canonical"
          href="https://pdftoolstack.com/pdf-to-excel" />
</HeadContent>

<div class="tool-page">
    <div class="tool-container">
        <h1>PDF to Excel Converter</h1>
        <p class="tool-subtitle">
            Extract tables from your PDF and convert to
            Excel spreadsheet format.
        </p>
        <div class="coming-soon-banner">
            <span class="coming-soon-icon">📊</span>
            <div>
                <h3>PDF to Excel Coming Soon</h3>
                <p>
                    We are building an intelligent table
                    extractor that identifies and converts
                    PDF tables to Excel format accurately.
                </p>
            </div>
        </div>
        <div class="notify-section">
            <h3>Get notified when it launches</h3>
            @if (NotifySubmitted)
            {
                <div class="contact-success">
                    <span>✅</span>
                    <p>We'll notify you when this launches!</p>
                </div>
            }
            else
            {
                <div class="notify-form">
                    <input type="email"
                           class="field-input"
                           style="max-width: 300px;"
                           placeholder="your@email.com"
                           @bind="NotifyEmail" />
                    <button class="process-button"
                            style="max-width: 160px;"
                            @onclick="SubmitNotify">
                        Notify Me
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string NotifyEmail = string.Empty;
    private bool NotifySubmitted = false;
    private async Task SubmitNotify()
    {
        if (string.IsNullOrWhiteSpace(NotifyEmail) ||
            !NotifyEmail.Contains('@')) return;
        await Task.Delay(500);
        NotifySubmitted = true;
        StateHasChanged();
    }
}