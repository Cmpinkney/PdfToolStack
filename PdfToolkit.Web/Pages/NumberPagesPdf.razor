@page "/number-pages"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService

<PageTitle>Number PDF Pages Free Online — Add Page Numbers to PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Add page numbers to your PDF free online. 
                   Choose position and starting number. 
                   No signup required." />
    <meta name="keywords"
          content="number pdf pages, add page numbers to pdf,
                   pdf page numbers free" />
    <link rel="canonical"
          href="https://pdftoolstack.com/number-pages" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <h1>Add Page Numbers to PDF</h1>
        <p class="tool-subtitle">
            Insert page numbers into your PDF for free.
            No signup required. Files deleted within 1 hour.
        </p>

        @if (CurrentState == PageState.Upload)
        {
            <FileUpload OnFileSelected="HandleFileSelected"
                        OnFileRemoved="HandleFileRemoved" />

            @if (SelectedFile != null)
            {
                <div class="tool-options-panel">
                    <div class="option-group">
                        <label>Position</label>
                        <select class="field-input"
                                @bind="Position">
                            <option value="bottom-center">
                                Bottom Center
                            </option>
                            <option value="bottom-left">
                                Bottom Left
                            </option>
                            <option value="bottom-right">
                                Bottom Right
                            </option>
                            <option value="top-center">
                                Top Center
                            </option>
                        </select>
                    </div>
                    <div class="option-group">
                        <label>Start numbering from</label>
                        <input type="number"
                               class="field-input"
                               min="1" max="999"
                               @bind="StartNumber" />
                    </div>
                </div>
                <button class="process-button"
                        @onclick="ProcessFile">
                    Add Page Numbers
                </button>
            }
        }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade
                FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                FileName="@(SelectedFile?.Name ?? "")"
                ToolType="NumberPages"
                OnCancel="Reset" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Adding page numbers...</p>
            </div>
        }

        @if (CurrentState == PageState.Complete
             && ResultBytes != null)
        {
            <AdSlot Size="rectangle" />
            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>Page Numbers Added!</h2>
                <p style="color: var(--gray);
                           margin-bottom: 1.5rem;">
                    Page numbers have been added to your PDF.
                </p>
                <button class="download-button"
                        @onclick="DownloadFile">
                    Download PDF
                </button>
                <button class="reset-button"
                        @onclick="Reset">
                    Number Another PDF
                </button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button"
                        @onclick="Reset">
                    Try Again
                </button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>Where can I place page numbers?</h3>
            <p>You can place page numbers at the bottom
               center, bottom left, bottom right, or
               top center of each page.</p>
        </div>
        <div class="faq-item">
            <h3>Can I start from a number other than 1?</h3>
            <p>Yes — set any starting number you need.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no
               signup required.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private string Position = "bottom-center";
    private int StartNumber = 1;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = file;
        ErrorMessage = null;
        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();
            if (PaymentService.IsFileTooLargeForFree(
                file.Size))
            {
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage =
                $"Could not read file: {ex.Message}";
            SelectedFile = null;
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null) return;
        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            ResultBytes = await ApiService.NumberPagesAsync(
                UploadedBytes, SelectedFile!.Name,
                Position, StartNumber);
            CurrentState = ResultBytes != null
                ? PageState.Complete : PageState.Error;
            if (ResultBytes == null)
                ErrorMessage =
                    "Failed to add page numbers.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "document")
            + "_numbered.pdf";
        await JS.InvokeVoidAsync("downloadFile",
            fileName,
            Convert.ToBase64String(ResultBytes));
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        Position = "bottom-center";
        StartNumber = 1;
    }
}