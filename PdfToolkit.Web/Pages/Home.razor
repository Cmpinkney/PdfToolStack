@page "/"

<PageTitle>Free PDF Tools Online — Fast, Free, No Signup</PageTitle>

<HeadContent>
    <meta name="description"
          content="Free online PDF tools. Compress, convert, merge,
                   fill and redact PDF files instantly.
                   No signup required." />
</HeadContent>

<div class="home-page">
    <div class="hero">
        <h1>Free PDF Tools Online</h1>
        <p>
            Fast, free, and no signup required.
            Your files are deleted within 1 hour.
        </p>
    </div>

    <div class="tools-grid">
        <a href="/compress-pdf" class="tool-card">
            <span class="tool-icon">🗜️</span>
            <h2>Compress PDF</h2>
            <p>Reduce PDF file size without losing quality</p>
        </a>

        <a href="/pdf-to-word" class="tool-card">
            <span class="tool-icon">📝</span>
            <h2>PDF to Word</h2>
            <p>Convert PDF to editable Word document</p>
        </a>

        <a href="/merge-pdf" class="tool-card">
            <span class="tool-icon">🔗</span>
            <h2>Merge PDF</h2>
            <p>Combine multiple PDFs into one document</p>
        </a>

        <a href="/fill-pdf-form" class="tool-card">
            <span class="tool-icon">📋</span>
            <h2>Fill PDF Form</h2>
            <p>Fill out interactive PDF forms online</p>
        </a>

        <a href="/redact-pdf" class="tool-card">
            <span class="tool-icon">🔒</span>
            <h2>Redact PDF</h2>
            <p>Permanently remove sensitive information</p>
        </a>
    </div>
</div>
