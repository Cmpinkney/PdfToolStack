@page "/"

<PageTitle>PDFToolstack — Free PDF Tools Online</PageTitle>

<HeadContent>
    <meta name="description"
          content="Free online PDF tools. Compress, convert, merge,
                   edit, sign, and more. No signup required." />
    <meta name="keywords"
          content="free pdf tools, pdf editor online, compress pdf,
                   merge pdf, convert pdf" />
    <link rel="canonical" href="https://pdftoolstack.com" />
</HeadContent>

<div class="home-page">
    <div class="hero">
        <h1>Free PDF Tools Online</h1>
        <p class="hero-subtitle">
            Everything you need to work with PDFs —
            completely free, no signup required,
            files deleted within 1 hour.
        </p>
    </div>

    <div class="tools-grid">

        <a href="/compress-pdf" class="tool-card">
            <span class="tool-icon">🗜️</span>
            <h3>Compress PDF</h3>
            <p>Reduce PDF file size without losing quality</p>
        </a>

        <a href="/pdf-to-word" class="tool-card">
            <span class="tool-icon">📝</span>
            <h3>PDF to Word</h3>
            <p>Convert PDF to editable Word document</p>
        </a>

        <a href="/word-to-pdf" class="tool-card">
            <span class="tool-icon">📄</span>
            <h3>Word to PDF</h3>
            <p>Convert Word documents to PDF files</p>
        </a>

        <a href="/merge-pdf" class="tool-card">
            <span class="tool-icon">🔗</span>
            <h3>Merge PDF</h3>
            <p>Combine multiple PDFs into one document</p>
        </a>

        <a href="/fill-pdf-form" class="tool-card">
            <span class="tool-icon">✍️</span>
            <h3>Fill PDF Form</h3>
            <p>Fill out PDF forms online instantly</p>
        </a>

        <a href="/redact-pdf" class="tool-card">
            <span class="tool-icon">🔒</span>
            <h3>Redact PDF</h3>
            <p>Remove sensitive information permanently</p>
        </a>

        <a href="/delete-pdf-pages" class="tool-card">
            <span class="tool-icon">🗑️</span>
            <h3>Delete PDF Pages</h3>
            <p>Remove one or multiple pages from your PDF</p>
        </a>

        <a href="/organize-pdf" class="tool-card">
            <span class="tool-icon">📋</span>
            <h3>Organize PDF</h3>
            <p>Rearrange, rotate and delete PDF pages</p>
        </a>

        <a href="/sign-pdf" class="tool-card">
            <span class="tool-icon">✒️</span>
            <h3>Sign PDF</h3>
            <p>Add your electronic signature to a PDF</p>
        </a>

        <a href="/edit-pdf" class="tool-card">
            <span class="tool-icon">🖊️</span>
            <h3>Edit PDF</h3>
            <p>Add text, shapes and drawings to your PDF</p>
        </a>

        <a href="/pdf-annotator" class="tool-card">
            <span class="tool-icon">🖍️</span>
            <h3>PDF Annotator</h3>
            <p>Highlight, underline and mark up your PDF</p>
        </a>

        <a href="/pdf-reader" class="tool-card">
            <span class="tool-icon">📖</span>
            <h3>PDF Reader</h3>
            <p>View and share PDFs directly in your browser</p>
        </a>

        <a href="/translate-pdf" class="tool-card">
            <span class="tool-icon">🌍</span>
            <h3>Translate PDF</h3>
            <p>Translate your PDF content to another language</p>
        </a>

    </div>
</div>