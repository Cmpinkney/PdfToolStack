    { "route": "/merge-pdfs-for-submission",     "redirect": "/merge-pdf",            "statusCode": 301 }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/robots.txt",
      "/sitemap.xml",
      "/_framework/*",
      "/_content/*",
      "/images/*",
      "/css/*",
      "/js/*",
      "/lib/*",
      "/*.{css,js,json,map,png,jpg,jpeg,svg,ico,wasm,gif,webp,txt,xml,br,gz,dat,dll,pdb}"
    ]
  },
  "mimeTypes": {
    ".svg": "image/svg+xml",
    ".txt": "text/plain",
    ".xml": "application/xml",
    ".wasm": "application/wasm"
  }
}