    { "route": "/ai-contract-review",            "redirect": "/review-contract",      "statusCode": 301 },
    { "route": "/ai-contract-reviewer/app",      "redirect": "/review-contract",      "statusCode": 301 },
    { "route": "/invoice-data-extraction",       "redirect": "/extract-invoice-data", "statusCode": 301 },
    { "route": "/batch-processing",              "redirect": "/batch",                "statusCode": 301 },
    { "route": "/sign-contract",                 "redirect": "/sign-pdf",             "statusCode": 301 },
    { "route": "/sign-contract/app",             "redirect": "/sign-pdf",             "statusCode": 301 },
    { "route": "/redact-pdf-online",             "redirect": "/redact-pdf",           "statusCode": 301 },
    { "route": "/compare-contracts",             "redirect": "/compare-pdf",          "statusCode": 301 },
    { "route": "/compare-pdf-documents",         "redirect": "/compare-pdf",          "statusCode": 301 },
    { "route": "/convert-pdf-to-editable-word",  "redirect": "/pdf-to-word",          "statusCode": 301 },
