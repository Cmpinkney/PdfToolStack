@page "/chat-with-pdf"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Authorization

<SeoHead Title="Chat with PDF Online - Ask Questions About PDFs | PdfToolStack"
         Description="Upload a PDF and ask questions, find details, or summarize sections with AI. Get document answers faster with private processing."
         CanonicalPath="/chat-with-pdf" />

<div class="tool-page ai-tool-page chat-ai-page">
    <div class="tool-container ai-tool-container">

        <section class="tool-hero ai-tool-hero">
            <div class="trust-row">
                <span>Private processing</span>
                <span>Secure upload</span>
                <span>Auto-delete after 1 hour</span>
            </div>
            <h1>Chat with your PDF <span class="hero-gradient-text">instantly</span></h1>
            <p>Upload a document, ask questions, and get grounded answers from your PDF.</p>
        </section>

        <div class="stepper ai-tool-stepper" aria-label="Chat with PDF steps">
            <div class="stepper-step active"><span>1</span>Upload</div>
            <div class="stepper-step"><span>2</span>Ask</div>
            <div class="stepper-step"><span>3</span>Review</div>
            <div class="stepper-step"><span>4</span>Continue</div>
        </div>

        <AuthorizeView>
            <NotAuthorized>
                <div class="ai-upgrade-card">
                    <div class="ai-upgrade-icon">💬</div>
                    <h2>Try Chat with PDF — 5 free uses</h2>
                    <p>Sign in to get 5 free AI uses per month. Ask your documents anything — contracts, manuals, research papers.</p>
                    <div class="ai-upgrade-features">
                        <div class="ai-upgrade-feat">✓ Ask questions in plain English</div>
                        <div class="ai-upgrade-feat">✓ Answers grounded in your document</div>
                        <div class="ai-upgrade-feat">✓ Works on contracts, manuals, papers</div>
                        <div class="ai-upgrade-feat">✓ Full conversation history</div>
                    </div>
                    <div class="ai-upgrade-actions">
                        <a href="authentication/login?screen_hint=signup" class="download-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign up free — 5 AI uses included
                        </a>
                        <a href="authentication/login" class="reset-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign in
                        </a>
                    </div>
                </div>
            </NotAuthorized>

            <Authorized>
                <section class="workflow-grid ai-tool-workflow chat-ai-workflow">
                    <div class="workspace-card ai-tool-workspace chat-ai-workspace">
                        @if (_isRateLimit)
                        {
                            <AiLimitBanner IsVisible="true"
                                           IsFreeLimit="@_isFreeLimit"
                                           Limit="@(_isFreeLimit ? 5 : 200)" />
                        }
                        else if (_fileBytes == null)
                        {
                            <div class="ai-tool-card-header">
                                <span>Upload</span>
                                <h2>Start a document conversation</h2>
                                <p>Upload a PDF, then ask direct questions about details, dates, clauses, or summaries.</p>
                            </div>

                            <FileUpload OnFileSelected="HandleFileSelected"
                                        OnFileRemoved="HandleFileRemoved"
                                        HintText="Upload a PDF to start chatting — up to 50MB" />
                        }
                        else
                        {
                            <div class="chat-file-bar">
                                <div class="chat-file-bar-left">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="1.5"
                                         stroke-linecap="round" stroke-linejoin="round"
                                         style="color:var(--primary); flex-shrink:0;">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                        <polyline points="14,2 14,8 20,8" />
                                    </svg>
                                    <span class="chat-file-name">@_fileName</span>
                                    <span class="chat-file-ready">Ready to chat</span>
                                </div>
                                <button class="reset-button"
                                        style="max-width:120px; padding:0.35rem 0.75rem; font-size:0.8rem;"
                                        @onclick="ClearFile">
                                    Change file
                                </button>
                            </div>

                            @if (_messages.Any())
                            {
                                <div class="chat-history" id="chatHistory">
                                    @foreach (var msg in _messages)
                                    {
                                        <div class="chat-bubble @(msg.IsUser ? "chat-user" : "chat-ai")">
                                            @if (!msg.IsUser)
                                            {
                                                <div class="chat-ai-avatar">AI</div>
                                            }
                                            <div class="chat-bubble-text">@msg.Text</div>
                                        </div>
                                    }
                                    @if (_processing)
                                    {
                                        <div class="chat-bubble chat-ai">
                                            <div class="chat-ai-avatar">AI</div>
                                            <div class="chat-bubble-text chat-thinking">
                                                <span class="chat-dot"></span>
                                                <span class="chat-dot"></span>
                                                <span class="chat-dot"></span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="chat-suggestions">
                                    <p class="chat-suggestions-label">Try asking:</p>
                                    <div class="chat-suggestions-grid">
                                        <button class="chat-suggestion-btn"
                                                @onclick='() => SetQuestion("What is the main topic of this document?")'>
                                            What is the main topic?
                                        </button>
                                        <button class="chat-suggestion-btn"
                                                @onclick='() => SetQuestion("Summarize the key points in 3 bullet points.")'>
                                            Summarize in 3 bullet points
                                        </button>
                                        <button class="chat-suggestion-btn"
                                                @onclick='() => SetQuestion("What are the most important dates or deadlines mentioned?")'>
                                            What are the key dates?
                                        </button>
                                        <button class="chat-suggestion-btn"
                                                @onclick='() => SetQuestion("What action items or obligations are mentioned?")'>
                                            What are the action items?
                                        </button>
                                    </div>
                                </div>
                            }

                            <div class="chat-input-row">
                                <input class="chat-input"
                                       type="text"
                                       placeholder="Ask a question about your document..."
                                       @bind="_question"
                                       @bind:event="oninput"
                                       @onkeydown="OnKeyDown"
                                       disabled="@_processing" />
                                <button class="process-button"
                                        style="max-width:90px; margin-top:0; flex-shrink:0;"
                                        @onclick="AskQuestion"
                                        disabled="@(_processing || string.IsNullOrWhiteSpace(_question))">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2.5"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="22" y1="2" x2="11" y2="13" />
                                        <polygon points="22,2 15,22 11,13 2,9" />
                                    </svg>
                                    Ask
                                </button>
                            </div>

                            @if (!string.IsNullOrEmpty(_error) && _error != "rate_limit")
                            {
                                <div class="error-message" style="margin-top:1rem;">@_error</div>
                            }
                        }
                    </div>

                    <aside class="settings-card ai-tool-settings chat-ai-settings">
                        <div class="ai-tool-card-header">
                            <span>Question guidance</span>
                            <h2>Ask grounded questions</h2>
                            <p>Specific prompts get stronger answers because the assistant responds from your uploaded document.</p>
                        </div>

                        @if (!_isPro && _aiUsed < 5)
                        {
                            <div class="free-uses-banner">
                                <span>✨ @(5 - _aiUsed) of 5 free AI uses remaining this month</span>
                                <a href="/pricing">Upgrade to Pro for 200 AI uses/month →</a>
                            </div>
                        }

                        <div class="ai-tool-guidance-card">
                            <h3>Useful questions</h3>
                            <div class="ai-tool-guidance-list">
                                <span>Summarize the document</span>
                                <span>Find deadlines or dates</span>
                                <span>Explain a clause or section</span>
                                <span>List obligations or action items</span>
                            </div>
                        </div>

                        <div class="chat-ai-value-card">
                            Answers stay grounded in the PDF you upload, and the conversation history stays available during this session.
                        </div>
                    </aside>
                </section>
            </Authorized>
        </AuthorizeView>

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What kinds of questions can I ask?</h3>
            <p>Anything about the document — summaries, specific facts, dates, names, clauses, definitions, or comparisons between sections.</p>
        </div>
        <div class="faq-item">
            <h3>Does it remember previous questions?</h3>
            <p>Yes — the conversation is maintained within your session. Each answer considers the full chat history.</p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored?</h3>
            <p>No. Your PDF is processed in memory and deleted within 1 hour. We never store document contents permanently.</p>
        </div>
    </div>
</div>

@code {
    private byte[]? _fileBytes;
    private string? _fileName;
    private bool _isPro;
    private int _aiUsed = 0;
    private bool _processing;
    private string _question = string.Empty;
    private string _error = string.Empty;
    private bool _isRateLimit = false;
    private bool _isFreeLimit = false;
    private List<ChatMessage> _messages = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst("sub")?.Value ?? string.Empty;
            var status = await SubService.GetStatusAsync(userId);
            _isPro = status.HasPro;

            if (!_isPro)
            {
                var usage = await ApiService.GetAsync<AiUsageResponse>("api/ai/usage");
                _aiUsed = usage?.Used ?? 0;
            }
        }
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 52_428_800).CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        _fileName = file.Name;
        _messages.Clear();
        _error = string.Empty;
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
        _messages.Clear();
        _question = string.Empty;
    }

    private void ClearFile()
    {
        _fileBytes = null;
        _fileName = null;
        _messages.Clear();
        _question = string.Empty;
    }

    private void SetQuestion(string q)
    {
        _question = q;
        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" &&
            !string.IsNullOrWhiteSpace(_question) &&
            !_processing)
            await AskQuestion();
    }

    private async Task AskQuestion()
    {
        if (_fileBytes == null || string.IsNullOrWhiteSpace(_question)) return;

        var q = _question.Trim();
        _question = string.Empty;
        _error = string.Empty;
        _messages.Add(new ChatMessage(q, true));
        _processing = true;
        StateHasChanged();

        await JS.InvokeVoidAsync("scrollToBottom", "chatHistory");

        try
        {
            using var content = new MultipartFormDataContent();
            var fc = new ByteArrayContent(_fileBytes);
            fc.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fc, "file", _fileName ?? "document.pdf");
            content.Add(new StringContent(q), "question");

            var result = await ApiService.PostMultipartWithStatusAsync<ChatResponse>(
                "api/ai/chat", content);

            if (result.IsRateLimit)
            {
                _isRateLimit = true;
                _isFreeLimit = !_isPro;
                _error = "rate_limit";
                // Remove the user question we added since it can't be answered
                if (_messages.Any() && _messages.Last().IsUser)
                    _messages.RemoveAt(_messages.Count - 1);
            }
            else
            {
                _messages.Add(new ChatMessage(
                    result.Data?.Answer ?? "Sorry, I couldn't find an answer in this document.",
                    false));
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _processing = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToBottom", "chatHistory");
        }
    }

    private record ChatMessage(string Text, bool IsUser);

    private class ChatResponse
    {
        public string Answer { get; set; } = string.Empty;
    }

    private class AiUsageResponse
    {
        public int Used { get; set; }
        public int Limit { get; set; }
    }
}
