@page "/chat-with-pdf"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Chat with PDF — Ask Your Document Questions | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="Upload a PDF and ask it anything. AI answers questions
                   based on your document content. Perfect for contracts,
                   manuals, and research papers." />
    <meta name="keywords" content="chat with pdf, ask pdf questions, pdf ai chatbot, talk to pdf" />
    <link rel="canonical" href="https://pdftoolstack.com/chat-with-pdf" />
</HeadContent>

<div class="tool-page">
    <div class="tool-container">

        <!-- Header -->
        <div class="ai-tool-header">
            <div class="ai-tool-badge">✨ AI-Powered</div>
            <h1>Chat with PDF</h1>
            <p class="tool-subtitle">
                Upload your PDF and ask it anything. Get instant answers
                based on your document — no reading required.
            </p>
        </div>

        <!-- How it works -->
        <div class="how-it-works">
            <div class="hiw-step">
                <div class="hiw-num">1</div>
                <div class="hiw-text">
                    <strong>Upload your PDF</strong>
                    <span>Contract, manual, paper</span>
                </div>
            </div>
            <div class="hiw-arrow">→</div>
            <div class="hiw-step">
                <div class="hiw-num">2</div>
                <div class="hiw-text">
                    <strong>Ask any question</strong>
                    <span>In plain English</span>
                </div>
            </div>
            <div class="hiw-arrow">→</div>
            <div class="hiw-step">
                <div class="hiw-num">3</div>
                <div class="hiw-text">
                    <strong>Get instant answers</strong>
                    <span>Grounded in your document</span>
                </div>
            </div>
        </div>

        <AuthorizeView>
            <NotAuthorized>
                <div class="ai-upgrade-card">
                    <div class="ai-upgrade-icon">💬</div>
                    <h2>Chat with PDF — Pro Feature</h2>
                    <p>Ask your documents anything. Claude reads your PDF and answers based on the content. Available on Pro — $19/month.</p>
                    <div class="ai-upgrade-features">
                        <div class="ai-upgrade-feat">✓ Ask unlimited questions</div>
                        <div class="ai-upgrade-feat">✓ Answers grounded in your document</div>
                        <div class="ai-upgrade-feat">✓ Works on contracts, manuals, papers</div>
                        <div class="ai-upgrade-feat">✓ Full conversation history</div>
                    </div>
                    <div class="ai-upgrade-actions">
                        <a href="/pricing" class="download-button"
                           style="display:inline-block; text-decoration:none;">
                            Upgrade to Pro — $19/mo
                        </a>
                        <a href="authentication/login" class="reset-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign in if you have Pro
                        </a>
                    </div>
                </div>
            </NotAuthorized>

            <Authorized>
                @if (!_isPro)
                {
                    <div class="ai-upgrade-card">
                        <div class="ai-upgrade-icon">💬</div>
                        <h2>Upgrade to Pro to unlock Chat with PDF</h2>
                        <p>You're signed in but on the Free plan. Upgrade to ask your documents anything.</p>
                        <div class="ai-upgrade-actions">
                            <a href="/pricing" class="download-button"
                               style="display:inline-block; text-decoration:none;">
                                Upgrade to Pro — $19/mo
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    @if (_fileBytes == null)
                    {
                        <FileUpload OnFileSelected="HandleFileSelected"
                                    OnFileRemoved="HandleFileRemoved"
                                    HintText="Upload a PDF to start chatting — up to 50MB" />
                    }
                    else
                    {
                        <!-- File indicator -->
                        <div class="chat-file-bar">
                            <div class="chat-file-bar-left">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.5"
                                     stroke-linecap="round" stroke-linejoin="round"
                                     style="color:var(--primary); flex-shrink:0;">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                    <polyline points="14,2 14,8 20,8" />
                                </svg>
                                <span class="chat-file-name">@_fileName</span>
                                <span class="chat-file-ready">Ready to chat</span>
                            </div>
                            <button class="reset-button"
                                    style="max-width:120px; padding:0.35rem 0.75rem; font-size:0.8rem;"
                                    @onclick="ClearFile">
                                Change file
                            </button>
                        </div>

                        <!-- Chat history -->
                        @if (_messages.Any())
                        {
                            <div class="chat-history" id="chatHistory">
                                @foreach (var msg in _messages)
                                {
                                    <div class="chat-bubble @(msg.IsUser ? "chat-user" : "chat-ai")">
                                        @if (!msg.IsUser)
                                        {
                                            <div class="chat-ai-avatar">AI</div>
                                        }
                                        <div class="chat-bubble-text">@msg.Text</div>
                                    </div>
                                }
                                @if (_processing)
                                {
                                    <div class="chat-bubble chat-ai">
                                        <div class="chat-ai-avatar">AI</div>
                                        <div class="chat-bubble-text chat-thinking">
                                            <span class="chat-dot"></span>
                                            <span class="chat-dot"></span>
                                            <span class="chat-dot"></span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <!-- Suggested questions -->
                            <div class="chat-suggestions">
                                <p class="chat-suggestions-label">Try asking:</p>
                                <div class="chat-suggestions-grid">
                                    <button class="chat-suggestion-btn"
                                            @onclick='() => SetQuestion("What is the main topic of this document?")'>
                                        What is the main topic?
                                    </button>
                                    <button class="chat-suggestion-btn"
                                            @onclick='() => SetQuestion("Summarize the key points in 3 bullet points.")'>
                                        Summarize in 3 bullet points
                                    </button>
                                    <button class="chat-suggestion-btn"
                                            @onclick='() => SetQuestion("What are the most important dates or deadlines mentioned?")'>
                                        What are the key dates?
                                    </button>
                                    <button class="chat-suggestion-btn"
                                            @onclick='() => SetQuestion("What action items or obligations are mentioned?")'>
                                        What are the action items?
                                    </button>
                                </div>
                            </div>
                        }

                        <!-- Input -->
                        <div class="chat-input-row">
                            <input class="chat-input"
                                   type="text"
                                   placeholder="Ask a question about your document..."
                                   @bind="_question"
                                   @bind:event="oninput"
                                   @onkeydown="OnKeyDown"
                                   disabled="@_processing" />
                            <button class="process-button"
                                    style="max-width:90px; margin-top:0; flex-shrink:0;"
                                    @onclick="AskQuestion"
                                    disabled="@(_processing || string.IsNullOrWhiteSpace(_question))">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.5"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="22" y1="2" x2="11" y2="13" />
                                    <polygon points="22,2 15,22 11,13 2,9" />
                                </svg>
                                Ask
                            </button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="error-message" style="margin-top:1rem;">@_error</div>
                    }
                }
            </Authorized>
        </AuthorizeView>

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What kinds of questions can I ask?</h3>
            <p>Anything about the document — summaries, specific facts, dates, names, clauses, definitions, or comparisons between sections.</p>
        </div>
        <div class="faq-item">
            <h3>Does it remember previous questions?</h3>
            <p>Yes — the conversation is maintained within your session. Each answer considers the full chat history.</p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored?</h3>
            <p>No. Your PDF is processed in memory and deleted within 1 hour. We never store document contents permanently.</p>
        </div>
    </div>
</div>

@code {
    private byte[]? _fileBytes;
    private string? _fileName;
    private bool _isPro;
    private bool _processing;
    private string _question = string.Empty;
    private string _error = string.Empty;
    private List<ChatMessage> _messages = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst("sub")?.Value ?? string.Empty;
            var status = await SubService.GetStatusAsync(userId);
            _isPro = status.HasPro;
        }
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 52_428_800).CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        _fileName = file.Name;
        _messages.Clear();
        _error = string.Empty;
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
        _messages.Clear();
        _question = string.Empty;
    }

    private void ClearFile()
    {
        _fileBytes = null;
        _fileName = null;
        _messages.Clear();
        _question = string.Empty;
    }

    private void SetQuestion(string q)
    {
        _question = q;
        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" &&
            !string.IsNullOrWhiteSpace(_question) &&
            !_processing)
            await AskQuestion();
    }

    private async Task AskQuestion()
    {
        if (_fileBytes == null || string.IsNullOrWhiteSpace(_question)) return;

        var q = _question.Trim();
        _question = string.Empty;
        _error = string.Empty;
        _messages.Add(new ChatMessage(q, true));
        _processing = true;
        StateHasChanged();

        await JS.InvokeVoidAsync("scrollToBottom", "chatHistory");

        try
        {
            using var content = new MultipartFormDataContent();
            var fc = new ByteArrayContent(_fileBytes);
            fc.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fc, "file", _fileName ?? "document.pdf");
            content.Add(new StringContent(q), "question");

            var result = await ApiService.PostMultipartAsync<ChatResponse>(
                "api/ai/chat", content);

            _messages.Add(new ChatMessage(
                result?.Answer ?? "Sorry, I couldn't find an answer in this document.",
                false));
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _processing = false;
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToBottom", "chatHistory");
        }
    }

    private record ChatMessage(string Text, bool IsUser);

    private class ChatResponse
    {
        public string Answer { get; set; } = string.Empty;
    }
}