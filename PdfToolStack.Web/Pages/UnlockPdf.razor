@code {
    private bool ShowAdsForCurrentUser = true; // TODO: Hide ads for paid users when subscription state is available here.
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private string Password = string.Empty;
    private int _uploadKey;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }

        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            if (PaymentService.IsFileTooLargeForFree(file.Size))
            {
                SelectedFile = file;
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesValidation = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesValidation.IsValid)
            {
                Toast.ShowError(bytesValidation.Message!);
                UploadedBytes = null;
                return;
            }

            if (bytesValidation.IsWarning)
                Toast.ShowWarning(bytesValidation.Message!);

            SelectedFile = file;
            Toast.ShowSuccess($"File ready - {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex)
        {
            UploadedBytes = null;
            Toast.ShowError($"Could not read file: {ex.Message}");
        }

        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        Password = string.Empty;
        _uploadKey++;
    }

    private async Task ProcessFile()
    {
        ErrorMessage = null;

        if (SelectedFile == null || UploadedBytes == null)
        {
            ErrorMessage = "Upload a PDF before unlocking it.";
            return;
        }

        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            var password = string.IsNullOrWhiteSpace(Password)
                ? null
                : Password;

            ResultBytes = await ApiService.UnlockPdfAsync(
                UploadedBytes,
                SelectedFile.Name,
                password);

            Password = string.Empty;

            if (ResultBytes?.Length > 0)
            {
                CurrentState = PageState.Complete;
                Toast.ShowSuccess("PDF unlocked successfully.");
            }
            else
            {
                ErrorMessage = "Failed to unlock PDF. Check the password and try again.";
                Toast.ShowError(ErrorMessage);
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            Password = string.Empty;
            ErrorMessage = $"Error: {ex.Message}";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null)
            return;

        var baseName = Path.GetFileNameWithoutExtension(SelectedFile?.Name ?? "document");
        var fileName = $"{baseName}_unlocked.pdf";

        await JS.InvokeVoidAsync(
            "downloadFile",
            fileName,
            Convert.ToBase64String(ResultBytes));

        SessionUsage.RecordToolCompletion("Unlock PDF");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        Password = string.Empty;
        _uploadKey++;
    }
}
