@page "/unlock-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Unlock PDF Online - Remove PDF Password | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="Unlock PDF files online by removing password protection from PDFs you own or have permission to modify. Secure processing with files deleted within 1 hour." />
    <meta name="keywords"
          content="unlock pdf, remove pdf password, decrypt pdf, pdf password remover" />
    <link rel="canonical" href="https://pdftoolstack.com/unlock-pdf" />
</HeadContent>

<div class="tool-page unlock-pdf-page">
    <div class="tool-container unlock-pdf-container">
        <section class="unlock-pdf-hero">
            <div class="unlock-pdf-hero-copy">
                <div class="unlock-pdf-trust-row">
                    <span>Secure processing</span>
                    <span>Files deleted in 1 hour</span>
                    <span>No permanent storage</span>
                </div>
                <h1>
                    Unlock PDFs <span class="unlock-pdf-gradient-text">you&apos;re authorized</span> to edit
                </h1>
                <p>
                    Remove password protection from PDFs you own or have permission to modify.
                </p>
            </div>

            <div class="unlock-pdf-hero-visual" aria-hidden="true">
                <div class="unlock-pdf-visual-frame">
                    <div class="unlock-pdf-document-card">
                        <div class="unlock-pdf-doc-top">
                            <span>PDF</span>
                            <small>Locked</small>
                        </div>
                        <div class="unlock-pdf-doc-line unlock-pdf-doc-line-wide"></div>
                        <div class="unlock-pdf-doc-line"></div>
                        <div class="unlock-pdf-doc-line unlock-pdf-doc-line-short"></div>
                        <div class="unlock-pdf-doc-status">
                            <span></span>
                            Password protected
                        </div>
                    </div>

                    <div class="unlock-pdf-key-mark">
                        <svg viewBox="0 0 72 72" role="img">
                            <circle cx="23" cy="36" r="12" />
                            <path d="M34 36h25" />
                            <path d="M51 36v8" />
                            <path d="M59 36v6" />
                            <circle cx="23" cy="36" r="4" />
                        </svg>
                    </div>

                    <div class="unlock-pdf-lock-mark">
                        <svg viewBox="0 0 64 64" role="img">
                            <path class="unlock-pdf-lock-shackle"
                                  d="M20 29v-8c0-7.2 5-12 12-12s12 4.8 12 12v8" />
                            <rect x="15" y="27" width="34" height="27" rx="8" />
                            <circle cx="32" cy="39" r="3.5" />
                            <path d="M32 42.5v5" />
                        </svg>
                    </div>

                    <div class="unlock-pdf-check-badge">
                        <svg viewBox="0 0 48 48" role="img">
                            <circle cx="24" cy="24" r="19" />
                            <path d="M15 24l6 6 12-14" />
                        </svg>
                    </div>
                </div>
            </div>
        </section>

        <AdPlaceholder ShowAds="ShowAdsForCurrentUser" />

        <div class="stepper unlock-pdf-stepper" aria-label="Unlock PDF workflow progress">
            <div class="step unlock-pdf-step @(CurrentState == PageState.Upload && SelectedFile == null ? "active" : SelectedFile != null || CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>1</span>
                <strong>Upload</strong>
            </div>
            <div class="step unlock-pdf-step @(CurrentState == PageState.Upload && SelectedFile != null ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>2</span>
                <strong>Enter Password</strong>
            </div>
            <div class="step unlock-pdf-step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">
                <span>3</span>
                <strong>Unlock</strong>
            </div>
            <div class="step unlock-pdf-step @(CurrentState == PageState.Complete ? "active complete" : "")">
                <span>4</span>
                <strong>Download</strong>
            </div>
        </div>

        <section class="workflow-grid unlock-pdf-workflow-grid">
            <div class="workspace-card unlock-pdf-workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="unlock-pdf-panel-header">
                        <span class="unlock-pdf-panel-eyebrow">Secure upload</span>
                        <h2>Start with your locked PDF</h2>
                        <p>Upload a file from your device, Dropbox, or Google Drive.</p>
                    </div>

                    <FileUpload @key="_uploadKey"
                                OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved"
                                ActionSummary="Will remove supported PDF protections" />

                    @if (SelectedFile != null)
                    {
                        <div class="unlock-pdf-file-summary">
                            <div>
                                <span class="unlock-pdf-file-name">@SelectedFile.Name</span>
                                <span class="unlock-pdf-file-size">@Validator.FormatSize(SelectedFile.Size)</span>
                            </div>
                            <span class="unlock-pdf-status-pill">Ready</span>
                        </div>
                    }
                    else
                    {
                        <div class="unlock-pdf-empty-state">
                            <strong>Permission-aware unlocking</strong>
                            <span>Use this workflow only for PDFs where you have the right to remove protection.</span>
                        </div>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade
                        FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                        FileName="@(SelectedFile?.Name ?? "")"
                        ToolType="UnlockPdf"
                        OnCancel="Reset" />
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="unlock-pdf-processing-container" role="status">
                        <div class="unlock-pdf-spinner"></div>
                        <h2>Unlocking your PDF</h2>
                        <p>Checking the password, removing supported protection, and preparing an editable copy.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete && ResultBytes != null)
                {
                    <ResultAdPlaceholder ShowAds="ShowAdsForCurrentUser" />
                    <div class="unlock-pdf-result-container">
                        <span class="unlock-pdf-result-icon">Unlocked</span>
                        <h2>Your unlocked PDF is ready</h2>
                        <p>Password protection has been removed from your authorized PDF copy.</p>

                        <button class="download-button unlock-pdf-download-button"
                                @onclick="DownloadFile">
                            Download unlocked PDF
                        </button>
                        <button class="reset-button unlock-pdf-reset-button"
                                @onclick="Reset">
                            Process another
                        </button>

                        <RecentFiles FileName="@(SelectedFile?.Name ?? "Unlocked PDF")"
                                     ToolName="Unlock PDF"
                                     OnDownloadAgain="@DownloadFile" />
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="unlock-pdf-error-container" role="alert">
                        <span class="unlock-pdf-error-icon">Unlock failed</span>
                        <h2>We could not unlock this PDF</h2>
                        <p class="unlock-pdf-error-message">@ErrorMessage</p>
                        <button class="reset-button unlock-pdf-reset-button"
                                @onclick="Reset">
                            Try again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card unlock-pdf-settings-card">
                <div class="unlock-pdf-panel-header">
                    <span class="unlock-pdf-panel-eyebrow">Unlock settings</span>
                    <h2>Enter the PDF password</h2>
                    <p>Provide the open password if the file requires one.</p>
                </div>

                <p class="unlock-pdf-legal-note">
                    Only unlock PDFs you own or are authorized to modify. Password-protected files require the correct password.
                </p>

                @if (SelectedFile != null && CurrentState == PageState.Upload)
                {
                    <div class="unlock-pdf-field-card">
                        <label for="unlock-pdf-password">Password</label>
                        <input id="unlock-pdf-password"
                               type="password"
                               class="unlock-pdf-field-input"
                               placeholder="Enter PDF password"
                               autocomplete="current-password"
                               @bind="Password"
                               @bind:event="oninput" />
                        <p>Leave blank only if the PDF has no open password.</p>
                    </div>
                }

                <div class="unlock-pdf-security-notes">
                    <div>
                        <strong>Password is never stored</strong>
                        <span>It is used only for this unlock request.</span>
                    </div>
                    <div>
                        <strong>Secure processing</strong>
                        <span>Files are handled privately during the operation.</span>
                    </div>
                    <div>
                        <strong>Files deleted within 1 hour</strong>
                        <span>No permanent storage for uploaded or unlocked files.</span>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage) && CurrentState == PageState.Upload)
                {
                    <p class="unlock-pdf-error-message">@ErrorMessage</p>
                }

                @if (CurrentState == PageState.Upload && SelectedFile != null)
                {
                    <button class="process-button unlock-pdf-process-button"
                            @onclick="ProcessFile">
                        Unlock PDF &amp; Download
                    </button>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button unlock-pdf-process-button disabled" disabled>
                        Upload a PDF to continue
                    </button>
                }
                @if (CurrentState == PageState.Complete)
                {
                    <SidebarAdPlaceholder ShowAds="ShowAdsForCurrentUser" />
                }
            </aside>
        </section>

        <section class="unlock-pdf-faq-section" aria-labelledby="unlock-pdf-faq-title">
            <div class="unlock-pdf-section-header">
                <span class="unlock-pdf-panel-eyebrow">Unlock FAQ</span>
                <h2 id="unlock-pdf-faq-title">Remove PDF protection responsibly</h2>
            </div>

            <div class="unlock-pdf-faq-grid">
                <article>
                    <h3>Do I need the password?</h3>
                    <p>Yes. Password-protected files require the correct password before they can be unlocked.</p>
                </article>
                <article>
                    <h3>Is it legal to unlock a PDF?</h3>
                    <p>Only unlock PDFs you own or have explicit permission to modify.</p>
                </article>
                <article>
                    <h3>Are files stored?</h3>
                    <p>Uploaded and processed files are deleted within 1 hour.</p>
                </article>
            </div>
        </section>
    </div>
</div>

<style>
    .unlock-pdf-page {
        width: 100%;
        max-width: none;
        min-height: calc(100vh - 72px);
        min-width: 0;
        margin: 0;
        padding: 48px 0 72px;
        box-sizing: border-box;
        background:
            radial-gradient(circle at 12% 0%, rgba(37, 99, 235, 0.13), transparent 28%),
            radial-gradient(circle at 88% 6%, rgba(5, 150, 105, 0.11), transparent 30%),
            linear-gradient(135deg, #f8fbff 0%, #f7f8fb 46%, #f5fbf8 100%);
        color: #172033;
    }

    .unlock-pdf-container {
        width: min(1320px, calc(100% - 64px));
        max-width: 1320px;
        margin: 0 auto;
    }

    .unlock-pdf-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.72fr);
        gap: 32px;
        align-items: center;
        margin: 28px 0 28px;
    }

    .unlock-pdf-hero-copy {
        min-width: 0;
    }

    .unlock-pdf-trust-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .unlock-pdf-trust-row span {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        border: 1px solid rgba(37, 99, 235, 0.14);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.78);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
        color: #334155;
        font-size: 0.84rem;
        font-weight: 850;
        padding: 0.5rem 0.8rem;
    }

    .unlock-pdf-trust-row span::before {
        content: "";
        width: 0.45rem;
        height: 0.45rem;
        flex: 0 0 auto;
        border-radius: 999px;
        background: linear-gradient(135deg, #10b981, #2563eb);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    }

    .unlock-pdf-hero h1 {
        max-width: 920px;
        margin: 0 0 16px;
        color: #0f172a;
        font-size: clamp(2.55rem, 5vw, 5.1rem);
        line-height: 0.98;
        letter-spacing: 0;
    }

    .unlock-pdf-hero p {
        max-width: 760px;
        margin: 0;
        color: #526173;
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .unlock-pdf-gradient-text {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 52%, #06b6d4 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .unlock-pdf-visual-frame {
        position: relative;
        min-height: 340px;
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 28px;
        background:
            linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(239, 246, 255, 0.86)),
            radial-gradient(circle at 72% 20%, rgba(16, 185, 129, 0.14), transparent 32%);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.1);
    }

    .unlock-pdf-visual-frame::before {
        content: "";
        position: absolute;
        inset: 24px;
        border: 1px dashed rgba(37, 99, 235, 0.18);
        border-radius: 22px;
    }

    .unlock-pdf-document-card {
        position: absolute;
        left: 14%;
        top: 52px;
        width: min(250px, 58%);
        min-height: 250px;
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 24px 52px rgba(30, 41, 59, 0.14);
        padding: 22px;
        animation: unlock-pdf-document-float 6.4s ease-in-out infinite;
    }

    .unlock-pdf-doc-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 26px;
    }

    .unlock-pdf-doc-top span {
        border-radius: 999px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #ffffff;
        font-size: 0.72rem;
        font-weight: 950;
        padding: 0.4rem 0.62rem;
    }

    .unlock-pdf-doc-top small {
        color: #64748b;
        font-size: 0.78rem;
        font-weight: 850;
        text-transform: uppercase;
    }

    .unlock-pdf-doc-line {
        height: 10px;
        width: 74%;
        margin-top: 14px;
        border-radius: 999px;
        background: #e2e8f0;
    }

    .unlock-pdf-doc-line-wide {
        width: 92%;
        background: #c7d2fe;
    }

    .unlock-pdf-doc-line-short {
        width: 52%;
    }

    .unlock-pdf-doc-status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 32px;
        border-radius: 999px;
        background: #fff7ed;
        color: #9a3412;
        font-size: 0.78rem;
        font-weight: 900;
        padding: 0.55rem 0.72rem;
    }

    .unlock-pdf-doc-status span {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #f97316;
        box-shadow: 0 0 0 5px rgba(249, 115, 22, 0.14);
    }

    .unlock-pdf-key-mark {
        position: absolute;
        right: 13%;
        top: 70px;
        display: grid;
        place-items: center;
        width: 98px;
        height: 98px;
        border: 1px solid rgba(37, 99, 235, 0.16);
        border-radius: 28px;
        background: #ffffff;
        box-shadow: 0 18px 38px rgba(37, 99, 235, 0.16);
        animation: unlock-pdf-key-turn 6.4s ease-in-out infinite;
    }

    .unlock-pdf-key-mark svg {
        width: 64px;
        height: 64px;
        fill: none;
        stroke: #2563eb;
        stroke-width: 5;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .unlock-pdf-lock-mark {
        position: absolute;
        right: 17%;
        bottom: 72px;
        display: grid;
        place-items: center;
        width: 116px;
        height: 116px;
        border: 1px solid rgba(37, 99, 235, 0.16);
        border-radius: 30px;
        background:
            radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.9), transparent 34%),
            linear-gradient(135deg, #6d5dfc 0%, #2563eb 62%, #06b6d4 100%);
        box-shadow: 0 22px 42px rgba(37, 99, 235, 0.28);
        animation: unlock-pdf-lock-open 6.4s ease-in-out infinite;
    }

    .unlock-pdf-lock-mark svg {
        width: 72px;
        height: 72px;
        fill: none;
        stroke: #ffffff;
        stroke-width: 4;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .unlock-pdf-lock-mark rect {
        fill: rgba(255, 255, 255, 0.16);
    }

    .unlock-pdf-lock-shackle {
        transform-box: fill-box;
        transform-origin: left bottom;
        animation: unlock-pdf-shackle-open 6.4s ease-in-out infinite;
    }

    .unlock-pdf-check-badge {
        position: absolute;
        right: 9%;
        bottom: 40px;
        display: grid;
        place-items: center;
        width: 78px;
        height: 78px;
        border: 1px solid rgba(16, 185, 129, 0.22);
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 18px 38px rgba(5, 150, 105, 0.18);
        animation: unlock-pdf-check-pop 6.4s ease-in-out infinite;
    }

    .unlock-pdf-check-badge svg {
        width: 48px;
        height: 48px;
        fill: #dcfce7;
        stroke: #059669;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .unlock-pdf-check-badge svg path {
        fill: none;
    }

    .unlock-pdf-workflow-grid {
        width: 100%;
        max-width: none;
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(360px, 0.75fr);
        gap: 28px;
        align-items: start;
    }

    .unlock-pdf-workspace-card,
    .unlock-pdf-settings-card {
        width: 100%;
        max-width: none;
        min-width: 0;
        box-sizing: border-box;
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
        padding: 28px;
    }

    .unlock-pdf-settings-card {
        position: sticky;
        top: 24px;
    }

    .unlock-pdf-workspace-card .upload-container {
        width: 100%;
        max-width: none;
    }

    .unlock-pdf-panel-header,
    .unlock-pdf-section-header {
        margin-bottom: 20px;
    }

    .unlock-pdf-panel-eyebrow {
        display: inline-flex;
        margin-bottom: 10px;
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-size: 0.76rem;
        font-weight: 950;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .unlock-pdf-panel-header h2,
    .unlock-pdf-section-header h2 {
        margin: 0 0 8px;
        color: #111827;
        font-size: 1.35rem;
        line-height: 1.2;
    }

    .unlock-pdf-panel-header p {
        margin: 0;
        color: #64748b;
        line-height: 1.6;
    }

    .unlock-pdf-file-summary,
    .unlock-pdf-empty-state,
    .unlock-pdf-field-card,
    .unlock-pdf-security-notes div,
    .unlock-pdf-legal-note {
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 18px;
        background: #f8fafc;
        padding: 16px;
    }

    .unlock-pdf-file-summary {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        margin-top: 18px;
    }

    .unlock-pdf-file-name,
    .unlock-pdf-file-size,
    .unlock-pdf-empty-state strong,
    .unlock-pdf-empty-state span,
    .unlock-pdf-security-notes strong,
    .unlock-pdf-security-notes span {
        display: block;
    }

    .unlock-pdf-file-name {
        color: #111827;
        font-weight: 900;
        overflow-wrap: anywhere;
    }

    .unlock-pdf-file-size,
    .unlock-pdf-empty-state span,
    .unlock-pdf-security-notes span,
    .unlock-pdf-field-card p {
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .unlock-pdf-status-pill {
        border-radius: 999px;
        background: #dcfce7;
        color: #166534;
        font-size: 0.78rem;
        font-weight: 900;
        padding: 0.35rem 0.6rem;
        white-space: nowrap;
    }

    .unlock-pdf-empty-state {
        display: grid;
        gap: 0.35rem;
        margin-top: 18px;
    }

    .unlock-pdf-empty-state strong {
        color: #111827;
    }

    .unlock-pdf-field-card {
        display: grid;
        gap: 8px;
        margin-bottom: 14px;
    }

    .unlock-pdf-field-card label {
        color: #111827;
        font-weight: 900;
    }

    .unlock-pdf-field-card p {
        margin: 0;
    }

    .unlock-pdf-field-input {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 14px;
        background: #ffffff;
        color: #111827;
        padding: 0.9rem 0.95rem;
    }

    .unlock-pdf-field-input:focus {
        border-color: rgba(37, 99, 235, 0.56);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
        outline: none;
    }

    .unlock-pdf-security-notes {
        display: grid;
        gap: 12px;
        margin: 18px 0;
    }

    .unlock-pdf-security-notes strong {
        color: #111827;
        margin-bottom: 4px;
    }

    .unlock-pdf-legal-note {
        margin: 0 0 18px;
        border-color: rgba(217, 119, 6, 0.22);
        background: linear-gradient(135deg, #fff7ed, #fffbeb);
        color: #92400e;
        font-size: 0.98rem;
        font-weight: 950;
        line-height: 1.5;
        box-shadow: 0 14px 30px rgba(217, 119, 6, 0.1);
    }

    .unlock-pdf-process-button,
    .unlock-pdf-download-button {
        width: 100%;
        border: 0;
        border-radius: 16px;
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.25);
        color: #ffffff;
        cursor: pointer;
        font-weight: 950;
        padding: 1rem 1.15rem;
        transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
    }

    .unlock-pdf-process-button:hover:not(:disabled),
    .unlock-pdf-download-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 24px 45px rgba(37, 99, 235, 0.32);
        filter: saturate(1.08);
    }

    .unlock-pdf-process-button.disabled {
        cursor: not-allowed;
        opacity: 0.58;
        transform: none;
        box-shadow: none;
        filter: grayscale(0.4);
    }

    .unlock-pdf-processing-container,
    .unlock-pdf-result-container,
    .unlock-pdf-error-container {
        display: grid;
        justify-items: center;
        gap: 0.9rem;
        border-radius: 24px;
        background: #f8fafc;
        padding: 2rem;
        text-align: center;
    }

    .unlock-pdf-processing-container h2,
    .unlock-pdf-result-container h2,
    .unlock-pdf-error-container h2 {
        margin: 0;
        color: #111827;
        font-size: 1.35rem;
    }

    .unlock-pdf-processing-container p,
    .unlock-pdf-result-container p,
    .unlock-pdf-error-container p {
        max-width: 560px;
        margin: 0;
