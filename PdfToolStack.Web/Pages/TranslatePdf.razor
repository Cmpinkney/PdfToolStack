    {
        if (_fileBytes == null) return;

        var langName = _selectedLang == "other" ? _customLanguage.Trim() : _selectedLangName;
        if (string.IsNullOrWhiteSpace(langName)) { _error = "Please enter a target language."; return; }

        _selectedLangName = langName;
        CurrentState = PageState.Processing;
        _step = 1;
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            _step = 2; StateHasChanged();

            using var content = new MultipartFormDataContent();
            var fc = new ByteArrayContent(_fileBytes);
            fc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fc, "file", _fileName ?? "document.pdf");
            content.Add(new StringContent(_selectedLang), "targetLanguage");
            content.Add(new StringContent(langName), "languageName");

            var pdfBytes = await ApiService.PostMultipartBytesAsync(
                "api/ai/translate", content);

            _step = 3; StateHasChanged();

            if (pdfBytes is { Length: > 0 })
            {
                _translatedPdfBytes = pdfBytes;
                _translatedFileName =
                    $"translated_{_selectedLang}_{Path.GetFileNameWithoutExtension(_fileName ?? "document")}.pdf";
                CurrentState = PageState.Complete;
                SessionUsage.RecordToolCompletion("Translate PDF");
            }
            else
            {
                _error = "Translation failed. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadTranslation()
    {
        if (_translatedPdfBytes == null) return;

        var name = string.IsNullOrWhiteSpace(_translatedFileName)
            ? $"translated_{_selectedLang}_{Path.GetFileNameWithoutExtension(_fileName ?? "document")}.pdf"
            : _translatedFileName;

        await JS.InvokeVoidAsync(
            "downloadFile",
            name,
            Convert.ToBase64String(_translatedPdfBytes));
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _fileBytes = null; _fileName = null;
        _translatedPdfBytes = null; _translatedFileName = string.Empty;
        _error = string.Empty;
        _step = 0; _isRateLimit = false; _isFreeLimit = false;
        _selectedLang = "es"; _selectedLangName = "Spanish";
        _customLanguage = string.Empty; _langSearch = string.Empty;
    }
}
