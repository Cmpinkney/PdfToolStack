@page "/pdf-ocr"
@inject ApiService ApiService
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@inject FileValidationService Validator
@inject NavigationManager Navigation
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>PDF OCR Free Online — Make Scanned PDF Searchable | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="Make scanned PDFs searchable with OCR free online.
                   Extract text from scanned documents, faxes, and image PDFs.
                   Powered by Tesseract. No signup required." />
    <meta name="keywords"
          content="pdf ocr, ocr pdf online free,
                   make pdf searchable, scanned pdf to text" />
    <link rel="canonical" href="https://pdftoolstack.com/pdf-ocr" />
</HeadContent>

<div class="tool-page ocr-tool-page">
    <div class="tool-container ocr-tool-container">

        <section class="tool-hero ocr-tool-hero">
            <div class="trust-row">
                <span>Secure upload</span>
                <span>OCR processing</span>
                <span>Auto-delete after 1 hour</span>
            </div>
            <h1>Make scanned PDFs <span class="hero-gradient-text">searchable</span></h1>
            <p>Add a searchable text layer where OCR succeeds, so recognized text can be searched and copied.</p>
        </section>

        <div class="stepper ai-tool-stepper ocr-tool-stepper" aria-label="OCR steps">
            <div class="stepper-step active"><span>1</span>Upload</div>
            <div class="stepper-step"><span>2</span>OCR</div>
            <div class="stepper-step"><span>3</span>Review</div>
            <div class="stepper-step"><span>4</span>Download</div>
        </div>

        <section class="workflow-grid ocr-tool-workflow">
            <div class="workspace-card ocr-tool-workspace">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="ocr-workspace-header">
                        <span>Upload scan</span>
                        <h2>Start with an image-based PDF</h2>
                        <p>Use OCR for faxes, photographed documents, scanned contracts, or PDFs where text cannot be selected.</p>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved"
                                HintText="Upload a scanned PDF — photos of documents, faxes, or image-based PDFs" />

                    @if (_fileBytes != null)
                    {
                        <div class="ocr-upload-status">
                            @if (_isPageCountLoading)
                            {
                                <span>Checking page count...</span>
                            }
                            else if (_pageCount <= FreePageLimit)
                            {
                                <strong>Free OCR available</strong>
                                <span>@_pageCount page@(_pageCount == 1 ? "" : "s") detected. English searchable PDF is included.</span>
                            }
                            else
                            {
                                <strong>@_pageCount pages detected</strong>
                                <span>Free OCR includes the first @FreePageLimit pages.</span>
                            }
                        </div>
                        @if (_showUpgradeRequired)
                        {
                            <div class="ocr-upgrade-card">
                                <span class="ocr-upgrade-kicker">Upgrade required</span>
                                    <h3>@_upgradeTitle</h3>
                                    <p>@_upgradeMessage</p>

                                <div class="ocr-upgrade-actions">
                                <button class="process-button ocr-secondary-cta"
                                        @onclick="() => RunOcr(OcrProcessMode.FreePreview)">
                                    OCR first @FreePageLimit pages free
                                </button>

                                <button class="process-button"
                                        @onclick="GoToPricing">
                                    Upgrade to Pro
                                </button>
                                </div>
                            </div>
                        }

                        @if (!_isPageCountLoading && _pageCount <= FreePageLimit)
                        {
                            <button class="process-button ocr-primary-cta" @onclick="() => RunOcr(OcrProcessMode.FreePreview)">
                                🔍 Make Searchable with Free OCR
                            </button>
                        }

                        @if (!_isPageCountLoading && _pageCount > FreePageLimit)
                        {
                            <div class="ocr-upgrade-card">
                                <span class="ocr-upgrade-kicker">Full document OCR is Pro</span>
                                <h3>This PDF has @_pageCount pages. Free OCR includes @FreePageLimit pages.</h3>
                                <p>Try the first @FreePageLimit pages now, or upgrade to OCR the full document with multilingual and export workflows.</p>
                                <div class="ocr-upgrade-actions">
                                    <button class="process-button ocr-secondary-cta" @onclick="() => RunOcr(OcrProcessMode.FreePreview)">
                                        OCR first @FreePageLimit pages free
                                    </button>
                                    <a class="ocr-upgrade-link" href="/pricing">
                                        Upgrade to OCR full document
                                    </a>
                                </div>
                            </div>
                        }
                    }
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="ai-processing-container ocr-processing-card">
                        <div class="ai-processing-icon">🔍</div>
                        <h3>OCR is reading your document...</h3>
                        <p>This may take 30–60 seconds for multi-page documents</p>
                        <div class="ai-processing-steps">
                            <div class="ai-processing-step @(_step >= 1 ? "done" : "")">
                                Rendering PDF pages
                            </div>
                            <div class="ai-processing-step @(_step >= 2 ? "done" : "")">
                                Reading text with OCR
                            </div>
                            <div class="ai-processing-step @(_step >= 3 ? "done" : "")">
                                Building searchable PDF
                            </div>
                        </div>
                    </div>
                }

                @if (CurrentState == PageState.Complete && _outputBytes != null)
                {
                    <div class="ai-result-card ocr-result-card">
                        <div class="ai-result-header">
                            <div>
                                <span class="ocr-result-kicker">Searchable document ready</span>
                                <h2>OCR complete</h2>
                                <p style="color:var(--text-secondary); font-size:0.875rem;">
                                    @_fileName — @OcrCompletionDescription
                                </p>
                            </div>
                            <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
                                <button class="download-button"
                                        style="max-width:220px; margin-top:0;"
                                        @onclick="DownloadFile">
                                    ⬇ Download Searchable PDF
                                </button>
                                <button class="reset-button"
                                        style="max-width:160px;"
                                        @onclick="Reset">
                                    Process Another
                                </button>
                            </div>
                        </div>

                        <div class="ocr-result-features">
                            <div class="ocr-result-feat">
                                <div class="ocr-result-feat-icon">✅</div>
                                <div>
                                    <strong>Text is now selectable</strong>
                                    <p>Click and drag to select any text in the PDF</p>
                                </div>
                            </div>
                            <div class="ocr-result-feat">
                                <div class="ocr-result-feat-icon">🔍</div>
                                <div>
                                    <strong>Ctrl+F search works</strong>
                                    <p>Find any word or phrase in the document</p>
                                </div>
                            </div>
                            <div class="ocr-result-feat">
                                <div class="ocr-result-feat-icon">📋</div>
                                <div>
                                    <strong>Text can be copied</strong>
                                    <p>Copy content directly from the PDF</p>
                                </div>
                            </div>
                            <div class="ocr-result-feat">
                                <div class="ocr-result-feat-icon">🌐</div>
                                <div>
                                    <strong>Searchable text layer</strong>
                                    <p>Recognized text can be searched and copied</p>
                                </div>
                            </div>
                        </div>

                        <div class="ocr-next-actions" aria-label="Next OCR actions">
                            <a class="ocr-next-card pro" href="/extract-invoice-data">
                                <span>Pro/AI</span>
                                <strong>Extract tables</strong>
                                <p>Turn scanned tables and invoices into structured data.</p>
                            </a>
                            <a class="ocr-next-card ai" href="/ai-summarizer">
                                <span>AI</span>
                                <strong>Summarize document</strong>
                                <p>Get key points from the OCR text in seconds.</p>
                            </a>
                            <a class="ocr-next-card ai" href="/chat-with-pdf">
                                <span>AI</span>
                                <strong>Ask questions</strong>
                                <p>Chat with the searchable PDF content.</p>
                            </a>
                            <a class="ocr-next-card pro" href="/pdf-to-word">
                                <span>Pro</span>
                                <strong>Convert to Word</strong>
                                <p>Export searchable content into an editable workflow.</p>
                            </a>
                            <a class="ocr-next-card pro" href="/batch">
                                <span>Pro</span>
                                <strong>Batch OCR similar files</strong>
                                <p>Process repeated scanned documents together.</p>
                            </a>
                        </div>

                        <div class="extract-download-cta" style="margin-top:1rem;">
                            <div class="extract-download-cta-text">
                                <svg width="20" height="20" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round"
                                     style="color:var(--success); flex-shrink:0;">
                                    <circle cx="11" cy="11" r="8" />
                                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                                </svg>
                                <div>
                                    <strong>Your PDF is ready</strong>
                                    <p>Recognized text can be searched and copied. Highlight alignment may vary depending on scan quality.</p>
                                </div>
                            </div>
                            <button class="download-button"
                                    style="max-width:220px; margin-top:0;"
                                    @onclick="DownloadFile">
                                ⬇ Download Searchable PDF
                            </button>
                        </div>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container" role="alert">
                        <span class="error-icon" aria-hidden="true">❌</span>
                        <p class="error-message">@_error</p>
                        <button class="reset-button" @onclick="Reset">Try Again</button>
                    </div>
                }
            </div>

            <aside class="settings-card ocr-tool-settings">
                <div class="ocr-settings-header">
                    <span>OCR settings</span>
                    <h2>What OCR does</h2>
                    <p>Choose the document language, then convert image-based text into a searchable PDF layer.</p>
                </div>

                <div class="ocr-plan-card">
                    @if (_isPro)
                    {
                        <div class="ocr-pro-unlocked">
                            Pro OCR unlocked — full document OCR is available.
                        </div>
                    }
                    <div>
                        <span class="ocr-plan-label">Free OCR includes</span>
                        <ul>
                            <li>English OCR</li>
                            <li>@FreePageLimit pages per PDF</li>
                            <li>Searchable PDF output</li>
                        </ul>
                    </div>
                    <div>
                        <span class="ocr-plan-label pro">Pro unlocks</span>
                        <ul>
                            <li>Full document OCR</li>
                            <li>Multilingual OCR</li>
                            <li>Batch OCR</li>
                            <li>Export to Word/Excel</li>
                        </ul>
                    </div>
                </div>

                <div class="ocr-lang-section">
                    <p class="ocr-lang-label">Document language</p>
                    <div class="ocr-lang-grid">
                        @foreach (var lang in _languages)
                        {
                            <button class="ocr-lang-btn @(_language == lang.Code ? "active" : "")"
                                    @onclick="() => _language = lang.Code">
                                <span class="ocr-lang-flag">@lang.Flag</span>
                                <span class="ocr-lang-name">@lang.Name</span>
                            </button>
                        }
                    </div>
                </div>

                <div class="ocr-value-card">
                    <h3>OCR helps you</h3>
                    <div class="ocr-value-list">
                        <span>Converts images into text</span>
                        <span>Make PDFs searchable</span>
                        <span>Enables copy &amp; paste</span>
                        <span>Works best with clean scans</span>
                    </div>
                    <p class="ocr-quality-note">Results may vary depending on scan quality.</p>
                </div>

                <div class="ocr-trust-card">
                    <span>Files deleted in 1 hour</span>
                    <span>Searchable PDF output</span>
                    <span>Copy and paste enabled</span>
                </div>
            </aside>
        </section>

    </div>

    <div class="faq-section" aria-labelledby="ocr-related-title">
        <h2 id="ocr-related-title">Related OCR workflows</h2>
        <div class="faq-item">
            <h3><a href="/translate-pdf">Translate PDF</a></h3>
            <p>Translate recognized text from text-based PDFs into supported languages.</p>
        </div>
        <div class="faq-item">
            <h3><a href="/chat-with-pdf">Chat with PDF</a></h3>
            <p>Ask questions after OCR makes recognized text available.</p>
        </div>
        <div class="faq-item">
            <h3><a href="/ai-summarizer">Summarize PDF</a></h3>
            <p>Turn long recognized documents into concise summaries.</p>
        </div>
        <div class="faq-item">
            <h3><a href="/extract-invoice-data">Extract Invoice Data</a></h3>
            <p>Extract structured fields from invoices and business PDFs.</p>
        </div>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What is OCR?</h3>
            <p>OCR (Optical Character Recognition) reads text from images and scanned documents, making it searchable and selectable. Perfect for faxes, scanned contracts, and photo PDFs.</p>
        </div>
        <div class="faq-item">
            <h3>What types of PDFs does this work on?</h3>
            <p>Any image-based PDF — scanned documents, photographed pages, faxes, and PDFs where you can't select the text. If you can already select text in your PDF, it doesn't need OCR.</p>
        </div>
        <div class="faq-item">
            <h3>How accurate is the OCR?</h3>
            <p>Our OCR engine is very accurate on clean, high-contrast scans. Handwriting and very low-quality scans may have reduced accuracy. For best results, use 300 DPI or higher scans.</p>
        </div>
        <div class="faq-item">
            <h3>Which languages are supported?</h3>
            <p>English is currently available. Additional OCR languages will be added as their language data is deployed.</p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored anywhere?</h3>
            <p>No. Files are processed in memory and deleted within 1 hour. We never store your documents permanently.</p>
        </div>
    </div>
</div>

<style>
    .ocr-upload-status,
    .ocr-upgrade-card,
    .ocr-plan-card,
    .ocr-trust-card,
    .ocr-next-card {
        border: 1px solid rgba(148,163,184,.18);
        background: rgba(255,255,255,.92);
        box-shadow: 0 10px 28px rgba(15,23,42,.05);
    }

    .ocr-upload-status {
        display: grid;
        gap: .25rem;
        margin-top: 1rem;
        border-radius: 16px;
        padding: 1rem 1.1rem;
        color: var(--text-secondary);
        font-size: .9rem;
    }

    .ocr-upload-status strong {
        color: var(--text);
        font-size: 1rem;
    }

    .ocr-upgrade-card {
        display: grid;
        gap: .8rem;
        margin-top: 1rem;
        border-radius: 18px;
        padding: 1.2rem;
    }

    .ocr-upgrade-kicker,
    .ocr-plan-label,
    .ocr-next-card span {
        color: var(--brand-primary);
        font-size: .74rem;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .ocr-plan-label.pro,
    .ocr-next-card.pro span {
        color: var(--accent);
    }

    .ocr-upgrade-card h3 {
        margin: 0;
        color: var(--text);
        font-size: 1.05rem;
        line-height: 1.35;
    }

    .ocr-upgrade-card p {
        margin: 0;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .ocr-upgrade-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: center;
    }

    .ocr-secondary-cta {
        width: auto;
        min-width: 210px;
        margin: 0;
    }

    .ocr-upgrade-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        border-radius: 14px;
        padding: .75rem 1rem;
        background: #111827;
        color: #fff;
        font-weight: 900;
        text-decoration: none;
    }

    .ocr-plan-card {
        display: grid;
        gap: 1rem;
        margin: 1rem 0;
        border-radius: 18px;
        padding: 1.2rem;
    }

    .ocr-plan-card ul {
        display: grid;
        gap: .45rem;
        margin: .65rem 0 0;
        padding: 0;
        list-style: none;
        color: var(--text-secondary);
        font-size: .9rem;
    }

    .ocr-plan-card li::before,
    .ocr-trust-card span::before {
        content: "";
        display: inline-block;
        width: .42rem;
        height: .42rem;
        margin-right: .55rem;
        border-radius: 999px;
        background: var(--brand-primary);
        vertical-align: .08em;
    }

    .ocr-trust-card {
        display: grid;
        gap: .55rem;
        margin-top: 1rem;
        border-radius: 16px;
        padding: 1rem 1.1rem;
        color: var(--text-secondary);
        font-size: .88rem;
        font-weight: 700;
    }

    .ocr-next-actions {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: .75rem;
        margin-top: 1rem;
    }

    .ocr-next-card {
        display: grid;
        gap: .35rem;
        min-height: 132px;
        border-radius: 18px;
        padding: 1rem;
        color: var(--text);
        text-decoration: none;
    }

    .ocr-next-card strong {
        font-size: .98rem;
        line-height: 1.25;
    }

    .ocr-next-card p {
        margin: 0;
        color: var(--text-secondary);
        font-size: .84rem;
        line-height: 1.45;
    }

    @@media (max-width: 980px) {
        .ocr-next-actions {
            grid-template-columns: 1fr;
        }

        .ocr-upgrade-actions,
        .ocr-secondary-cta,
        .ocr-upgrade-link {
            width: 100%;
        }
    }
</style>

@code {
    private enum PageState { Upload, Processing, Complete, Error }
    private PageState CurrentState = PageState.Upload;
    private const int FreePageLimit = 3;
    private byte[]? _fileBytes;
    private string? _fileName;
    private byte[]? _outputBytes;
    private string _language = "eng";
    private string _error = string.Empty;
    private int _step = 0;
    private int _pageCount = 1;
    private bool _isPageCountLoading;
    private bool _processedFirstThreeOnly;
    private bool _isAuthenticated;
    private bool _isPro;
    private bool _showUpgradeRequired;
    private string _upgradeTitle = string.Empty;
    private string _upgradeMessage = string.Empty;

    private enum OcrProcessMode
    {
        FreePreview,
        FullDocument
    }

    private string OcrCompletionDescription =>
        _processedFirstThreeOnly && _pageCount > FreePageLimit
            ? $"first {FreePageLimit} pages are searchable"
            : "has a searchable text layer where OCR succeeded";

    private record LangOption(string Code, string Name, string Flag);

    private readonly List<LangOption> _languages = new()
    {
        new("eng", "English", "🇬🇧"),
    };

    private async Task HandleFileSelected(IBrowserFile file)
    {
        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }

        using var stream = file.OpenReadStream(maxAllowedSize: 524288000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        _fileName = file.Name;
        _outputBytes = null;
        _processedFirstThreeOnly = false;
        _isPageCountLoading = true;
        Toast.ShowSuccess($"File ready — {Validator.FormatSize(file.Size)}");
        StateHasChanged();

        try
        {
            _pageCount = await ApiService.GetPageCountAsync(_fileBytes, file.Name);
        }
        catch
        {
            _pageCount = 1;
            Toast.ShowWarning("Could not detect page count. Free OCR will continue with the first pages.");
        }
        finally
        {
            _isPageCountLoading = false;
            StateHasChanged();
        }
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
        _outputBytes = null;
        _pageCount = 1;
        _processedFirstThreeOnly = false;
    }

    private async Task RunOcr(OcrProcessMode mode)
    {
        if (_fileBytes == null) return;

        _showUpgradeRequired = false;
        _upgradeTitle = string.Empty;
        _upgradeMessage = string.Empty;

        var processMode = mode == OcrProcessMode.FullDocument
            ? "full-document"
            : "free-preview";

        _processedFirstThreeOnly = mode == OcrProcessMode.FreePreview && _pageCount > FreePageLimit;

        CurrentState = PageState.Processing;
        _step = 1;
        StateHasChanged();

        try
        {
            _ = AnimateSteps();

            using var content = new MultipartFormDataContent();
            var fc = new ByteArrayContent(_fileBytes);
            fc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fc, "file", _fileName ?? "document.pdf");

            _outputBytes = await ApiService.PostMultipartBytesAsync(
                $"api/ai/ocr?language={_language}&processMode={processMode}",
                content);

            if (_outputBytes == null || _outputBytes.Length == 0)
            {
                _error = "OCR processing failed. Please try again.";
                CurrentState = PageState.Error;
                Toast.ShowError(_error);
                return;
            }

            _step = 3;
            CurrentState = PageState.Complete;

            Toast.ShowSuccess(_processedFirstThreeOnly
                ? $"Free preview complete — first {FreePageLimit} pages are searchable."
                : "OCR complete — full document is searchable!");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.PaymentRequired)
        {
            _showUpgradeRequired = true;
            _upgradeTitle = "Upgrade to OCR the full document";
            _upgradeMessage = $"Free OCR supports up to {FreePageLimit} pages. Upgrade to Pro to process the full document.";
            _error = _upgradeMessage;
            CurrentState = PageState.Upload;
            Toast.ShowWarning(_upgradeMessage);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Forbidden)
        {
            _showUpgradeRequired = true;
            _upgradeTitle = "Pro OCR required";
            _upgradeMessage = _language != "eng"
                ? "Multilingual OCR requires Pro."
                : "This OCR feature requires Pro.";
            _error = _upgradeMessage;
            CurrentState = PageState.Upload;
            Toast.ShowWarning(_upgradeMessage);
        }
        catch (Exception ex)
        {
            _error = $"OCR failed: {ex.Message}";
            CurrentState = PageState.Error;
            Toast.ShowError(_error);
        }

        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await Auth.GetAuthenticationStateAsync();
            _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

            if (_isAuthenticated)
            {
                var userId = authState.User.FindFirst("sub")?.Value
                          ?? authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

                if (!string.IsNullOrWhiteSpace(userId))
                {
                    var status = await SubService.GetStatusAsync(userId);
                    _isPro = status?.IsActive == true;
                }
            }
        }
        catch
        {
            _isAuthenticated = false;
            _isPro = false;
        }
    }

    private OcrProcessMode GetDefaultProcessMode()
    {
        if (_isPro && _pageCount > FreePageLimit)
        {
            return OcrProcessMode.FullDocument;
        }

        return OcrProcessMode.FreePreview;
    }

    private string GetPrimaryButtonText()
{
    if (_isPro && _pageCount > FreePageLimit)
    {
        return "OCR full document";
    }

    return "Make searchable with free OCR";
}

    private void GoToPricing()
    {
        Navigation.NavigateTo("/pricing");
    }
    private async Task AnimateSteps()
    {
        await Task.Delay(1500);
        if (CurrentState == PageState.Processing)
        {
            _step = 2;
            StateHasChanged();
        }
    }

    private async Task DownloadFile()
    {
        if (_outputBytes == null) return;
        var name = Path.GetFileNameWithoutExtension(
            _fileName ?? "document") + "_searchable.pdf";
        await JS.InvokeVoidAsync("downloadFile", name,
            Convert.ToBase64String(_outputBytes));
        SessionUsage.RecordToolCompletion("PDF OCR");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _fileBytes = null;
        _fileName = null;
        _outputBytes = null;
        _error = string.Empty;
        _step = 0;
        _pageCount = 1;
