@page "/pdf-ocr"

<PageTitle>PDF OCR - Make Scanned PDFs Searchable | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="PDF OCR text recognition is temporarily unavailable while we improve accuracy. Try our other free PDF tools including Compress PDF, PDF to Word, and Merge PDF." />
    <meta name="keywords"
          content="pdf ocr, ocr pdf online, make pdf searchable, scanned pdf to text" />
    <link rel="canonical" href="https://pdftoolstack.com/pdf-ocr" />
</HeadContent>

<div class="tool-page ocr-upgrade-page">
    <div class="tool-container">
        <section class="ocr-upgrade-hero" aria-labelledby="ocr-upgrade-title">
            <div class="ocr-upgrade-copy">
                <div class="trust-row ocr-upgrade-trust">
                    <span>OCR upgrade in progress</span>
                    <span>No uploads needed</span>
                    <span>Other tools are live</span>
                </div>

                <span class="panel-eyebrow ocr-upgrade-eyebrow">Coming soon</span>
                <h1 id="ocr-upgrade-title">PDF OCR is being <span class="hero-gradient-text">upgraded</span></h1>
                <p class="tool-subtitle">
                    Our OCR text-recognition engine is temporarily unavailable while we improve
                    accuracy and speed. We expect to restore it shortly. Thank you for your patience.
                </p>

                <div class="ocr-upgrade-actions">
                    <a href="/compress-pdf" class="process-button">Try Compress PDF</a>
                    <a href="/#tools" class="reset-button ocr-secondary-button">View all PDF tools</a>
                </div>
            </div>

            <div class="ocr-upgrade-visual" aria-hidden="true">
                <div class="ocr-document-stack">
                    <div class="ocr-document-card ocr-document-card-back"></div>
                    <div class="ocr-document-card">
                        <div class="ocr-doc-header">
                            <span></span>
                            <span></span>
                        </div>
                        <div class="ocr-doc-lines">
                            <span></span>
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <div class="ocr-scan-band"></div>
                    </div>
                </div>
            </div>
        </section>

        <div class="stepper ocr-upgrade-stepper" aria-label="PDF OCR upgrade status">
            <div class="step complete">
                <span>1</span>
                <strong>Paused</strong>
            </div>
            <div class="step active">
                <span>2</span>
                <strong>Upgrade</strong>
            </div>
            <div class="step">
                <span>3</span>
                <strong>Test</strong>
            </div>
            <div class="step">
                <span>4</span>
                <strong>Restore</strong>
            </div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card ocr-upgrade-workspace">
                <div class="panel-header">
                    <span class="panel-eyebrow">Available now</span>
                    <h2>Keep working with these PDF tools</h2>
                    <p>
                        OCR processing is paused, but these related tools are ready for PDF cleanup,
                        conversion, image export, and document assembly.
                    </p>
                </div>

                <div class="empty-state ocr-upgrade-message">
                    <span class="empty-kicker">Temporarily offline</span>
                    <strong>PDF OCR is being upgraded.</strong>
                    <span>No OCR files are uploaded or processed from this page while the upgrade is underway.</span>
                </div>

                <div class="ocr-related-grid" aria-label="Related PDF tools">
                    <a href="/compress-pdf" class="ocr-related-card">
                        <span class="ocr-related-icon">CP</span>
                        <span>
                            <strong>Compress PDF</strong>
                            <small>Reduce file size instantly</small>
                        </span>
                    </a>
                    <a href="/pdf-to-word" class="ocr-related-card">
                        <span class="ocr-related-icon">WD</span>
                        <span>
                            <strong>PDF to Word</strong>
                            <small>Convert to editable DOCX</small>
                        </span>
                    </a>
                    <a href="/pdf-to-jpg" class="ocr-related-card">
                        <span class="ocr-related-icon">JPG</span>
                        <span>
                            <strong>PDF to JPG</strong>
                            <small>Export pages as images</small>
                        </span>
                    </a>
                    <a href="/merge-pdf" class="ocr-related-card">
                        <span class="ocr-related-icon">MG</span>
                        <span>
                            <strong>Merge PDF</strong>
                            <small>Combine multiple PDFs</small>
                        </span>
                    </a>
                </div>
            </div>

            <aside class="settings-card ocr-upgrade-settings">
                <div class="panel-header">
                    <span class="panel-eyebrow">Status</span>
                    <h2>OCR API calls are paused</h2>
                    <p>
                        This temporary page does not upload files or call the OCR API.
                    </p>
                </div>

                <div class="option-list">
                    <span>
                        <strong>Upgrade focus</strong>
                        <small>Improving text-recognition accuracy and processing speed.</small>
                    </span>
                    <span>
                        <strong>Safer placeholder</strong>
                        <small>No OCR workflow is started while maintenance is active.</small>
                    </span>
                    <span>
                        <strong>Tool library available</strong>
                        <small>Browse the full PDF tool list from the homepage.</small>
                    </span>
                </div>

                <a href="/#tools" class="process-button">View all PDF tools</a>
                <div class="secure-note">
                    Need something now? Compress, convert, export, or merge PDFs using the live tools.
                </div>
            </aside>
        </section>
    </div>
</div>

<style>
    .ocr-upgrade-page {
        color: var(--text, #0f172a);
    }

    .ocr-upgrade-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.6fr);
        gap: 32px;
        align-items: center;
        margin: 0 0 24px;
        padding: clamp(1.5rem, 3vw, 2.5rem);
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 28px;
        background:
            radial-gradient(circle at 16% 0%, rgba(109, 93, 252, 0.38), transparent 34%),
            radial-gradient(circle at 88% 18%, rgba(6, 182, 212, 0.28), transparent 30%),
            linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.92));
        box-shadow: 0 26px 70px rgba(15, 23, 42, 0.18);
    }

    .ocr-upgrade-copy {
        position: relative;
        z-index: 1;
        min-width: 0;
    }

    .ocr-upgrade-page .ocr-upgrade-trust span {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.14);
        box-shadow: none;
        color: #e2e8f0;
    }

    .ocr-upgrade-eyebrow {
        display: inline-flex;
        margin-bottom: 12px;
    }

    .ocr-upgrade-hero h1 {
        max-width: 780px;
        margin: 0 0 16px;
        color: #f8fafc;
        font-size: clamp(2.6rem, 5vw, 4.8rem);
        font-weight: 850;
        line-height: 0.98;
        letter-spacing: -0.035em;
    }

    .ocr-upgrade-hero .tool-subtitle {
        max-width: 720px;
        color: #cbd5e1 !important;
    }

    .ocr-upgrade-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
    }

    .ocr-upgrade-actions .process-button,
    .ocr-upgrade-actions .reset-button {
        width: auto;
        min-width: 170px;
    }

    .ocr-secondary-button {
        min-height: 48px;
        border-color: rgba(255, 255, 255, 0.18) !important;
        background: rgba(255, 255, 255, 0.1) !important;
        color: #f8fafc !important;
        text-decoration: none !important;
    }

    .ocr-upgrade-visual {
        position: relative;
        z-index: 1;
        display: grid;
        justify-items: center;
    }

    .ocr-document-stack {
        position: relative;
        width: min(100%, 320px);
        aspect-ratio: 0.82;
    }

    .ocr-document-card {
        position: absolute;
        inset: 18px 18px 0 0;
        display: grid;
        align-content: start;
        gap: 24px;
        padding: 28px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 24px 50px rgba(2, 6, 23, 0.28);
    }

    .ocr-document-card-back {
        inset: 0 0 18px 18px;
        background: linear-gradient(135deg, rgba(109, 93, 252, 0.55), rgba(6, 182, 212, 0.4));
        transform: rotate(4deg);
    }

    .ocr-doc-header,
    .ocr-doc-lines {
        display: grid;
        gap: 10px;
    }

    .ocr-doc-header span,
    .ocr-doc-lines span {
        display: block;
        height: 10px;
        border-radius: 999px;
        background: #c7d2fe;
    }

    .ocr-doc-header span:first-child {
        width: 52%;
        height: 18px;
        background: linear-gradient(135deg, #6d5dfc, #2563eb);
    }

    .ocr-doc-header span:last-child {
        width: 34%;
        background: #bae6fd;
    }

    .ocr-doc-lines span:nth-child(1) {
        width: 88%;
    }

    .ocr-doc-lines span:nth-child(2) {
        width: 76%;
    }

    .ocr-doc-lines span:nth-child(3) {
        width: 94%;
    }

    .ocr-doc-lines span:nth-child(4) {
        width: 62%;
    }

    .ocr-scan-band {
        height: 68px;
        border: 1px solid rgba(37, 99, 235, 0.16);
        border-radius: 18px;
        background:
            linear-gradient(90deg, transparent, rgba(6, 182, 212, 0.22), transparent),
            rgba(239, 246, 255, 0.9);
    }

    .ocr-upgrade-workspace,
    .ocr-upgrade-settings {
        padding: clamp(1.25rem, 2vw, 1.75rem);
    }

    .ocr-upgrade-page .panel-header {
        margin-bottom: 1rem;
    }

    .ocr-upgrade-page .panel-header h2 {
        margin: 0.25rem 0 0;
        color: var(--text, #0f172a);
        font-size: 1.35rem;
        line-height: 1.2;
    }

    .ocr-upgrade-page .panel-header p {
        margin: 0.45rem 0 0;
        color: var(--text-secondary, #64748b);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .ocr-upgrade-page .panel-eyebrow,
    .ocr-upgrade-page .empty-kicker {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .ocr-upgrade-message {
        display: grid;
        gap: 0.4rem;
        margin: 0 0 18px;
        padding: 1rem;
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 20px;
        background: #f8fafc;
    }

    .ocr-upgrade-message strong,
    .ocr-upgrade-message span {
        display: block;
    }

    .ocr-upgrade-message strong {
        color: #1e293b;
        font-size: 1.1rem;
    }

    .ocr-upgrade-message span:last-child {
        color: #64748b;
    }

    .ocr-related-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .ocr-related-card {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 12px;
        align-items: center;
        min-height: 92px;
        padding: 1rem;
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 18px;
        background: rgba(248, 250, 252, 0.92);
        color: inherit;
        text-decoration: none;
        transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .ocr-related-card:hover {
        transform: translateY(-2px);
        border-color: rgba(37, 99, 235, 0.28);
        box-shadow: 0 16px 34px rgba(37, 99, 235, 0.12);
    }

    .ocr-related-icon {
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(109, 93, 252, 0.15), rgba(6, 182, 212, 0.14));
        color: #2563eb;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.02em;
    }

    .ocr-related-card strong,
    .ocr-related-card small {
        display: block;
    }

    .ocr-related-card strong {
        color: var(--text, #0f172a);
        font-size: 0.98rem;
        line-height: 1.2;
    }

    .ocr-related-card small {
        margin-top: 0.25rem;
        color: var(--text-secondary, #64748b);
        font-size: 0.84rem;
        line-height: 1.45;
    }

    .ocr-upgrade-page .option-list {
        display: grid;
        gap: 0.7rem;
        margin-bottom: 1rem;
    }

    .ocr-upgrade-page .option-list span {
        display: grid;
        gap: 0.25rem;
        padding: 0.9rem 1rem;
        border-radius: 16px;
        background: #f8fafc;
    }

    .ocr-upgrade-page .option-list strong {
        color: var(--text, #0f172a);
        font-size: 0.95rem;
    }

    .ocr-upgrade-page .option-list small,
    .ocr-upgrade-page .secure-note {
        color: var(--text-secondary, #64748b);
        font-size: 0.86rem;
        line-height: 1.5;
    }

    .ocr-upgrade-page .settings-card .process-button {
        width: 100%;
        text-decoration: none;
    }

    .ocr-upgrade-page .secure-note {
        margin-top: 1rem;
        text-align: center;
    }

    [data-theme="dark"] .ocr-upgrade-message,
    [data-theme="dark"] .ocr-related-card,
    [data-theme="dark"] .ocr-upgrade-page .option-list span {
        background: rgba(15, 23, 42, 0.72);
        border-color: rgba(148, 163, 184, 0.22);
    }

    [data-theme="dark"] .ocr-upgrade-message strong,
    [data-theme="dark"] .ocr-related-card strong,
    [data-theme="dark"] .ocr-upgrade-page .option-list strong {
        color: #f8fafc;
    }

    [data-theme="dark"] .ocr-upgrade-message span:last-child,
    [data-theme="dark"] .ocr-related-card small,
    [data-theme="dark"] .ocr-upgrade-page .option-list small,
    [data-theme="dark"] .ocr-upgrade-page .secure-note {
        color: #cbd5e1;
    }

    @@media (max-width: 980px) {
        .ocr-upgrade-hero {
            grid-template-columns: 1fr;
        }

        .ocr-upgrade-visual {
            justify-items: start;
        }

        .ocr-document-stack {
            max-width: 260px;
        }
    }

    @@media (max-width: 640px) {
        .ocr-upgrade-hero {
            padding: 1.2rem;
            border-radius: 22px;
        }

        .ocr-upgrade-hero h1 {
            font-size: clamp(2.25rem, 13vw, 3.1rem);
        }

        .ocr-upgrade-actions,
        .ocr-upgrade-actions .process-button,
        .ocr-upgrade-actions .reset-button {
            width: 100%;
        }

        .ocr-related-grid {
            grid-template-columns: 1fr;
        }

        .ocr-upgrade-stepper {
            grid-template-columns: repeat(4, minmax(118px, 1fr)) !important;
        }
    }
</style>
