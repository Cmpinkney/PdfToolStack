@page "/pricing"
@inject NavigationManager Navigation
@inject AuthenticationStateProvider Auth
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject PdfToolStack.Web.Services.ApiService ApiService
@inject HttpClient Http
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json

<PageTitle>Pricing — PdfToolStack AI Document Tools</PageTitle>

<HeadContent>
    <meta name="description" content="Simple pricing for PdfToolStack. Free forever for 35+ PDF tools. Pro at $19/month for AI tools, batch processing, and unlimited files. Teams at $29/month for 5 users." />
    <link rel="canonical" href="https://pdftoolstack.com/pricing" />
</HeadContent>

<div class="pricing-page pricing-premium-page">

    <div class="pricing-hero">
        <div class="pricing-eyebrow">Simple plans for serious document work</div>
        <h1>Choose the plan that fits your document workflow</h1>
        <p>Start free, then upgrade when you need larger files, batch processing, faster workflows, and secure document handling built for daily work.</p>
        <div class="pricing-trust-row">
            <span>Secure processing</span>
            <span>Cancel anytime</span>
            <span>No data training</span>
            <span>Files auto-deleted</span>
        </div>

        <!-- Billing toggle -->
        <div class="pricing-toggle-wrap">
            <span class="pricing-toggle-label @(!_isAnnual ? "active" : "")">Monthly</span>
            <button class="pricing-toggle @(_isAnnual ? "on" : "")"
                    @onclick="ToggleBilling"
                    aria-label="Toggle billing period">
                <span class="pricing-toggle-thumb"></span>
            </button>
            <span class="pricing-toggle-label @(_isAnnual ? "active" : "")">
                Annual
                <span class="pricing-save-badge">Save 33%</span>
            </span>
        </div>
    </div>

    <!-- Pricing Cards -->
    <div class="pricing-grid pricing-grid-3">

        <!-- Free -->
        <div class="pricing-card pricing-card-free">
            <div class="pricing-card-kicker">Start here</div>
            <div class="pricing-plan-name">Free</div>
            <div class="pricing-price">
                $0
                <span>/forever</span>
            </div>
            <div class="pricing-desc">
                Basic tools for quick PDF tasks with smaller files and occasional document work.
            </div>
            <ul class="pricing-features">
                <li class="feat-yes">Basic PDF tools included</li>
                <li class="feat-yes">Smaller files up to 25MB</li>
                <li class="feat-yes">Limited batch access</li>
                <li class="feat-yes">5 AI uses per month</li>
                <li class="feat-yes">Secure processing and 1-hour deletion</li>
                <li class="feat-no">No download history</li>
                <li class="feat-no">Ads shown</li>
            </ul>
            <a href="/" class="pricing-btn-free">
                Get Started Free
            </a>
        </div>

        <!-- Pro -->
        <div class="pricing-card pricing-card-featured">
            <div class="pricing-popular-badge">Recommended</div>
            <div class="pricing-card-kicker">Best for daily workflows</div>
            <div class="pricing-plan-name">Pro</div>
            <div class="pricing-price">
                @if (_isAnnual)
                {
                    <span class="pricing-price-old">$19</span>
                    <span class="pricing-price-main">$12.67</span>
                    <span>/month</span>
                }
                else
                {
                    <span class="pricing-price-main">$19</span>
                    <span>/month</span>
                }
            </div>
            @if (_isAnnual)
            {
                <div class="pricing-billed-note">Billed $152/year — save $76</div>
            }
            else
            {
                <div class="pricing-billed-note">Or $152/year and save $76</div>
            }
            <div class="pricing-desc">
                For professionals who need bigger files, repeat workflows, AI tools, and faster document turnaround.
            </div>
            <ul class="pricing-features">
                <li class="feat-yes">Everything in Free</li>
                <li class="feat-yes">Larger files up to 500MB</li>
                <li class="feat-yes">Batch workflows up to 20 files</li>
                <li class="feat-yes">Faster processing for busy days</li>
                <li class="feat-yes">Priority AI features with 200 uses per month</li>
                <li class="feat-yes">OCR, Translate, Chat, Summarize, and Compare</li>
                <li class="feat-yes">Download history for 30 days</li>
                <li class="feat-yes">Cloud storage with Drive, OneDrive, and Dropbox</li>
                <li class="feat-yes">No ads</li>
            </ul>
            <button class="pricing-btn-pro"
                    @onclick="() => Subscribe(_isAnnual ? _yearlyPriceId : _monthlyPriceId)"
                    disabled="@(IsLoading || string.IsNullOrWhiteSpace(_isAnnual ? _yearlyPriceId : _monthlyPriceId))">
                @if (IsLoading && _checkoutTarget == "pro")
                {
                    <span>Loading...</span>
                }
                else if (_isAnnual)
                {
                    <span>Start Pro — $152/year</span>
                }
                else
                {
                    <span>Start Pro — $19/month</span>
                }
            </button>
            @if (!_isAnnual)
            {
                <div class="pricing-yearly-nudge">
                    Or
                    <button class="pricing-link-btn"
                            @onclick='() => { _isAnnual = true; }'>
                        save $76 with annual billing →
                    </button>
                </div>
            }
        </div>

        <!-- Teams -->
        <div class="pricing-card pricing-card-teams">
            <div class="pricing-teams-badge">For Small Teams</div>
            <div class="pricing-card-kicker">Shared document operations</div>
            <div class="pricing-plan-name">Teams</div>
            <div class="pricing-price">
                <span class="pricing-price-main">$29</span>
                <span>/month</span>
            </div>
            <div class="pricing-billed-note">
                Up to 5 users included — $6/mo per additional seat
            </div>
            <div class="pricing-desc">
                For groups that need shared workflows, admin controls, and higher usage across a team.
            </div>
            <ul class="pricing-features">
                <li class="feat-yes">Everything in Pro</li>
                <li class="feat-yes">5 seats included</li>
                <li class="feat-yes">Shared team workspace</li>
                <li class="feat-yes">Admin usage dashboard</li>
                <li class="feat-yes">Higher shared usage with 500 AI uses per month</li>
                <li class="feat-yes">Invoice &amp; PO billing</li>
                <li class="feat-yes">Priority support</li>
                <li class="feat-yes">Onboarding call included</li>
            </ul>
            <button class="pricing-btn-teams"
                    @onclick='() => Subscribe(_teamsPriceId)'
                    disabled="@(IsLoading || string.IsNullOrWhiteSpace(_teamsPriceId))">
                @if (IsLoading && _checkoutTarget == "teams")
                {
                    <span>Loading...</span>
                }
                else
                {
                    <span>Start Teams — $29/month</span>
                }
            </button>
            <div class="pricing-yearly-nudge">
                5 seats = $29/mo — less than one billable hour
            </div>
        </div>

    </div>

    <!-- Pay as you go -->
    <div class="pricing-addons">
        <h2>Pay as you go</h2>
        <p class="pricing-addons-subtitle">
            Need a one-time unlock instead of a subscription? Buy only what you need and keep moving.
        </p>

        <div class="addon-grid">

            <div class="addon-card">
                <div class="addon-badge">One-time</div>
                <h3>Large File Unlock</h3>
                <div class="addon-price">$1.99</div>
                <p class="addon-description">
                    Process one file up to 500MB without upgrading to Pro.
                </p>
                <ul class="addon-features">
                    <li>One oversized file</li>
                    <li>Up to 500MB</li>
                    <li>Great for occasional use</li>
                </ul>
                <button class="pricing-btn-addon"
                        @onclick='() => BuyAddon(_largeFilePriceId, "large_file")'
                        disabled="@(IsLoading || string.IsNullOrWhiteSpace(_largeFilePriceId))">
                    @if (IsLoading && _checkoutTarget == "large_file")
                    {
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Unlock for $1.99</span>
                    }
                </button>
            </div>

            <div class="addon-card">
                <div class="addon-badge">One-time</div>
                <h3>AI Day Pass</h3>
                <div class="addon-price">$4.99</div>
                <p class="addon-description">
                    Get 20 AI uses valid for 24 hours. Perfect for a busy day of document work.
                </p>
                <ul class="addon-features">
                    <li>20 AI uses</li>
                    <li>Valid for 24 hours</li>
                    <li>No subscription required</li>
                </ul>
                <button class="pricing-btn-addon"
