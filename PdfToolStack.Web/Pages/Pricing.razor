                <h3>AI Credit Pack</h3>
                <div class="addon-price">$9.99</div>
                <p class="addon-description">
                    Buy 50 AI credits that do not expire. Best for occasional AI-heavy workflows.
                </p>
                <ul class="addon-features">
                    <li>50 AI credits</li>
                    <li>Never expire</li>
                    <li>Good for repeat use</li>
                </ul>
                <button class="pricing-btn-addon"
                        @onclick='() => BuyAddon(_aiCredits50PriceId, "ai_credit_pack")'
                        disabled="@(IsLoading || string.IsNullOrWhiteSpace(_aiCredits50PriceId))">
                    @if (IsLoading && _checkoutTarget == "ai_credit_pack")
                    {
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Buy for $9.99</span>
                    }
                </button>
            </div>

            <div class="addon-card">
                <div class="addon-badge">One-time</div>
                <h3>Batch Unlock</h3>
                <div class="addon-price">$4.99</div>
                <p class="addon-description">
                    Run one batch job for up to 20 files without subscribing to Pro.
                </p>
                <ul class="addon-features">
                    <li>One batch job</li>
                    <li>Up to 20 files</li>
                    <li>Fast one-off workflow</li>
                </ul>
                <button class="pricing-btn-addon"
                        @onclick='() => BuyAddon(_batchUnlockPriceId, "batch_unlock")'
                        disabled="@(IsLoading || string.IsNullOrWhiteSpace(_batchUnlockPriceId))">
                    @if (IsLoading && _checkoutTarget == "batch_unlock")
                    {
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Buy for $4.99</span>
                    }
                </button>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(_addonError))
        {
            <div class="pricing-addon-error">@_addonError</div>
        }

        <div class="pricing-addons-note">
            One-time purchases are ideal for occasional work. If you handle documents every week, Pro is usually the better value.
        </div>
    </div>

    <!-- Competitor comparison -->
    <div class="pricing-vs-bar">
        <div class="pricing-vs-inner">
            <span class="pricing-vs-label">How we compare</span>
            <div class="pricing-vs-items">
                <div class="pricing-vs-item">
                    <span class="pricing-vs-them">Smallpdf Pro</span>
