@code {
    private bool IsLoading = false;
    private bool _isAnnual = false;
    private string _checkoutTarget = string.Empty;
    private string UserId = string.Empty;
    private string UserEmail = string.Empty;

    private string? _monthlyPriceId;
    private string? _yearlyPriceId;
    private string? _teamsPriceId;

    private string? _largeFilePriceId;
    private string? _aiDayPassPriceId;
    private string? _aiCredits50PriceId;
    private string? _batchUnlockPriceId;

    private string? _addonError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        UserId = user.FindFirst("sub")?.Value ?? string.Empty;
        UserEmail = user.FindFirst("email")?.Value ?? string.Empty;

        await LoadPlansAsync();
        await LoadAddonsAsync();
    }

    private void ToggleBilling() => _isAnnual = !_isAnnual;

    private async Task LoadPlansAsync()
    {
        try
        {
            var plans = await ApiService.GetAsync<PlansResponse>("api/subscription/plans");

            if (plans != null)
            {
                _monthlyPriceId = plans.Monthly?.PriceId;
                _yearlyPriceId = plans.Yearly?.PriceId;
                _teamsPriceId = plans.Teams?.PriceId;
            }
        }
        catch
        {
            // Buttons stay disabled if plans fail to load
        }
    }

    private async Task LoadAddonsAsync()
    {
        try
        {
            var addons = await ApiService.GetAsync<AddonsResponse>("api/subscription/addons");

            if (addons != null)
            {
                _largeFilePriceId = addons.LargeFile?.PriceId;
                _aiDayPassPriceId = addons.AiDayPass?.PriceId;
                _aiCredits50PriceId = addons.AiCredits50?.PriceId;
                _batchUnlockPriceId = addons.BatchUnlock?.PriceId;
            }
        }
        catch
        {
            // Add-on buttons stay disabled if endpoint is not wired yet
        }
    }

    private async Task Subscribe(string? priceId)
    {
        if (string.IsNullOrEmpty(priceId)) return;

        if (string.IsNullOrEmpty(UserId))
        {
            Navigation.NavigateTo("authentication/login");
            return;
        }

        _checkoutTarget = priceId == _teamsPriceId ? "teams" : "pro";
        IsLoading = true;
        StateHasChanged();

        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        var url = await SubService.CreateCheckoutSessionAsync(
            priceId, UserId, UserEmail, baseUrl);

        if (!string.IsNullOrEmpty(url))
        {
            Navigation.NavigateTo(url, true);
            return;
        }

        IsLoading = false;
        StateHasChanged();
    }

    private async Task BuyAddon(string? priceId, string addonType)
    {
        if (string.IsNullOrWhiteSpace(priceId))
            return;

        if (string.IsNullOrEmpty(UserId))
        {
            Navigation.NavigateTo("authentication/login");
            return;
        }

        _addonError = null;
        _checkoutTarget = addonType;
        IsLoading = true;
        StateHasChanged();

        var baseUrl = Navigation.BaseUri.TrimEnd('/');

        try
        {
            var response = await Http.PostAsJsonAsync("api/subscription/create-addon-checkout", new AddonCheckoutRequest
            {
                PriceId = priceId,
                AddonType = addonType,
                Email = UserEmail,
                SuccessUrl = baseUrl + "/subscription/success",
                CancelUrl = baseUrl + "/pricing"
            });

            if (!response.IsSuccessStatusCode)
            {
                var errorText = await response.Content.ReadAsStringAsync();
                _addonError = string.IsNullOrWhiteSpace(errorText)
                    ? "Could not start checkout. Please try again."
                    : errorText;
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<CheckoutResponseDto>();

            if (result == null || string.IsNullOrWhiteSpace(result.Url))
            {
                _addonError = "Checkout URL was not returned.";
                return;
            }

            Navigation.NavigateTo(result.Url, forceLoad: true);
            return;
        }
        catch
        {
            _addonError = "Could not start checkout. Please try again.";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private class PlansResponse
    {
        public PlanInfo? Monthly { get; set; }
        public PlanInfo? Yearly { get; set; }
        public PlanInfo? Teams { get; set; }
    }

    private class AddonsResponse
    {
        public AddonInfo? LargeFile { get; set; }
        public AddonInfo? AiDayPass { get; set; }
        public AddonInfo? AiCredits50 { get; set; }
        public AddonInfo? BatchUnlock { get; set; }
    }

    private class PlanInfo
    {
        public string PriceId { get; set; } = string.Empty;
        public int Amount { get; set; }
        public string Label { get; set; } = string.Empty;
    }

    private class AddonInfo
    {
        public string PriceId { get; set; } = string.Empty;
        public int Amount { get; set; }
        public string Label { get; set; } = string.Empty;
    }

    private class AddonCheckoutRequest
    {
        public string PriceId { get; set; } = string.Empty;
        public string AddonType { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string SuccessUrl { get; set; } = string.Empty;
        public string CancelUrl { get; set; } = string.Empty;
    }

    private class CheckoutResponseDto
    {
        public string Url { get; set; } = string.Empty;
    }
}
