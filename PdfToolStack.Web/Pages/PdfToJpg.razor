@page "/pdf-to-jpg"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage


<PageTitle>PDF to JPG Converter Free Online — Convert PDF Pages to Images</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert PDF pages to JPG images free online.
                   Extract images from PDF or save each page
                   as a separate image. No signup required." />
    <meta name="keywords"
          content="pdf to jpg, convert pdf to image,
                   pdf to png free online, pdf to image, pdf page to image" />
    <link rel="canonical"
          href="https://pdftoolstack.com/pdf-to-jpg" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <section class="tool-hero">
            <div>
                <div class="trust-row">
                    <span>Secure processing</span>
                    <span>JPG or ZIP output</span>
                    <span>Deleted in 1 hour</span>
                </div>

                <h1>Convert PDF to JPG <span class="hero-gradient-text">instantly</span></h1>
                <p class="tool-subtitle">
                    Turn PDF pages into high-quality JPG images for sharing,
                    previews, and web use.
                </p>
            </div>
        </section>

        <div class="stepper" aria-label="Conversion progress">
            <div class="step @(CurrentState == PageState.Upload && SelectedFile == null ? "active" : SelectedFile != null || CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>1</span>
                <strong>Upload</strong>
            </div>
            <div class="step @(CurrentState == PageState.Upload && SelectedFile != null ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>2</span>
                <strong>Configure</strong>
            </div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">
                <span>3</span>
                <strong>Process</strong>
            </div>
            <div class="step @(CurrentState == PageState.Complete ? "active complete" : "")">
                <span>4</span>
                <strong>Download</strong>
            </div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Upload PDF</span>
                        <h2>Start with your pages</h2>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved"
                                HintText="Upload a PDF — each page becomes a JPG image" />

                    @if (SelectedFile != null)
                    {
                        <div class="file-ready-card">
                            <div class="file-ready-header">
                                <div class="file-ready-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z" />
                                        <polyline points="14 2 14 7 19 7" />
                                        <polyline points="9 14 11 16 15 12" />
                                    </svg>
                                </div>
                                <div>
                                <span class="panel-eyebrow">Ready to process</span>
                                <strong>@SelectedFile.Name</strong>
                                <div class="file-ready-meta">
                                    <span>@Path.GetExtension(SelectedFile.Name).TrimStart('.').ToUpperInvariant()</span>
                                    <span>@FormatFileSize(SelectedFile.Size)</span>
                                </div>
                                <small>Will convert pages to JPG</small>
                                </div>
                            </div>
                            <div class="ready-metrics">
                                <span>Every page</span>
                                <span>High-quality JPG</span>
                                <span>ZIP if needed</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-kicker">Image export</span>
                            <strong>Upload a PDF to render pages as crisp JPG images.</strong>
                            <span>Your image output profile appears once the document is ready.</span>
                        </div>
                    }
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container" role="status">
                        <div class="spinner"></div>
                        <h2>Rendering your pages</h2>
                        <p>Converting each page, optimizing image quality, and preparing your download.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete && OutputBytes != null)
                {
                    <div class="result-container">
                        <span class="result-icon" aria-hidden="true">Ready</span>
                        <h2>Your JPG images are ready</h2>
                        <p class="result-copy">
                            @ResultMessage
                        </p>
                        <button class="download-button" @onclick="DownloadFile">
                            @DownloadLabel
                        </button>
                        <button class="reset-button" @onclick="Reset">
                            Convert Another PDF
                        </button>
                        <div class="post-success-upsell">
                            <div class="post-success-accent"></div>
                            <div class="post-success-copy">
                                <strong>Need to process more files?</strong>
                                <p>Upgrade to Pro for larger files, faster processing, and batch workflows.</p>
                                <div class="post-success-benefits">
                                    <span>Larger files</span>
                                    <span>Faster processing</span>
                                    <span>Batch workflows</span>
                                </div>
                            </div>
                            <a class="post-success-link" href="/pricing">
                                View Pro options
                            </a>
                        </div>

                        <RecentFiles FileName="@(SelectedFile?.Name ?? "Converted PDF")"
                                     ToolName="PDF to JPG"
                                     OnDownloadAgain="@DownloadFile" />
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container" role="alert">
                        <span class="error-icon" aria-hidden="true">Conversion failed</span>
                        <h2>We could not finish the image export</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button" @onclick="Reset">Try Again</button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Image output</span>
                    <h2>Create JPG images</h2>
                    <p>Export PDF pages into sharp images for previews, sharing, web use, and asset handoff.</p>
                </div>

                @if (SelectedFile != null)
                {
                    <div class="file-summary">
                        <span class="file-name">@SelectedFile.Name</span>
                        <span class="file-size">@FormatFileSize(SelectedFile.Size)</span>
                    </div>
                }

                <div class="option-list">
                    <span><strong>Page-by-page export</strong><small>Converts every PDF page into an image output.</small></span>
                    <span><strong>High-quality images</strong><small>Renders clear JPGs suited for previews and sharing.</small></span>
                    <span><strong>ZIP output</strong><small>Bundles multiple page images into one clean download.</small></span>
                </div>

                @if (CurrentState == PageState.Upload && SelectedFile != null)
                {
                    <button class="process-button" @onclick="ProcessFile">
                        Convert to JPG
                    </button>
                    <div class="secure-note">
                        Secure processing. Files are deleted within 1 hour.
                    </div>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>
                        Convert to JPG
                    </button>
                    <p class="action-hint">Upload a PDF to enable conversion.</p>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What image format is the output?</h3>
            <p>
                Single page PDFs download as a JPG file.
                Multi-page PDFs download as a ZIP file containing
                one JPG per page.
            </p>
        </div>
        <div class="faq-item">
            <h3>Can I convert specific pages only?</h3>
            <p>
                Currently all pages are converted. Page selection
                is coming in a future update.
            </p>
        </div>
        <div class="faq-item">
            <h3>Will this affect my PDF quality?</h3>
            <p>
                Pages are rendered at high resolution (1080px wide)
                so the output images are clear and sharp.
            </p>
        </div>
        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>
                Your file is automatically deleted within
                1 hour of processing. We never store your
                documents permanently.
            </p>
        </div>
    </div>
</div>

<style>
