@code {
    private bool ShowAdsForCurrentUser = true; // TODO: Hide ads for paid users when subscription state is available here.
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private string Password = string.Empty;
    private string ConfirmPassword = string.Empty;
    private bool RequirePasswordToOpen = true;
    private bool RestrictEditingAndCopying = true;
    private int _uploadKey;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    private bool CanAttemptLock =>
        SelectedFile != null
        && UploadedBytes != null
        && !string.IsNullOrWhiteSpace(Password)
        && !string.IsNullOrWhiteSpace(ConfirmPassword);

    private string PasswordHint =>
        RequirePasswordToOpen
            ? "This password will be required to open the protected PDF."
            : "This password is used for PDF permission controls.";

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }

        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            if (PaymentService.IsFileTooLargeForFree(file.Size))
            {
                SelectedFile = file;
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesValidation = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesValidation.IsValid)
            {
                Toast.ShowError(bytesValidation.Message!);
                UploadedBytes = null;
                return;
            }

            if (bytesValidation.IsWarning)
                Toast.ShowWarning(bytesValidation.Message!);

            SelectedFile = file;
            Toast.ShowSuccess($"File ready - {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex)
        {
            UploadedBytes = null;
            Toast.ShowError($"Could not read file: {ex.Message}");
        }

        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        Password = string.Empty;
        ConfirmPassword = string.Empty;
        _uploadKey++;
    }

    private async Task ProcessFile()
    {
        ErrorMessage = null;

        if (SelectedFile == null || UploadedBytes == null)
        {
            ErrorMessage = "Upload a PDF before locking it.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Enter a password for the protected PDF.";
            return;
        }

        if (!string.Equals(Password, ConfirmPassword, StringComparison.Ordinal))
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        if (!RequirePasswordToOpen && !RestrictEditingAndCopying)
        {
            ErrorMessage = "Require an open password or enable permission restrictions.";
            return;
        }

        var userPassword = RequirePasswordToOpen ? Password : string.Empty;
        var ownerPassword = Password;
        var allowPrinting = true;
        var allowCopying = !RestrictEditingAndCopying;

        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            ResultBytes = await ApiService.ProtectPdfAsync(
                UploadedBytes,
                SelectedFile.Name,
                userPassword,
                ownerPassword,
                allowPrinting,
                allowCopying);

            Password = string.Empty;
            ConfirmPassword = string.Empty;

            if (ResultBytes?.Length > 0)
            {
                CurrentState = PageState.Complete;
                Toast.ShowSuccess("PDF locked successfully.");
            }
            else
            {
                ErrorMessage = "Failed to lock PDF. Please try again.";
                Toast.ShowError(ErrorMessage);
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            Password = string.Empty;
            ConfirmPassword = string.Empty;
            ErrorMessage = $"Error: {ex.Message}";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null)
            return;

        var baseName = Path.GetFileNameWithoutExtension(SelectedFile?.Name ?? "document");
        var fileName = $"{baseName}_locked.pdf";

        await JS.InvokeVoidAsync(
            "downloadFile",
            fileName,
            Convert.ToBase64String(ResultBytes));

        SessionUsage.RecordToolCompletion("Lock PDF");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        Password = string.Empty;
        ConfirmPassword = string.Empty;
        RequirePasswordToOpen = true;
        RestrictEditingAndCopying = true;
        _uploadKey++;
    }
}
