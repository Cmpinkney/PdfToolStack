@page "/account/delete"
@inject ApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Delete Account — PdfToolStack</PageTitle>

<div class="tool-page">
    <div class="tool-container" style="max-width:560px;margin:0 auto;">

        @if (!_confirmed)
        {
            <div class="sign-card" style="text-align:center;padding:2.5rem;">
                <div style="font-size:3rem;margin-bottom:1rem;">⚠️</div>
                <h1 style="font-size:1.5rem;margin-bottom:1rem;">
                    Delete your account
                </h1>
                <p style="color:var(--text-secondary);margin-bottom:2rem;line-height:1.7;">
                    This will permanently delete all your data including your
                    subscription, download history, and account. This action
                    <strong>cannot be undone</strong>.
                </p>
                <div style="background:var(--bg-secondary);border-radius:8px;padding:1.25rem;margin-bottom:2rem;text-align:left;">
                    <p style="font-size:0.875rem;font-weight:500;margin-bottom:0.5rem;">
                        What will be deleted:
                    </p>
                    <ul style="font-size:0.875rem;color:var(--text-secondary);line-height:2;">
                        <li>Your Auth0 account and login credentials</li>
                        <li>Your Pro subscription (cancelled immediately)</li>
                        <li>Your download history</li>
                        <li>All AI usage logs</li>
                        <li>Any stored files (already auto-deleted after 1hr)</li>
                    </ul>
                </div>
                <div style="display:flex;gap:1rem;justify-content:center;">
                    <button class="reset-button"
                            @onclick='() => Navigation.NavigateTo("/account")'>
                        Cancel
                    </button>
                    <button class="process-button"
                            style="background:#DC2626;"
                            @onclick="() => _confirmed = true">
                        Yes, delete my account
                    </button>
                </div>
            </div>
        }
        else if (_deleting)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Deleting your account...</p>
            </div>
        }
        else if (_deleted)
        {
            <div class="result-container" style="text-align:center;">
                <span class="result-icon">✅</span>
                <h2>Account deleted</h2>
                <p style="color:var(--text-secondary);margin-bottom:1.5rem;">
                    All your data has been permanently deleted.
                    Thank you for using PdfToolStack.
                </p>
                <button class="process-button"
                        @onclick='() => Navigation.NavigateTo("/")'>
                    Go to home
                </button>
            </div>
        }
        else if (_error != null)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@_error</p>
                <p style="font-size:0.875rem;color:var(--text-secondary);">
                    Please email
                    <a href="mailto:support@pdftoolstack.com">
                        support@pdftoolstack.com
                    </a>
                    and we will delete your account within 30 days.
                </p>
                <button class="reset-button"
                        @onclick='() => Navigation.NavigateTo("/account")'>
                    Back to account
                </button>
            </div>
        }

        @if (_confirmed && !_deleting && !_deleted && _error == null)
        {
            <div class="sign-card" style="text-align:center;padding:2.5rem;">
                <h2 style="margin-bottom:1rem;">
                    Final confirmation
                </h2>
                <p style="color:var(--text-secondary);margin-bottom:1.5rem;">
                    Type <strong>DELETE</strong> to confirm.
                </p>
                <input type="text"
                       class="sign-type-input"
                       placeholder="Type DELETE"
                       @bind="_confirmText" />
                <div style="display:flex;gap:1rem;justify-content:center;margin-top:1.5rem;">
                    <button class="reset-button"
                            @onclick="() => _confirmed = false">
                        Cancel
                    </button>
                    <button class="process-button"
                            style="background:#DC2626;"
                            disabled="@(_confirmText != "DELETE")"
                            @onclick="ExecuteDeletion">
                        Permanently delete
                    </button>
                </div>
            </div>
        }

    </div>
</div>

@code {
    private bool _confirmed = false;
    private bool _deleting = false;
    private bool _deleted = false;
    private string? _error;
    private string _confirmText = "";

    private async Task ExecuteDeletion()
    {
        if (_confirmText != "DELETE") return;

        _deleting = true;
        StateHasChanged();

        var success = await ApiService.DeleteAccountAsync();

        if (success)
        {
            _deleted = true;
            _deleting = false;
            StateHasChanged();
            await Task.Delay(3000);
            Navigation.NavigateTo(
                "/authentication/logout", true);
        }
        else
        {
            _error = "Deletion failed. Please contact support@pdftoolstack.com";
            _deleting = false;
            StateHasChanged();
        }
    }
}