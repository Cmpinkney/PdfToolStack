    private void ClearFiles()
    {
        _files.Clear(); _fileStatuses.Clear(); _fileProgress.Clear();
        _fileOutputSizes.Clear(); _fileErrors.Clear(); _zipBytes = null;
        _error = string.Empty; _processedCount = 0; _successCount = 0; _failCount = 0;
        _overallPct = 0; _totalOutputBytes = 0; _showErrors = false; _showUpgradeModal = false;
        SyncFileCount();
        _activityFeed.Clear();
    }

    private void ContinueWithFreeLimit()
    {
        if (_files.Count > 3)
        {
            _files = _files.Take(3).ToList();
            _fileStatuses.Clear(); _fileProgress.Clear();
            _fileOutputSizes.Clear(); _fileErrors.Clear();
            _zipBytes = null; _error = string.Empty; _successCount = 0; _failCount = 0;
            _overallPct = 0; _totalOutputBytes = 0; _showErrors = false;
            AddActivity("Trimmed batch to the free 3-file limit.");
        }

        SyncFileCount();
        _showUpgradeModal = false;
    }

