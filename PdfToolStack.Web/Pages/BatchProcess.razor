    private async Task StartBatchUnlockCheckout()
    {
        if (string.IsNullOrWhiteSpace(_batchUnlockPriceId))
        {
            _checkoutError = "Batch Unlock checkout is not available yet. Please try Pro or continue with 3 files.";
            return;
        }

        _checkoutLoading = true;
        _checkoutTarget = "batch";
        _checkoutError = string.Empty;
        StateHasChanged();

        try
        {
            var pending = await EnsurePendingBatchSavedAsync();
            if (pending == null)
                return;

            if (string.IsNullOrEmpty(_userId))
            {
                Navigation.NavigateTo(BuildLoginUrl("resumeBatchUnlock=true"));
                return;
            }

            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var returnPath = BuildBatchReturnPath("batchUnlocked=true");
            var url = await SubService.CreateAddonCheckoutSessionAsync(
                _batchUnlockPriceId,
                "batch_unlock",
                _userId,
                _userEmail,
                baseUrl,
                returnPath,
                new Dictionary<string, string>
                {
                    { "pendingBatchId", pending.PendingBatchId.ToString() },
                    { "payment_type", "BatchUnlock" }
                });

            if (!string.IsNullOrWhiteSpace(url))
            {
                Navigation.NavigateTo(url, forceLoad: true);
                return;
            }

            _checkoutError = "Could not start Batch Unlock checkout. Please try again.";
        }
        catch
        {
            _checkoutError = "Something went wrong starting checkout. Please try again.";
        }
        finally
        {
            _checkoutLoading = false;
            _checkoutTarget = string.Empty;
            StateHasChanged();
        }
    }

