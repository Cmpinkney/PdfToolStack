@page "/batch"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject CloudPickerService CloudPicker
@inject Microsoft.AspNetCore.Components.WebAssembly.Hosting.IWebAssemblyHostEnvironment HostEnvironment
@using PdfToolStack.Application.DTOs
@using PdfToolStack.Domain.Enums

<PageTitle>Batch PDF Processing — Process 20 PDFs at Once | PdfToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Batch process PDFs online. Apply any PDF tool to up to 20 files at once. Pro feature." />
    <link rel="canonical" href="https://pdftoolstack.com/batch" />
</HeadContent>

<div class="bp-wrap">

    <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
    <div class="bp-header">
        <div class="bp-header-left">
            <div class="bp-pro-pill">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" /></svg>
                Batch workflow
            </div>
            <h1 class="bp-hero-title">Batch process PDFs in <span class="hero-gradient-text">one workflow</span></h1>
            <p>Apply tools to multiple files at once and download everything as a single package.</p>
            <div class="bp-trust-chips">
                <span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                    Process multiple files
                </span>
                <span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                    Secure &amp; private
                </span>
                <span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16" /><path d="M4 12h16" /><path d="M4 17h10" /></svg>
                    Bulk workflow
                </span>
            </div>
        </div>
        <div class="bp-stat-cards">
            <div class="bp-stat-card">
                <div class="bp-stat-icon" style="background:#EDE9FE;color:#4338CA">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                </div>
                <div class="bp-stat-body">
                    <div class="bp-stat-label">PIPELINE READY</div>
                    <div class="bp-stat-num">@_files.Count</div>
                    <div class="bp-stat-sub">@(_files.Count == 0 ? "Drop files to begin" : $"{_files.Count} file{(_files.Count == 1 ? "" : "s")} queued")</div>
                </div>
            </div>
            <div class="bp-stat-card">
                <div class="bp-stat-icon" style="background:#DCFCE7;color:#16A34A">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <div class="bp-stat-body">
                    <div class="bp-stat-label">CURRENT OPERATION</div>
                    <div class="bp-stat-num bp-stat-num--sm">@GetToolLabel(_selectedTool)</div>
                    <div class="bp-stat-sub">Active tool</div>
                </div>
            </div>
            <div class="bp-stat-card">
                <div class="bp-stat-icon" style="background:#FEF3C7;color:#D97706">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                </div>
                <div class="bp-stat-body">
                    <div class="bp-stat-label">OUTPUT PACKAGE</div>
                    <div class="bp-stat-num">~@(_files.Count > 0 ? _files.Count * 3 : 0)s</div>
                    <div class="bp-stat-sub">Estimated time</div>
                </div>
            </div>
        </div>
    </div>

    <div class="bp-stepper" aria-label="Progress">
        <div class="bp-flow-step @(!_files.Any() ? "bp-flow-step--active" : "bp-flow-step--done")"><span>1</span>Upload</div>
        <div class="bp-flow-step @(_files.Any() && !_processing && _zipBytes == null ? "bp-flow-step--active" : _processing || _zipBytes != null ? "bp-flow-step--done" : "")"><span>2</span>Configure</div>
        <div class="bp-flow-step @(_processing ? "bp-flow-step--active" : _zipBytes != null ? "bp-flow-step--done" : "")"><span>3</span>Process</div>
        <div class="bp-flow-step @(_zipBytes != null ? "bp-flow-step--active" : "")"><span>4</span>Download</div>
    </div>

    <!-- ══ GATE STATES ════════════════════════════════════════════════════ -->
    @if (DateTime.MinValue > DateTime.Now)
    {
            <div class="bp-gate">
                <div class="bp-gate-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                </div>
                <h2>Batch Processing — Pro Feature</h2>
                <p>Process up to 20 PDFs at once with any tool. Sign in or upgrade to get started.</p>
                <div class="bp-gate-feats">
                    @foreach (var f in new[] { "Up to 20 files per batch", "All 9 PDF tools", "Single ZIP download", "500MB per file" })
                    {
                        <div class="bp-gate-feat">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4338CA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                            @f
                        </div>
                    }
                </div>
                <div class="bp-gate-btns">
                    <a href="/pricing" class="bp-btn-up" style="text-decoration:none">Upgrade to Pro — $19/mo</a>
                    <a href="authentication/login" class="bp-btn-si" style="text-decoration:none">Sign in if you have Pro</a>
                </div>
            </div>
    }

    @if (DateTime.MinValue > DateTime.Now)
            {
                <div class="bp-gate">
                    <div class="bp-gate-icon" style="background:#FEF3C7;color:#D97706">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" /></svg>
                    </div>
                    <h2>Upgrade to Pro to unlock Batch</h2>
                    <p>You're on the Free plan. Upgrade to process up to 20 files at once.</p>
                    <a href="/pricing" class="bp-btn-up" style="text-decoration:none">Upgrade to Pro — $19/mo</a>
                </div>
            }
            else
            {
                <!-- ══ MAIN TWO-COLUMN LAYOUT ════════════════════════════════ -->
                <section class="bp-main workflow-grid">

                    <!-- ── LEFT COLUMN 60% ─────────────────────────────── -->
                    <div class="bp-col-left workspace-card">

                        @if (_files.Any())
                        {
                            <div class="bp-batch-summary">
                                <div>
                                    <span class="bp-summary-kicker">Batch plan</span>
                                    <strong>@_files.Count file@(_files.Count == 1 ? "" : "s") · @GetToolLabel(_selectedTool)</strong>
                                    <p>@GetOperationDescription()</p>
                                </div>
                                <div class="bp-summary-metrics">
                                    <span>@FormatSize(_files.Sum(f => f.Size)) total</span>
                                    <span>@GetCompressionEstimate()</span>
                                    <span>~@GetRemainingEstimate()s est.</span>
                                </div>
                            </div>
                        }

                        <!-- Dropzone -->
                        <label class="bp-dropzone @(_batchDragging ? "bp-dropzone--active" : "")"
                               @ondragover="() => _batchDragging = true" @ondragover:preventDefault="true"
                               @ondragleave="() => _batchDragging = false"
                               @ondrop="() => _batchDragging = false" @ondrop:preventDefault="true">
                            <div class="bp-dz-cloud">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4338CA" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="16 16 12 12 8 16" />
                                    <line x1="12" y1="12" x2="12" y2="21" />
                                    <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" />
                                </svg>
                            </div>
                            <p class="bp-dz-title">Drag &amp; drop up to 20 PDF files here</p>
                            <p class="bp-dz-sub">or click to browse your device</p>
                            <p class="bp-dz-hint">PDF only · Max 500 MB each</p>
                            <InputFile OnChange="OnFilesSelected" multiple accept=".pdf"
                                       style="position:absolute;inset:0;opacity:0;cursor:pointer;" />
                        </label>

                        <div class="cloud-row">
                            <span class="cloud-label">Import from cloud</span>
                            <div class="cloud-actions">
                                <button type="button" class="cloud-btn" @onclick="PickDropbox" disabled="@(_cloudLoading || _processing)">
                                    <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M7.1 3.2 2 6.5l5.1 3.3 5.1-3.3-5.1-3.3Zm9.8 0-5.1 3.3 5.1 3.3L22 6.5l-5.1-3.3ZM2 13l5.1 3.3 5.1-3.3-5.1-3.3L2 13Zm14.9-3.3L11.8 13l5.1 3.3L22 13l-5.1-3.3ZM12 14.8 7.1 18 12 21.2l4.9-3.2-4.9-3.2Z" fill="#0061FF" />
                                    </svg>
                                    Dropbox
                                </button>
                                <button type="button" class="cloud-btn" @onclick="PickGoogleDrive" disabled="@(_cloudLoading || _processing)">
                                    <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M9.6 3.2 3 14.5h4.5l6.5-11.3H9.6Z" fill="#34A853" />
                                        <path d="M14.1 3.2h-4.5l6.6 11.3h4.5L14.1 3.2Z" fill="#FBBC04" />
                                        <path d="M7.5 14.5 9.8 18.4h10.9L18.4 14.5H7.5Z" fill="#4285F4" />
                                    </svg>
                                    Google Drive
                                </button>
                            </div>
                            @if (_cloudLoading)
                            {
                                <p class="cloud-status">Importing from cloud...</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(_cloudError))
                            {
                                <p class="cloud-error">@_cloudError</p>
                            }
                        </div>

                        @if (!_files.Any())
                        {
                            <div class="bp-empty-command-center">
                                <div class="bp-empty-card">
                                    <span class="bp-empty-kicker">Pipeline ready</span>
                                    <strong>No files uploaded yet</strong>
                                    <p>Drop PDFs into the lane above to build a processing queue.</p>
                                </div>
                                <div class="bp-empty-card">
                                    <span class="bp-empty-kicker">Current operation</span>
                                    <strong>@GetToolLabel(_selectedTool)</strong>
                                    <p>@GetOperationDescription()</p>
                                </div>
                                <div class="bp-empty-card">
                                    <span class="bp-empty-kicker">Output package</span>
                                    <strong>@(_outputMode == "zip" ? "Single ZIP" : "Individual files")</strong>
                                    <p>Your processed files will be organized for clean download.</p>
                                </div>
                            </div>
                        }

                        <!-- File Pipeline -->
                        @if (_files.Any())
                        {
                            <div class="bp-pipeline">
                                <div class="bp-pipeline-hdr">
                                    <span class="bp-pl-title">File Pipeline (@_files.Count)</span>
                                    <div class="bp-pipeline-actions">
                                        <span class="bp-pl-reorder">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
                                            Remove and re-add to adjust order
                                        </span>
                                        <button type="button" class="bp-add-more-btn">+ Add more files</button>
                                    </div>
                                </div>

                                @for (int i = 0; i < _files.Count; i++)
                                {
                                    var idx = i;
                                    var f = _files[i];
                                    var status = _fileStatuses.TryGetValue(f.Name, out var sv) ? sv : "waiting";
                                    var progress = _fileProgress.TryGetValue(f.Name, out var pv) ? pv : 0;
                                    var outSize = _fileOutputSizes.TryGetValue(f.Name, out var ov) ? ov : 0L;
                                    var errMsg = _fileErrors.TryGetValue(f.Name, out var ev) ? ev : "";

                                    <div class="bp-file-row @GetRowClass(status)">
                                        <span class="bp-drag-handle">⠿</span>
                                        <span class="bp-timeline-marker @GetTimelineClass(status)"></span>
                                        <div class="bp-row-num">@(idx + 1)</div>
                                        <div class="bp-pdf-badge">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                            PDF
                                        </div>
                                        <span class="bp-fname" title="@f.Name">@TruncateName(f.Name, 28)</span>
                                        <span class="bp-fsize">@FormatSize(f.Size)</span>

                                        <div class="bp-status-area">
                                            @if (status == "waiting")
                                            {
                                                <span class="bp-pill bp-pill--green"><span class="bp-dot bp-dot--green"></span> Ready to process</span>
                                            }
                                            else if (status == "queued")
                                            {
                                                <span class="bp-pill bp-pill--yellow"><span class="bp-dot bp-dot--yellow"></span> Queued</span>
                                            }
                                            else if (status == "processing")
                                            {
                                                <div class="bp-proc-status">
                                                    <span class="bp-pill bp-pill--purple"><div class="bp-spin-xs"></div> Processing</span>
                                                    <div class="bp-file-pbar"><div class="bp-file-pbar-fill" style="width:@progress%"></div></div>
                                                    <span class="bp-pct-lbl">@progress%</span>
                                                </div>
                                            }
                                            else if (status == "done")
                                            {
                                                <div class="bp-done-row">
                                                    <span class="bp-pill bp-pill--green">
                                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                                        Completed
                                                    </span>
                                                    @if (outSize > 0)
                                                    {
                                                        <span class="bp-out-size">@FormatSize(outSize)</span>
                                                        <span class="bp-savings">↓ @GetSavingsPct(f.Size, outSize)% smaller</span>
                                                    }
                                                </div>
                                            }
                                            else if (status == "error")
                                            {
                                                <div class="bp-err-row">
                                                    <span class="bp-pill bp-pill--red">
                                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                                                        Failed
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(errMsg))
                                                    {
                                                        <span class="bp-err-msg">Error: @errMsg</span>
                                                    }
                                                    <button class="bp-retry-link" @onclick="() => RetryFile(idx)">Retry</button>
                                                </div>
                                            }
                                        </div>

                                        <button class="bp-remove-btn" @onclick="() => RemoveFile(idx)" disabled="@_processing">×</button>
                                    </div>
                                }

                                <div class="bp-pipeline-footer">
                                    <span>@_files.Count file@(_files.Count == 1 ? "" : "s") · @FormatSize(_files.Sum(f => f.Size)) total</span>
                                    <button class="bp-clear-btn" @onclick="ClearFiles" disabled="@_processing">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /></svg>
                                        Clear All
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- ── RIGHT COLUMN 40% ────────────────────────────── -->
                    <aside class="bp-col-right settings-card">

                        <div class="bp-workflow-pipeline">
                            <div class="bp-workflow-title">
                                <span>Processing pipeline</span>
                                <strong>@GetToolLabel(_selectedTool)</strong>
                            </div>
                            <div class="bp-workflow-lane">
                                <div class="bp-workflow-node @(_files.Any() ? "bp-workflow-node--ready" : "")">
                                    <span>1</span>
                                    <strong>Files</strong>
                                    <small>@(_files.Any() ? $"{_files.Count} queued" : "Waiting")</small>
                                </div>
                                <div class="bp-workflow-link"></div>
                                <div class="bp-workflow-node bp-workflow-node--active">
                                    <span>2</span>
                                    <strong>@GetToolLabel(_selectedTool)</strong>
                                    <small>@GetCompressionEstimate()</small>
                                </div>
                                <div class="bp-workflow-link"></div>
                                <div class="bp-workflow-node @(_zipBytes != null ? "bp-workflow-node--ready" : "")">
                                    <span>3</span>
                                    <strong>@(_outputMode == "zip" ? "ZIP" : "Files")</strong>
                                    <small>@(_zipBytes != null ? "Ready" : "Output")</small>
                                </div>
                            </div>
                            <p>@GetOperationDescription()</p>
                        </div>

                        <!-- Card 1: Select Tool -->
                        <div class="bp-card">
                            <div class="bp-card-hdr">
                                <div class="bp-step-num">1</div>
                                <span>Batch Operation</span>
                                <span class="bp-card-note">Applies to all files</span>
                            </div>
                            <div class="bp-tool-grid">
                                @foreach (var tool in BatchTools)
                                {
                                    var selectedTool = tool.Type;

                                    <button type="button"
                                            class="bp-tool-btn @(_selectedTool == selectedTool ? "bp-tool-btn--on" : "")"
                                            @onclick="EventCallback.Factory.Create(this, () => SelectTool(selectedTool))">
                                        <div class="bp-tool-icon" style="background:@tool.Bg;color:@GetToolAccent(tool.Type)">
                                            @((MarkupString)tool.Svg)
                                        </div>
                                        <span class="bp-tool-name">@tool.Label</span>
                                        <span class="bp-tool-desc">@tool.Desc</span>
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Card 2: Settings -->
                        <div class="bp-card">
                            <div class="bp-card-hdr">
                                <div class="bp-step-num">2</div>
                                <span>@GetSettingsTitle(_selectedTool)</span>
                            </div>

                            <label class="bp-toggle-row">
                                <span>Apply these settings to every file</span>
                                <input type="checkbox" @bind="_applyToAll" />
                            </label>

                            @if (_selectedTool == ToolType.CompressPdf)
                            {
                                <div class="bp-compress-opts">
                                    @foreach (var option in CompressionOptions)
                                    {
                                        <label class="bp-copt @(_compressionLevel == option.Value ? "bp-copt--on" : "")">
                                            <div class="bp-copt-radio">
                                                @if (_compressionLevel == option.Value)
                                                {
                                                    <div class="bp-copt-dot"></div>
                                                }
                                            </div>

                                            <div class="bp-copt-body">
                                                <strong>@option.Title</strong>
                                                <small>@option.Line1</small>
                                                <small>@option.Line2</small>
                                            </div>

                                            <input type="radio"
                                                   name="cl"
                                                   value="@option.Value"
                                                   checked="@(_compressionLevel == option.Value)"
                                                   @onchange="() => SetCompressionLevel(option.Value)"
                                                   style="display:none" />
                                        </label>
                                    }
                                </div>
                                <div class="bp-preview-card">
                                    <div class="bp-preview-hdr">
                                        <span class="bp-preview-title">Live Preview</span>
                                        <span class="bp-preview-sub">Estimated reduction</span>
                                    </div>
                                    <div class="bp-lp-pct">~@(_compressionLevel == "maximum" ? "60–80%" : _compressionLevel == "medium" ? "40–60%" : "20–40%")</div>
                                    <div class="bp-lp-bars">
                                        <div class="bp-lp-row"><span>Original</span><div class="bp-lp-track"><div class="bp-lp-orig"></div></div></div>
                                        <div class="bp-lp-row"><span>Estimated</span><div class="bp-lp-track"><div class="bp-lp-fill" style="width:@(_compressionLevel == "maximum" ? "25" : _compressionLevel == "medium" ? "45" : "70")%"></div></div></div>
                                    </div>
                                </div>
                            }

                            @if (_selectedTool == ToolType.WatermarkPdf)
                            {
                                <div class="bp-fg">
                                    <label class="bp-lbl">Watermark Text</label>
                                    <input class="bp-input" placeholder="CONFIDENTIAL" @bind="_watermarkText" @bind:event="oninput" maxlength="40" />
                                </div>
                                <div class="bp-row2">
                                    <div class="bp-fg">
                                        <label class="bp-lbl">Font Size <span class="bp-badge-sm">@_watermarkFontSize</span></label>
                                        <input type="range" class="bp-range" min="20" max="100" @bind="_watermarkFontSize" @bind:event="oninput" />
                                    </div>
                                    <div class="bp-fg">
                                        <label class="bp-lbl">Color</label>
                                        <input type="color" class="bp-colorpick" @bind="_watermarkColor" />
                                    </div>
                                </div>
                                <div class="bp-fg">
                                    <label class="bp-lbl">Opacity <span class="bp-badge-sm">@_watermarkOpacity%</span></label>
                                    <input type="range" class="bp-range" min="10" max="80" @bind="_watermarkOpacity" @bind:event="oninput" />
                                </div>
                                <div class="bp-fg">
                                    <label class="bp-lbl">Position</label>
                                    <div class="bp-pos-pills">
                                        @foreach (var (pos, lbl) in new[] { ("center-diagonal", "Diagonal"), ("top-left", "Top L"), ("top-right", "Top R"), ("bottom-left", "Bot L"), ("bottom-right", "Bot R") })
                                        {
                                            <button class="bp-pos-pill @(_watermarkPosition == pos ? "bp-pos-pill--on" : "")" @onclick="() => _watermarkPosition = pos">@lbl</button>
                                        }
                                    </div>
                                </div>
                                <div class="bp-preview-card">
                                    <span class="bp-preview-title">Live Preview</span>
                                    <div class="bp-wm-doc">
                                        <div class="bp-doc-lines">
                                            <div class="bp-doc-line" style="width:90%"></div>
                                            <div class="bp-doc-line" style="width:75%"></div>
                                            <div class="bp-doc-line" style="width:85%"></div>
                                            <div class="bp-doc-line" style="width:65%"></div>
                                            <div class="bp-doc-line" style="width:80%"></div>
                                        </div>
                                        <div class="bp-wm-text @GetWmClass()"
                                             style="color:@_watermarkColor;opacity:@(_watermarkOpacity / 100.0);font-size:@(Math.Max(8, _watermarkFontSize / 5))px;transform:@GetWmTransform()">
                                            @(string.IsNullOrWhiteSpace(_watermarkText) ? "CONFIDENTIAL" : _watermarkText)
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (_selectedTool == ToolType.NumberPages)
                            {
                                <div class="bp-fg">
                                    <label class="bp-lbl">Position</label>
                                    <div class="bp-pos-grid">
                                        @foreach (var pos in new[] { "top-left", "top-center", "top-right", "middle-left", "center", "middle-right", "bottom-left", "bottom-center", "bottom-right" })
                                        {
                                            <button class="bp-pgb @(_numberPosition == pos ? "bp-pgb--on" : "")" @onclick="() => _numberPosition = pos">
                                                <div class="bp-pgdot @(_numberPosition == pos ? "bp-pgdot--on" : "")"></div>
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="bp-row2">
                                    <div class="bp-fg">
                                        <label class="bp-lbl">Start from</label>
                                        <div class="bp-num-ctrl">
                                            <button class="bp-ncb" @onclick="() => _numberStart = Math.Max(1, _numberStart - 1)">−</button>
                                            <input type="number" class="bp-nci" min="1" max="999" @bind="_numberStart" />
                                            <button class="bp-ncb" @onclick="() => _numberStart = Math.Min(999, _numberStart + 1)">+</button>
                                        </div>
                                    </div>
                                    <div class="bp-fg">
                                        <label class="bp-lbl">Style</label>
                                        <select class="bp-select" @bind="_numberStyle">
                                            <option value="numeric">1, 2, 3...</option>
                                            <option value="roman">i, ii, iii...</option>
                                            <option value="Roman">I, II, III...</option>
                                            <option value="alpha">a, b, c...</option>
                                            <option value="page-of">Page X of N</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="bp-preview-card">
                                    <span class="bp-preview-title">Live Preview</span>
                                    <div class="bp-wm-doc">
                                        <div class="bp-doc-lines">
                                            <div class="bp-doc-line" style="width:90%"></div>
                                            <div class="bp-doc-line" style="width:70%"></div>
                                            <div class="bp-doc-line" style="width:80%"></div>
                                        </div>
                                        <div class="bp-num-pos @GetNumClass()">@_numberStart</div>
                                    </div>
                                </div>
                            }

                            @if (_selectedTool == ToolType.RotatePdf)
                            {
                                <div class="bp-rotate-opts">
                                    @foreach (var (deg, lbl, sym) in new[] { ("90", "90° Clockwise", "↻"), ("180", "180°", "↕"), ("270", "90° Counter-CW", "↺") })
                                    {
                                        <button class="bp-ropt @(_rotateDegrees == deg ? "bp-ropt--on" : "")" @onclick="() => _rotateDegrees = deg">
                                            <span class="bp-ropt-sym">@sym</span>
                                            <span class="bp-ropt-lbl">@lbl</span>
                                        </button>
                                    }
                                </div>
                                <div class="bp-preview-card">
                                    <span class="bp-preview-title">Live Preview</span>
                                    <div class="bp-rotate-preview">
                                        <div class="bp-rot-doc" style="transform:rotate(@(_rotateDegrees == "90" ? "90deg" : _rotateDegrees == "180" ? "180deg" : "-90deg"))">
                                            <div class="bp-doc-line" style="width:100%;margin-bottom:4px"></div>
                                            <div class="bp-doc-line" style="width:80%;margin-bottom:4px"></div>
                                            <div class="bp-doc-line" style="width:90%"></div>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (_selectedTool == ToolType.ProtectPdf)
                            {
                                <div class="bp-fg">
                                    <label class="bp-lbl">Password</label>
                                    <div class="bp-pw-wrap">
                                        <input type="@(_showPw ? "text" : "password")" class="bp-input" placeholder="Enter password..." @bind="_protectPassword" @bind:event="oninput" />
                                        <button class="bp-pw-toggle" @onclick="() => _showPw = !_showPw">@(_showPw ? "Hide" : "Show")</button>
                                    </div>
                                </div>
                                <div class="bp-fg">
                                    <label class="bp-lbl">Confirm Password</label>
                                    <input type="@(_showPw ? "text" : "password")" class="bp-input" placeholder="Confirm password..." @bind="_protectConfirm" />
                                </div>
                                @if (!string.IsNullOrEmpty(_protectPassword))
                                {
                                    <div class="bp-pw-strength">
                                        <div class="bp-pw-track"><div class="bp-pw-fill" style="width:@GetPwPct()%;background:@GetPwColor()"></div></div>
                                        <span style="font-size:.7rem;color:@GetPwColor();font-weight:700">@GetPwLabel()</span>
                                    </div>
                                }
                                <div class="bp-warn-badge">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                                    Save your password — it cannot be recovered
                                </div>
                            }

                            @if (_selectedTool == ToolType.UnlockPdf)
                            {
                                <div class="bp-fg">
                                    <label class="bp-lbl">Current Password</label>
                                    <div class="bp-pw-wrap">
                                        <input type="@(_showPw ? "text" : "password")" class="bp-input" placeholder="Enter current PDF password..." @bind="_unlockPassword" />
                                        <button class="bp-pw-toggle" @onclick="() => _showPw = !_showPw">@(_showPw ? "Hide" : "Show")</button>
                                    </div>
                                </div>
                                <div class="bp-info-badge">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                    Enter the current password to remove protection from all files.
                                </div>
                            }

                            @if (_selectedTool == ToolType.PdfToWord || _selectedTool == ToolType.PdfToJpg || _selectedTool == ToolType.FlattenPdf)
                            {
                                <div class="bp-ready-card">
                                    <div class="bp-ready-check">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    </div>
                                    <div>
                                        <strong>Ready to process</strong>
                                        <p>@GetSimpleDesc(_selectedTool)</p>
                                    </div>
                                    <span class="bp-fmt-badge">@GetFmt(_selectedTool)</span>
                                </div>
                            }
                        </div>

                        <!-- Card 3: Output Strategy -->
                        <div class="bp-card">
                            <div class="bp-card-hdr">
                                <div class="bp-step-num">3</div>
                                <span>Output Strategy</span>
                            </div>
                            <div class="bp-output-options">
                                <label class="bp-output-option @(_outputMode == "zip" ? "bp-output-option--on" : "")">
                                    <input type="radio" name="outputMode" value="zip" @onchange='() => _outputMode = "zip"' checked="@(_outputMode == "zip")" />
                                    <div>
                                        <strong>Single ZIP</strong>
                                        <span>Best for downloading many processed files at once.</span>
                                    </div>
                                </label>
                                <label class="bp-output-option @(_outputMode == "individual" ? "bp-output-option--on" : "")">
                                    <input type="radio" name="outputMode" value="individual" @onchange='() => _outputMode = "individual"' checked="@(_outputMode == "individual")" />
                                    <div>
                                        <strong>Individual files</strong>
                                        <span>Keep each output file separate in the results package.</span>
                                    </div>
                                </label>
                            </div>
                            <div class="bp-fg bp-fg-compact">
                                <label class="bp-lbl">Output filename suffix</label>
                                <input class="bp-input" @bind="_fileNameSuffix" placeholder="-processed" maxlength="24" />
                            </div>
                        </div>

                        <!-- Card 4: Process -->
                        <div class="bp-card bp-process-card">
                            <div class="bp-card-hdr">
                                <div class="bp-step-num">4</div>
                                <span>Process</span>
                            </div>
                            @if (!_isProUser && !_batchUnlocked && _files.Count >= 3 && !_processing && _zipBytes == null)
                            {
                                <div class="bp-soft-upsell">
                                    <div class="bp-soft-upsell-bar"></div>
                                    <div class="bp-soft-upsell-copy">
                                        <strong>Processing multiple files?</strong>
                                        <p>Upgrade to Pro for larger batches, faster processing, and saved workflows.</p>
                                        <div class="bp-soft-upsell-benefits">
                                            <span>Larger batches</span>
                                            <span>Faster processing</span>
                                            <span>Saved workflows</span>
                                        </div>
                                    </div>
                                    <button type="button"
                                            class="bp-soft-upsell-cta"
                                            @onclick="StartProCheckout">
                                        Upgrade to Pro
                                    </button>
                                </div>
                            }
                            @if (!_isProUser && !_batchUnlocked && _fileCount > 3)
                            {
                                <div class="bp-upgrade-warning">
                                    Free plan includes 3 files. Upgrade to process all @_fileCount files.
                                </div>
                            }
                            <button class="bp-proc-btn" @onclick="RunBatch" disabled="@(_processing || !_files.Any())">
                                @if (_processing)
                                {
                                    <div class="bp-spin-btn"></div>
                                    <span>Processing @_processedCount of @_files.Count files...</span>
                                }
                                else
                                {
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                                    <span>Process Files @(_files.Any() ? $"({_files.Count})" : "")</span>
                                }
                            </button>
                            <div class="bp-secure-note">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                                Your files are secure and private
                            </div>
                        </div>

                    </aside>
                </section>

                @if (_showUpgradeModal)
                {
                    <div class="bp-upgrade-overlay" role="dialog" aria-modal="true" aria-labelledby="batch-upgrade-title">
                        <div class="bp-upgrade-modal">
                            <button type="button" class="bp-upgrade-close" @onclick="CloseUpgradeModal" aria-label="Close upgrade dialog">×</button>
                            <div class="bp-upgrade-icon">
                                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
                            </div>
                            <p class="bp-upgrade-eyebrow">Batch limit reached</p>
                            <h2 id="batch-upgrade-title">You’re processing @_fileCount files</h2>
                            <div class="bp-upgrade-free">
                                <span>Free plan includes</span>
                                <strong>Up to 3 files per batch</strong>
                            </div>
                            <div class="bp-upgrade-actions">
                                <button type="button" class="bp-upgrade-primary" @onclick="StartBatchUnlockCheckout" disabled="@_checkoutLoading">
                                    @if (_checkoutLoading && _checkoutTarget == "batch")
                                    {
                                        <span>Starting checkout...</span>
                                    }
                                    else
                                    {
                                        <span>Unlock all @_fileCount files instantly — $4.99</span>
                                    }
                                </button>
                                <span class="bp-upgrade-or">or</span>
                                <button type="button" class="bp-upgrade-pro" @onclick="StartProCheckout" disabled="@_checkoutLoading">
                                    @if (_checkoutLoading && _checkoutTarget == "pro")
                                    {
                                        <span>Starting checkout...</span>
                                    }
                                    else
                                    {
                                        <span>Upgrade to Pro — $19/month</span>
                                    }
                                </button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_checkoutError))
                            {
                                <div class="bp-upgrade-error">@_checkoutError</div>
                            }
                            <div class="bp-upgrade-secondary">
                                <button type="button" class="bp-upgrade-trim" @onclick="ContinueWithFreeLimit">
                                    Continue with limited batch (3 files)
                                </button>
                                <button type="button" class="bp-upgrade-cancel" @onclick="CloseUpgradeModal">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <!-- ══ FULL-WIDTH PROGRESS ══════════════════════════════════ -->
                @if (_processing || (_zipBytes != null && _files.Any()))
                {
                    <div class="bp-progress-section">
                        <div class="bp-prog-header">
                            <span class="bp-prog-title">Overall Progress</span>
                            <span class="bp-prog-message">Processing @GetDisplayFileCount() files... optimizing... preparing download...</span>
                            <span class="bp-prog-pct">@_overallPct% complete</span>
                            <span class="bp-prog-count">@_processedCount of @GetDisplayFileCount() files processed</span>
                        </div>
                        <div class="bp-prog-track">
                            <div class="bp-prog-fill @(_processing ? "bp-prog-fill--anim" : "")" style="width:@_overallPct%"></div>
                        </div>
                        <div class="bp-mini-cards">
                            @foreach (var f in _files)
                            {
                                var st = _fileStatuses.TryGetValue(f.Name, out var sv2) ? sv2 : "waiting";
                                var pr = _fileProgress.TryGetValue(f.Name, out var pv2) ? pv2 : 0;
                                var os = _fileOutputSizes.TryGetValue(f.Name, out var ov2) ? ov2 : 0L;
                                <div class="bp-mini-card bp-mini-@st">
                                    <div class="bp-mini-icon bp-mini-icon--@st">
                                        @if (st == "done")
                                        {
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                        }
                                        else if (st == "processing")
                                        {
                                            <div class="bp-spin-xs-w"></div>
                                        }
                                        else if (st == "error")
                                        {
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                                        }
                                        else if (st == "queued")
                                        {
                                            <div class="bp-dot-yellow"></div>
                                        }
                                        else
                                        {
                                            <div class="bp-dot-gray"></div>
                                        }
                                    </div>
                                    <span class="bp-mini-name">@TruncateName(f.Name, 16)</span>
                                    <span class="bp-mini-size">@FormatSize(f.Size)</span>
                                    @if (st == "processing")
                                    {
                                        <div class="bp-mini-bar"><div class="bp-mini-fill" style="width:@pr%"></div></div>
                                        <span class="bp-mini-pct">@pr%</span>
                                    }
                                    else if (st == "done" && os > 0)
                                    {
                                        <span class="bp-mini-out">@FormatSize(os)</span>
                                    }
                                    else
                                    {
                                        <span class="bp-mini-lbl">@GetStatusLabel(f.Name)</span>
                                    }
                                    @if (st == "error")
                                    {
                                        <button class="bp-mini-retry" @onclick="() => RetryFile(_files.IndexOf(f))">Retry</button>
                                    }
                                </div>
                            }
                        </div>

                        @if (_activityFeed.Any())
                        {
                            <div class="bp-activity-feed">
                                <div class="bp-activity-title">Live activity</div>
                                @foreach (var item in _activityFeed.TakeLast(6))
                                {
                                    <div class="bp-activity-item">
                                        <span class="bp-activity-dot"></span>
                                        <span>@item</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="bp-error-banner">
                        <div>
                            <strong>Batch could not finish</strong>
                            <p>@_error</p>
                        </div>
                        <button class="bp-quick-btn" @onclick="RetryFailedFiles" disabled="@(!_fileErrors.Any())">Retry failed</button>
                    </div>
                }

                @if (_files.Any())
                {
                    <div class="bp-insight-grid">
                        <div class="bp-insight-card bp-insight-card--activity">
                            <div class="bp-insight-title"><span class="bp-live-dot"></span>Live Activity</div>
                            @if (_activityFeed.Any())
                            {
                                @foreach (var item in _activityFeed.TakeLast(5))
                                {
                                    <div class="bp-activity-line"><span>@item.Split(" · ").FirstOrDefault()</span><strong>@item.Split(" · ").LastOrDefault()</strong></div>
                                }
                            }
                            else
                            {
                                <p class="bp-muted-note">Activity will appear here once files are added or processed.</p>
                            }
                        </div>
                        <div class="bp-insight-card">
                            <div class="bp-insight-title">Batch Statistics</div>
                            <div class="bp-stat-grid-mini">
                                <div><strong>@_successCount</strong><span>Completed</span></div>
                                <div><strong>@_failCount</strong><span>Failed</span></div>
                                <div><strong>@Math.Max(0, _files.Count - _successCount - _failCount)</strong><span>Remaining</span></div>
                                <div><strong>@(_totalOutputBytes > 0 ? FormatSize(_totalOutputBytes) : "—")</strong><span>Output</span></div>
                            </div>
                        </div>
                        <div class="bp-insight-card">
                            <div class="bp-insight-title">Quick Actions</div>
                            <div class="bp-quick-actions">
                                <button type="button" class="bp-quick-btn" @onclick="RetryFailedFiles" disabled="@(!_fileErrors.Any())">Retry failed (@_fileErrors.Count)</button>
                                <button type="button" class="bp-quick-btn bp-quick-btn--danger" @onclick="ClearFiles" disabled="@_processing">Clear completed</button>
                            </div>
                        </div>
                    </div>
                }

                <!-- ══ FULL-WIDTH RESULT BANNER ══════════════════════════════ -->
                @if (_zipBytes != null)
                {
                    <div class="bp-result">
                        <div class="bp-result-left">
                            <div class="bp-result-circle">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                            </div>
                            <div>
                                <div class="bp-result-title">Your batch is ready</div>
                                <div class="bp-result-sub">@_successCount files processed</div>
                                @if (_totalProcessTime > 0)
                                {
                                    <div class="bp-result-time">Completed in @_totalProcessTime seconds</div>
                                }
                            </div>
                        </div>

                        <div class="bp-result-stats">
                            <div class="bp-rstat">
                                <div class="bp-rstat-num" style="color:#16A34A">@_successCount</div>
                                <div class="bp-rstat-lbl">Succeeded</div>
                                <div class="bp-rstat-sub" style="color:#16A34A">@((GetDisplayFileCount() > 0 ? _successCount * 100 / GetDisplayFileCount() : 0))%</div>
                            </div>
                            @if (_failCount > 0)
                            {
                                <div class="bp-rstat">
                                    <div class="bp-rstat-num" style="color:#DC2626">@_failCount</div>
                                    <div class="bp-rstat-lbl">Failed</div>
                                    <div class="bp-rstat-sub" style="color:#DC2626">@((GetDisplayFileCount() > 0 ? _failCount * 100 / GetDisplayFileCount() : 0))%</div>
                                </div>
                            }
                            @if (_totalOutputBytes > 0)
                            {
                                <div class="bp-rstat">
                                    <div class="bp-rstat-num">@FormatSize(_totalOutputBytes)</div>
                                    <div class="bp-rstat-lbl">Total Output Size</div>
                                    <div class="bp-rstat-sub" style="color:#16A34A">@GetTotalSavings()% smaller</div>
                                </div>
                            }
                        </div>

                        <div class="bp-result-right">
                            <button class="bp-dl-btn" @onclick="DownloadZip">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                                Download ZIP
                            </button>
                            <button class="bp-again-btn" @onclick="ClearFiles">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
                                Process another batch
                            </button>
                            @if (_failCount > 0)
                            {
                                <button class="bp-retry-failed-btn" @onclick="RetryFailedFiles">
                                    Retry failed only (@_failCount)
                                </button>
                            }
                        </div>

                        @if (_failCount > 0)
                        {
                            <div class="bp-fail-section">
                                <button class="bp-fail-toggle" @onclick='() => _showErrors = !_showErrors'>
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                    @_failCount file@(_failCount == 1 ? "" : "s") failed — View errors
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(@(_showErrors ? "180deg" : "0deg"));transition:transform .2s"><polyline points="6 9 12 15 18 9" /></svg>
                                </button>
                                @if (_showErrors)
                                {
                                    <div class="bp-fail-list">
                                        @foreach (var kv in _fileErrors)
                                        {
                                            <div class="bp-fail-item">
                                                <span class="bp-fail-fname">@kv.Key</span>
                                                <span class="bp-fail-msg">@kv.Value</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <PostSuccessUpsell ToolName="Batch Process" ActionPerformed="@GetToolLabel(_selectedTool)" />
                }
            }

    <!-- FAQ -->
    <div class="bp-faq">
        <h2>Frequently Asked Questions</h2>
        @foreach (var (q, a) in new[]{
                ("How many files can I process at once?","Up to 20 PDFs per batch. Each file can be up to 500MB with a Pro plan."),
                ("What happens if one file fails?","The ZIP downloads with all successful files. A batch_errors.txt lists any failures."),
                ("Are my files stored after processing?","No. All files are deleted within 1 hour of processing."),
                })
        {
            <details class="bp-faq-item"><summary>@q</summary><p>@a</p></details>
        }
    </div>

</div>

<style>
    .bp-wrap {
        --bp-primary: #4f46e5;
        --bp-primary-2: #7c3aed;
        --bp-primary-soft: rgba(79, 70, 229, .10);
        --bp-success: #16a34a;
        --bp-warning: #d97706;
        --bp-danger: #dc2626;
        --bp-shadow: 0 20px 60px rgba(31, 41, 55, .08);
        --bp-card-shadow: 0 10px 28px rgba(31, 41, 55, .07);
        max-width: 1680px;
        margin: 0 auto;
        padding: 2rem clamp(1rem, 2vw, 2rem) 5rem;
        font-family: inherit;
        color: var(--text, #111827);
    }

        .bp-wrap::before {
            content: "";
            position: fixed;
            inset: 64px 0 auto;
            height: 420px;
            background: radial-gradient(circle at 22% 5%, rgba(124, 58, 237, .18), transparent 38%), radial-gradient(circle at 92% 12%, rgba(14, 165, 233, .18), transparent 36%), linear-gradient(135deg, rgba(245, 243, 255, .85), rgba(239, 246, 255, .72));
            z-index: -1;
            pointer-events: none;
        }

    .bp-header {
        display: grid;
        grid-template-columns: minmax(320px, 1fr) minmax(420px, 560px);
        gap: 2rem;
        align-items: start;
        padding: 1.35rem 0 2rem;
    }

    .bp-header-left h1,
    .bp-hero-title {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        line-height: 1.1;
        font-weight: 800;
        color: var(--text, #111827);
        letter-spacing: -.03em;
        margin: .4rem 0 .35rem;
    }

    .bp-title-accent { color: #4338CA; }

    .bp-header-left p {
        font-size: 1.03rem;
        color: var(--text-muted, #667085);
        margin: 0;
        max-width: 720px;
        line-height: 1.65;
    }

    .bp-pro-pill {
        display: inline-flex;
        align-items: center;
        gap: .42rem;
        background: linear-gradient(135deg, #fef3c7, #fde68a);
        color: #92400e;
        border: 1px solid rgba(217, 119, 6, .18);
        font-size: .68rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .09em;
        padding: .36rem .78rem;
        border-radius: 999px;
        box-shadow: 0 8px 20px rgba(217, 119, 6, .12);
    }

    .bp-trust-chips {
        display: flex;
        align-items: center;
        gap: .65rem;
        flex-wrap: wrap;
        margin-top: 1.2rem;
    }

        .bp-trust-chips span {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .46rem .75rem;
            border: 1px solid var(--border, #e5e7eb);
            background: rgba(255, 255, 255, .82);
            color: var(--text-muted, #667085);
            border-radius: 999px;
            font-size: .78rem;
            font-weight: 750;
            box-shadow: 0 6px 18px rgba(17, 24, 39, .04);
            backdrop-filter: blur(12px);
        }

    .bp-stat-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        background: rgba(255, 255, 255, .86);
        border: 1px solid rgba(226, 232, 240, .95);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: var(--bp-shadow);
        backdrop-filter: blur(18px);
        align-self: start;
    }

    .bp-stat-card {
        display: flex;
        align-items: center;
        gap: .95rem;
        padding: 1.2rem 1.3rem;
        border-right: 1px solid var(--border, #e5e7eb);
        min-height: 86px;
    }

        .bp-stat-card:last-child {
            border-right: none;
        }

    .bp-stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 17px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.7);
    }

    .bp-stat-body {
        display: flex;
        flex-direction: column;
        gap: .16rem;
        min-width: 0;
    }

    .bp-stat-num {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1;
        color: var(--text, #111827);
    }

    .bp-stat-num--sm {
        font-size: .9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 150px;
    }

    .bp-stat-label {
        font-size: .65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #4338CA;
    }

    .bp-stat-sub {
        font-size: .75rem;
        color: var(--text-muted, #6B7280);
    }

    .bp-gate {
        max-width: 520px;
        margin: 3rem auto;
        background: rgba(255,255,255,.9);
        border: 1px solid var(--border, #e5e7eb);
        border-radius: 28px;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
        box-shadow: var(--bp-shadow);
        backdrop-filter: blur(18px);
    }

    .bp-gate-icon {
        width: 72px;
        height: 72px;
        border-radius: 22px;
        background: #ede9fe;
        color: var(--bp-primary);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bp-gate h2 {
        font-size: 1.35rem;
        font-weight: 850;
        margin: 0;
        color: var(--text, #111827);
    }

    .bp-gate p {
        font-size: .92rem;
        color: var(--text-muted, #667085);
        margin: 0;
        line-height: 1.6;
    }

    .bp-gate-feats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .55rem;
        align-self: stretch;
        margin: .5rem 0;
    }

    .bp-gate-feat {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        color: var(--text-muted, #475467);
        text-align: left;
    }

    .bp-gate-btns {
        display: flex;
        flex-direction: column;
        gap: .65rem;
        width: 100%;
    }

    .bp-btn-up, .bp-dl-btn, .bp-proc-btn {
        background: linear-gradient(135deg, #4338CA 0%, #6D28D9 100%);
        color: #fff;
        box-shadow: 0 4px 20px rgba(67,56,202,.4);
    }

    .bp-proc-btn:disabled {
        opacity: .4;
        box-shadow: none;
    }

    .bp-btn-up, .bp-btn-si {
        display: block;
        font-weight: 850;
        font-size: .9rem;
        padding: .82rem 1.4rem;
        border-radius: 14px;
        text-align: center;
        border: none;
        cursor: pointer;
    }

    .bp-btn-si {
        background: var(--surface, #fff);
        color: var(--text, #344054);
        border: 1px solid var(--border, #e5e7eb);
        box-shadow: 0 8px 20px rgba(17,24,39,.04);
    }

    .bp-main {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 520px;
        gap: 1.25rem;
        align-items: start;
    }

    .bp-col-left, .bp-col-right {
        min-width: 0;
    }

    .bp-col-right {
        position: sticky;
        top: 88px;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .bp-batch-summary {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 1.25rem;
        background: rgba(255, 255, 255, .88);
        border: 1px solid var(--border, #e5e7eb);
        border-radius: 20px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        box-shadow: var(--bp-card-shadow);
        backdrop-filter: blur(18px);
    }

    .bp-summary-kicker {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        color: var(--bp-primary);
        font-size: .72rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: .32rem;
    }

    .bp-batch-summary strong {
        display: block;
        font-size: .98rem;
        color: var(--text, #111827);
    }

    .bp-batch-summary p {
        margin: .2rem 0 0;
        color: var(--text-muted, #667085);
        font-size: .8rem;
        line-height: 1.45;
    }

    .bp-summary-metrics {
        display: grid;
        grid-template-columns: repeat(3, auto);
        gap: .7rem;
    }

        .bp-summary-metrics span {
            padding: .52rem .72rem;
            border: 1px solid var(--border, #e5e7eb);
            background: var(--bg, #f9fafb);
            border-radius: 12px;
            color: var(--text-muted, #475467);
            font-size: .76rem;
            font-weight: 800;
            white-space: nowrap;
        }

    .bp-dropzone {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .42rem;
        min-height: 210px;
        border: 2px dashed #C4B5FD;
        border-radius: 16px;
        background: var(--surface, #fff);
        padding: 2.2rem;
        cursor: pointer;
        position: relative;
        transition: background .15s ease, border-color .15s ease;
        text-align: center;
        margin-bottom: 1rem;
    }

        .bp-dropzone:hover, .bp-dropzone--active {
            border-color: #4338CA;
            background: rgba(237,233,254,.031);
        }

    .bp-dz-cloud {
        width: 68px;
        height: 68px;
        border-radius: 22px;
        background: linear-gradient(135deg, #ede9fe, #eef2ff);
        color: var(--bp-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: .35rem;
        box-shadow: 0 14px 30px rgba(79,70,229,.16);
    }

    .bp-dz-title {
        font-size: 1.05rem;
        font-weight: 850;
        color: var(--text, #111827);
        margin: 0;
    }

    .bp-dz-sub {
        font-size: .86rem;
        color: var(--text-muted, #667085);
        margin: 0;
    }

    .bp-dz-hint {
        font-size: .76rem;
        color: var(--text-muted, #98a2b3);
        margin: 0;
    }

    .cloud-row {
        display: grid;
        gap: .75rem;
        margin: 0 0 1rem;
        padding: .95rem;
        border: 1px solid var(--border, #e5e7eb);
        border-radius: 18px;
        background: rgba(248,250,252,.78);
        text-align: center;
    }

    .cloud-label {
        color: var(--text-muted, #667085);
        font-size: .72rem;
        font-weight: 900;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .cloud-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .65rem;
    }

    .cloud-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        min-height: 42px;
        border: 1px solid rgba(99,102,241,.22);
        border-radius: 12px;
        background: var(--surface, #fff);
        color: var(--text, #111827);
        font-size: .82rem;
        font-weight: 850;
        cursor: pointer;
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

        .cloud-btn:hover:not(:disabled) {
            transform: translateY(-1px);
            border-color: rgba(79,70,229,.45);
            box-shadow: 0 12px 24px rgba(79,70,229,.12);
        }

        .cloud-btn:disabled {
            cursor: not-allowed;
            opacity: .58;
        }

    .cloud-icon {
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
    }

    .cloud-status,
    .cloud-error {
        margin: 0;
        font-size: .82rem;
        line-height: 1.5;
    }

    .cloud-status {
        color: var(--text-muted, #667085);
    }

    .cloud-error {
        color: #dc2626;
        font-weight: 750;
    }

    @@media (max-width: 640px) {
        .cloud-actions {
            grid-template-columns: 1fr;
        }
    }

    .bp-empty-command-center {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .9rem;
        margin-top: .85rem;
    }

    .bp-empty-card {
        background: rgba(255,255,255,.76);
        border: 1px solid var(--border, #e5e7eb);
        border-radius: 18px;
        padding: 1rem;
        box-shadow: 0 12px 26px rgba(17,24,39,.05);
    }

    .bp-empty-kicker {
        display: block;
        font-size: .68rem;
        font-weight: 900;
        color: var(--bp-primary);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: .35rem;
    }

    .bp-empty-card strong {
        display: block;
        font-size: .88rem;
        color: var(--text, #111827);
        margin-bottom: .25rem;
    }

    .bp-empty-card p {
        margin: 0;
        font-size: .76rem;
        color: var(--text-muted, #667085);
        line-height: 1.45;
    }

    .bp-pipeline, .bp-progress-section, .bp-card, .bp-result, .bp-insight-card, .bp-faq {
        background: var(--surface, #fff);
        border: 1px solid #E5E7EB;
        border-radius: 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
    }

    .bp-pipeline {
        overflow: hidden;
    }

    .bp-pipeline-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: .95rem 1.1rem;
        border-bottom: 1px solid var(--border, #e5e7eb);
        background: linear-gradient(180deg, rgba(248,250,252,.92), rgba(255,255,255,.78));
    }

    .bp-pl-title {
        font-size: .9rem;
        font-weight: 900;
        color: var(--text, #111827);
    }

    .bp-pipeline-actions {
        display: flex;
        align-items: center;
        gap: .65rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .bp-pl-reorder {
        display: flex;
        align-items: center;
        gap: .35rem;
        font-size: .72rem;
        color: var(--text-muted, #667085);
        font-weight: 700;
    }

    .bp-add-more-btn {
        border: 1px solid #c7d2fe;
        background: #eef2ff;
        color: var(--bp-primary);
        border-radius: 10px;
        padding: .38rem .62rem;
        font-size: .72rem;
        font-weight: 850;
        cursor: pointer;
    }

    .bp-file-row {
        position: relative;
        display: grid;
        grid-template-columns: 20px 18px 26px 48px minmax(120px, 1fr) 76px minmax(210px, auto) 28px;
        align-items: center;
        gap: .65rem;
        min-height: 54px;
        padding: .62rem 1rem;
        border-bottom: 1px solid #eef2f7;
        background: rgba(255,255,255,.72);
        transition: background .16s, transform .16s, box-shadow .16s;
    }

        .bp-file-row:hover {
            background: #fff;
            box-shadow: inset 3px 0 0 rgba(79,70,229,.22);
        }

        .bp-file-row:last-of-type {
            border-bottom: none;
        }

    .bp-file-row--done {
        background: linear-gradient(90deg, rgba(240,253,244,.78), rgba(255,255,255,.76));
    }

    .bp-file-row--error {
        background: linear-gradient(90deg, rgba(254,242,242,.85), rgba(255,255,255,.78));
    }

    .bp-file-row--processing {
        background: linear-gradient(90deg, rgba(245,243,255,.95), rgba(255,255,255,.78));
    }

    .bp-file-row::before {
        content: "";
        position: absolute;
        left: 47px;
        top: 0;
        bottom: 0;
        width: 1px;
        background: #dbe3ef;
    }

    .bp-drag-handle {
        font-size: 1rem;
        color: var(--text-muted, #98a2b3);
        cursor: grab;
        z-index: 1;
    }

    .bp-timeline-marker {
        width: 11px;
        height: 11px;
        border-radius: 999px;
        border: 2px solid #cbd5e1;
        background: #fff;
        z-index: 2;
        box-shadow: 0 0 0 4px #fff;
    }

    .bp-timeline-marker--waiting {
        border-color: #94a3b8;
    }

    .bp-timeline-marker--queued {
        border-color: #f59e0b;
        background: #f59e0b;
    }

    .bp-timeline-marker--processing {
        border-color: #8b5cf6;
        background: #8b5cf6;
        box-shadow: 0 0 0 4px rgba(139,92,246,.16);
        animation: bpPulse 1.4s infinite;
    }

    .bp-timeline-marker--done {
        border-color: #16a34a;
        background: #16a34a;
    }

    .bp-timeline-marker--error {
        border-color: #ef4444;
        background: #ef4444;
    }

    .bp-row-num {
        font-size: .72rem;
        font-weight: 900;
        color: var(--text-muted, #667085);
        text-align: center;
        z-index: 1;
    }

    .bp-pdf-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 3px;
        width: 42px;
        height: 30px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #fff;
        font-size: .54rem;
        font-weight: 900;
        border-radius: 9px;
        letter-spacing: .02em;
        box-shadow: 0 8px 16px rgba(79,70,229,.18);
    }

    .bp-fname {
        font-size: .82rem;
        font-weight: 750;
        color: var(--text, #111827);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
    }

    .bp-fsize {
        font-size: .74rem;
        color: var(--text-muted, #667085);
        font-weight: 650;
    }

    .bp-status-area {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        min-width: 0;
    }

    .bp-pill {
        display: inline-flex;
        align-items: center;
        gap: .36rem;
        font-size: .72rem;
        font-weight: 850;
        padding: .28rem .62rem;
        border-radius: 999px;
        white-space: nowrap;
    }

    .bp-pill--gray {
        background: #f1f5f9;
        color: #64748b;
    }

    .bp-pill--yellow {
        background: #fef3c7;
        color: #a16207;
    }

    .bp-pill--purple {
        background: #ede9fe;
        color: #5b21b6;
    }

    .bp-pill--green {
        background: #dcfce7;
        color: #15803d;
    }

    .bp-pill--red {
        background: #fee2e2;
        color: #b91c1c;
    }

    .bp-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    .bp-dot--gray {
        background: #94a3b8;
    }

    .bp-dot--yellow, .bp-dot-yellow {
        background: #f59e0b;
    }

    .bp-dot-gray {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #94a3b8;
    }

    .bp-proc-status, .bp-done-row, .bp-err-row {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .bp-file-pbar {
        width: 150px;
        height: 7px;
        background: #e5e7eb;
        border-radius: 999px;
        overflow: hidden;
    }

    .bp-file-pbar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--bp-primary), #8b5cf6);
        border-radius: inherit;
        transition: width .25s ease;
    }

    .bp-pct-lbl {
        font-size: .72rem;
        color: #4f46e5;
        font-weight: 900;
        min-width: 34px;
        text-align: right;
    }

    .bp-out-size {
        font-size: .74rem;
        color: var(--text-muted,#667085);
        font-weight: 700;
    }

    .bp-savings {
        font-size: .72rem;
        color: #16a34a;
        font-weight: 900;
    }

    .bp-err-msg {
        font-size: .72rem;
        color: #dc2626;
        font-weight: 700;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .bp-retry-link {
        color: #4f46e5;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        font-size: .72rem;
        font-weight: 900;
        text-decoration: underline;
    }

    .bp-remove-btn {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        border: 1px solid var(--border,#e5e7eb);
        background: transparent;
        color: #94a3b8;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .bp-remove-btn:hover {
            background: #fee2e2;
            border-color: #fecaca;
            color: #dc2626;
        }

        .bp-remove-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    .bp-pipeline-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .8rem 1rem;
        border-top: 1px solid var(--border,#e5e7eb);
        background: #f8fafc;
        color: var(--text-muted,#667085);
        font-size: .78rem;
        font-weight: 700;
    }

    .bp-clear-btn {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        color: #dc2626;
        border: none;
        background: transparent;
        cursor: pointer;
        font-weight: 850;
        font-size: .75rem;
    }

        .bp-clear-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    .bp-card {
        padding: 1.05rem;
    }

    .bp-card-hdr {
        display: flex;
        align-items: center;
        gap: .7rem;
        margin-bottom: .95rem;
        font-size: .95rem;
        font-weight: 900;
        color: var(--text,#111827);
    }

    .bp-card-note {
        margin-left: auto;
        padding: .28rem .55rem;
        border-radius: 999px;
        background: #eef2ff;
        color: var(--bp-primary);
        font-size: .68rem;
        font-weight: 900;
    }

    .bp-step-num {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4338CA, #6D28D9);
        color: #fff;
        font-size: .75rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

