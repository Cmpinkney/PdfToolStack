    private async Task<PendingBatchCreateResponse?> EnsurePendingBatchSavedAsync()
    {
        if (_pendingBatchId.HasValue && !string.IsNullOrWhiteSpace(_pendingBatchToken))
        {
            return new PendingBatchCreateResponse
            {
                PendingBatchId = _pendingBatchId.Value,
                PendingAccessToken = _pendingBatchToken,
                FileCount = _fileCount,
                ExpiresAtUtc = DateTime.UtcNow.AddHours(1)
            };
        }

        _checkoutError = string.Empty;
        AddActivity("Saving your batch before checkout...");
        StateHasChanged();

        var pending = await ApiService.CreatePendingBatchJobAsync(_files, _selectedTool);
        if (pending == null)
        {
            _checkoutError = "Could not save this batch before leaving the page. Please try again.";
            if (string.Equals(HostEnvironment.Environment, "Development", StringComparison.OrdinalIgnoreCase) &&
                !string.IsNullOrWhiteSpace(ApiService.LastPendingBatchCreateError))
            {
                _checkoutError += $" Details: {ApiService.LastPendingBatchCreateError}";
            }
            return null;
        }

        _pendingBatchId = pending.PendingBatchId;
        _pendingBatchToken = pending.PendingAccessToken;
        return pending;
    }

