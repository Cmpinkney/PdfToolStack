    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var hasUnlockReturn = string.Equals(query["batchUnlocked"], "true", StringComparison.OrdinalIgnoreCase);
        var resumeAfterAuth = string.Equals(query["resumeAfterAuth"], "true", StringComparison.OrdinalIgnoreCase);
        var resumeBatchUnlock = string.Equals(query["resumeBatchUnlock"], "true", StringComparison.OrdinalIgnoreCase);
        var proCheckoutSuccess = string.Equals(query["proCheckoutSuccess"], "true", StringComparison.OrdinalIgnoreCase);
        if (Guid.TryParse(query["pendingBatchId"], out var pendingBatchId))
        {
            _pendingBatchId = pendingBatchId;
        }
        _pendingBatchToken = query["pendingBatchToken"] ?? string.Empty;

        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirst("sub")?.Value ?? string.Empty;
        _userEmail = user.FindFirst("email")?.Value ?? string.Empty;

        if (user.Identity?.IsAuthenticated == true)
        {
            if (!string.IsNullOrEmpty(_userId))
            {
                SubService.ClearCache();
                var status = await SubService.GetStatusAsync(_userId);
                _isPro = status.HasPro || status.HasTeams;
                _isProUser = _isPro;
            }
        }

        await LoadPaymentOptionsAsync();

        if (_pendingBatchId.HasValue && !string.IsNullOrWhiteSpace(_pendingBatchToken) && !string.IsNullOrWhiteSpace(_userId))
        {
            await ApiService.ClaimPendingBatchJobAsync(_pendingBatchId.Value, _pendingBatchToken, _userId);
        }

        if ((hasUnlockReturn || proCheckoutSuccess) && _pendingBatchId.HasValue)
        {
            await ResumePendingBatchIfAuthorizedAsync(_pendingBatchId.Value);
        }
        else if (_pendingBatchId.HasValue && resumeAfterAuth)
        {
            if (_isProUser)
            {
                await ResumePendingBatchIfAuthorizedAsync(_pendingBatchId.Value);
            }
            else if (!string.IsNullOrWhiteSpace(_userId))
            {
                await StartProCheckoutForPendingBatchAsync();
            }
        }
        else if (_pendingBatchId.HasValue && resumeBatchUnlock && !string.IsNullOrWhiteSpace(_userId))
        {
            await StartBatchUnlockCheckout();
        }
    }

    private void SelectTool(ToolType t) { _selectedTool = t; }

    private async Task LoadPaymentOptionsAsync()
    {
        try
        {
            var addons = await ApiService.GetAsync<AddonsResponse>("api/subscription/addons");
            _batchUnlockPriceId = addons?.BatchUnlock?.PriceId;
        }
        catch
        {
            _batchUnlockPriceId = null;
        }

        try
        {
            var plans = await ApiService.GetAsync<PlansResponse>("api/subscription/plans");
            _proMonthlyPriceId = plans?.Monthly?.PriceId;
        }
        catch
        {
            _proMonthlyPriceId = null;
        }
