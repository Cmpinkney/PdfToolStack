            linear-gradient(180deg, #F8FAFC 0%, #EEF2F7 100%);
        color: #111827;
    }

    .bp-header,
    .bp-stepper,
    .bp-main,
    .bp-progress-section,
    .bp-insight-grid,
    .bp-result,
    .bp-gate,
    .bp-faq {
        max-width: 1180px;
        margin-left: auto;
        margin-right: auto;
    }

    .bp-header {
        display: flex;
