    .bp-quick-btn--danger {
        color: #dc2626;
        background: #fff7f7;
        border-color: #fecaca;
    }

    .bp-activity-feed {
        margin-top: 1rem;
        padding-top: .9rem;
        border-top: 1px solid var(--border,#e5e7eb);
    }

    .bp-activity-title {
        margin-bottom: .5rem;
        color: var(--text,#344054);
        font-size: .76rem;
        font-weight: 950;
    }

    .bp-activity-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .26rem 0;
        color: var(--text-muted,#667085);
        font-size: .72rem;
    }

    .bp-activity-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--bp-primary);
        box-shadow: 0 0 0 3px rgba(79,70,229,.12);
        flex-shrink: 0;
    }

    .bp-result {
        margin-top: 1rem;
        padding: 1.15rem;
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(360px, auto) 320px;
        align-items: center;
        gap: 1.1rem;
        background: linear-gradient(135deg, rgba(240,253,244,.95), rgba(255,255,255,.92));
        border-color: #bbf7d0;
    }

    .bp-result-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .bp-result-circle {
        width: 70px;
        height: 70px;
        border-radius: 24px;
        background: linear-gradient(135deg,#16a34a,#22c55e);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 18px 34px rgba(22,163,74,.22);
        flex-shrink: 0;
    }

    .bp-result-title {
        font-size: 1.1rem;
        font-weight: 950;
        color: var(--text,#111827);
    }

    .bp-result-sub, .bp-result-time {
        color: var(--text-muted,#667085);
        font-size: .8rem;
        margin-top: .18rem;
        font-weight: 700;
    }

    .bp-result-stats {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .8rem;
        background: rgba(255,255,255,.8);
        border: 1px solid #dcfce7;
        border-radius: 16px;
        padding: .8rem;
    }

    .bp-rstat {
        border-right: 1px solid var(--border,#e5e7eb);
        padding-right: .7rem;
    }

        .bp-rstat:last-child {
            border-right: none;
        }

    .bp-rstat-num {
        font-size: 1.25rem;
        font-weight: 950;
        color: var(--text,#111827);
    }

    .bp-rstat-lbl, .bp-rstat-sub {
        color: var(--text-muted,#667085);
        font-size: .68rem;
        font-weight: 800;
    }

    .bp-result-right {
        display: flex;
        flex-direction: column;
        gap: .55rem;
    }

    .bp-again-btn, .bp-retry-failed-btn {
        border: 0;
        background: transparent;
        color: var(--bp-primary);
        font-size: .78rem;
        font-weight: 900;
        cursor: pointer;
        padding: .55rem;
        border-radius: 12px;
    }

    .bp-retry-failed-btn {
        color: #b91c1c;
        background: #fee2e2;
        border: 1px solid #fecaca;
    }

    .bp-fail-section {
        grid-column: 1 / -1;
        background: #fff;
        border: 1px solid #fecaca;
        border-radius: 16px;
        padding: .8rem;
    }

    .bp-fail-toggle {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        color: #b91c1c;
        background: transparent;
        border: 0;
        font-weight: 900;
        cursor: pointer;
    }

    .bp-fail-list {
        margin-top: .7rem;
        display: flex;
        flex-direction: column;
        gap: .45rem;
    }

    .bp-fail-item {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        color: var(--text-muted,#667085);
        font-size: .78rem;
    }

    .bp-fail-fname {
        font-weight: 900;
        color: var(--text,#344054);
    }

    .bp-fail-msg {
        color: #dc2626;
    }

    .bp-faq {
        margin-top: 1.5rem;
        padding: 1.2rem;
    }

        .bp-faq h2 {
            margin: 0 0 1rem;
            font-size: 1.1rem;
            font-weight: 950;
            color: var(--text,#111827);
        }

    .bp-faq-item {
        border: 1px solid var(--border,#e5e7eb);
        border-radius: 14px;
        background: #fff;
        margin-bottom: .65rem;
        overflow: hidden;
    }

        .bp-faq-item summary {
            cursor: pointer;
            padding: .85rem 1rem;
            color: var(--text,#344054);
            font-weight: 900;
            font-size: .85rem;
        }

        .bp-faq-item p {
            margin: 0;
            padding: 0 1rem 1rem;
            color: var(--text-muted,#667085);
            line-height: 1.6;
            font-size: .82rem;
        }

    .bp-spin-xs, .bp-spin-xs-w, .bp-spin-btn {
        border-radius: 50%;
        border: 2px solid currentColor;
        border-top-color: transparent;
        animation: bpSpin .8s linear infinite;
    }

    .bp-spin-xs {
        width: 10px;
        height: 10px;
        color: #5b21b6;
    }

    .bp-spin-xs-w {
        width: 10px;
        height: 10px;
        color: #fff;
    }

    .bp-spin-btn {
        width: 16px;
        height: 16px;
        color: #fff;
    }

    [data-theme="dark"] .bp-wrap::before {
        background: radial-gradient(circle at 25% 0%, rgba(124,58,237,.18), transparent 38%), linear-gradient(135deg, rgba(20,20,35,.95), rgba(15,23,42,.85));
    }

    [data-theme="dark"] .bp-stat-cards,
    [data-theme="dark"] .bp-pipeline,
    [data-theme="dark"] .bp-progress-section,
    [data-theme="dark"] .bp-card,
    [data-theme="dark"] .bp-result,
    [data-theme="dark"] .bp-insight-card,
    [data-theme="dark"] .bp-faq,
    [data-theme="dark"] .bp-empty-card,
    [data-theme="dark"] .bp-batch-summary,
    [data-theme="dark"] .bp-gate {
        background: rgba(24, 24, 38, .86);
        border-color: rgba(148,163,184,.18);
    }

    [data-theme="dark"] .bp-dropzone {
        background: rgba(99,102,241,.08);
        border-color: #6d28d9;
    }

    [data-theme="dark"] .cloud-row {
        background: rgba(15,23,42,.62);
        border-color: rgba(148,163,184,.22);
    }

    [data-theme="dark"] .cloud-btn {
        background: rgba(15,23,42,.82);
        border-color: rgba(148,163,184,.24);
        color: var(--text, #f8fafc);
    }

    [data-theme="dark"] .bp-file-row, [data-theme="dark"] .bp-tool-btn, [data-theme="dark"] .bp-copt, [data-theme="dark"] .bp-mini-card, [data-theme="dark"] .bp-faq-item, [data-theme="dark"] .bp-output-option, [data-theme="dark"] .bp-input, [data-theme="dark"] .bp-select {
        background: rgba(15,23,42,.42);
    }

    [data-theme="dark"] .bp-wm-doc, [data-theme="dark"] .bp-rot-doc {
        background: #111827;
    }

    [data-theme="dark"] .bp-doc-line {
        background: #334155;
    }

    @@keyframes bpSpin {
        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes bpPulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.18);
        }
    }

    @@keyframes bpShimmer {
        0% {
            background-position: 0% 50%;
        }

        100% {
            background-position: 200% 50%;
        }
    }

    @@media (max-width: 1180px) {
        .bp-header {
            grid-template-columns: 1fr;
        }

        .bp-stat-cards {
            max-width: 680px;
        }

        .bp-main {
            grid-template-columns: 1fr;
        }

        .bp-col-right, .bp-process-card {
            position: static;
        }

        .bp-insight-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .bp-wrap {
            padding-inline: .85rem;
        }

        .bp-stat-cards {
            grid-template-columns: 1fr;
        }

        .bp-stat-card {
            border-right: 0;
            border-bottom: 1px solid var(--border,#e5e7eb);
        }

            .bp-stat-card:last-child {
                border-bottom: 0;
            }

        .bp-batch-summary, .bp-summary-metrics {
            grid-template-columns: 1fr;
        }

        .bp-empty-command-center {
            grid-template-columns: 1fr;
        }

        .bp-tool-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .bp-compress-opts, .bp-rotate-opts, .bp-output-options, .bp-row2 {
            grid-template-columns: 1fr;
        }

        .bp-file-row {
            grid-template-columns: 18px 16px 22px minmax(0,1fr) 58px 28px;
        }

        .bp-pdf-badge {
            display: none;
        }

        .bp-status-area {
            grid-column: 4 / span 2;
            justify-content: flex-start;
        }

        .bp-file-pbar {
            width: 110px;
        }

        .bp-prog-header {
            grid-template-columns: 1fr;
        }

        .bp-prog-pct, .bp-prog-count {
            justify-self: start;
        }

        .bp-result {
            grid-template-columns: 1fr;
        }

        .bp-result-stats {
            grid-template-columns: 1fr;
        }

        .bp-rstat {
            border-right: 0;
            border-bottom: 1px solid var(--border,#e5e7eb);
            padding: 0 0 .55rem;
        }

            .bp-rstat:last-child {
                border-bottom: 0;
            }

        .bp-gate-feats {
            grid-template-columns: 1fr;
        }
    }
    /* ── SaaS workflow-builder facelift overrides ───────────────────── */
    .bp-wrap {
        max-width: none;
        min-height: 100vh;
        padding: 1.5rem;
        background:
            radial-gradient(circle at 15% 0%, rgba(20, 184, 166, .12), transparent 34%),
