    private async Task PickCloudFile(
        string providerName,
        Func<Task<PdfToolStack.Web.Services.CloudPickerService.CloudFileInfo?>> picker)
    {
        _cloudError = string.Empty;

        if (_files.Count >= 20)
        {
            _cloudError = "The batch queue is full. Remove a file before importing another PDF.";
            return;
        }

        _cloudLoading = true;
        StateHasChanged();

        try
        {
            var cloudFile = await picker();
            if (cloudFile == null)
                return;

            if (!IsPdfFileName(cloudFile.Name))
            {
                _cloudError = $"{providerName}: Please choose a PDF file.";
                return;
            }

            var bytes = await CloudPicker.DownloadFileAsync(cloudFile.Url, cloudFile.AccessToken);
            if (bytes == null || bytes.Length == 0)
            {
                _cloudError = $"{providerName}: Could not download the selected file.";
                return;
            }

            var fileName = GetUniqueFileName(cloudFile.Name);
            _files.Add(new CloudBrowserFile(fileName, bytes));
            SyncFileCount();
            ClearBatchArtifactsAfterQueueChange();
            AddActivity($"Imported {fileName} from {providerName}.");
        }
        catch (Exception ex)
        {
            _cloudError = $"{providerName}: {ex.Message}";
        }
        finally
        {
            _cloudLoading = false;
            StateHasChanged();
        }
    }

    private void ClearBatchArtifactsAfterQueueChange()
    {
        _showUpgradeModal = false;
        _batchUnlocked = false;
        _pendingBatchId = null;
        _pendingBatchToken = string.Empty;
        _pendingFileNames.Clear();
        _fileStatuses.Clear();
        _fileProgress.Clear();
        _fileOutputSizes.Clear();
        _fileErrors.Clear();
        _zipBytes = null;
        _error = string.Empty;
        _successCount = 0;
        _failCount = 0;
        _overallPct = 0;
        _totalOutputBytes = 0;
        _showErrors = false;
    }

    private static bool IsPdfFileName(string name)
        => name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);

    private string GetUniqueFileName(string name)
    {
        var safeName = string.IsNullOrWhiteSpace(name)
            ? "cloud-file.pdf"
            : System.IO.Path.GetFileName(name);

        if (string.IsNullOrWhiteSpace(safeName))
            safeName = "cloud-file.pdf";

        var extension = System.IO.Path.GetExtension(safeName);
        var baseName = System.IO.Path.GetFileNameWithoutExtension(safeName);
        if (string.IsNullOrWhiteSpace(baseName))
            baseName = "cloud-file";
        if (string.IsNullOrWhiteSpace(extension))
            extension = ".pdf";

        var candidate = $"{baseName}{extension}";
        var suffix = 2;
        while (_files.Any(f => string.Equals(f.Name, candidate, StringComparison.OrdinalIgnoreCase)))
        {
            candidate = $"{baseName} ({suffix}){extension}";
            suffix++;
        }

        return candidate;
    }

    private void RemoveFile(int idx)
    {
        if (idx < 0 || idx >= _files.Count) return;
        var name = _files[idx].Name;
        _files.RemoveAt(idx);
        SyncFileCount();
        if (_fileCount <= 3) _showUpgradeModal = false;
        _fileStatuses.Remove(name); _fileProgress.Remove(name);
        _fileOutputSizes.Remove(name); _fileErrors.Remove(name);
        AddActivity($"Removed {name} from the batch.");
    }

    private void RetryFile(int idx)
    {
        if (idx < 0 || idx >= _files.Count) return;
        var name = _files[idx].Name;
        _fileStatuses[name] = "waiting";
        _fileErrors.Remove(name);
        AddActivity($"Queued {name} for retry.");
    }

    private void RetryFailedFiles()
    {
        foreach (var name in _fileErrors.Keys.ToList())
        {
            _fileStatuses[name] = "waiting";
        }

        var count = _fileErrors.Count;
        _fileErrors.Clear();
        _failCount = 0;
        _zipBytes = null;
        _showErrors = false;
        AddActivity($"Reset {count} failed file{(count == 1 ? "" : "s")} for another run.");
    }

    private async Task RunBatch()
    {
        if (!_files.Any()) return;
        SyncFileCount();
        if (!_isProUser && !_batchUnlocked && _fileCount > 3)
        {
            _showUpgradeModal = true;
            return;
        }

        _processing = true; _processedCount = 0; _zipBytes = null;
        _error = string.Empty; _fileStatuses.Clear(); _fileProgress.Clear();
        _fileOutputSizes.Clear(); _fileErrors.Clear();
        _successCount = 0; _failCount = 0; _overallPct = 0; _totalOutputBytes = 0;
        _activityFeed.Clear();
        AddActivity($"Started {GetToolLabel(_selectedTool).ToLower()} batch for {_files.Count} file{(_files.Count == 1 ? "" : "s")}.");
        var startTime = DateTime.Now;

        foreach (var f in _files) _fileStatuses[f.Name] = "queued";
        StateHasChanged();

        try
        {
            var fileData = new List<(byte[] Bytes, string FileName)>();
            foreach (var file in _files)
            {
                _fileStatuses[file.Name] = "processing";
                _fileProgress[file.Name] = 0;
                AddActivity($"Reading {file.Name}...");
                StateHasChanged();

                using var ms = new MemoryStream();
                await file.OpenReadStream(maxAllowedSize: 524_288_000).CopyToAsync(ms);
                fileData.Add((ms.ToArray(), file.Name));

                // Simulate read progress
                for (int p = 20; p <= 80; p += 20)
                {
                    _fileProgress[file.Name] = p;
                    StateHasChanged();
                    await Task.Delay(80);
                }
                _fileStatuses[file.Name] = "queued";
                AddActivity($"Queued {file.Name} for processing.");
                _processedCount++;
                _overallPct = (int)((double)_processedCount / (_files.Count * 2) * 100);
                StateHasChanged();
            }

            foreach (var f in _files) { _fileStatuses[f.Name] = "processing"; _fileProgress[f.Name] = 50; }
            StateHasChanged();

            AddActivity("Sending files to the batch processor...");
            _zipBytes = await ApiService.BatchProcessAsync(fileData, _selectedTool);

            _totalProcessTime = (int)(DateTime.Now - startTime).TotalSeconds;

            if (_zipBytes != null)
            {
                _successCount = _files.Count;
                foreach (var f in _files)
                {
                    _fileStatuses[f.Name] = "done";
                    _fileProgress[f.Name] = 100;
                    var ratio = _selectedTool == ToolType.CompressPdf
                        ? (_compressionLevel == "maximum" ? 0.25 : _compressionLevel == "medium" ? 0.45 : 0.70)
                        : 1.0;
                    _fileOutputSizes[f.Name] = (long)(f.Size * ratio);
                    _totalOutputBytes += _fileOutputSizes[f.Name];
                    AddActivity($"Completed {f.Name}.");
                }
                _overallPct = 100;
            }
            else
            {
                _error = "Batch processing failed. Please try again.";
                AddActivity("Batch failed. Review errors and retry.");
                foreach (var f in _files) { _fileStatuses[f.Name] = "error"; _fileErrors[f.Name] = "Processing failed"; }
                _failCount = _files.Count;
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
            AddActivity($"Error: {ex.Message}");
            foreach (var f in _files) { _fileStatuses[f.Name] = "error"; _fileErrors[f.Name] = ex.Message; }
            _failCount = _files.Count;
        }
        finally { _processing = false; StateHasChanged(); }
    }

    private async Task DownloadZip()
    {
        if (_zipBytes == null) return;
        await JS.InvokeVoidAsync("downloadFile",
            $"pdftoolstack_batch_{_selectedTool.ToString().ToLower()}.zip",
