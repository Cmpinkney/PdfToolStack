    .bp-stat-card,
    .bp-card,
    .bp-workflow-pipeline,
    .bp-batch-summary,
    .bp-dropzone,
    .bp-empty-card,
    .bp-pipeline,
    .bp-progress-section,
    .bp-insight-card,
    .bp-result,
    .bp-gate {
