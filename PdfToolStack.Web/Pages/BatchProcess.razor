    private int GetPwPct()
    {
        if (string.IsNullOrEmpty(_protectPassword)) return 0;
        var s = 0;
        if (_protectPassword.Length >= 8) s += 25;
        if (_protectPassword.Length >= 12) s += 25;
        if (_protectPassword.Any(char.IsUpper)) s += 25;
        if (_protectPassword.Any(char.IsDigit) || _protectPassword.Any(c => !char.IsLetterOrDigit(c))) s += 25;
        return s;
    }
    private string GetPwColor() => GetPwPct() switch { >= 75 => "#16A34A", >= 50 => "#D97706", _ => "#DC2626" };
    private string GetPwLabel() => GetPwPct() switch { >= 75 => "Strong", >= 50 => "Moderate", _ => "Weak" };

