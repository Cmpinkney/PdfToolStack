    private string BuildLoginUrl(string marker)
    {
        var returnUrl = BuildBatchReturnPath(marker.TrimStart('/').TrimStart('?'));
        var absoluteReturnUrl = Navigation.BaseUri.TrimEnd('/') + returnUrl;
        return $"authentication/login?returnUrl={Uri.EscapeDataString(absoluteReturnUrl)}";
    }

    private string BuildBatchReturnPath(string marker)
    {
        var separator = marker.Contains('=') ? "&" : string.Empty;
        var queryPrefix = marker.StartsWith('?') ? marker[1..] : marker;
        return $"/batch?{queryPrefix}{separator}pendingBatchId={_pendingBatchId}&pendingBatchToken={Uri.EscapeDataString(_pendingBatchToken)}";
    }

    private async Task ResumePendingBatchIfAuthorizedAsync(Guid pendingBatchId)
    {
        var pending = await ApiService.GetPendingBatchJobAsync(pendingBatchId, _pendingBatchToken);
        if (pending == null)
        {
            _error = "Could not load the pending batch.";
            return;
        }

        _pendingFileNames = pending.FileNames;
        _fileCount = pending.FileCount;
        _selectedTool = pending.ToolType;

        if (!pending.IsAuthorized || pending.IsUsed)
        {
            _batchUnlocked = false;
            _error = pending.IsUsed
                ? "This Batch Unlock has already been used."
                : "Payment or Pro status has not been verified for this batch yet. Please wait a moment and refresh.";
            return;
        }

        _batchUnlocked = true;
        _showUpgradeModal = false;
        _processing = true;
        _processedCount = 0;
        _overallPct = 15;
        _error = string.Empty;
        _activityFeed.Clear();
        AddActivity("Welcome back. Resuming your batch...");
        StateHasChanged();

        var bytes = await ApiService.ProcessPendingBatchJobAsync(pendingBatchId, _pendingBatchToken);
        if (bytes == null || bytes.Length == 0)
        {
            _error = "The paid batch could not be processed. Please contact support.";
            _failCount = pending.FileCount;
            _processing = false;
            _overallPct = 0;
            StateHasChanged();
            return;
        }

        _zipBytes = bytes;
        _successCount = pending.FileCount;
        _processedCount = pending.FileCount;
        _overallPct = 100;
        _processing = false;
        AddActivity("Paid batch completed.");
        StateHasChanged();
    }

