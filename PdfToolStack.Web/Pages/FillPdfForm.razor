@page "/fill-pdf-form"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Fill PDF Form Online Free — Fill Out PDF Forms Instantly</PageTitle>

<HeadContent>
    <meta name="description"
          content="Fill out PDF forms online for free.
                   No signup required. Fill and download
                   your completed PDF instantly." />
    <meta name="keywords"
          content="fill pdf form, fill out pdf online,
                   pdf form filler free, complete pdf form" />
    <link rel="canonical"
          href="https://yoursite.com/fill-pdf-form" />
</HeadContent>

<div class="tool-page fill-tool-page">
    <div class="tool-container">
        <section class="tool-hero fill-hero">
            <div class="trust-row">
                <span>Secure upload</span>
                <span>Editable fields</span>
                <span>Auto-delete</span>
            </div>

            <h1>Fill PDF forms <span class="hero-gradient-text">online</span></h1>
            <p>
                Upload a fillable PDF, complete the detected fields, and download
                a finished document without installing software.
            </p>
        </section>

        <div class="stepper fill-stepper">
            <div class="step @(CurrentState == PageState.Upload || CurrentState == PageState.LargeFile ? "active" : "complete")">
                <span>1</span>
                <p>Upload</p>
            </div>
            <div class="step @(CurrentState == PageState.Upload || CurrentState == PageState.LargeFile ? "" : CurrentState == PageState.FillFields ? "active" : "complete")">
                <span>2</span>
                <p>Detect Fields</p>
            </div>
            <div class="step @(CurrentState == PageState.FillFields ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>3</span>
                <p>Fill</p>
            </div>
            <div class="step @(CurrentState == PageState.Complete ? "complete active" : "")">
                <span>4</span>
                <p>Download</p>
            </div>
        </div>

        <section class="workflow-grid fill-workflow-grid">
            <div class="workspace-card fill-workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Upload workspace</span>
                        <h2>Start with a fillable PDF</h2>
                        <p>
                            Choose a PDF form from your device, Google Drive, or Dropbox.
                            We will scan for interactive fields before you fill it.
                        </p>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved" />

                    @if (SelectedFile != null && !IsDetecting)
                    {
                        <div class="fill-file-ready">
                            <div>
                                <strong>@SelectedFile.Name</strong>
                                <span>@Validator.FormatSize(SelectedFile.Size)</span>
                            </div>
                            <button class="fill-primary-button"
                                    @onclick="DetectFields">
                                Load Form Fields
                            </button>
                        </div>
                    }

                    @if (IsDetecting)
                    {
                        <div class="fill-state-card">
                            <div class="spinner"></div>
                            <h3>Detecting form fields...</h3>
                            <p>Scanning your PDF for editable fields and answer areas.</p>
                        </div>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                                      FileName="@(SelectedFile?.Name ?? "")"
                                      ToolType="FillPdfForm"
                                      OnCancel="Reset" />
                }

                @if (CurrentState == PageState.FillFields)
                {
                    <div class="fill-document-card">
                        <div class="fill-document-icon">
                            <span>PDF</span>
                        </div>

                        <div class="fill-document-copy">
                            <span class="panel-eyebrow">Document status</span>
                            <h2>Document ready</h2>
                            <p>
                                We detected the form fields in your PDF. Enter your
                                responses on the right, then download the completed file.
                            </p>
                        </div>

                        <div class="fill-document-stats">
                            <div>
                                <span>File name</span>
                                <strong>@(SelectedFile?.Name ?? "Selected PDF")</strong>
                            </div>
                            <div>
                                <span>Detected fields</span>
                                <strong>@FormFields.Count</strong>
                            </div>
                            <div>
                                <span>Output</span>
                                <strong>Completed PDF</strong>
                            </div>
                        </div>

                        <div class="fill-placement-note">
                            Live field placement preview is coming later. Filled values
                            are applied when you download.
                        </div>
                    </div>
                }

                @if (CurrentState == PageState.NoFields)
                {
                    <div class="fill-state-card fill-warning-card">
                        <span class="fill-state-icon">!</span>
                        <h2>No fillable fields found</h2>
                        <p>
                            This PDF does not contain interactive form fields. Scanned or
                            flat PDFs are not supported by this form filler yet.
                        </p>
                        <button class="fill-secondary-button"
                                @onclick="Reset">
                            Try Another PDF
                        </button>
                    </div>
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="fill-state-card">
                        <div class="spinner"></div>
                        <h2>Filling your PDF form...</h2>
                        <p>Applying your answers and preparing a completed PDF download.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete)
                {
                    <div class="fill-state-card fill-success-card">
                        <span class="fill-state-icon">✓</span>
                        <h2>Form filled successfully</h2>
                        <p>Your completed PDF is ready to download.</p>

                        <div class="fill-action-row">
                            <button class="fill-primary-button"
                                    @onclick="DownloadFile">
                                Download Filled PDF
                            </button>

                            <button class="fill-secondary-button"
                                    @onclick="Reset">
                                Fill Another PDF
                            </button>
                        </div>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="fill-state-card fill-error-card">
                        <span class="fill-state-icon">×</span>
                        <h2>Something went wrong</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="fill-secondary-button" @onclick="Reset">
                            Try Again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card fill-settings-card">
                @if (CurrentState == PageState.FillFields)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Detected fields</span>
                        <h2>Complete your form</h2>
                        <p>
                            Detected fields are listed below.
                        </p>
                    </div>

                    <div class="fields-list fill-fields-list">
                        @foreach (var field in FormFields)
                        {
                            <div class="field-item fill-field-item">
                                <label class="field-label">
                                    @FormatFieldName(field.Name)
                                    <span class="field-technical-name">@field.Name</span>
                                </label>

                                @if (field.FieldType == "checkbox")
                                {
                                    <div class="checkbox-wrapper fill-checkbox-wrapper">
                                        <input type="checkbox"
                                               class="field-checkbox"
                                               @onchange="e => HandleCheckboxChange(field.Name, e.Value)" />
                                        <span>Check this box</span>
                                    </div>
                                }
                                else if (field.FieldType == "dropdown"
                                && field.Options.Count > 0)
                                {
                                    <select class="field-input"
                                            @onchange="e => HandleSelectChange(field.Name, e.Value)">
                                        <option value="">
                                            Select an option...
                                        </option>
                                        @foreach (var option in field.Options)
                                        {
                                            <option value="@option">
                                                @option
                                            </option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <input type="text"
                                           class="field-input"
                                           placeholder="@($"Enter {FormatFieldName(field.Name)}...")"
                                           @oninput="e => HandleInputChange(field.Name, e.Value)" />
                                }
                            </div>
                        }
                    </div>

                    <button class="fill-primary-button fill-full-button"
                            @onclick="FillForm">
                        Fill & Download PDF
                    </button>

                    <button class="fill-secondary-button fill-full-button"
                            @onclick="Reset">
                        Upload Different PDF
                    </button>
                }
                else
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Form workflow</span>
                        <h2>Detect, fill, download</h2>
                        <p>
                            Use this workflow for PDFs that already contain interactive
                            fields such as applications, forms, and agreements.
                        </p>
                    </div>

                    <div class="fill-value-list">
                        <div>
                            <span>1</span>
                            <strong>Detect fields</strong>
                            <p>Find text boxes, dropdowns, and checkboxes automatically.</p>
                        </div>
                        <div>
                            <span>2</span>
                            <strong>Fill answers</strong>
                            <p>Complete the detected fields in a clean side panel.</p>
                        </div>
                        <div>
                            <span>3</span>
                            <strong>Download completed PDF</strong>
                            <p>Generate a finished copy with your filled values applied.</p>
                        </div>
                    </div>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
            <h3>What types of PDF forms can I fill?</h3>
            <p>
                Any PDF with interactive form fields — including
                government forms, applications, contracts, and
                tax documents.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is the filled PDF stored on your servers?</h3>
            <p>
                Your files are automatically deleted within 1 hour.
                We never store your documents permanently.
            </p>
        </div>

        <div class="faq-item">
            <h3>Can I fill any PDF?</h3>
            <p>
                Only PDFs with interactive form fields can be filled.
                Scanned or flat PDFs without form fields are not
                supported by this tool.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is this PDF form filler free?</h3>
            <p>Yes — completely free with no signup required.</p>
        </div>

        <div class="faq-item">
            <h3>Will the filled fields be permanent?</h3>
            <p>
                Yes — once downloaded the filled values are
                permanently embedded in the PDF and cannot
                be edited further.
            </p>
        </div>
    </div>
</div>

@code {
    private enum PageState
    {
        Upload, FillFields, NoFields,
        Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private List<PdfFormField> FormFields = new();
    private Dictionary<string, string> FieldValues = new();
    private byte[]? FilledBytes;
    private string? ErrorMessage;
    private bool IsDetecting = false;

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }
        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesVal = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid)
            {
                Toast.ShowError(bytesVal.Message!);
                UploadedBytes = null;
                return;
            }
            if (bytesVal.IsWarning)
                Toast.ShowWarning(bytesVal.Message!);

            SelectedFile = file;
            if (PaymentService.IsFileTooLargeForFree(file.Size))
            {
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            Toast.ShowSuccess(
                $"File ready — {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;
    }

    private async Task DetectFields()
    {
        if (UploadedBytes == null) return;

        IsDetecting = true;
        StateHasChanged();

        try
        {
            var response = await ApiService.DetectFormFieldsAsync(
                UploadedBytes, SelectedFile!.Name);

            if (response == null)
            {
                ErrorMessage = "Could not detect form fields.";
                CurrentState = PageState.Error;
                return;
            }

            if (!response.HasFields ||
                response.Fields.Count == 0)
            {
                CurrentState = PageState.NoFields;
                return;
            }

            FormFields = response.Fields;
            FieldValues = FormFields.ToDictionary(
                f => f.Name, f => f.Value);
            CurrentState = PageState.FillFields;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }
        finally
        {
            IsDetecting = false;
        }

        StateHasChanged();
    }

    private void UpdateFieldValue(string fieldName, string value)
    {
        FieldValues[fieldName] = value;
    }

    private void HandleCheckboxChange(
        string fieldName, object? value)
    {
        var isChecked = value?.ToString() == "True";
        UpdateFieldValue(fieldName, isChecked ? "Yes" : "Off");
    }

    private void HandleSelectChange(
        string fieldName, object? value)
    {
        UpdateFieldValue(fieldName,
            value?.ToString() ?? string.Empty);
    }

    private void HandleInputChange(
        string fieldName, object? value)
    {
        UpdateFieldValue(fieldName,
            value?.ToString() ?? string.Empty);
    }

    private async Task FillForm()
    {
        if (UploadedBytes == null) return;

        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            FilledBytes = await ApiService.FillFormAsync(
                UploadedBytes,
                SelectedFile!.Name,
                FieldValues);

            if (FilledBytes != null)
                CurrentState = PageState.Complete;
            else
            {
                ErrorMessage = "Form fill failed. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (FilledBytes == null) return;

        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "filled") + "_filled.pdf";

        await JS.InvokeVoidAsync(
            "downloadFile",
            fileName,
            Convert.ToBase64String(FilledBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        FormFields.Clear();
        FieldValues.Clear();
        FilledBytes = null;
        ErrorMessage = null;
        IsDetecting = false;
    }

    private string FormatFieldName(string name)
    {
        var cleaned = name;

        // IRS forms use dot notation — split and take the last part
        if (cleaned.Contains('.'))
        {
            var parts = cleaned.Split('.');
            cleaned = parts[parts.Length - 1];
        }

        // Remove array indices like [0]
        cleaned = System.Text.RegularExpressions
            .Regex.Replace(cleaned, @"\[\d+\]", "");

        // Convert F1_01 → Line 01
        cleaned = System.Text.RegularExpressions
            .Regex.Replace(cleaned,
                @"^[Ff]\d+_0*(\d+)$", "Line $1");

        // Convert f1_01 → Line 01
        cleaned = System.Text.RegularExpressions
            .Regex.Replace(cleaned,
                @"^[Ff](\d+)_(\d+)$", "Part $1 Line $2");

        // Clean up underscores and extra spaces
        cleaned = cleaned
            .Replace("_", " ")
            .Replace("-", " ")
            .Trim();

        cleaned = System.Text.RegularExpressions
            .Regex.Replace(cleaned, @"\s+", " ");

        // Capitalize first letter
        if (!string.IsNullOrEmpty(cleaned))
            cleaned = char.ToUpper(cleaned[0])
                    + cleaned.Substring(1);

        return string.IsNullOrWhiteSpace(cleaned) ? name : cleaned;
    }
}
