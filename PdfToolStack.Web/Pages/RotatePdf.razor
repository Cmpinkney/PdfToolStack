@page "/rotate-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast

<PageTitle>Rotate PDF Free Online — Rotate PDF Pages</PageTitle>

<HeadContent>
    <meta name="description" content="Rotate PDF pages free online. Rotate one or all pages in your PDF. No signup required." />
    <meta name="keywords" content="rotate pdf, rotate pdf pages free, fix pdf orientation, pdf rotation tool" />
    <link rel="canonical" href="https://pdftoolstack.com/rotate-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <h1>Rotate PDF Pages</h1>
        <p class="tool-subtitle">Rotate one or all pages in your PDF for free. No signup required.</p>

        @if (CurrentState == PageState.Upload)
        {
            <FileUpload OnFileSelected="HandleFileSelected" OnFileRemoved="HandleFileRemoved" />

            @if (SelectedFile != null)
            {
                <div class="rotate-options">
                    <h3>Rotation Options</h3>
                    <div class="rotate-controls">
                        <div class="form-group">
                            <label>Rotation Angle</label>
                            <select class="field-input" @bind="RotationAngle">
                                <option value="90">90° Clockwise</option>
                                <option value="180">180°</option>
                                <option value="270">270° (90° Counter-clockwise)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Apply To</label>
                            <select class="field-input" @bind="RotateMode">
                                <option value="all">All Pages</option>
                                <option value="specific">Specific Pages</option>
                            </select>
                        </div>
                        @if (RotateMode == "specific")
                        {
                            <div class="form-group">
                                <label>Page Numbers (comma separated)</label>
                                <input type="text" class="field-input" placeholder="e.g. 1,3,5" @bind="SpecificPages" />
                            </div>
                        }
                    </div>
                    <button class="process-button" @onclick="ProcessFile">Rotate PDF</button>
                </div>
            }
        }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)" FileName="@(SelectedFile?.Name ?? "")" ToolType="RotatePdf" OnCancel="Reset" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container"><div class="spinner"></div><p>Rotating your PDF...</p></div>
        }

        @if (CurrentState == PageState.Complete && ResultBytes != null)
        {
            <AdSlot Size="rectangle" />
            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>PDF Rotated!</h2>
                <p style="color: var(--gray); margin-bottom: 1.5rem;">Your PDF pages have been rotated successfully.</p>
                <button class="download-button" @onclick="DownloadFile">Download PDF</button>
                <button class="reset-button" @onclick="Reset">Rotate Another PDF</button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button" @onclick="Reset">Try Again</button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>Can I rotate just one page?</h3>
            <p>Yes — select "Specific Pages" and enter the page numbers you want to rotate.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no signup required.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Processing, Complete, Error, LargeFile }
    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private int RotationAngle = 90;
    private string RotateMode = "all";
    private string SpecificPages = string.Empty;

    [SupplyParameterFromQuery] private string? Paid { get; set; }
    protected override void OnInitialized() { if (Paid == "true") CurrentState = PageState.Upload; }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }
        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesVal = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid)
            {
                Toast.ShowError(bytesVal.Message!);
                UploadedBytes = null;
                return;
            }
            if (bytesVal.IsWarning)
                Toast.ShowWarning(bytesVal.Message!);

            if (PaymentService.IsFileTooLargeForFree(file.Size))
            {
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            SelectedFile = file;
            Toast.ShowSuccess(
                $"File ready — {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved() { SelectedFile = null; UploadedBytes = null; }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null) return;
        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            var pages = RotateMode == "specific" && !string.IsNullOrEmpty(SpecificPages) ? SpecificPages : null;
            ResultBytes = await ApiService.RotatePdfAsync(UploadedBytes, SelectedFile!.Name, RotationAngle, pages);
            CurrentState = ResultBytes != null ? PageState.Complete : PageState.Error;
            if (ResultBytes == null) ErrorMessage = "Rotation failed. Please try again.";
        }
        catch (Exception ex) { ErrorMessage = $"Error: {ex.Message}"; CurrentState = PageState.Error; }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        await JS.InvokeVoidAsync("downloadFile", Path.GetFileNameWithoutExtension(SelectedFile?.Name ?? "document") + "_rotated.pdf", Convert.ToBase64String(ResultBytes));
    }

    private void Reset() { CurrentState = PageState.Upload; SelectedFile = null; UploadedBytes = null; ResultBytes = null; ErrorMessage = null; RotateMode = "all"; SpecificPages = string.Empty; }
}