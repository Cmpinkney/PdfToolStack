@page "/ai-pdf-assist"
@inject NavigationManager Navigation

<PageTitle>AI PDF Tools — Summarize, Chat, Extract, Translate | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="AI-powered PDF tools. Summarize documents, chat with your PDF,
                   extract invoice data, translate, rewrite, and review contracts — all powered by Claude AI." />
    <meta name="keywords" content="ai pdf tools, pdf ai assistant, document ai, intelligent pdf processing" />
    <link rel="canonical" href="https://pdftoolstack.com/ai-pdf-assist" />
</HeadContent>

<main class="ai-hub-page">
    <section class="ai-hub-hero">
        <div class="ai-hub-hero-copy">
            <div class="ai-hub-trust-row">
                <span>Private processing</span>
                <span>Secure upload</span>
                <span>Auto-delete after 1 hour</span>
                <span>5 free AI uses</span>
            </div>

            <h1>Understand any PDF faster</h1>
            <p>
                Upload a document, choose an AI workflow, and turn long PDFs into summaries,
                answers, extracted data, reviews, or rewritten text.
            </p>

            <div class="ai-hub-hero-actions">
                <a href="#ai-workflows" class="ai-hub-primary-cta">Choose an AI workflow</a>
                <a href="/pricing" class="ai-hub-secondary-cta">View pricing</a>
            </div>
        </div>

        <div class="ai-hub-animation" aria-hidden="true">
            <div class="ai-flow-line"></div>

            <div class="ai-flow-stage ai-flow-upload">
                <div class="ai-flow-file">
                    <div class="ai-flow-file-top"></div>
                    <strong>Quarterly report.pdf</strong>
                    <span>48 pages</span>
                    <div class="ai-flow-file-lines">
                        <i></i><i></i><i></i>
                    </div>
                </div>
                <div class="ai-flow-label">Uploaded PDF</div>
            </div>

            <div class="ai-flow-stage ai-flow-brain">
                <div class="ai-workspace-panel">
                    <div class="ai-workspace-header">
                        <span></span>
                        AI workspace
                    </div>
                    <div class="ai-workflow-chip-stack">
                        <span class="ai-workflow-chip chip-one">Summarize</span>
                        <span class="ai-workflow-chip chip-two">Ask</span>
                        <span class="ai-workflow-chip chip-three">Extract</span>
                        <span class="ai-workflow-chip chip-four">Review</span>
                        <span class="ai-workflow-chip chip-five">Rewrite</span>
                    </div>
                    <div class="ai-processing-bar"><span></span></div>
                </div>
            </div>

            <div class="ai-flow-stage ai-flow-output">
                <div class="ai-output-stack">
                    <div class="ai-output-card output-one">
                        <strong>Summary</strong>
                        <span>Key points ready</span>
                    </div>
                    <div class="ai-output-card output-two">
                        <strong>Answers</strong>
                        <span>Grounded in document</span>
                    </div>
                    <div class="ai-output-card output-three">
                        <strong>Data table</strong>
                        <span>Rows extracted</span>
                    </div>
                    <div class="ai-output-card output-four">
                        <strong>Risks</strong>
                        <span>Clauses flagged</span>
                    </div>
                    <div class="ai-output-card output-five">
                        <strong>Rewritten text</strong>
                        <span>Cleaner draft</span>
                    </div>
                </div>
                <div class="ai-flow-label">Useful output</div>
            </div>
        </div>
    </section>

    <section class="ai-hub-section" id="ai-workflows">
        <div class="ai-hub-section-header">
            <span class="ai-hub-eyebrow">AI workflows</span>
            <h2>What do you want AI to do with your document?</h2>
            <p>Start with the outcome you need and jump into the right document workflow.</p>
        </div>

        <div class="ai-hub-grid">
            <a href="/chat-with-pdf" class="ai-hub-card">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Ask questions</div>
                    <div class="ai-hub-desc">Chat with your PDF and get answers grounded in the document.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>

            <a href="/ai-summarizer" class="ai-hub-card">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="8" y1="6" x2="21" y2="6" />
                        <line x1="8" y1="12" x2="21" y2="12" />
                        <line x1="8" y1="18" x2="15" y2="18" />
                        <path d="M3 6l1 1 2-3" />
                        <path d="M3 12l1 1 2-3" />
                        <path d="M3 18l1 1 2-3" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Summarize long PDFs</div>
                    <div class="ai-hub-desc">Turn dense documents into concise summaries and key takeaways.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>

            <a href="/extract-invoice-data" class="ai-hub-card ai-hub-featured">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <path d="M3 9h18" />
                        <path d="M9 21V9" />
                        <path d="M15 14h3" />
                        <path d="M15 17h2" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Extract invoice data</div>
                    <div class="ai-hub-desc">Read invoices and export structured fields and line items to Excel.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>

            <a href="/review-contract" class="ai-hub-card">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14,2 14,8 20,8" />
                        <path d="M9 13h6M9 17h4" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Review contract risks</div>
                    <div class="ai-hub-desc">Flag risky clauses, key dates, obligations, and missing terms.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>

            <a href="/ai-rewrite" class="ai-hub-card">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 20h9" />
                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Rewrite document text</div>
                    <div class="ai-hub-desc">Simplify, formalize, shorten, or rewrite selected document text.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>

            <a href="/ai-questions" class="ai-hub-card">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Generate study questions</div>
                    <div class="ai-hub-desc">Create quiz questions, study prompts, and review material from a PDF.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>

            <a href="/translate-pdf" class="ai-hub-card">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 0 1 6.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Translate a PDF</div>
                    <div class="ai-hub-desc">Translate documents into 50+ languages with a simple workflow.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>

            <a href="/compare-pdf" class="ai-hub-card">
                <div class="ai-hub-icon-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h4" />
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                        <line x1="12" y1="3" x2="12" y2="21" />
                        <line x1="6" y1="9" x2="9" y2="9" />
                        <line x1="15" y1="9" x2="18" y2="9" />
                    </svg>
                </div>
                <div class="ai-hub-content">
                    <div class="ai-hub-name">Compare two PDFs</div>
                    <div class="ai-hub-desc">Find document differences and review changes between versions.</div>
                </div>
                <div class="ai-hub-footer"><span>Open workflow</span><span class="ai-hub-arrow">→</span></div>
            </a>
        </div>
    </section>

    <section class="ai-hub-privacy">
        <div>
            <span class="ai-hub-eyebrow">Privacy</span>
            <h2>Built for private document work</h2>
            <p>Use AI workflows with clear boundaries around files, processing, and usage.</p>
        </div>
        <div class="ai-hub-privacy-grid">
            <div><strong>Secure upload</strong><span>Protected document transfer</span></div>
            <div><strong>Auto-delete after 1 hour</strong><span>Files do not linger</span></div>
            <div><strong>No permanent storage</strong><span>Documents are not kept</span></div>
            <div><strong>Clear AI usage limits</strong><span>Free uses and Pro limits are visible</span></div>
        </div>
    </section>

    <section class="ai-hub-final-cta">
        <h2>Start with an AI workflow</h2>
        <p>Choose what you want to do with your PDF and let the assistant handle the heavy reading.</p>
        <div class="ai-hub-hero-actions">
            <a href="#ai-workflows" class="ai-hub-primary-cta">Start with an AI workflow</a>
            <a href="/pricing" class="ai-hub-secondary-cta">View pricing</a>
        </div>
    </section>
</main>
