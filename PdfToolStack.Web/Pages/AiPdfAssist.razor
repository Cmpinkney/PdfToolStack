@page "/ai-pdf-assist"
@inject NavigationManager Navigation

<PageTitle>AI PDF Tools — Summarize, Chat, Extract Data | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="AI-powered PDF tools. Summarize documents, chat with your PDF,
                   extract invoice data, and generate questions — all with AI." />
    <meta name="keywords" content="ai pdf tools, pdf ai assistant, document ai, intelligent pdf processing" />
    <link rel="canonical" href="https://pdftoolstack.com/ai-pdf-assist" />
</HeadContent>

<div class="tool-page">
    <div class="tool-hero">
        <h1>AI PDF Tools</h1>
        <p>Everything you need to work smarter with documents. Powered by Claude AI.</p>
    </div>

    <div class="ai-hub-grid">

        <div class="ai-hub-card" @onclick='() => Navigation.NavigateTo("/ai-summarizer")'>
            <div class="ai-hub-icon">✨</div>
            <div class="ai-hub-name">AI Summarizer</div>
            <div class="ai-hub-desc">Get concise summaries of long documents. Key points in seconds.</div>
            <span class="ai-hub-badge">Pro</span>
        </div>

        <div class="ai-hub-card" @onclick='() => Navigation.NavigateTo("/chat-with-pdf")'>
            <div class="ai-hub-icon">💬</div>
            <div class="ai-hub-name">Chat with PDF</div>
            <div class="ai-hub-desc">Ask your document anything. Get instant answers based on its content.</div>
            <span class="ai-hub-badge">Pro</span>
        </div>

        <div class="ai-hub-card" @onclick='() => Navigation.NavigateTo("/extract-invoice-data")'>
            <div class="ai-hub-icon">📊</div>
            <div class="ai-hub-name">Data Extractor</div>
            <div class="ai-hub-desc">Extract invoice data, contract fields, and form values to Excel automatically.</div>
            <span class="ai-hub-badge">Pro</span>
        </div>

        <div class="ai-hub-card" @onclick='() => Navigation.NavigateTo("/ai-questions")'>
            <div class="ai-hub-icon">📝</div>
            <div class="ai-hub-name">Questions Generator</div>
            <div class="ai-hub-desc">Generate quiz questions and study guides from any PDF document.</div>
            <span class="ai-hub-badge">Pro</span>
        </div>

    </div>
</div>