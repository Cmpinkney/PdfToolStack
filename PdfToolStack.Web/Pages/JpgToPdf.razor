@page "/jpg-to-pdf"
@inject ApiService ApiService
@inject CloudPickerService CloudPicker
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage
@using PdfToolStack.Web.Components
@using static PdfToolStack.Web.Components.FileUpload

<PageTitle>JPG to PDF Converter Free Online — Images to PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert JPG, PNG, BMP, GIF and TIFF images to PDF
                   free online. No signup required." />
    <meta name="keywords"
          content="jpg to pdf, image to pdf, png to pdf,
                   convert images to pdf free, convert jpg to pdf, png to pdf online free" />
    <link rel="canonical"
          href="https://pdftoolstack.com/jpg-to-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <section class="tool-hero">
            <div class="trust-row">
                <span>Multi-image PDF</span>
                <span>Full quality</span>
                <span>Deleted in 1 hour</span>
            </div>
            <h1>Convert JPG to PDF <span class="hero-gradient-text">instantly</span></h1>
            <p>Combine JPG, PNG, and other images into one clean PDF for sharing or storage.</p>
        </section>

        <div class="stepper" aria-label="JPG to PDF workflow progress">
            <div class="step @(UploadedFiles.Any() || CurrentState != PageState.Upload ? "complete" : "active")">Upload</div>
            <div class="step @(UploadedFiles.Any() && CurrentState == PageState.Upload ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">Configure</div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">Process</div>
            <div class="step @(CurrentState == PageState.Complete ? "complete active" : "")">Download</div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Image upload</span>
                        <h2>Build your image queue</h2>
                        <p>Add up to 20 images. Each image becomes a page in the PDF.</p>
                    </div>

                    <div class="merge-upload-area">
                        @for (int i = 0;
                            i < UploadedFiles.Count; i++)
                        {
                            var idx = i;
                            <div class="merge-file-item">
                                <span class="merge-file-number">
                                    @(idx + 1)
                                </span>
                                <span class="merge-file-name">
                                    @UploadedFiles[idx].Name
                                </span>
                                <span class="merge-file-size">
                                    @FormatSize(
                                        UploadedFileBytes[idx].Length)
                                </span>
                                <button class="remove-button"
                                        @onclick="() =>
                                            RemoveFile(idx)">
                                    x
                                </button>
                            </div>
                        }

                        @if (UploadedFiles.Count < 20)
                        {
                            <div class="upload-container">
                                <span class="upload-icon">IMG</span>
                                <p>
                                    @(UploadedFiles.Count == 0
                                        ? "Upload your images"
                                        : "Add another image")
                                </p>
                                <label class="upload-button">
                                    Browse Images
                                    <InputFile
                                        OnChange="HandleFileSelected"
                                        accept=".jpg,.jpeg,.png,.bmp,.gif,.tiff,.tif,.webp"
                                        style="display:none" />
                                </label>
                                <p class="upload-hint">
                                    Supports JPG, PNG, BMP, GIF,
                                    TIFF - up to 20 images
                                </p>
                                <div class="cloud-picker-row">
                                    <span class="cloud-picker-label">OR IMPORT FROM</span>
                                    <div class="cloud-picker-buttons">
                                        <button class="cloud-picker-btn" @onclick="PickGoogleDrive" disabled="@_cloudLoading">
                                            <svg width="16" height="16" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg"><path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da" /><path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44a9.06 9.06 0 0 0 -1.2 4.5h27.5z" fill="#00ac47" /><path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.502l5.852 11.5z" fill="#ea4335" /><path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d" /><path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc" /><path d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 28h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00" /></svg>
                                            Google Drive
                                        </button>
                                        <button class="cloud-picker-btn" @onclick="PickDropbox" disabled="@_cloudLoading">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#0061FF"><path d="M6 2L0 6l6 4-6 4 6 4 6-4-6-4 6-4L6 2zm12 0l-6 4 6 4-6 4 6 4 6-4-6-4 6-4-6-4zm-6 13l-6 4 6 4 6-4-6-4z" /></svg>
                                            Dropbox
                                        </button>
                                    </div>
                                </div>
                                @if (_cloudLoading)
                                {
                                    <p class="cloud-loading-hint">Downloading from cloud...</p>
                                }
                                @if (!string.IsNullOrEmpty(_cloudError))
                                {
                                    <p class="error-message">@_cloudError</p>
                                }
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <p class="error-message">@ErrorMessage</p>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade
                        FileSizeBytes="@_largeFileSize"
                        FileName="@_largeFileName"
                        ToolType="JpgToPdf"
                        OnCancel="Reset" />
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container">
                        <div class="spinner"></div>
                        <h2>Creating your image PDF</h2>
                        <p>Ordering images... adding pages... preparing your download...</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete
                     && ResultBytes != null)
                {
                    <AdSlot Size="rectangle" />
                    <div class="result-container">
                        <span class="result-icon">Done</span>
                        <h2>Your image PDF is ready</h2>
                        <p>
                            @UploadedFiles.Count image(s) have
                            been converted to PDF successfully.
                        </p>
                        <button class="download-button"
                                @onclick="DownloadFile">
                            Download PDF
                        </button>
                        <button class="reset-button"
                                @onclick="Reset">
                            Convert More Images
                        </button>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container">
                        <span class="error-icon">Issue</span>
                        <h2>We could not create this PDF</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button"
                                @onclick="Reset">
                            Try Again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Image PDF settings</span>
                    <h2>Build one PDF</h2>
                    <p>Every uploaded image becomes a page in the final PDF.</p>
                </div>

                <div class="estimate-card">
                    <span>Images queued</span>
                    <strong>@UploadedFiles.Count / 20</strong>
                    <small>Images are added in the order shown.</small>
                </div>

                <div class="value-list">
                    <div><strong>Multi-image output</strong><span>Combine several images into one PDF.</span></div>
                    <div><strong>Quality retained</strong><span>Images are embedded at full quality.</span></div>
                    <div><strong>Cloud imports</strong><span>Use existing Google Drive and Dropbox options.</span></div>
                </div>

                @if (UploadedFiles.Count >= 1 && CurrentState == PageState.Upload)
                {
                    <button class="process-button"
                            @onclick="ProcessFiles">
                        Convert @UploadedFiles.Count
                        Image(s) to PDF
                    </button>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>
                        Add images to continue
                    </button>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What image formats are supported?</h3>
            <p>We support JPG, PNG, BMP, GIF, TIFF,
               and WebP image formats.</p>
        </div>
        <div class="faq-item">
            <h3>How many images can I convert at once?</h3>
            <p>You can convert up to 20 images at once.
               Each image becomes one page in the PDF.</p>
        </div>
        <div class="faq-item">
            <h3>Will image quality be preserved?</h3>
            <p>Yes — images are embedded at full quality
               in the PDF without compression.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free with no signup
               required.</p>
        </div>
    </div>
</div>

<style>
    .tool-page { width: 100%; min-height: calc(100vh - 72px); padding: 48px 0 72px; background: radial-gradient(circle at top left, rgba(109,40,217,.12), transparent 32%), linear-gradient(135deg, #f8f7ff 0%, #eef5ff 100%); }
    .tool-container { width: min(1320px, calc(100% - 64px)); max-width: 1320px; margin: 0 auto; }
    .tool-hero { width: 100%; max-width: none; margin-bottom: 24px; text-align: left; }
    .tool-hero h1 { max-width: 900px; margin: 0 0 14px; color: #111827; font-size: clamp(2.4rem, 3vw, 3.8rem); line-height: 1.02; letter-spacing: -0.04em; }
    .tool-hero p { max-width: 760px; margin: 0; color: #526173; font-size: 1rem; line-height: 1.7; }
    .hero-gradient-text { background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .trust-row { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 18px; }
    .trust-row span { border: 1px solid rgba(37,99,235,.16); border-radius: 999px; background: rgba(255,255,255,.76); color: #334155; font-size: .83rem; font-weight: 800; padding: .48rem .78rem; box-shadow: 0 10px 30px rgba(15,23,42,.06); }
    .stepper { width: 100%; max-width: none; margin: 0 0 24px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 8px; border-radius: 999px; background: rgba(255,255,255,.8); box-shadow: 0 18px 45px rgba(15,23,42,.08); }
    .step { min-height: 44px; display: flex; align-items: center; justify-content: center; border-radius: 999px; color: #64748b; font-size: .9rem; font-weight: 900; }
    .step.active { background: linear-gradient(135deg, #6d5dfc, #2563eb); color: #fff; box-shadow: 0 12px 26px rgba(37,99,235,.24); }
    .step.complete { background: #eef2ff; color: #3730a3; }
