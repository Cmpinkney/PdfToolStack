@page "/jpg-to-pdf"
@inject ApiService ApiService
@inject CloudPickerService CloudPicker
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage
@using PdfToolStack.Web.Components
@using static PdfToolStack.Web.Components.FileUpload

<PageTitle>JPG to PDF Converter Free Online — Images to PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert JPG, PNG, BMP, GIF and TIFF images to PDF
                   free online. No signup required." />
    <meta name="keywords"
          content="jpg to pdf, image to pdf, png to pdf,
                   convert images to pdf free, convert jpg to pdf, png to pdf online free" />
    <link rel="canonical"
          href="https://pdftoolstack.com/jpg-to-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <h1>JPG to PDF Converter</h1>
        <p class="tool-subtitle">
            Convert JPG, PNG, BMP, GIF, and TIFF images
            to PDF for free. Add multiple images at once.
            No signup required.
        </p>

        @if (CurrentState == PageState.Upload)
        {
            <div class="merge-upload-area">
                @for (int i = 0;
                    i < UploadedFiles.Count; i++)
                {
                    var idx = i;
                    <div class="merge-file-item">
                        <span class="merge-file-number">
                            @(idx + 1)
                        </span>
                        <span class="merge-file-name">
                            @UploadedFiles[idx].Name
                        </span>
                        <span class="merge-file-size">
                            @FormatSize(
                                UploadedFileBytes[idx].Length)
                        </span>
                        <button class="remove-button"
                                @onclick="() => 
                                    RemoveFile(idx)">
                            ✕
                        </button>
                    </div>
                }

                @if (UploadedFiles.Count < 20)
                {
                    <div class="upload-container">
                        <span class="upload-icon">🖼️</span>
                        <p>
                            @(UploadedFiles.Count == 0
                                ? "Upload your images"
                                : "Add another image")
                        </p>
                        <label class="upload-button">
                            Browse Images
                            <InputFile
                                OnChange="HandleFileSelected"
                                accept=".jpg,.jpeg,.png,.bmp,.gif,.tiff,.tif,.webp"
                                style="display:none" />
                        </label>
                        <p class="upload-hint">
                            Supports JPG, PNG, BMP, GIF,
                            TIFF — up to 20 images
                        </p>
                <div class="cloud-picker-row">
                    <span class="cloud-picker-label">OR IMPORT FROM</span>
                    <div class="cloud-picker-buttons">
                        <button class="cloud-picker-btn" @onclick="PickGoogleDrive" disabled="@_cloudLoading">
                            <svg width="16" height="16" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg"><path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da" /><path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44a9.06 9.06 0 0 0 -1.2 4.5h27.5z" fill="#00ac47" /><path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.502l5.852 11.5z" fill="#ea4335" /><path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d" /><path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc" /><path d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 28h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00" /></svg>
                            Google Drive
                        </button>
                        <button class="cloud-picker-btn" @onclick="PickDropbox" disabled="@_cloudLoading">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#0061FF"><path d="M6 2L0 6l6 4-6 4 6 4 6-4-6-4 6-4L6 2zm12 0l-6 4 6 4-6 4 6 4 6-4-6-4 6-4-6-4zm-6 13l-6 4 6 4 6-4-6-4z" /></svg>
                            Dropbox
                        </button>
                    </div>
                </div>
                @if (_cloudLoading)
                    {
                        <p class="cloud-loading-hint">⏳ Downloading from cloud...</p>
                    }
                    @if (!string.IsNullOrEmpty(_cloudError))
                    {
                        <p class="error-message">@_cloudError</p>
                    }
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="error-message">@ErrorMessage</p>
            }

            @if (UploadedFiles.Count >= 1)
            {
                <button class="process-button"
                        @onclick="ProcessFiles">
                    Convert @UploadedFiles.Count
                    Image(s) to PDF
                </button>
            }
        }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade
                FileSizeBytes="@_largeFileSize"
                FileName="@_largeFileName"
                ToolType="JpgToPdf"
                OnCancel="Reset" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Converting images to PDF...</p>
            </div>
        }

        @if (CurrentState == PageState.Complete
             && ResultBytes != null)
        {
            <AdSlot Size="rectangle" />
            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>Conversion Complete!</h2>
                <p style="color: var(--gray);
                           margin-bottom: 1.5rem;">
                    @UploadedFiles.Count image(s) have
                    been converted to PDF successfully.
                </p>
                <button class="download-button"
                        @onclick="DownloadFile">
                    Download PDF
                </button>
                <button class="reset-button"
                        @onclick="Reset">
                    Convert More Images
                </button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button"
                        @onclick="Reset">
                    Try Again
                </button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What image formats are supported?</h3>
            <p>We support JPG, PNG, BMP, GIF, TIFF,
               and WebP image formats.</p>
        </div>
        <div class="faq-item">
            <h3>How many images can I convert at once?</h3>
            <p>You can convert up to 20 images at once.
               Each image becomes one page in the PDF.</p>
        </div>
        <div class="faq-item">
            <h3>Will image quality be preserved?</h3>
            <p>Yes — images are embedded at full quality
               in the PDF without compression.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free with no signup
               required.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private List<IBrowserFile> UploadedFiles = new();
    private List<byte[]> UploadedFileBytes = new();
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private long _largeFileSize = 0;
    private string _largeFileName = string.Empty;
    private bool _cloudLoading = false;
    private string _cloudError = string.Empty;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(
    InputFileChangeEventArgs e)
    {
        ErrorMessage = null;
        var file = e.File;

        var validation = Validator.ValidateImageFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }

        if (PaymentService.IsFileTooLargeForFree(file.Size))
        {
            _largeFileSize = file.Size;
            _largeFileName = file.Name;
            CurrentState = PageState.LargeFile;
            StateHasChanged();
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 52428800);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedFiles.Add(file);
            UploadedFileBytes.Add(ms.ToArray());
            Toast.ShowSuccess($"Added {file.Name}");
        }
        catch (Exception ex)
        {
            Toast.ShowError(
                $"Could not read {file.Name}: {ex.Message}");
        }
        StateHasChanged();
    }


    private void RemoveFile(int index)
    {
        UploadedFiles.RemoveAt(index);
        UploadedFileBytes.RemoveAt(index);
        StateHasChanged();
    }

    private async Task ProcessFiles()
    {
        if (!UploadedFileBytes.Any()) return;

        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            var fileNames = UploadedFiles
                .Select(f => f.Name).ToList();

            ResultBytes = await ApiService.JpgToPdfAsync(
                UploadedFileBytes, fileNames);

            CurrentState = ResultBytes != null
                ? PageState.Complete : PageState.Error;

            if (ResultBytes == null)
                ErrorMessage =
                    "Conversion failed. Please try again.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task PickGoogleDrive()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenGoogleDriveAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Google Drive: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task PickDropbox()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenDropboxAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Dropbox: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task LoadCloudFile(string name, string url, string? accessToken)
    {
        var bytes = await CloudPicker.DownloadFileAsync(url, accessToken);
        if (bytes is null || bytes.Length == 0) { _cloudError = "Could not download file. Please try again."; return; }
        // For JpgToPdf — add to the image list
        UploadedFileBytes.Add(bytes);
        UploadedFiles.Add(new CloudBrowserFile(name, bytes));
        Toast.ShowSuccess($"Added {name}");
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        await JS.InvokeVoidAsync("downloadFile",
            "images.pdf",
            Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        UploadedFiles.Clear();
        UploadedFileBytes.Clear();
        ResultBytes = null;
        ErrorMessage = null;
        _largeFileSize = 0;
        _largeFileName = string.Empty;
    }

    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024)
            return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024)} MB";
    }
}
