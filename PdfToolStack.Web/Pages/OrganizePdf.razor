@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private class PageModel
    {
        public int OriginalPage { get; set; }
        public int Rotation { get; set; } = 0;
        public bool IsDeleted { get; set; } = false;
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private List<PageModel> Pages = new();

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private string GetTileClass(bool isDeleted) =>
        isDeleted ? "organize-tile organize-tile-deleted"
                  : "organize-tile";

    private string GetDeleteLabel(bool isDeleted) =>
        isDeleted ? "↩" : "✕";

    private int DeletedPageCount => Pages.Count(p => p.IsDeleted);

    private int RotatedPageCount => Pages.Count(p => p.Rotation != 0);

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        Pages.Clear();
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }
        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesVal = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid)
            {
                Toast.ShowError(bytesVal.Message!);
                UploadedBytes = null;
                return;
            }
            if (bytesVal.IsWarning)
                Toast.ShowWarning(bytesVal.Message!);

            if (PaymentService.IsFileTooLargeForFree(file.Size))
            {
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            var pageCount = await ApiService.GetPageCountAsync(
                UploadedBytes, file.Name);

            var pageVal = Validator.ValidatePageCount(pageCount);
            if (pageVal.IsWarning)
                Toast.ShowWarning(pageVal.Message!);

            Pages = Enumerable.Range(1, pageCount)
                .Select(p => new PageModel { OriginalPage = p })
                .ToList();

            SelectedFile = file;
            Toast.ShowSuccess(
                $"PDF loaded — {pageCount} pages");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        Pages.Clear();
    }

    private void MoveLeft(int index)
    {
        if (index <= 0) return;
        (Pages[index], Pages[index - 1]) =
            (Pages[index - 1], Pages[index]);
        StateHasChanged();
    }

    private void MoveRight(int index)
    {
        if (index >= Pages.Count - 1) return;
        (Pages[index], Pages[index + 1]) =
            (Pages[index + 1], Pages[index]);
        StateHasChanged();
    }

    private void RotatePage(int index)
    {
        Pages[index].Rotation =
            (Pages[index].Rotation + 90) % 360;
        StateHasChanged();
    }

    private void ToggleDelete(int index)
    {
        Pages[index].IsDeleted = !Pages[index].IsDeleted;
        StateHasChanged();
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null) return;

        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            var operations = new List<object>();
            var order = 0;

            foreach (var page in Pages)
            {
                if (page.IsDeleted)
                {
                    operations.Add(new
                    {
                        order = order++,
                        type = "delete",
                        pageNumber = page.OriginalPage,
                        targetIndex = 0,
                        rotationDegrees = 0
                    });
                }
                else if (page.Rotation != 0)
                {
                    operations.Add(new
                    {
                        order = order++,
                        type = "rotate",
                        pageNumber = page.OriginalPage,
                        targetIndex = 0,
                        rotationDegrees = page.Rotation
                    });
                }
            }

            var newOrder = Pages
                .Where(p => !p.IsDeleted)
                .Select((p, i) => new
                {
                    order = order++,
                    type = "move",
                    pageNumber = p.OriginalPage,
                    targetIndex = i,
                    rotationDegrees = 0
                }).ToList();

            operations.AddRange(newOrder.Cast<object>());

            ResultBytes = await ApiService.OrganizePdfAsync(
                UploadedBytes, SelectedFile!.Name, operations);

            CurrentState = ResultBytes != null
                ? PageState.Complete
                : PageState.Error;

            if (ResultBytes == null)
                ErrorMessage = "Failed to organize PDF. Please try again.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "document") + "_organized.pdf";
        await JS.InvokeVoidAsync("downloadFile",
            fileName, Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        Pages.Clear();
    }
}
