@page "/organize-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Organize PDF Free Online — Rearrange and Rotate Pages</PageTitle>

<HeadContent>
    <meta name="description"
          content="Organize your PDF pages free online.
                   Rearrange, rotate, and delete pages easily.
                   No signup required." />
    <meta name="keywords"
          content="organize pdf, rearrange pdf pages,
                   rotate pdf pages, rearrange pdf, reorder pdf free, pdf page organizer" />
    <link rel="canonical"
          href="https://pdftoolstack.com/organize-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <section class="tool-hero">
            <div>
                <div class="trust-row">
                    <span>Secure processing</span>
                    <span>Page controls</span>
                    <span>Deleted in 1 hour</span>
                </div>

                <h1>Organize PDF pages <span class="hero-gradient-text">visually</span></h1>
                <p class="tool-subtitle">
                    Rearrange, rotate, and remove pages before creating a clean,
                    reordered PDF.
                </p>
            </div>
        </section>

        <div class="stepper" aria-label="Organize PDF workflow progress">
            <div class="step @(CurrentState == PageState.Upload && SelectedFile == null ? "active" : SelectedFile != null || CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>1</span>
                <strong>Upload</strong>
            </div>
            <div class="step @(CurrentState == PageState.Upload && SelectedFile != null ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>2</span>
                <strong>Arrange</strong>
            </div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">
                <span>3</span>
                <strong>Process</strong>
            </div>
            <div class="step @(CurrentState == PageState.Complete ? "active complete" : "")">
                <span>4</span>
                <strong>Download</strong>
            </div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Upload PDF</span>
                        <h2>Start with your source file</h2>
                        <p>Load a PDF, then use the page tiles to move, rotate, or remove pages.</p>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved"
                                HintText="Upload a PDF — page controls appear after loading" />

                    @if (SelectedFile != null && Pages.Any())
                    {
                        <div class="file-ready-card">
                            <div class="file-ready-header">
                                <div class="file-ready-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z" />
                                        <polyline points="14 2 14 7 19 7" />
                                        <polyline points="9 14 11 16 15 12" />
                                    </svg>
                                </div>
                                <div>
                                    <span class="panel-eyebrow">Ready to arrange</span>
                                    <strong>@SelectedFile.Name</strong>
                                    <div class="file-ready-meta">
                                        <span>PDF</span>
                                        <span>@Validator.FormatSize(SelectedFile.Size)</span>
                                    </div>
                                    <small>@Pages.Count pages loaded</small>
                                </div>
                            </div>
                            <div class="ready-metrics">
                                <span>Move pages</span>
                                <span>Rotate pages</span>
                                <span>Remove pages</span>
                            </div>
                        </div>

                        <div class="organize-container">
                            <div class="organize-header">
                                <span class="panel-eyebrow">Arrange pages</span>
                                <h3>Use page controls to set the final order</h3>
                                <p>Move pages left or right, rotate individual pages, or mark pages for removal.</p>
                            </div>
                            <div class="organize-grid">
                                @for (int i = 0; i < Pages.Count; i++)
                                {
                                    var idx = i;
                                    var pg = Pages[idx];
                                    <div class="@GetTileClass(pg.IsDeleted)">
                                        <div class="organize-page-num">
                                            @pg.OriginalPage
                                        </div>
                                        <div class="organize-actions">
                                            <button class="org-btn"
                                                    title="Move left"
                                                    disabled="@(idx == 0 || pg.IsDeleted)"
                                                    @onclick="() => MoveLeft(idx)">
                                                ←
                                            </button>
                                            <button class="org-btn"
                                                    title="Rotate"
                                                    disabled="@pg.IsDeleted"
                                                    @onclick="() => RotatePage(idx)">
                                                ↻
                                            </button>
                                            <button class="org-btn org-btn-delete"
                                                    title="Delete"
                                                    @onclick="() => ToggleDelete(idx)">
                                                @GetDeleteLabel(pg.IsDeleted)
                                            </button>
                                            <button class="org-btn"
                                                    title="Move right"
                                                    disabled="@(idx == Pages.Count - 1 || pg.IsDeleted)"
                                                    @onclick="() => MoveRight(idx)">
                                                →
                                            </button>
                                        </div>
                                        @if (pg.Rotation != 0)
                                        {
                                            <span class="rotation-badge">@pg.Rotation°</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-kicker">Page organizer</span>
                            <strong>Upload a PDF to preview the page controls.</strong>
                            <span>Your arrange workspace appears once the document is ready.</span>
                        </div>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade
                        FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                        FileName="@(SelectedFile?.Name ?? "")"
                        ToolType="OrganizePdf"
                        OnCancel="Reset" />
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container" role="status">
                        <div class="spinner"></div>
                        <h2>Organizing your PDF</h2>
                        <p>Applying page order, rotations, removals, and preparing your download.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete && ResultBytes != null)
                {
                    <AdSlot Size="rectangle" />
                    <div class="result-container">
                        <span class="result-icon" aria-hidden="true">Ready</span>
                        <h2>Your organized PDF is ready</h2>
                        <p class="result-copy">
                            Your PDF pages have been reorganized successfully.
                        </p>
                        <button class="download-button" @onclick="DownloadFile">
                            Download PDF
                        </button>
                        <button class="reset-button" @onclick="Reset">
                            Organize Another PDF
                        </button>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container" role="alert">
                        <span class="error-icon" aria-hidden="true">Organize failed</span>
                        <h2>We could not apply the page changes</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button" @onclick="Reset">Try Again</button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Page workflow</span>
                    <h2>Finalize page changes</h2>
                    <p>Review the current page count, removal count, and output before applying changes.</p>
                </div>

                @if (SelectedFile != null)
                {
                    <div class="file-summary">
                        <span class="file-name">@SelectedFile.Name</span>
                        <span class="file-size">@Validator.FormatSize(SelectedFile.Size)</span>
                    </div>
                }

                <div class="option-list">
                    <span><strong>Reorder pages</strong><small>Use arrows on each tile to move pages into position.</small></span>
                    <span><strong>Rotate pages</strong><small>Rotate individual pages before generating the final PDF.</small></span>
                    <span><strong>Remove pages</strong><small>Mark pages for deletion while keeping the original upload unchanged.</small></span>
                </div>

                @if (CurrentState == PageState.Upload && SelectedFile != null && Pages.Any())
                {
                    <div class="organize-summary">
                        <span>
                            <strong>@Pages.Count</strong>
                            <small>Total pages</small>
                        </span>
                        <span>
                            <strong>@DeletedPageCount</strong>
                            <small>Marked for removal</small>
                        </span>
                        <span>
                            <strong>@RotatedPageCount</strong>
                            <small>Rotated</small>
                        </span>
                    </div>

                    <button class="process-button" @onclick="ProcessFile">
                        Apply Changes
                    </button>
                    <div class="secure-note">
                        Secure processing. Files are deleted within 1 hour.
                    </div>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>
                        Apply Changes
                    </button>
                    <p class="action-hint">Upload a PDF to enable page organization.</p>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>Can I reorder pages in my PDF?</h3>
            <p>Yes — use the arrow buttons to move pages
               left or right into your desired order.</p>
        </div>
        <div class="faq-item">
            <h3>Can I rotate individual pages?</h3>
            <p>Yes — click the rotate button on any page
               to rotate it 90 degrees clockwise.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no
               signup required.</p>
        </div>
    </div>
</div>

<style>
