@page "/redact-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@implements IDisposable
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Redact PDF Online — Permanently Remove Sensitive Information</PageTitle>
<HeadContent>
    <meta name="description" content="Permanently redact sensitive information from PDF files. Remove SSNs, addresses, financial data, and confidential text. True redaction — content cannot be recovered. Free, secure, no signup." />
    <meta name="keywords" content="redact pdf, pdf redaction, remove sensitive information pdf, black out pdf text, permanently remove pdf content" />
    <link rel="canonical" href="https://pdftoolstack.com/redact-pdf" />
</HeadContent>

<div class="rp-page">
    <section class="rp-shell">
        <div class="rp-hero">
            <div>
                <span class="rp-eyebrow">PDF workspace</span>
                <h1 class="rp-title">Redact PDF <span class="hero-gradient-text">securely</span></h1>
                <p class="rp-subtitle">Permanently remove sensitive content with precise redaction overlays, page review, and secure processing.</p>
            </div>
            <div class="rp-trust-row" aria-label="Privacy and security">
                <span class="rp-trust-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                    Secure upload
                </span>
                <span class="rp-trust-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /></svg>
                    Auto-delete
                </span>
                <span class="rp-trust-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                    Private processing
                </span>
            </div>
        </div>

        <div class="rp-stepper" aria-label="Progress">
            <div class="rp-step @(CurrentState == PageState.Upload || CurrentState == PageState.LargeFile ? "rp-step--active" : "rp-step--done")"><span>1</span>Upload</div>
            <div class="rp-step @(CurrentState == PageState.Redact ? "rp-step--active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete || CurrentState == PageState.Error ? "rp-step--done" : "")"><span>2</span>Configure</div>
            <div class="rp-step @(CurrentState == PageState.Processing ? "rp-step--active" : CurrentState == PageState.Complete || CurrentState == PageState.Error ? "rp-step--done" : "")"><span>3</span>Process</div>
            <div class="rp-step @(CurrentState == PageState.Complete ? "rp-step--active" : "")"><span>4</span>Download</div>
        </div>
    </section>

    <AdPlaceholder ShowAds="ShowAdsForCurrentUser" />

    <!-- ── UPLOAD STATE ──────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Upload || CurrentState == PageState.LargeFile)
    {
        <div class="rp-upload-hero">
            <div class="rp-upload-header">
                <div class="rp-tool-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                    True Redaction
                </div>
                <h2 class="rp-upload-title">Upload your document</h2>
                <p class="rp-upload-sub">Mark sensitive areas, review every overlay, then create a permanently redacted copy.</p>
                <div class="rp-trust-chips">
                    <span class="rp-chip rp-chip--red">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        True redaction — permanently removed
                    </span>
                    <span class="rp-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                        Files deleted in 1 hour
                    </span>
                    <span class="rp-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                        Legal & compliance ready
                    </span>
                </div>
            </div>

            @if (CurrentState == PageState.LargeFile)
            {
                <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)" FileName="@(SelectedFile?.Name ?? "")" ToolType="RedactPdf" OnCancel="Reset" />
            }
            else
            {
                <div class="rp-upload-zone">
                    <FileUpload OnFileSelected="HandleFileSelected" OnFileRemoved="HandleFileRemoved" />
                    @if (SelectedFile != null)
                    {
                        <button class="rp-load-btn" @onclick="LoadPdf">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                            Open Redaction Editor
                        </button>
                    }
                </div>

                <div class="rp-how-it-works">
                    @foreach (var (num, title, desc) in new[] {
                        ("1", "Upload PDF", "Drag & drop or click to upload your document"),
                        ("2", "Mark areas", "Draw boxes over content to redact, or use AI auto-detect"),
                        ("3", "Apply & download", "Permanently redacted PDF ready instantly")
                        })
                    {
                        <div class="rp-step">
                            <span class="rp-step-num">@num</span>
                            <div>
                                <strong>@title</strong>
                                <p>@desc</p>
                            </div>
                        </div>
                    }
                </div>

                <aside class="rp-upload-inspector">
                    <div class="rp-panel-title">Security workflow</div>
                    <div class="rp-feature-list">
                        <div>
                            <strong>Permanent removal</strong>
                            <span>Redactions are burned into the output PDF, not placed as removable shapes.</span>
                        </div>
                        <div>
                            <strong>Review before apply</strong>
                            <span>Use before/after mode and page badges to confirm every marked area.</span>
                        </div>
                        <div>
                            <strong>Private processing</strong>
                            <span>Files are processed securely and automatically deleted after 1 hour.</span>
                        </div>
                    </div>
                </aside>
            }
        </div>
    }

    <!-- ── EDITOR STATE ──────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Redact)
    {
        <PdfLoadingOverlay IsVisible="@_isPdfLoading" Message="Loading PDF..." SubMessage="Preparing redaction canvas" />

        <div class="rp-editor @(_isPdfLoading ? "rp-editor--hidden" : "")">

            <!-- Top bar -->
            <div class="rp-editor-topbar">
                <div class="rp-editor-topbar-left">
                    <button class="rp-back-btn" @onclick="Reset">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                        Back
                    </button>
                    <span class="rp-filename">@(SelectedFile?.Name ?? "document.pdf")</span>
                </div>
                <div class="rp-editor-topbar-center">
                    <button class="rp-nav-btn" @onclick="PreviousPage" disabled="@(CurrentPage <= 1)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                    </button>
                    <span class="rp-page-label">Page <strong>@CurrentPage</strong> of @TotalPages</span>
                    <button class="rp-nav-btn" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
                    </button>
                </div>
                <div class="rp-editor-topbar-right">
                    @if (AllRegions.Any())
                    {
                        <span class="rp-regions-badge">@AllRegions.Count redaction@(AllRegions.Count == 1 ? "" : "s")</span>
                    }
                </div>
            </div>

            <!-- Editor body: sidebar + canvas + panel -->
            <div class="rp-editor-body">

                <!-- Page thumbnail sidebar -->
                <div class="rp-thumbnails">
                    <div class="rp-thumbnails-label">Pages</div>
                    @for (int p = 1; p <= TotalPages; p++)
                    {
                        var pageNum = p;
                        var pageRegions = AllRegions.Count(r => r.PageNumber == pageNum);
                        <div class="rp-thumb @(CurrentPage == pageNum ? "rp-thumb--active" : "")"
                             @onclick="() => GoToPage(pageNum)">
                            <div class="rp-thumb-inner">
                                <svg width="24" height="32" viewBox="0 0 24 32" fill="none">
                                    <rect x="1" y="1" width="22" height="30" rx="2" fill="var(--surface,#fff)" stroke="var(--border,#E5E7EB)" stroke-width="1.5" />
                                    <line x1="4" y1="7" x2="20" y2="7" stroke="var(--border,#D1D5DB)" stroke-width="1" />
                                    <line x1="4" y1="11" x2="20" y2="11" stroke="var(--border,#D1D5DB)" stroke-width="1" />
                                    <line x1="4" y1="15" x2="16" y2="15" stroke="var(--border,#D1D5DB)" stroke-width="1" />
                                    <line x1="4" y1="19" x2="20" y2="19" stroke="var(--border,#D1D5DB)" stroke-width="1" />
                                    <line x1="4" y1="23" x2="14" y2="23" stroke="var(--border,#D1D5DB)" stroke-width="1" />
                                </svg>
                                @if (pageRegions > 0)
                                {
                                    <span class="rp-thumb-badge">@pageRegions</span>
                                }
                            </div>
                            <span class="rp-thumb-num">@pageNum</span>
                        </div>
                    }
                </div>

                <!-- Canvas area -->
                <div class="rp-canvas-area">
                    <div class="rp-canvas-hint">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" /></svg>
                        Drag to draw redaction areas on the document
                    </div>
                    <div class="rp-canvas-wrap" style="position:relative;display:inline-block;">
                        <canvas id="pdfCanvas" style="display:block;max-width:100%;border-radius:8px;"></canvas>
                        <canvas id="redactCanvas" style="position:absolute;top:0;left:0;cursor:crosshair;"></canvas>
                    </div>
                </div>

                <!-- Right settings panel -->
                <div class="rp-panel">
                    <div class="rp-panel-section">
                        <div class="rp-panel-title">Redaction Tools</div>

                        <button class="rp-panel-btn rp-panel-btn--primary" @onclick="AddRedactionMode">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /></svg>
                            Add Redaction
                        </button>

                        <button class="rp-panel-btn rp-panel-btn--ai" @onclick="AutoDetectSensitiveData" disabled="@_aiDetecting">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10" /><path d="M12 6v6l4 2" /></svg>
                            @(_aiDetecting ? "Detecting..." : "Auto-Detect Sensitive Data")
                            <span class="rp-ai-badge">AI</span>
                        </button>

                        <div class="rp-divider"></div>

                        <button class="rp-panel-btn" @onclick="SearchAndRedact">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                            Search & Redact
                        </button>

                        <button class="rp-panel-btn" @onclick="TextRedactionMode">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z" /></svg>
                            Text Redaction
                        </button>
                    </div>

                    <div class="rp-divider"></div>

                    <div class="rp-panel-section">
                        <div class="rp-panel-title">Actions</div>
                        <div class="rp-action-row">
                            <button class="rp-action-btn" @onclick="UndoLast" disabled="@(!AllRegions.Any())">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4" /><path d="M20 20v-7a4 4 0 0 0-4-4H4" /></svg>
                                Undo
                                <span class="rp-kbd">Ctrl+Z</span>
                            </button>
                            <button class="rp-action-btn" @onclick="ClearCurrentPage" disabled="@(!CurrentPageRegions.Any())">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /></svg>
                                Clear Page
                            </button>
                        </div>
                        @if (AllRegions.Count > 0)
                        {
                            <button class="rp-action-btn rp-action-btn--remove" @onclick="ClearAll">
                                Remove All (@AllRegions.Count)
                            </button>
                        }
                    </div>

                    <div class="rp-divider"></div>

                    <div class="rp-panel-section">
                        <div class="rp-panel-title">Redaction Color</div>
                        <div class="rp-color-row">
                            @foreach (var c in RedactColors)
                            {
                                <button class="rp-color-swatch @(_selectedColor == c.Hex ? "rp-color-swatch--active" : "")"
                                        style="background:@c.Hex"
                                        title="@c.Name"
                                        @onclick="() => SelectColor(c.Hex)">
                                    @if (_selectedColor == c.Hex)
                                    {
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    }
                                </button>
                            }
                        </div>
                        <p class="rp-color-label">@(RedactColors.FirstOrDefault(c => c.Hex == _selectedColor)?.Name ?? "Black")</p>
                    </div>

                    <div class="rp-divider"></div>

                    <div class="rp-panel-section rp-confidence">
                        <div class="rp-panel-title">Confidence Check</div>
                        <div class="rp-confidence-grid">
                            <div>
                                <strong>@AllRegions.Count</strong>
                                <span>Total redactions</span>
                            </div>
                            <div>
                                <strong>@CurrentPageRegions.Count</strong>
                                <span>This page</span>
                            </div>
                            <div>
                                <strong>@AllRegions.Select(r => r.PageNumber).Distinct().Count()</strong>
                                <span>Pages marked</span>
                            </div>
                        </div>
                        <p class="rp-confidence-note">
                            Redactions are permanent after processing. Review every page before download.
                        </p>
                    </div>

                    <div class="rp-divider"></div>

                    <div class="rp-panel-tip">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                        <span>Drag to select an area or click the AI button to auto-detect sensitive data.</span>
                    </div>
                </div>

            </div>

            <!-- Bottom action bar -->
            <div class="rp-action-bar">
                <div class="rp-action-bar-left">
                    @if (AllRegions.Any())
                    {
                        <span class="rp-action-summary">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /></svg>
                            @AllRegions.Count redaction@(AllRegions.Count == 1 ? "" : "s") on @AllRegions.Select(r => r.PageNumber).Distinct().Count() page@(AllRegions.Select(r => r.PageNumber).Distinct().Count() == 1 ? "" : "s")
                        </span>
                    }
                    else
                    {
                        <span class="rp-action-summary rp-action-summary--empty">Draw boxes over content to redact</span>
                    }

                    <!-- Before/After toggle -->
                    <div class="rp-before-after">
                        <button class="rp-ba-btn @(!_showAfter ? "rp-ba-btn--active" : "")" @onclick='() => SetBeforeAfter(false)'>Before</button>
                        <button class="rp-ba-btn @(_showAfter ? "rp-ba-btn--active" : "")" @onclick='() => SetBeforeAfter(true)'>After</button>
                    </div>
                </div>

                <div class="rp-action-bar-right">
                    <label class="rp-apply-all">
                        <input type="checkbox" @bind="_applyToAllPages" />
                        Apply to all pages
                    </label>
                    <button class="rp-apply-btn"
                            @onclick="ApplyRedaction"
                            disabled="@(!AllRegions.Any() || IsProcessing)">
                        @if (IsProcessing)
                        {
                            <div class="rp-btn-spinner"></div>
                            <span>Processing...</span>
                        }
                        else
                        {
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                            <span>Apply Redactions &amp; Download</span>
                        }
                    </button>
                    <span class="rp-no-cc">No credit card required</span>
                </div>
            </div>

            <!-- Warning banner -->
            @if (AllRegions.Any())
            {
                <div class="rp-permanent-warning">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                    All redactions are permanent and cannot be undone. Review carefully before applying.
                </div>
            }

            <!-- Search & redact modal -->
            @if (_showSearchPanel)
            {
                <div class="rp-search-modal">
                    <div class="rp-search-card">
                        <div class="rp-search-header">
                            <strong>Search & Redact</strong>
                            <button @onclick='() => _showSearchPanel = false' class="rp-search-close">✕</button>
                        </div>
                        <p class="rp-search-desc">Enter text to find and redact all matching instances in the document.</p>
                        <input class="rp-search-input" placeholder="e.g. John Smith, SSN, account number..."
                               @bind="_searchText" @bind:event="oninput" />
                        <div class="rp-search-actions">
                            <button class="rp-panel-btn" @onclick='() => _showSearchPanel = false'>Cancel</button>
                            <button class="rp-panel-btn rp-panel-btn--primary" @onclick="ExecuteSearchRedact"
                                    disabled="@(string.IsNullOrWhiteSpace(_searchText))">
                                Find & Redact All
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ── PROCESSING STATE ──────────────────────────────────────────── -->
    @if (CurrentState == PageState.Processing)
    {
        <div class="rp-processing">
            <div class="rp-processing-card">
                <div class="rp-processing-icon">
                    <div class="rp-processing-ring"></div>
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                </div>
                <h2>Applying redactions...</h2>
                <p>Permanently removing @_completedRegionCount area@(_completedRegionCount == 1 ? "" : "s") from your PDF</p>
                <div class="rp-progress-bar">
                    <div class="rp-progress-fill"></div>
                </div>
                <span class="rp-processing-note">This may take a few seconds</span>
            </div>
        </div>
    }

    <!-- ── COMPLETE STATE ────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Complete)
    {
        <div class="rp-complete">
            <div class="rp-complete-card">
                <div class="rp-complete-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <h2>Redaction Complete</h2>
                <p>@_completedRegionCount area@(_completedRegionCount == 1 ? "" : "s") permanently removed from your PDF.</p>

                <div class="rp-complete-badges">
                    <div class="rp-complete-badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Data permanently destroyed
                    </div>
                    <div class="rp-complete-badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Metadata stripped
                    </div>
                    <div class="rp-complete-badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        PDF structure preserved
                    </div>
                </div>

                <button class="rp-download-btn" @onclick="DownloadFile">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Download Redacted PDF
                </button>
                <button class="rp-restart-btn" @onclick="Reset">Redact Another PDF</button>
            </div>
        </div>
        <ResultAdPlaceholder ShowAds="ShowAdsForCurrentUser" />
    }

    <!-- ── ERROR STATE ───────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Error)
    {
        <div class="rp-complete">
            <div class="rp-complete-card">
                <div class="rp-complete-icon" style="background:#FEE2E2;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <h2>Redaction Failed</h2>
                <p style="color:var(--text-muted,#6B7280)">@ErrorMessage</p>
                <button class="rp-restart-btn" @onclick="Reset">Try Again</button>
            </div>
        </div>
    }

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Upload)
    {
        <div class="rp-faq">
            <h2>Frequently Asked Questions</h2>
            @foreach (var (q, a) in Faqs)
            {
                <details class="rp-faq-item">
                    <summary>@q</summary>
                    <p>@a</p>
                </details>
            }
        </div>
    }

