        box-shadow: 0 22px 42px rgba(37, 99, 235, .3);
    }

    [data-theme="dark"] .rp-page {
        background:
            radial-gradient(circle at 15% 0%, rgba(248, 113, 113, .10), transparent 34%),
            radial-gradient(circle at 92% 8%, rgba(96, 165, 250, .12), transparent 30%),
            linear-gradient(180deg, var(--bg, #07111f) 0%, #0f172a 100%);
        color: var(--text-primary, #f8fafc);
