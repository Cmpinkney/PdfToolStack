    [data-theme="dark"] .rp-upload-sub,
    [data-theme="dark"] .rp-feature-list span,
    [data-theme="dark"] .rp-page-label,
    [data-theme="dark"] .rp-thumbnails-label,
    [data-theme="dark"] .rp-thumb-num,
    [data-theme="dark"] .rp-color-label,
    [data-theme="dark"] .rp-search-desc,
    [data-theme="dark"] .rp-processing-card p,
    [data-theme="dark"] .rp-processing-note,
    [data-theme="dark"] .rp-complete-card p,
