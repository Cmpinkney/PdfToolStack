    [data-theme="dark"] .rp-upload-title,
    [data-theme="dark"] .rp-editor-topbar,
    [data-theme="dark"] .rp-filename,
    [data-theme="dark"] .rp-panel-title,
    [data-theme="dark"] .rp-search-header h3,
    [data-theme="dark"] .rp-processing-card h2,
    [data-theme="dark"] .rp-complete-card h2,
