@code {
    private bool ShowAdsForCurrentUser = true; // TODO: Hide ads for paid users when subscription state is available here.
    private record RedactColorDef(string Hex, string Name);
    private static readonly RedactColorDef[] RedactColors = new[]
    {
        new RedactColorDef("#000000", "Black"),
        new RedactColorDef("#1F2937", "Charcoal"),
        new RedactColorDef("#DC2626", "Red"),
        new RedactColorDef("#1D4ED8", "Blue"),
        new RedactColorDef("#047857", "Green"),
        new RedactColorDef("#7C3AED", "Purple"),
    };

    private bool _isPdfLoading = false;
    private bool _aiDetecting = false;
    private bool _showAfter = false;
    private bool _showSearchPanel = false;
    private bool _applyToAllPages = false;
    private string _selectedColor = "#000000";
    private string _searchText = string.Empty;

    private enum PageState { Upload, Redact, Processing, Complete, Error, LargeFile }
    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? RedactedBytes;
    private string? ErrorMessage;
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int _completedRegionCount = 0;
    private bool IsProcessing = false;

    private List<RedactionRegionModel> AllRegions = new();
    private List<RedactionRegionModel> CurrentPageRegions =>
        AllRegions.Where(r => r.PageNumber == CurrentPage).ToList();

    private class RedactionRegionModel
    {
        public float X1 { get; set; }
        public float Y1 { get; set; }
        public float X2 { get; set; }
        public float Y2 { get; set; }
        public int PageNumber { get; set; }
    }

    private (string q, string a)[] Faqs => new[]
    {
        ("Is the redaction permanent?",
         "Yes — redacted areas are permanently removed from the PDF. The content cannot be recovered or revealed by removing a visible overlay. Data is destroyed at the binary level."),
        ("Who needs PDF redaction?",
         "Legal professionals, HR teams, healthcare providers, financial institutions, and anyone sharing documents containing SSNs, addresses, account numbers, or other sensitive personal information."),
        ("Is metadata also removed?",
         "Yes — document metadata including author information and edit history is stripped during redaction to prevent hidden data leaks."),
        ("Is this tool free?",
         "Yes — completely free with no signup required. Upload your PDF, draw redaction areas, and download the permanently redacted file instantly."),
        ("Are my files secure?",
         "Your files are processed on secure servers and automatically deleted within 1 hour. We never store your documents permanently or use them for any purpose."),
    };

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null; UploadedBytes = null; ErrorMessage = null;
        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid) { Toast.ShowError(validation.Message!); return; }
        if (validation.IsWarning) Toast.ShowWarning(validation.Message!);
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();
            var bytesVal = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid) { Toast.ShowError(bytesVal.Message!); UploadedBytes = null; return; }
            SelectedFile = file;
            if (PaymentService.IsFileTooLargeForFree(file.Size)) CurrentState = PageState.LargeFile;
            else Toast.ShowSuccess($"File ready — {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex) { Toast.ShowError($"Could not read file: {ex.Message}"); UploadedBytes = null; }
        StateHasChanged();
    }

    private void HandleFileRemoved() { SelectedFile = null; UploadedBytes = null; }

    private async Task LoadPdf()
    {
        if (UploadedBytes == null) return;
        try
        {
            TotalPages = await ApiService.GetPageCountAsync(UploadedBytes, SelectedFile!.Name);
            CurrentPage = 1;
            _isPdfLoading = true;
            CurrentState = PageState.Redact;
            StateHasChanged();
            await JS.InvokeVoidAsync("renderPdfPage", Convert.ToBase64String(UploadedBytes), CurrentPage);
            // Lock page scroll when editor is open

            _isPdfLoading = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex) { ErrorMessage = $"Error loading PDF: {ex.Message}"; CurrentState = PageState.Error; StateHasChanged(); }
    }

    private async Task GoToPage(int page)
    {
        if (page == CurrentPage || page < 1 || page > TotalPages) return;
        CurrentPage = page;
        await RenderCurrentPage();
    }

    private async Task PreviousPage() { if (CurrentPage > 1) { CurrentPage--; await RenderCurrentPage(); } }
    private async Task NextPage() { if (CurrentPage < TotalPages) { CurrentPage++; await RenderCurrentPage(); } }

    private async Task RenderCurrentPage()
    {
        await JS.InvokeVoidAsync("renderPdfPage", Convert.ToBase64String(UploadedBytes!), CurrentPage);
        await RedrawRegions();
    }

    private async Task RedrawRegions()
    {
        var regions = CurrentPageRegions.Select(r => new { r.X1, r.Y1, r.X2, r.Y2 }).ToArray();
        await JS.InvokeVoidAsync("redrawRegions", (object)regions);
    }

    private void AddRedactionMode() => Toast.ShowInfo("Draw a rectangle over the area you want to redact.");

    private async Task AutoDetectSensitiveData()
    {
        _aiDetecting = true;
        StateHasChanged();
        // Simulated AI detection — in production: call API endpoint for AI detection
        await Task.Delay(1800);
        Toast.ShowInfo("AI detection complete. Review highlighted areas before applying.");
        _aiDetecting = false;
        StateHasChanged();
    }

    private void SearchAndRedact() => _showSearchPanel = true;
    private void TextRedactionMode() => Toast.ShowInfo("Click on text in the PDF to select it for redaction.");

    private async Task ExecuteSearchRedact()
    {
        _showSearchPanel = false;
        if (string.IsNullOrWhiteSpace(_searchText)) return;
        Toast.ShowInfo($"Searching for \"{_searchText}\"...");
        await Task.CompletedTask;
    }

    private async Task UndoLast()
    {
        if (!AllRegions.Any()) return;
        var last = AllRegions.LastOrDefault(r => r.PageNumber == CurrentPage);
        if (last != null) AllRegions.Remove(last);
        await RedrawRegions();
        StateHasChanged();
    }

    private async Task ClearCurrentPage()
    {
        AllRegions.RemoveAll(r => r.PageNumber == CurrentPage);
        await JS.InvokeVoidAsync("clearRedactCanvas");
        StateHasChanged();
    }

    private async Task ClearAll()
    {
        AllRegions.Clear();
        await JS.InvokeVoidAsync("clearRedactCanvas");
        StateHasChanged();
    }

    private async Task SetBeforeAfter(bool showAfter)
    {
        _showAfter = showAfter;
        await JS.InvokeVoidAsync("setRedactBeforeAfter", showAfter ? "after" : "before");
    }

    private async Task SelectColor(string color)
    {
        _selectedColor = color;
        await JS.InvokeVoidAsync("setRedactColor", color);
    }

    private async Task ApplyRedaction()
    {
        if (!AllRegions.Any() || UploadedBytes == null) return;
        _completedRegionCount = AllRegions.Count;
        IsProcessing = true;
        CurrentState = PageState.Processing;
        StateHasChanged();
        await Task.Delay(50);
        try
        {
            RedactedBytes = await ApiService.RedactPdfAsync(UploadedBytes, SelectedFile!.Name,
                AllRegions.Select(r => new { r.X1, r.Y1, r.X2, r.Y2, r.PageNumber }).ToList());

            CurrentState = RedactedBytes != null ? PageState.Complete : PageState.Error;
            if (RedactedBytes == null) ErrorMessage = "Redaction failed. Please try again.";
            else SessionUsage.RecordToolCompletion("Redact PDF");
            // Restore scroll when leaving editor

        }
        catch (Exception ex) { ErrorMessage = $"Error: {ex.Message}"; CurrentState = PageState.Error; }
        finally { IsProcessing = false; }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (RedactedBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(SelectedFile?.Name ?? "document") + "_redacted.pdf";
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(RedactedBytes));
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null; UploadedBytes = null; RedactedBytes = null;
        AllRegions.Clear(); ErrorMessage = null;
        CurrentPage = 1; TotalPages = 1;
        IsProcessing = false; _isPdfLoading = false;
        _completedRegionCount = 0; _showSearchPanel = false;
        // Restore page scroll when leaving editor

    }

    private DotNetObjectReference<RedactPdf>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initRedactCanvas", _dotNetRef);
        }
    }

    public void Dispose() => _dotNetRef?.Dispose();

    [JSInvokable]
    public async Task AddRegion(float x1, float y1, float x2, float y2)
    {
        if (x2 - x1 < 5 || y2 - y1 < 5) return;
        AllRegions.Add(new RedactionRegionModel { X1 = x1, Y1 = y1, X2 = x2, Y2 = y2, PageNumber = CurrentPage });
        // Auto-switch to After view when first redaction is drawn
        if (!_showAfter)
            await SetBeforeAfter(true);
        StateHasChanged();
    }
}
