@page "/sign-pdf"
@page "/sign-contract/app"
@page "/sign-pdf-document"
@inject NavigationManager Navigation
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@implements IDisposable
@inject FileValidationService Validator
@inject ToastService Toast

<PageTitle>@(IsContractMode ? "Sign Contract Online Free — Electronic Signature | PdfToolStack" : "Sign PDF Free Online — Add Electronic Signature to PDF")</PageTitle>
<HeadContent>
    <meta name="description" content="@(IsContractMode ? "Sign contracts online free. Add your electronic signature to any contract PDF. Legally binding, no signup required." : "Sign PDF documents free online. Draw your signature and place it on your PDF. No signup required.")" />
    <link rel="canonical" href="https://pdftoolstack.com/sign-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">

        <div class="ai-tool-header">
            <div class="ai-tool-badge">✒️ Free Tool</div>
            <h1>@(IsContractMode ? "Sign Contract Online" : "Sign PDF Online")</h1>
            <p class="tool-subtitle">
                @(IsContractMode
                                ? "Upload your contract and add a legally binding electronic signature. No account needed."
                                : "Draw your signature and place it anywhere on your PDF. Free, private, and instant.")
            </p>
        </div>

        <div class="how-it-works">
            <div class="hiw-step">
                <div class="hiw-num">1</div>
                <div class="hiw-text"><strong>Upload PDF</strong><span>Up to 25MB free</span></div>
            </div>
            <div class="hiw-arrow">→</div>
            <div class="hiw-step">
                <div class="hiw-num">2</div>
                <div class="hiw-text"><strong>Use signature tool</strong><span>Draw or type in toolbar</span></div>
            </div>
            <div class="hiw-arrow">→</div>
            <div class="hiw-step">
                <div class="hiw-num">3</div>
                <div class="hiw-text"><strong>Place &amp; download</strong><span>Click to position anywhere</span></div>
            </div>
        </div>

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@_largeFileSize"
                              FileName="@_largeFileName"
                              ToolType="SignPdf"
                              OnCancel="ResetAll" />
        }
        else if (!_viewerActive)
        {
            <FileUpload OnFileSelected="HandleFileSelected"
                        OnFileRemoved="HandleFileRemoved" />
        }

        <SfPdfViewerShell @ref="_viewer"
                          ResetLabel="Sign Another PDF"
                          Height="85vh"
                          ToolbarItems="@_signToolbar"
                          OnReset="ResetAll" />

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container" role="alert">
                <span class="error-icon">❌</span>
                <p class="error-message">@_errorMessage</p>
                <button class="reset-button" @onclick="ResetAll">Try Again</button>
            </div>
        }

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>Is an electronic signature legally valid?</h3>
            <p>Electronic signatures are legally recognized in most countries under laws like the US ESIGN Act and EU eIDAS regulation.</p>
        </div>
        <div class="faq-item">
            <h3>How do I add my signature?</h3>
            <p>Click the signature tool in the Syncfusion toolbar (pen icon), draw or type your signature, then click anywhere on the document to place it.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no signup required.</p>
        </div>
        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>Your file is processed entirely in your browser. It never leaves your device.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Error, LargeFile }

    private PageState CurrentState = PageState.Upload;
    private SfPdfViewerShell? _viewer;
    private bool _viewerActive = false;
    private string _errorMessage = string.Empty;
    private long _largeFileSize;
    private string _largeFileName = string.Empty;

    private bool IsContractMode =>
        Navigation.Uri.Contains("/sign-contract", StringComparison.OrdinalIgnoreCase) ||
        Navigation.Uri.Contains("/sign-pdf-document", StringComparison.OrdinalIgnoreCase);

    // Restrict toolbar to signing-relevant tools only
    // If build errors occur on any value, remove that line — names vary by SF version
    private List<ToolbarItem> _signToolbar = new()
    {
        ToolbarItem.PageNavigationTool,
        ToolbarItem.MagnificationTool,
        ToolbarItem.PanTool,
        ToolbarItem.SelectionTool,
        ToolbarItem.AnnotationEditTool,
        ToolbarItem.DownloadOption,
        ToolbarItem.PrintOption,
    };

    private async Task HandleFileSelected(IBrowserFile file)
    {
        CurrentState = PageState.Upload;
        _errorMessage = string.Empty;

        if (PaymentService.IsFileTooLargeForFree(file.Size))
        {
            _largeFileSize = file.Size;
            _largeFileName = file.Name;
            CurrentState = PageState.LargeFile;
            StateHasChanged();
            return;
        }

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid) { Toast.ShowError(validation.Message!); return; }
        if (validation.IsWarning) Toast.ShowWarning(validation.Message!);

        // Read bytes BEFORE any StateHasChanged
        byte[] bytes;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 524_288_000);
            using var ms = new MemoryStream((int)Math.Min(file.Size, int.MaxValue));
            await stream.CopyToAsync(ms);
            bytes = ms.ToArray();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            return;
        }

        _viewerActive = true;
        StateHasChanged();

        var success = await _viewer!.LoadBytesAsync(file.Name, bytes);
        if (!success)
        {
            _viewerActive = false;
            StateHasChanged();
        }
    }

    private void HandleFileRemoved() { }

    private void ResetAll()
    {
        _viewer?.Reset();
        CurrentState = PageState.Upload;
        _viewerActive = false;
        _errorMessage = string.Empty;
    }

    public void Dispose() { }
}
