@page "/excel-to-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage
@inject CloudPickerService CloudPicker

<PageTitle>Excel to PDF Converter Free Online — Convert XLSX to PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert Excel spreadsheets to PDF free online.
                   No signup required. Fast and secure conversion." />
    <meta name="keywords"
          content="excel to pdf, xlsx to pdf,
                   convert excel to pdf free, convert spreadsheet to pdf, excel to pdf converter" />
    <link rel="canonical"
          href="https://pdftoolstack.com/excel-to-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <h1>Excel to PDF Converter</h1>
        <p class="tool-subtitle">
            Convert your Excel spreadsheet to PDF for free.
            No signup required. Files deleted within 1 hour.
        </p>

        @if (CurrentState == PageState.Upload)
        {
            <div class="upload-container">
                <span class="upload-icon">📊</span>
                <p>Upload your Excel file (.xlsx)</p>
                <label class="upload-button">
                    Browse File
                    <InputFile OnChange="HandleFileSelected"
                               accept=".xlsx,.xls"
                               style="display:none" />
                </label>
                <div class="cloud-picker-row">
                    <span class="cloud-picker-label">OR IMPORT FROM</span>
                    <div class="cloud-picker-buttons">
                        <button class="cloud-picker-btn" @onclick="PickGoogleDrive" disabled="@_cloudLoading">
                            <svg width="16" height="16" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg"><path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da" /><path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44a9.06 9.06 0 0 0 -1.2 4.5h27.5z" fill="#00ac47" /><path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.502l5.852 11.5z" fill="#ea4335" /><path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d" /><path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc" /><path d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 28h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00" /></svg>
                            Google Drive
                        </button>
                        <button class="cloud-picker-btn" @onclick="PickDropbox" disabled="@_cloudLoading">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#0061FF"><path d="M6 2L0 6l6 4-6 4 6 4 6-4-6-4 6-4L6 2zm12 0l-6 4 6 4-6 4 6 4 6-4-6-4 6-4-6-4zm-6 13l-6 4 6 4 6-4-6-4z" /></svg>
                            Dropbox
                        </button>
                    </div>
                </div>
                @if (_cloudLoading)
                {
                    <p class="cloud-loading-hint">⏳ Downloading from cloud...</p>
                }
                @if (!string.IsNullOrEmpty(_cloudError))
                {
                    <p class="error-message">@_cloudError</p>
                }
                <p class="upload-hint">Supports .xlsx files up to 25MB</p>
            </div>

            @if (SelectedFile != null)
            {
                <div class="selected-file-info">
                    <span>📊 @SelectedFile.Name</span>
                </div>
                <button class="process-button" @onclick="ProcessFile">Convert to PDF</button>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="error-message">@ErrorMessage</p>
            }
        }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                              FileName="@(SelectedFile?.Name ?? "")"
                              ToolType="ExcelToPdf"
                              OnCancel="Reset" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Converting your spreadsheet to PDF...</p>
            </div>
        }

        @if (CurrentState == PageState.Complete && ResultBytes != null)
        {
            <AdSlot Size="rectangle" />
            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>Conversion Complete!</h2>
                <p style="color: var(--gray); margin-bottom: 1.5rem;">
                    Your Excel spreadsheet has been converted to PDF successfully.
                </p>
                <button class="download-button" @onclick="DownloadFile">Download PDF</button>
                <button class="reset-button" @onclick="Reset">Convert Another Spreadsheet</button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button" @onclick="Reset">Try Again</button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What Excel formats are supported?</h3>
            <p>We support .xlsx files. Each worksheet becomes a separate table in the PDF.</p>
        </div>
        <div class="faq-item">
            <h3>Will formulas be calculated?</h3>
            <p>The PDF will show the calculated values, not the formula text.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no signup required.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Processing, Complete, Error, LargeFile }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? _cloudFileName;
    private string? ErrorMessage;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true") CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidateExcelFile(e.File);
        if (!validation.IsValid) { Toast.ShowError(validation.Message!); return; }

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();
            SelectedFile = e.File;

            if (PaymentService.IsFileTooLargeForFree(e.File.Size))
                CurrentState = PageState.LargeFile;
            else
                Toast.ShowSuccess($"File ready — {Validator.FormatSize(e.File.Size)}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null || SelectedFile == null) return;
        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            ResultBytes = await ApiService.ExcelToPdfAsync(UploadedBytes, SelectedFile.Name);
            CurrentState = ResultBytes != null ? PageState.Complete : PageState.Error;
            if (ResultBytes == null) ErrorMessage = "Conversion failed.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(SelectedFile?.Name ?? "spreadsheet") + ".pdf";
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
    }

    // ── Cloud pickers ──────────────────────────────────────────────────────
    private bool _cloudLoading = false;
    private string _cloudError = string.Empty;

    private async Task PickGoogleDrive()
    {
        _cloudError = string.Empty; _cloudLoading = true; StateHasChanged();
        try { var f = await CloudPicker.OpenGoogleDriveAsync(); if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken); }
        catch (Exception ex) { _cloudError = $"Google Drive: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task PickDropbox()
    {
        _cloudError = string.Empty; _cloudLoading = true; StateHasChanged();
        try { var f = await CloudPicker.OpenDropboxAsync(); if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken); }
        catch (Exception ex) { _cloudError = $"Dropbox: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task LoadCloudFile(string name, string url, string? accessToken)
    {
        var bytes = await CloudPicker.DownloadFileAsync(url, accessToken);
        if (bytes is null || bytes.Length == 0) { _cloudError = "Could not download file. Please try again."; return; }
        UploadedBytes = bytes;
        _cloudFileName = name;
        Toast.ShowSuccess($"File ready — {Validator.FormatSize(bytes.LongLength)}");
        StateHasChanged();
    }
}
