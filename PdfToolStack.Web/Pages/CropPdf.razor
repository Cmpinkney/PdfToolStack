@code {
    private enum PageState { Upload, LargeFile, Configure, Processing, Complete, Error }
    private PageState CurrentState = PageState.Upload;

    private byte[]? _uploadedBytes;
    private byte[]? _resultBytes;
    private string _fileName = string.Empty;
    private string _errorMessage = string.Empty;
    private long _largeFileSize;
    private string _largeFileName = string.Empty;
    private string? _largeFilePriceId;
    private string? _proMonthlyPriceId;

    // Editor state
    private int _pageCount = 0;
    private int _currentPage = 1;
    private int _zoomPercent = 100;
    private string _activeTool = "select";

    // Crop settings
    private float _marginTop;
    private float _marginRight;
    private float _marginBottom;
    private float _marginLeft;
    private string _scope = "all";
    private string _pageNumbersInput = string.Empty;

    private float ToPts(float mm) => mm * 2.8346f;

    private bool CanProcess =>
        _uploadedBytes != null &&
        (_marginTop > 0 || _marginRight > 0 || _marginBottom > 0 || _marginLeft > 0);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var addons = await ApiService.GetAsync<AddonsResponse>("api/subscription/addons");
            _largeFilePriceId = addons?.LargeFile?.PriceId;
            var plans = await ApiService.GetAsync<PlansResponse>("api/subscription/plans");
            _proMonthlyPriceId = plans?.Monthly?.PriceId;
        }
        catch { }
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        CurrentState = PageState.Upload;
        _uploadedBytes = null; _resultBytes = null;
        _fileName = string.Empty; _errorMessage = string.Empty;

        if (PaymentService.IsFileTooLargeForFree(file.Size))
        {
            _largeFileSize = file.Size; _largeFileName = file.Name;
            CurrentState = PageState.LargeFile; StateHasChanged(); return;
        }

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid) { Toast.ShowError(validation.Message!); return; }
        if (validation.IsWarning) Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 524_288_000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _uploadedBytes = ms.ToArray();
            _fileName = file.Name;

            _pageCount = await ApiService.GetPageCountAsync(_uploadedBytes, file.Name);
            _currentPage = 1;
            CurrentState = PageState.Configure;
            StateHasChanged();

            await JS.InvokeVoidAsync("renderCropPreview", Convert.ToBase64String(_uploadedBytes), _currentPage);
        }
        catch (Exception ex) { Toast.ShowError($"Could not read file: {ex.Message}"); }
    }

    private async Task GoToPage(int page)
    {
        if (page == _currentPage) return;
        _currentPage = page;
        if (_uploadedBytes != null)
            await JS.InvokeVoidAsync("renderCropPreview", Convert.ToBase64String(_uploadedBytes), page);
    }

    private async Task PrevPage() { if (_currentPage > 1) await GoToPage(_currentPage - 1); }
    private async Task NextPage() { if (_currentPage < _pageCount) await GoToPage(_currentPage + 1); }

    private void ZoomIn() => _zoomPercent = Math.Min(200, _zoomPercent + 25);
    private void ZoomOut() => _zoomPercent = Math.Max(50, _zoomPercent - 25);

    private void AutoCrop() { _marginTop = 10; _marginRight = 10; _marginBottom = 10; _marginLeft = 10; }
    private void SetNoMargin() { _marginTop = _marginRight = _marginBottom = _marginLeft = 0; }
    private void SetPreset(float val, bool custom = false) { if (!custom) { _marginTop = _marginRight = _marginBottom = _marginLeft = val; } }
    private void ResetMargins() => SetNoMargin();

    private async Task ProcessFile()
    {
        if (_uploadedBytes == null) return;
        CurrentState = PageState.Processing;
        _errorMessage = string.Empty;
        StateHasChanged();
        try
        {
            string? pageNumbers = _scope == "range" && !string.IsNullOrWhiteSpace(_pageNumbersInput)
                ? _pageNumbersInput.Trim() : null;

            _resultBytes = await ApiService.CropPdfAsync(
                _uploadedBytes, _fileName,
                ToPts(_marginTop), ToPts(_marginRight),
                ToPts(_marginBottom), ToPts(_marginLeft),
                pageNumbers);

            CurrentState = _resultBytes?.Length > 0 ? PageState.Complete : PageState.Error;
            if (_resultBytes == null || _resultBytes.Length == 0)
                _errorMessage = "Crop failed — please check your margin values and try again.";
            else SessionUsage.RecordToolCompletion("Crop PDF");
        }
        catch (Exception ex) { _errorMessage = $"Something went wrong: {ex.Message}"; CurrentState = PageState.Error; }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (_resultBytes == null) return;
        var outName = Path.GetFileNameWithoutExtension(_fileName) + "-cropped.pdf";
        await JS.InvokeVoidAsync("downloadFile", outName, Convert.ToBase64String(_resultBytes));
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _uploadedBytes = null; _resultBytes = null;
        _fileName = string.Empty; _errorMessage = string.Empty;
        _marginTop = _marginRight = _marginBottom = _marginLeft = 0;
        _scope = "all"; _pageNumbersInput = string.Empty;
        _pageCount = 0; _currentPage = 1; _zoomPercent = 100;
    }

    private class PlansResponse { public PlanInfo? Monthly { get; set; } }
    private class AddonsResponse { public AddonInfo? LargeFile { get; set; } }
    private class PlanInfo { public string PriceId { get; set; } = string.Empty; }
    private class AddonInfo { public string PriceId { get; set; } = string.Empty; }
}
