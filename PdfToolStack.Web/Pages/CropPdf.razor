@page "/crop-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject AuthenticationStateProvider Auth
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage
@using Microsoft.AspNetCore.Components.Authorization
@using PdfToolStack.Web.Services

<PageTitle>Crop PDF Free Online — Crop and Trim PDF Pages | PdfToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Crop and trim your PDF pages free online. Remove margins, white space, and unwanted areas from any PDF. Auto-crop detects whitespace. No signup required." />
    <meta name="keywords" content="crop pdf, trim pdf, pdf cropper free online, remove margins from pdf, resize pdf page, trim pdf margins" />
    <link rel="canonical" href="https://pdftoolstack.com/crop-pdf" />
</HeadContent>

<div class="cp-page">

    <!-- ── UPLOAD STATE ──────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Upload || CurrentState == PageState.LargeFile)
    {
        <div class="cp-upload-hero">
            <div class="cp-upload-header">
                <h1 class="cp-title">Crop PDF <span class="cp-title-accent">Online</span></h1>
                <p class="cp-subtitle">Remove white space and unwanted margins from your PDF. Free, private, and instant.</p>
                <div class="cp-chips">
                    <span class="cp-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Precise cropping — drag or enter values
                    </span>
                    <span class="cp-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Auto-crop detects whitespace automatically
                    </span>
                    <span class="cp-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                        Files deleted in 1 hour
                    </span>
                </div>
            </div>

            @if (CurrentState == PageState.LargeFile)
            {
                <LargeFileUpgrade FileSizeBytes="@_largeFileSize" FileName="@_largeFileName"
                                  ToolType="CropPdf" LargeFilePriceId="@_largeFilePriceId"
                                  ProMonthlyPriceId="@_proMonthlyPriceId" OnCancel="Reset" />
            }
            else
            {
                <div class="cp-upload-area">
                    <FileUpload OnFileSelected="HandleFileSelected" Accept=".pdf" HintText="Up to 25MB free · 500MB with Pro" />
                </div>
            }
        </div>
    }

    <!-- ── EDITOR STATE ──────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Configure)
    {
        <!-- Top bar -->
        <div class="cp-topbar">
            <div class="cp-topbar-left">
                <button class="cp-back-btn" @onclick="Reset">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                    Back
                </button>
                <span class="cp-filename">@_fileName</span>
                @if (_pageCount > 0)
                {
                    <span class="cp-page-chip">@_pageCount pages</span>
                }
            </div>
            <div class="cp-topbar-center">
                <button class="cp-nav-btn" @onclick="PrevPage" disabled="@(_currentPage <= 1)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <span class="cp-page-label">Page <strong>@_currentPage</strong> of @_pageCount</span>
                <button class="cp-nav-btn" @onclick="NextPage" disabled="@(_currentPage >= _pageCount)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
            <div class="cp-topbar-right">
                <span class="cp-topbar-hint">Drag the crop handles or enter values</span>
            </div>
        </div>

        <!-- Editor body -->
        <div class="cp-editor">

            <!-- Page thumbnail sidebar -->
            <div class="cp-thumbs">
                <div class="cp-thumbs-label">Pages</div>
                @for (int p = 1; p <= _pageCount; p++)
                {
                    var pg = p;
                    <div class="cp-thumb @(_currentPage == pg ? "cp-thumb--active" : "")" @onclick="() => GoToPage(pg)">
                        <div class="cp-thumb-page">
                            <div class="cp-thumb-lines">
                                <div class="cp-thumb-line"></div>
                                <div class="cp-thumb-line" style="width:70%"></div>
                                <div class="cp-thumb-line"></div>
                                <div class="cp-thumb-line" style="width:80%"></div>
                                <div class="cp-thumb-line" style="width:60%"></div>
                            </div>
                        </div>
                        <span class="cp-thumb-num">@pg</span>
                    </div>
                }
                <button class="cp-add-pages-btn">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    Add pages
                </button>
            </div>

            <!-- Canvas area with crop overlay -->
            <div class="cp-canvas-area">
                <div class="cp-canvas-toolbar">
                    <button class="cp-tool-btn @(_activeTool == "select" ? "cp-tool-btn--active" : "")" title="Select" @onclick='() => _activeTool = "select"'>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3l14 9-7 1-4 7z" /></svg>
                    </button>
                    <button class="cp-tool-btn @(_activeTool == "hand" ? "cp-tool-btn--active" : "")" title="Pan" @onclick='() => _activeTool = "hand"'>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8" /><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15" /></svg>
                    </button>
                    <div class="cp-tool-divider"></div>
                    <button class="cp-tool-btn" title="Zoom in" @onclick="ZoomIn">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /><line x1="11" y1="8" x2="11" y2="14" /><line x1="8" y1="11" x2="14" y2="11" /></svg>
                    </button>
                    <span class="cp-zoom-label">@(_zoomPercent)%</span>
                    <button class="cp-tool-btn" title="Zoom out" @onclick="ZoomOut">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /><line x1="8" y1="11" x2="14" y2="11" /></svg>
                    </button>
                    <button class="cp-tool-btn" title="Fullscreen">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9" /><polyline points="9 21 3 21 3 15" /><line x1="21" y1="3" x2="14" y2="10" /><line x1="3" y1="21" x2="10" y2="14" /></svg>
                    </button>
                </div>

                <div class="cp-canvas-wrap">
                    <!-- PDF preview with crop overlay -->
                    <div class="cp-preview-doc" style="transform:scale(@(_zoomPercent / 100.0))">
                        <!-- PDF canvas -->
                        <canvas id="cpPdfCanvas" style="display:block;max-width:100%;border-radius:4px;"></canvas>

                        <!-- Crop overlay - shows the crop region -->
                        <div class="cp-crop-overlay">
                            <!-- Dark masks -->
                            <div class="cp-mask cp-mask--top" style="height:@(_marginTop)px"></div>
                            <div class="cp-mask cp-mask--bottom" style="height:@(_marginBottom)px"></div>
                            <div class="cp-mask cp-mask--left" style="width:@(_marginLeft)px; top:@(_marginTop)px; bottom:@(_marginBottom)px"></div>
                            <div class="cp-mask cp-mask--right" style="width:@(_marginRight)px; top:@(_marginTop)px; bottom:@(_marginBottom)px"></div>
                            <!-- Crop border -->
                            <div class="cp-crop-border" style="top:@(_marginTop)px;right:@(_marginRight)px;bottom:@(_marginBottom)px;left:@(_marginLeft)px">
                                <!-- Corner handles -->
                                <div class="cp-handle cp-handle--tl"></div>
                                <div class="cp-handle cp-handle--tr"></div>
                                <div class="cp-handle cp-handle--bl"></div>
                                <div class="cp-handle cp-handle--br"></div>
                                <!-- Edge handles -->
                                <div class="cp-handle cp-handle--t"></div>
                                <div class="cp-handle cp-handle--b"></div>
                                <div class="cp-handle cp-handle--l"></div>
                                <div class="cp-handle cp-handle--r"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Settings panel -->
            <div class="cp-settings">
                <div class="cp-settings-title">Crop Settings</div>

                <!-- Preset buttons -->
                <div class="cp-setting-group">
                    <div class="cp-preset-row">
                        <button class="cp-preset-btn cp-preset-btn--auto" @onclick="AutoCrop">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10" /><path d="M12 6v6l4 2" /></svg>
                            Auto Crop
                        </button>
                        <button class="cp-preset-btn" @onclick="SetNoMargin">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /></svg>
                            No Margin
                        </button>
                    </div>
                    <div class="cp-preset-row">
                        <button class="cp-preset-btn" @onclick='() => SetPreset(10)'>
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="5" width="14" height="14" rx="1" /></svg>
                            Standard
                        </button>
                        <button class="cp-preset-btn" @onclick='() => SetPreset(0, true)'>
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2" /><path d="M9 2v20M15 2v20M2 9h20M2 15h20" /></svg>
                            Custom
                        </button>
                    </div>
                </div>

                <div class="cp-divider"></div>

                <!-- Crop margin inputs -->
                <div class="cp-setting-group">
                    <label class="cp-setting-label">
                        Crop Margin
                        <button class="cp-reset-link" @onclick="ResetMargins">Reset</button>
                    </label>

                    <!-- Top -->
                    <div class="cp-margin-input-row">
                        <span class="cp-margin-label">Top</span>
                        <input type="number" class="cp-margin-input" min="0" step="1"
                               @bind="_marginTop" @bind:event="oninput" />
                        <span class="cp-margin-unit">mm</span>
                        <span class="cp-margin-dots">···</span>
                    </div>
                    <!-- Right -->
                    <div class="cp-margin-input-row">
                        <span class="cp-margin-label">Right</span>
                        <input type="number" class="cp-margin-input" min="0" step="1"
                               @bind="_marginRight" @bind:event="oninput" />
                        <span class="cp-margin-unit">mm</span>
                        <span class="cp-margin-dots">···</span>
                    </div>
                    <!-- Bottom -->
                    <div class="cp-margin-input-row">
                        <span class="cp-margin-label">Bottom</span>
                        <input type="number" class="cp-margin-input" min="0" step="1"
                               @bind="_marginBottom" @bind:event="oninput" />
                        <span class="cp-margin-unit">mm</span>
                        <span class="cp-margin-dots">···</span>
                    </div>
                    <!-- Left -->
                    <div class="cp-margin-input-row">
                        <span class="cp-margin-label">Left</span>
                        <input type="number" class="cp-margin-input" min="0" step="1"
                               @bind="_marginLeft" @bind:event="oninput" />
                        <span class="cp-margin-unit">mm</span>
                        <span class="cp-margin-dots">···</span>
                    </div>
                </div>

                <div class="cp-divider"></div>

                <!-- Apply to -->
                <div class="cp-setting-group">
                    <label class="cp-setting-label">Apply to</label>
                    <div class="cp-apply-row">
                        <label class="cp-radio">
                            <input type="radio" name="cpscope" checked="@(_scope == "all")"
                                   @onchange='() => _scope = "all"' />
                            All pages
                        </label>
                        <label class="cp-radio">
                            <input type="radio" name="cpscope" checked="@(_scope == "range")"
                                   @onchange='() => _scope = "range"' />
                            Specific pages
                        </label>
                    </div>
                    @if (_scope == "range")
                    {
                        <input class="cp-pages-input" placeholder="e.g. 1-3, 5, 7-10"
                               @bind="_pageNumbersInput" />
                    }
                </div>

                <div class="cp-divider"></div>

                <!-- Auto crop tip -->
                <div class="cp-tip">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    <span>Click <strong>Auto Crop</strong> to detect and remove white space automatically.</span>
                </div>

                <!-- CTA -->
                <button class="cp-apply-btn" @onclick="ProcessFile" disabled="@(!CanProcess)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Apply Crop &amp; Download
                </button>
                <p class="cp-no-cc">No credit card required</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="cp-inline-error">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                @_errorMessage
            </div>
        }
    }

    <!-- ── PROCESSING STATE ──────────────────────────────────────────── -->
    @if (CurrentState == PageState.Processing)
    {
        <div class="cp-state-center">
            <div class="cp-state-card">
                <div class="cp-proc-ring"></div>
                <h2>Cropping your PDF...</h2>
                <p>Applying crop to @(_scope == "all" ? "all pages" : "selected pages")</p>
                <div class="cp-proc-progress"><div class="cp-proc-fill"></div></div>
            </div>
        </div>
    }

    <!-- ── COMPLETE STATE ────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Complete)
    {
        <div class="cp-state-center">
            <div class="cp-state-card">
                <div class="cp-complete-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <h2>PDF Cropped!</h2>
                <p>White space and margins have been removed.</p>
                <div class="cp-complete-badges">
                    <div class="cp-complete-badge">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Content kept safe
                    </div>
                    <div class="cp-complete-badge">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        High quality output
                    </div>
                </div>
                <button class="cp-download-btn" @onclick="DownloadFile">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Download Cropped PDF
                </button>
                <button class="cp-restart-btn" @onclick="Reset">Crop Another PDF</button>
            </div>
        </div>
    }

    <!-- ── ERROR STATE ───────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Error)
    {
        <div class="cp-state-center">
            <div class="cp-state-card">
                <div class="cp-complete-icon" style="background:#FEE2E2;">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <h2>Crop Failed</h2>
                <p style="color:var(--text-muted,#6B7280)">@_errorMessage</p>
                <button class="cp-restart-btn" @onclick="Reset">Try Again</button>
            </div>
        </div>
    }

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Upload)
    {
        <div class="cp-faq">
            <h2>Frequently Asked Questions</h2>
            @foreach (var (q, a) in new[] {
                ("What does cropping a PDF do?", "Cropping sets a visible boundary on each page, hiding content outside that boundary. Perfect for removing scan borders, printer margins, or extra white space."),
                ("Will cropping reduce the file size?", "Cropping changes the visible area but does not remove underlying content. To reduce file size, use our Compress PDF tool."),
                ("Can I crop individual pages differently?", "Yes — select \"Specific pages\" and enter the page numbers you want to crop. All other pages remain untouched."),
                ("Is this tool free?", "Yes — completely free up to 25MB with no signup required. Pro handles files up to 500MB."),
                })
            {
                <details class="cp-faq-item">
                    <summary>@q</summary>
                    <p>@a</p>
                </details>
            }
        </div>
    }

</div>

<style>
    /* ════════════════════════════════════════════════════════
       Crop PDF — Enterprise Editor
    ════════════════════════════════════════════════════════ */
    .cp-page {
        min-height: 100vh;
    }

    /* ── Upload hero ──────────────────────────────────────── */
    .cp-upload-hero {
        max-width: 680px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 3rem;
    }

    .cp-upload-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .cp-title {
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        font-weight: 800;
        color: var(--text,#111827);
        letter-spacing: -.03em;
        margin: 0 0 .75rem;
    }

    .cp-title-accent {
        color: #0D9488;
    }

    .cp-subtitle {
        font-size: 1rem;
        color: var(--text-muted,#6B7280);
        line-height: 1.6;
        margin: 0 0 1.25rem;
    }

    .cp-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        justify-content: center;
    }

    .cp-chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-size: .75rem;
        font-weight: 500;
        color: var(--text-muted,#6B7280);
        background: var(--bg,#F9FAFB);
        border: 1px solid var(--border,#E5E7EB);
        padding: 4px 12px;
        border-radius: 20px;
    }

    /* ── Top bar ──────────────────────────────────────────── */
    .cp-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .625rem 1.25rem;
        background: var(--surface,#fff);
        border-bottom: 1px solid var(--border,#E5E7EB);
        gap: 1rem;
        position: sticky;
        top: 64px;
        z-index: 50;
    }

    .cp-topbar-left {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .cp-topbar-center {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .cp-topbar-right {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .cp-back-btn {
        display: flex;
        align-items: center;
        gap: .3rem;
        padding: .375rem .75rem;
        border-radius: 8px;
        border: 1px solid var(--border,#E5E7EB);
        background: var(--bg,#F9FAFB);
        color: var(--text,#374151);
        font-size: .8rem;
        font-weight: 500;
        cursor: pointer;
    }

        .cp-back-btn:hover {
            background: var(--border,#E5E7EB);
        }

    .cp-filename {
        font-size: .82rem;
        font-weight: 600;
        color: var(--text,#374151);
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .cp-page-chip {
        font-size: .72rem;
        font-weight: 600;
        background: var(--bg,#F3F4F6);
        border: 1px solid var(--border,#E5E7EB);
        padding: 2px 8px;
        border-radius: 20px;
        color: var(--text-muted,#6B7280);
    }

    .cp-nav-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border,#E5E7EB);
        background: var(--bg,#F9FAFB);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .cp-nav-btn:hover:not(:disabled) {
            background: var(--border,#E5E7EB);
        }

        .cp-nav-btn:disabled {
            opacity: .35;
            cursor: not-allowed;
        }

    .cp-page-label {
        font-size: .82rem;
        color: var(--text-muted,#6B7280);
        white-space: nowrap;
    }

        .cp-page-label strong {
            color: var(--text,#111827);
        }

    .cp-topbar-hint {
        font-size: .75rem;
        color: var(--text-muted,#9CA3AF);
    }

    /* ── Editor layout ────────────────────────────────────── */
    .cp-editor {
        display: grid;
