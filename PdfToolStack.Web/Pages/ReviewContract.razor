@page "/review-contract"
@page "/ai-contract-reviewer/app"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@inject ToastService Toast
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Json

<PageTitle>AI Contract Reviewer — Review Contracts Instantly | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="Upload any contract for AI-assisted contract analysis that may identify
                   risky clauses, key dates, obligations, and missing elements. Built for
                   freelancers, paralegals, and small business owners." />
    <meta name="keywords" content="ai contract review, contract analyzer, review contract online, risky clause detector" />
    <link rel="canonical" href="https://pdftoolstack.com/review-contract" />
</HeadContent>

<div class="tool-page ai-tool-page review-contract-page">
    <div class="tool-container ai-tool-container">

        <section class="tool-hero ai-tool-hero">
            <div class="trust-row">
                <span>Private processing</span>
                <span>Secure upload</span>
                <span>Auto-delete after 1 hour</span>
            </div>
            <h1>Review contracts <span class="hero-gradient-text">with AI</span></h1>
            <p>AI-assisted contract analysis may help identify risks, obligations, missing clauses, and key terms. Not legal advice.</p>
        </section>

        <div class="stepper ai-tool-stepper" aria-label="Contract review steps">
            <div class="stepper-step active"><span>1</span>Upload</div>
            <div class="stepper-step"><span>2</span>Analyze</div>
            <div class="stepper-step"><span>3</span>Review</div>
            <div class="stepper-step"><span>4</span>Export</div>
        </div>

        <AuthorizeView>
            <NotAuthorized>
                <div class="ai-upgrade-card">
                    <div class="ai-upgrade-icon">⚖️</div>
                    <h2>Try AI Contract Reviewer — 5 free uses</h2>
                    <p>Sign in to get 5 free AI uses per month. Review contracts and surface potential risks, unusual clauses, and key terms.</p>
                    <div class="ai-upgrade-features">
                        <div class="ai-upgrade-feat">✓ Risky clause detection</div>
                        <div class="ai-upgrade-feat">✓ Key dates &amp; deadlines</div>
                        <div class="ai-upgrade-feat">✓ Party obligations summary</div>
                        <div class="ai-upgrade-feat">✓ Plain English recommendations</div>
                    </div>
                    <div class="ai-upgrade-actions">
                        <a href="authentication/login?screen_hint=signup" class="download-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign up free — 5 AI uses included
                        </a>
                        <a href="authentication/login" class="reset-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign in
                        </a>
                    </div>
                </div>
            </NotAuthorized>

            <Authorized>
                <section class="workflow-grid ai-tool-workflow review-contract-workflow">
                    <div class="workspace-card ai-tool-workspace review-contract-workspace">
                        @if (CurrentState == PageState.Upload)
                        {
                            <div class="ai-tool-card-header">
                                <span>Contract analysis</span>
                                <h2>Upload a contract for review</h2>
                                <p>Use this for NDAs, service agreements, leases, employment contracts, and vendor agreements.</p>
                            </div>

                            <FileUpload OnFileSelected="HandleFileSelected"
                                        OnFileRemoved="HandleFileRemoved"
                                        HintText="Upload a contract PDF — NDA, service agreement, lease, employment contract" />

                            @if (_fileBytes != null)
                            {
                                <button class="process-button ai-tool-primary-cta" @onclick="RunReview">
                                    ⚖️ Review Contract with AI
                                </button>
                            }
                        }

                        @if (CurrentState == PageState.Processing)
                        {
                            <div class="ai-processing-container ai-tool-processing">
                                <div class="ai-processing-icon">⚖️</div>
                                <h3>AI is reviewing your contract...</h3>
                                <p>Analyzing clauses, dates, obligations and risks</p>
                                <div class="ai-processing-steps">
                                    <div class="ai-processing-step @(_step >= 1 ? "done" : "")">Reading contract text</div>
                                    <div class="ai-processing-step @(_step >= 2 ? "done" : "")">Identifying parties &amp; dates</div>
                                    <div class="ai-processing-step @(_step >= 3 ? "done" : "")">Detecting risky clauses</div>
                                    <div class="ai-processing-step @(_step >= 4 ? "done" : "")">Generating recommendations</div>
                                </div>
                            </div>
                        }

                        @if (CurrentState == PageState.Complete && _review != null)
                        {
                            <div class="contract-review-results review-contract-results-card">

                        <div class="review-header">
                            <div>
                                <span class="ai-tool-result-kicker">Contract analysis</span>
                                <h2>Contract Review Complete</h2>
                                <p style="color:var(--text-secondary); font-size:0.875rem;">
                                    @_fileName
                                </p>
                            </div>
                            <button class="reset-button"
                                    style="max-width:180px;"
                                    @onclick="Reset">
                                Review Another
                            </button>
                        </div>

                        <div class="risk-score-card risk-score-@_review.RiskLevel.ToLower()">
                            <div class="risk-score-left">
                                <div class="risk-score-meter">
                                    <div class="risk-score-track">
                                        <div class="risk-score-fill risk-fill-@_review.RiskLevel.ToLower()"></div>
                                        <div class="risk-score-marker risk-marker-@_review.RiskLevel.ToLower()"></div>
                                    </div>
                                    <div class="risk-score-labels">
                                        <span>Low</span>
                                        <span>Medium</span>
                                        <span>High</span>
                                    </div>
                                </div>
                            </div>
                            <div class="risk-score-right">
                                <div class="risk-score-badge risk-badge-@_review.RiskLevel.ToLower()">
                                    @GetRiskIcon(_review.RiskLevel)
                                    @_review.RiskLevel.ToUpper() RISK
                                </div>
                                <p class="risk-score-desc">
                                    @GetRiskDescription(_review.RiskLevel, _review.RiskyClauses?.Count ?? 0)
                                </p>
                            </div>
                        </div>

                        <div class="review-section">
                            <h3>Summary</h3>
                            <p class="review-summary">@_review.Summary</p>
                        </div>

                        @if (_review.Parties?.Any() == true)
                        {
                            <div class="review-section">
                                <h3>Parties Involved</h3>
                                <div class="review-tags">
                                    @foreach (var party in _review.Parties)
                                    {
                                        <div class="review-tag">
                                            <span class="review-tag-label">@party.Role</span>
                                            <span class="review-tag-value">@party.Name</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (_review.KeyDates?.Any() == true)
                        {
                            <div class="review-section">
                                <h3>Key Dates &amp; Deadlines</h3>
                                <div class="review-dates-grid">
                                    @foreach (var date in _review.KeyDates)
                                    {
                                        <div class="review-date-card">
                                            <span class="review-date-label">@date.Label</span>
                                            <span class="review-date-value">@date.Date</span>
                                            <span class="review-date-note">@date.Importance</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (_review.RiskyClauses?.Any() == true)
                        {
                            <div class="review-section">
                                <h3>⚠️ Risky Clauses</h3>
                                <div class="review-risks">
                                    @foreach (var clause in _review.RiskyClauses)
                                    {
                                        <div class="review-risk-card severity-@clause.Severity.ToLower()">
                                            <div class="review-risk-header">
                                                <span class="review-risk-title">@clause.Title</span>
                                                <span class="review-risk-severity">@clause.Severity.ToUpper()</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(clause.Excerpt))
                                            {
                                                <blockquote class="review-risk-excerpt">@clause.Excerpt</blockquote>
                                            }
                                            <p class="review-risk-explanation">@clause.Risk</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (_review.Obligations?.Any() == true)
                        {
                            <div class="review-section">
                                <h3>Key Obligations</h3>
                                <div class="review-obligations">
                                    @foreach (var ob in _review.Obligations)
                                    {
                                        <div class="review-obligation @(ob.Critical ? "obligation-critical" : "")">
                                            <span class="obligation-party">@ob.Party</span>
                                            <span class="obligation-text">@ob.Description</span>
                                            @if (ob.Critical)
                                            {
                                                <span class="obligation-critical-badge">Critical</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (_review.MissingElements?.Any() == true)
                        {
                            <div class="review-section">
                                <h3>🔍 Missing Elements</h3>
                                <div class="review-missing">
                                    @foreach (var item in _review.MissingElements)
                                    {
                                        <div class="review-missing-item">⚠️ @item</div>
                                    }
                                </div>
                            </div>
                        }

                        @if (_review.Recommendations?.Any() == true)
                        {
                            <div class="review-section">
                                <h3>✅ Recommendations</h3>
                                <div class="review-recommendations">
                                    @foreach (var rec in _review.Recommendations)
                                    {
                                        <div class="review-rec-item">@rec</div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="review-disclaimer">
                            <strong>Note:</strong> This AI review is for informational purposes only
                            and does not constitute legal advice. Consult a qualified attorney for
                            legally binding decisions.
                        </div>

                        <button class="reset-button" style="margin-top:1rem;" @onclick="Reset">
                            Review Another Contract
                        </button>
                            </div>
                        }

                        @if (CurrentState == PageState.Error)
                        {
                            @if (_isRateLimit)
                            {
                                <AiLimitBanner IsVisible="true"
                                               IsFreeLimit="@_isFreeLimit"
                                               Limit="@(_isFreeLimit ? 5 : 200)" />
                                <button class="reset-button" style="margin-top:1rem;" @onclick="Reset">Try Again</button>
                            }
                            else
                            {
                                <div class="error-container" role="alert">
                                    <span class="error-icon" aria-hidden="true">❌</span>
                                    <p class="error-message">@_error</p>
                                    <button class="reset-button" @onclick="Reset">Try Again</button>
                                </div>
                            }
                        }
                    </div>

                    <aside class="settings-card ai-tool-settings review-contract-settings">
                        <div class="ai-tool-card-header">
                            <span>Review scope</span>
                            <h2>What this analysis checks</h2>
                            <p>AI reviews the uploaded contract for common business and legal risk signals.</p>
                        </div>

                        @if (!_isPro && _aiUsed < 5)
                        {
                            <div class="free-uses-banner">
                                <span>✨ @(5 - _aiUsed) of 5 free AI uses remaining this month</span>
                                <a href="/pricing">Upgrade to Pro for 200 AI uses/month →</a>
                            </div>
                        }

                        <div class="ai-tool-guidance-card review-contract-checks">
                            <h3>Checks included</h3>
                            <div class="ai-tool-guidance-list">
                <span>Potentially risky clauses</span>
                                <span>Missing protections</span>
                                <span>Key obligations</span>
                                <span>Important dates</span>
                            </div>
                        </div>

                        <div class="review-contract-note">
                            This is an AI-generated review and not legal advice.
                        </div>
                    </aside>
                </section>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="faq-section" aria-labelledby="contract-related-title">
        <h2 id="contract-related-title">Related contract tools</h2>
        <div class="faq-item">
            <h3><a href="/compare-pdf">Compare PDF</a></h3>
            <p>Compare two versions of a contract and review likely text changes.</p>
        </div>
        <div class="faq-item">
            <h3><a href="/chat-with-pdf">Chat with PDF</a></h3>
            <p>Ask questions about contract terms, obligations, or sections.</p>
        </div>
        <div class="faq-item">
            <h3><a href="/ai-summarizer">Summarize PDF</a></h3>
            <p>Create a concise summary before deeper review.</p>
        </div>
        <div class="faq-item">
            <h3><a href="/sign-pdf">Sign PDF</a></h3>
            <p>Add an electronic signature after the document is ready.</p>
        </div>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What types of contracts can it review?</h3>
            <p>NDAs, service agreements, employment contracts, lease agreements, freelance contracts, vendor agreements, and any other standard contract format.</p>
        </div>
        <div class="faq-item">
            <h3>Is this a replacement for a lawyer?</h3>
            <p>No. This tool provides AI-assisted contract analysis for informational purposes only. Always consult a qualified attorney for legal advice or legally binding decisions.</p>
        </div>
        <div class="faq-item">
            <h3>Is my contract stored anywhere?</h3>
            <p>No. Your PDF is processed in memory and deleted within 1 hour. We never store document contents permanently.</p>
        </div>
        <div class="faq-item">
            <h3>How accurate is the AI review?</h3>
            <p>It can help identify common clause patterns and risk signals, but AI can miss context. Complex, high-value, or jurisdiction-specific issues should be reviewed by a qualified professional.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Processing, Complete, Error }
    private PageState CurrentState = PageState.Upload;
    private byte[]? _fileBytes;
    private string? _fileName;
    private bool _isPro = false;
    private int _aiUsed = 0;
    private int _step = 0;
    private string _error = string.Empty;
    private bool _isRateLimit = false;
    private bool _isFreeLimit = false;
    private ContractReview? _review;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst("sub")?.Value ?? string.Empty;
            var status = await SubService.GetStatusAsync(userId);
            _isPro = status.HasPro;

            if (!_isPro)
            {
                var usage = await ApiService.GetAsync<AiUsageResponse>("api/ai/usage");
                _aiUsed = usage?.Used ?? 0;
            }
        }
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 52_428_800).CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        _fileName = file.Name;
        _error = string.Empty;
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
    }

    private async Task RunReview()
    {
        if (_fileBytes == null) return;

        CurrentState = PageState.Processing;
        _step = 1;
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            _step = 2; StateHasChanged();

            using var content = new MultipartFormDataContent();
            var fc = new ByteArrayContent(_fileBytes);
            fc.Headers.ContentType = new System.Net.Http.Headers
                .MediaTypeHeaderValue("application/pdf");
            content.Add(fc, "file", _fileName ?? "contract.pdf");

            await Task.Delay(400);
            _step = 3; StateHasChanged();

            var response = await ApiService.PostMultipartWithStatusAsync<ReviewResponse>(
                "api/ai/review", content);

            _step = 4; StateHasChanged();
            await Task.Delay(300);

            if (response.IsRateLimit)
            {
                _isRateLimit = true;
                _isFreeLimit = !_isPro;
                CurrentState = PageState.Error;
                return;
            }

            if (!response.IsSuccess || response.Data == null)
            {
                _error = "Review failed. Please try again.";
                CurrentState = PageState.Error;
                return;
            }

            _review = ParseReview(response.Data.Json);
            CurrentState = PageState.Complete;
            Toast.ShowSuccess("Contract review complete!");
        }
        catch (Exception ex)
        {
            _error = $"Review failed: {ex.Message}";
            CurrentState = PageState.Error;
            Toast.ShowError(_error);
        }

        StateHasChanged();
    }

    private ContractReview? ParseReview(string json)
    {
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<ContractReview>(json, options);
        }
        catch { return null; }
    }

    private static string GetRiskDescription(string risk, int riskyCount) =>
        risk.ToLower() switch
        {
            "high" => $"This contract has {riskyCount} high-risk clause{(riskyCount == 1 ? "" : "s")} that need immediate attention before signing.",
            "medium" => $"This contract has {riskyCount} clause{(riskyCount == 1 ? "" : "s")} worth reviewing. Proceed with caution.",
            _ => "This contract appears relatively standard. Review the details below before signing."
        };

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _fileBytes = null;
        _fileName = null;
        _review = null;
        _error = string.Empty;
        _step = 0;
        _isRateLimit = false;
        _isFreeLimit = false;
    }

    private static string GetRiskIcon(string risk) => risk.ToLower() switch
    {
        "high" => "🔴",
        "medium" => "🟡",
        _ => "🟢"
    };

    private class ReviewResponse
    {
        public string Json { get; set; } = string.Empty;
    }

    private class ContractReview
    {
        public string Summary { get; set; } = string.Empty;
        public string RiskLevel { get; set; } = "medium";
        public List<KeyDate>? KeyDates { get; set; }
        public List<Party>? Parties { get; set; }
        public List<Obligation>? Obligations { get; set; }
        public List<RiskyClause>? RiskyClauses { get; set; }
        public List<string>? MissingElements { get; set; }
        public List<string>? Recommendations { get; set; }
    }

    private class KeyDate
    {
        public string Label { get; set; } = string.Empty;
        public string Date { get; set; } = string.Empty;
        public string Importance { get; set; } = string.Empty;
    }

    private class Party
    {
        public string Role { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    private class Obligation
    {
        public string Party { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public bool Critical { get; set; }
    }

    private class RiskyClause
    {
        public string Title { get; set; } = string.Empty;
        public string Excerpt { get; set; } = string.Empty;
        public string Risk { get; set; } = string.Empty;
        public string Severity { get; set; } = "medium";
    }

    private class AiUsageResponse
    {
        public int Used { get; set; }
        public int Limit { get; set; }
    }
}
