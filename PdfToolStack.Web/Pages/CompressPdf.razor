@page "/compress-pdf"
@page "/fix-pdf-too-large-for-email"
@page "/compress-for-email"

@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject NavigationManager Navigation

<PageTitle>Compress PDF Online Free — Reduce PDF Size Instantly</PageTitle>

<HeadContent>
    <meta name="description" content="Compress PDF files free online — reduce PDF size by up to 80% without losing quality. No signup required. Files deleted in 1 hour." />
    <meta name="keywords" content="compress pdf, reduce pdf size, pdf compressor, shrink pdf file" />
    <link rel="canonical" href="https://pdftoolstack.com/compress-pdf" />
</HeadContent>

<div class="tool-page">

    <AdSlot Size="banner" />

    <div class="tool-container">
        <h1>@PageHeading</h1>
        <p class="tool-subtitle">
            @PageSubtitle
        </p>

        @if (CurrentState == PageState.Upload)
        {
            <FileUpload OnFileSelected="HandleFileSelected"
                        OnFileRemoved="HandleFileRemoved"
                        HintText="@UploadHintText" />

            @if (SelectedFile != null)
            {
                <button class="process-button"
                        @onclick="ProcessFile">
                    @ProcessButtonText
                </button>
            }
        }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                              FileName="@(SelectedFile?.Name ?? "")"
                              ToolType="CompressPdf"
                              Title="This PDF is over the free limit"
                              Message="This file is above the free processing limit."
                              SecondaryButtonText="Return to upload"
                              OnCancel="ResetToFreeMode" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Compressing your PDF...</p>
            </div>
        }

        @if (CurrentState == PageState.Complete && Response != null)
        {
            <AdSlot Size="rectangle" />

            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>Compression Complete!</h2>

                <div class="stats">
                    <div class="stat">
                        <span class="stat-label">Original Size</span>
                        <span class="stat-value">
                            @FormatFileSize(Response.OriginalSizeBytes)
                        </span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Compressed Size</span>
                        <span class="stat-value">
                            @FormatFileSize(Response.OutputSizeBytes)
                        </span>
                    </div>
                    <div class="stat highlight">
                        <span class="stat-label">You Saved</span>
                        <span class="stat-value">
                            @Response.CompressionRatio%
                        </span>
                    </div>
                </div>

                <button class="download-button"
                        @onclick="DownloadFile">
                    Download Compressed PDF
                </button>

                <button class="reset-button"
                        @onclick="Reset">
                    Compress Another PDF
                </button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button" @onclick="Reset">
                    Try Again
                </button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
            <h3>Is this PDF compressor free?</h3>
            <p>
                Yes — free processing is available for files up to 25MB.
                For larger files up to 500MB, upgrade to Pro for $19/month
                with unlimited file size and all AI tools.
            </p>
        </div>

        <div class="faq-item">
            <h3>What is the maximum file size?</h3>
            <p>
                Free processing supports files up to 25MB.
                Pro subscribers ($19/month) can process files up to 500MB
                with no restrictions.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>
                Your file is automatically deleted within
                1 hour of processing. We never store your
                documents permanently.
            </p>
        </div>

        <div class="faq-item">
            <h3>What is the maximum file size?</h3>
            <p>
                Free processing supports files up to 10MB.
                For larger files up to 500MB you can use
                our pay-per-file option for just $0.99.
            </p>
        </div>

        <div class="faq-item">
            <h3>Will compression reduce my PDF quality?</h3>
            <p>
                Text quality is preserved completely.
                Images may have minor quality reduction
                to achieve maximum compression.
            </p>
        </div>
    </div>
</div>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private bool IsEmailMode =>
    Navigation.Uri.Contains("/fix-pdf-too-large-for-email",
        StringComparison.OrdinalIgnoreCase) ||
    Navigation.Uri.Contains("/compress-for-email",
        StringComparison.OrdinalIgnoreCase);

    private string PageHeading =>
        IsEmailMode ? "Fix PDF Too Large for Email" : "Compress PDF Online";

    private string PageSubtitle =>
    IsEmailMode
        ? "Reduce your PDF so it fits Gmail and Outlook limits in seconds. No signup required. Files deleted within 1 hour."
        : PaymentService.IsTestModeEnabled
            ? "Reduce your PDF file size securely. Testing mode is enabled right now. No signup required. Files deleted within 1 hour."
            : "Reduce your PDF file size for free. No signup required. Files deleted within 1 hour.";

    private string ProcessButtonText =>
        IsEmailMode ? "Fix My PDF" : "Compress PDF";

    private string UploadHintText =>
    IsEmailMode
        ? $"Best for Gmail/Outlook attachments · {PaymentService.FormatFileSize(PaymentService.FreeTierMaxBytes)} free · 500MB paid"
        : $"Maximum file size: {PaymentService.FormatFileSize(PaymentService.FreeTierMaxBytes)} free · 500MB paid";

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private ProcessResponse? Response;
    private byte[]? ProcessedBytes;
    private byte[]? UploadedBytes;
    private string? ErrorMessage;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    [SupplyParameterFromQuery]
    private string? JobId { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }

        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesValidation = Validator
                .ValidatePdfBytes(UploadedBytes);
            if (!bytesValidation.IsValid)
            {
                Toast.ShowError(bytesValidation.Message!);
                UploadedBytes = null;
                return;
            }

            if (bytesValidation.IsWarning)
                Toast.ShowWarning(bytesValidation.Message!);

            SelectedFile = file;

            if (PaymentService.IsFileTooLargeForFree(file.Size))
            {
                CurrentState = PageState.LargeFile;

                if (IsEmailMode)
                {
                    Toast.ShowWarning(
                        $"Your PDF is {Validator.FormatSize(file.Size)} and may be too large for email. You can fix it instantly or use free compression.");
                }
            }
            else
            {
                if (IsEmailMode)
                {
                    Toast.ShowSuccess(
                        $"Your PDF is {Validator.FormatSize(file.Size)} and fits within the free tier.");
                }
                else
                {
                    Toast.ShowSuccess(
                        $"File ready — {Validator.FormatSize(file.Size)}");
                }
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError(
                $"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }

        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;
    }

    private async Task ProcessFile()
    {
        if (SelectedFile == null || UploadedBytes == null)
            return;

        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            using var cts = new CancellationTokenSource(
                TimeSpan.FromSeconds(120));

            Response = await ApiService.ProcessPdfAsync(
                UploadedBytes,
                SelectedFile.Name,
                ToolType.CompressPdf);

            if (Response != null && Response.IsSuccess)
            {
                ProcessedBytes = Response.OutputBytes;

                if (ProcessedBytes == null || ProcessedBytes.Length == 0)
                {
                    ErrorMessage = "Compression completed, but no output file was returned.";
                    Toast.ShowError(ErrorMessage);
                    CurrentState = PageState.Error;
                    return;
                }

                CurrentState = PageState.Complete;
                Toast.ShowSuccess("PDF compressed successfully!");
            }
            else
            {
                var msg = Response?.ErrorMessage
                    ?? "Compression failed. Please try again.";
                ErrorMessage = msg;
                Toast.ShowError(msg);
                CurrentState = PageState.Error;
            }
        }
        catch (TaskCanceledException)
        {
            ErrorMessage =
                "Processing timed out after 2 minutes. " +
                "Try a smaller file or split your PDF first.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (HttpRequestException)
        {
            ErrorMessage =
                "Network error — please check your connection " +
                "and try again.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ProcessedBytes == null) return;

        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "compressed")
            + "_compressed.pdf";

        await JS.InvokeVoidAsync(
            "downloadFile",
            fileName,
            Convert.ToBase64String(ProcessedBytes));
    }

    private Task ResetToFreeMode()
    {
        CurrentState = PageState.Upload;
        ErrorMessage = null;
        return Task.CompletedTask;
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        Response = null;
        ProcessedBytes = null;
        UploadedBytes = null;
        ErrorMessage = null;
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024)} MB";
    }
}