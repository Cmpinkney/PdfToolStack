@page "/pdf-to-excel"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>PDF to Excel Converter Free Online — Extract Tables from PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert PDF to Excel spreadsheet free online.
                   Extract tables from PDF to XLSX.
                   No signup required." />
    <meta name="keywords"
          content="pdf to excel, convert pdf to xlsx,
                   pdf table extractor free, pdf to xlsx, extract table from pdf, pdf data extractor" />
    <link rel="canonical"
          href="https://pdftoolstack.com/pdf-to-excel" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <section class="tool-hero">
            <div>
                <div class="trust-row">
                    <span>Secure processing</span>
                    <span>XLSX output</span>
                    <span>Deleted in 1 hour</span>
                </div>

                <h1>Convert PDF to Excel <span class="hero-gradient-text">accurately</span></h1>
                <p class="tool-subtitle">
                    Extract tables, rows, and columns from PDFs into structured
                    XLSX spreadsheets for analysis, cleanup, and reporting.
                </p>
            </div>
        </section>

        <div class="stepper" aria-label="Extraction progress">
            <div class="step @(CurrentState == PageState.Upload && SelectedFile == null ? "active" : SelectedFile != null || CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>1</span>
                <strong>Upload</strong>
            </div>
            <div class="step @(CurrentState == PageState.Upload && SelectedFile != null ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>2</span>
                <strong>Configure</strong>
            </div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">
                <span>3</span>
                <strong>Process</strong>
            </div>
            <div class="step @(CurrentState == PageState.Complete ? "active complete" : "")">
                <span>4</span>
                <strong>Download</strong>
            </div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Upload PDF</span>
                        <h2>Start with your source file</h2>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved"
                                HintText="Upload a PDF — tables and text will be extracted to Excel" />

                    @if (SelectedFile != null)
                    {
                        <div class="file-ready-card">
                            <div>
                                <span class="panel-eyebrow">File ready</span>
                                <strong>@SelectedFile.Name</strong>
                                <small>@FormatFileSize(SelectedFile.Size) selected for spreadsheet extraction</small>
                            </div>
                            <div class="ready-metrics">
                                <span>Table detection</span>
                                <span>Rows and columns</span>
                                <span>Editable XLSX</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-kicker">Data extraction</span>
                            <strong>Upload a PDF with tables or structured data.</strong>
                            <span>Your extraction profile appears once the source file is ready.</span>
                        </div>
                    }
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container" role="status">
                        <div class="spinner"></div>
                        <h2>Building your spreadsheet</h2>
                        <p>Detecting tables, extracting rows, preserving columns, and preparing your XLSX file.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete && OutputBytes != null)
                {
                    <div class="result-container">
                        <span class="result-icon" aria-hidden="true">Ready</span>
                        <h2>Your Excel file is ready</h2>
                        <p class="result-copy">
                            Your PDF data has been extracted into a structured XLSX spreadsheet.
                        </p>
                        <button class="download-button" @onclick="DownloadFile">
                            Download Excel File
                        </button>
                        <button class="reset-button" @onclick="Reset">
                            Convert Another PDF
                        </button>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container" role="alert">
                        <span class="error-icon" aria-hidden="true">Extraction failed</span>
                        <h2>We could not finish the table extraction</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button" @onclick="Reset">Try Again</button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Extraction profile</span>
                    <h2>Create structured spreadsheet</h2>
                    <p>Built for reliable data handoff: table detection, row and column structure, and editable XLSX output.</p>
                </div>

                @if (SelectedFile != null)
                {
                    <div class="file-summary">
                        <span class="file-name">@SelectedFile.Name</span>
                        <span class="file-size">@FormatFileSize(SelectedFile.Size)</span>
                    </div>
                }

                <div class="option-list">
                    <span><strong>Table detection</strong><small>Finds tabular regions and structured data blocks.</small></span>
                    <span><strong>Rows and columns</strong><small>Keeps extracted data organized for review and cleanup.</small></span>
                    <span><strong>Editable spreadsheet</strong><small>Creates XLSX output for Excel, Sheets, and reporting workflows.</small></span>
                </div>

                @if (CurrentState == PageState.Upload && SelectedFile != null)
                {
                    <button class="process-button" @onclick="ProcessFile">
                        Convert to Excel
                    </button>
                    <div class="secure-note">
                        Secure processing. Files are deleted within 1 hour.
                    </div>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>
                        Convert to Excel
                    </button>
                    <p class="action-hint">Upload a PDF to enable extraction.</p>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>How accurate is the conversion?</h3>
            <p>
                The converter extracts all text from your PDF and
                attempts to detect column structure based on spacing.
                Simple tables and structured data work best. Complex
                multi-column layouts may need minor adjustments in Excel.
            </p>
        </div>
        <div class="faq-item">
            <h3>What does the output look like?</h3>
            <p>
                Each PDF page becomes a separate sheet in the Excel
                workbook. Text is organized into columns based on
                its position in the original PDF.
            </p>
        </div>
        <div class="faq-item">
            <h3>Does it work with scanned PDFs?</h3>
            <p>
                Scanned PDFs (image-based) cannot be extracted directly.
                For scanned documents, use our PDF OCR tool first to
                make the text selectable, then convert to Excel.
            </p>
        </div>
        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>
                Your file is automatically deleted within
                1 hour of processing. We never store your
                documents permanently.
            </p>
        </div>
        <div class="faq-item">
            <h3>What is the maximum file size?</h3>
            <p>
                Free processing supports files up to 25MB.
                Larger files up to 500MB are available with
                a Pro subscription.
            </p>
        </div>
    </div>
</div>

