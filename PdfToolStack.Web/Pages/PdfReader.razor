@code {
    private bool IsLoaded = false;
    private int CurrentPage = 1;
    private int PageInput = 1;
    private int TotalPages = 1;
    private int Scale = 100;
    private string? FileName;
    private string? ErrorMessage;
    private string? PdfBase64;

    protected override async Task OnInitializedAsync()
    {
        await HandleOneDriveCallbackIfNeeded();
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        ErrorMessage = null;
        _cloudError = string.Empty;
        FileName = file.Name;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await LoadPdfBytes(file.Name, ms.ToArray());
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Could not open PDF: {ex.Message}";
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        Reset();
    }

    private async Task LoadPdfBytes(string name, byte[] bytes)
    {
        FileName = name;
        PdfBase64 = Convert.ToBase64String(bytes);
        TotalPages = await JS.InvokeAsync<int>("getPdfPageCount", PdfBase64);
        CurrentPage = 1;
        PageInput = 1;
        IsLoaded = true;
        StateHasChanged();
        await RenderPage();
    }

    private async Task RenderPage()
    {
        if (string.IsNullOrEmpty(PdfBase64)) return;
        PageInput = CurrentPage;
        await JS.InvokeVoidAsync("renderPdfReaderPage", PdfBase64, CurrentPage, Scale / 100.0);
    }

    private async Task PreviousPage()
    {
        if (CurrentPage <= 1) return;
        CurrentPage--;
        await RenderPage();
    }

    private async Task NextPage()
    {
        if (CurrentPage >= TotalPages) return;
        CurrentPage++;
        await RenderPage();
    }

    private async Task JumpToPage()
    {
        if (!IsLoaded) return;
        CurrentPage = Math.Clamp(PageInput, 1, TotalPages);
        await RenderPage();
    }

    private async Task HandlePageInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await JumpToPage();
    }

    private async Task ZoomIn()
    {
        if (Scale >= 200) return;
        Scale += 25;
        await RenderPage();
    }

    private async Task ZoomOut()
    {
        if (Scale <= 50) return;
        Scale -= 25;
        await RenderPage();
    }

    private async Task DownloadPdf()
    {
        if (string.IsNullOrEmpty(PdfBase64)) return;

        var fileName = string.IsNullOrWhiteSpace(FileName)
            ? "document.pdf"
            : FileName;

        await JS.InvokeVoidAsync("downloadFile", fileName, PdfBase64);
    }

    private void Reset()
    {
        IsLoaded = false; CurrentPage = 1; PageInput = 1; TotalPages = 1;
        Scale = 100; FileName = null; PdfBase64 = null; ErrorMessage = null;
        _cloudError = string.Empty; _cloudLoading = false;
    }

    // Cloud pickers
    private bool _cloudLoading = false;
    private bool _handledOneDriveCallback = false;
    private string _cloudError = string.Empty;

    private async Task PickGoogleDrive()
    {
        await PickCloudFile("Google Drive", async () =>
            await CloudPicker.OpenGoogleDriveAsync());
    }

    private async Task PickDropbox()
    {
        await PickCloudFile("Dropbox", async () =>
            await CloudPicker.OpenDropboxAsync());
    }

    private async Task PickOneDrive()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();

        try
        {
            await CloudPicker.OpenOneDriveAsync();
        }
        catch (Exception ex)
        {
            _cloudError = $"OneDrive: {ex.Message}";
            _cloudLoading = false;
            StateHasChanged();
        }
    }

    private async Task PickCloudFile(
        string providerName,
        Func<Task<CloudPickerService.CloudFileInfo?>> picker)
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();

        try
        {
            var file = await picker();
            if (file != null)
                await LoadFromCloud(file.Name, file.Url, file.AccessToken);
        }
        catch (Exception ex)
        {
            _cloudError = $"{providerName}: {ex.Message}";
        }
        finally
        {
            _cloudLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleOneDriveCallbackIfNeeded()
    {
        var currentUrl = Navigation.Uri;
        if (_handledOneDriveCallback ||
            !CloudPicker.HasPendingOneDriveCallback(currentUrl))
        {
            return;
        }

        _handledOneDriveCallback = true;
        _cloudLoading = true;
        StateHasChanged();

        try
        {
            var query = System.Web.HttpUtility.ParseQueryString(
                new Uri(currentUrl).Query);

            var cloudError = query["cloud_error"];
            if (!string.IsNullOrEmpty(cloudError))
            {
                _cloudError = cloudError switch
                {
                    "auth_denied" => "OneDrive access was denied.",
                    "token_failed" => "Could not connect to OneDrive. Please try again.",
                    "no_pdfs" => "No PDF files found in your OneDrive root folder.",
                    _ => "OneDrive connection failed. Please try again."
                };
                await CloudPicker.CleanCallbackUrlAsync();
                return;
            }

            var files = CloudPicker.ParseCallbackFiles(currentUrl);
            if (files is null || files.Count == 0)
            {
                await CloudPicker.CleanCallbackUrlAsync();
                return;
            }

            var chosen = await JS.InvokeAsync<OneDriveFileSelection?>(
                "cloudPickers._showOneDrivePicker",
                files.Select(f => new
                {
                    name = f.Name,
                    url = f.Url,
                    size = f.Size,
                    accessToken = f.AccessToken
                }).ToArray());

            await CloudPicker.CleanCallbackUrlAsync();

            if (chosen is not null)
                await LoadFromCloud(
                    chosen.Name,
                    chosen.Url,
                    chosen.AccessToken);
        }
        catch (Exception ex)
        {
            _cloudError = $"OneDrive: {ex.Message}";
        }
        finally
        {
            _cloudLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadFromCloud(string name, string url, string? accessToken)
    {
        var bytes = await CloudPicker.DownloadFileAsync(url, accessToken);
        if (bytes is null || bytes.Length == 0)
        {
            _cloudError = "Could not download file.";
            return;
        }
        await LoadPdfBytes(name, bytes);
    }

    private sealed record OneDriveFileSelection(
        string Name,
        string Url,
        long Size,
        string? AccessToken = null);
}
