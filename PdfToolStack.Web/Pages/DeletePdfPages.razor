</style>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private int TotalPages = 0;
    private int DeletedPageCount = 0;
    private HashSet<int> SelectedPages = new();

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        SelectedPages.Clear();
        TotalPages = 0;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }
        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesVal = Validator
                .ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid)
            {
                Toast.ShowError(bytesVal.Message!);
                UploadedBytes = null;
                return;
            }
            if (bytesVal.IsWarning)
                Toast.ShowWarning(bytesVal.Message!);

            if (PaymentService.IsFileTooLargeForFree(
                file.Size))
            {
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            SelectedFile = file;
            TotalPages = await ApiService.GetPageCountAsync(
                UploadedBytes, file.Name);

            var pageVal = Validator
                .ValidatePageCount(TotalPages);
            if (pageVal.IsWarning)
                Toast.ShowWarning(pageVal.Message!);

            Toast.ShowSuccess(
                $"PDF loaded — {TotalPages} pages");
        }
        catch (Exception ex)
        {
            Toast.ShowError(
                $"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        SelectedPages.Clear();
        TotalPages = 0;
    }

    private void TogglePage(int pageNum)
    {
        if (SelectedPages.Contains(pageNum))
            SelectedPages.Remove(pageNum);
        else
            SelectedPages.Add(pageNum);
        StateHasChanged();
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null ||
            !SelectedPages.Any()) return;

        DeletedPageCount = SelectedPages.Count;
        CurrentState = PageState.Processing;
        StateHasChanged();

        try
        {
            ResultBytes = await ApiService.DeletePagesAsync(
                UploadedBytes,
                SelectedFile!.Name,
                SelectedPages);

            if (ResultBytes != null)
            {
                CurrentState = PageState.Complete;
                Toast.ShowSuccess(
                    $"Deleted {DeletedPageCount} page(s)!");
            }
            else
            {
                ErrorMessage =
                    "Failed to delete pages. Try again.";
                Toast.ShowError(ErrorMessage);
                CurrentState = PageState.Error;
            }
        }
        catch (TaskCanceledException)
        {
            ErrorMessage =
                "Processing timed out. Try a smaller file.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "document")
            + "_pages_deleted.pdf";
        await JS.InvokeVoidAsync("downloadFile",
            fileName,
            Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        TotalPages = 0;
        DeletedPageCount = 0;
        SelectedPages.Clear();
    }
}
