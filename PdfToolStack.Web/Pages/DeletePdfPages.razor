@page "/delete-pdf-pages"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Delete PDF Pages Free Online — Remove Pages from PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Delete pages from your PDF free online.
                   Remove one or multiple pages instantly.
                   No signup required." />
    <meta name="keywords"
          content="delete pdf pages, remove pages from pdf,
                   pdf page remover free" />
    <link rel="canonical"
          href="https://pdftoolstack.com/delete-pdf-pages" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <section class="tool-hero">
            <div class="trust-row">
                <span>Safe page removal</span>
                <span>Review before deleting</span>
                <span>Deleted in 1 hour</span>
            </div>
            <h1>Delete PDF pages <span class="hero-gradient-text">safely</span></h1>
            <p>
                Select the pages you want removed and create a cleaner PDF without
                changing the rest of your document.
            </p>
        </section>

        <div class="stepper" aria-label="Delete pages workflow progress">
            <div class="step @(SelectedFile != null || CurrentState != PageState.Upload ? "complete" : "active")">Upload</div>
            <div class="step @(SelectedFile != null && CurrentState == PageState.Upload ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">Configure</div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">Process</div>
            <div class="step @(CurrentState == PageState.Complete ? "complete active" : "")">Download</div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">PDF upload</span>
                        <h2>Start with your document</h2>
                        <p>Upload a PDF, then mark the pages you want removed.</p>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved" />

                    @if (SelectedFile != null)
                    {
                        <div class="file-summary">
                            <div>
                                <span class="file-name">@SelectedFile.Name</span>
                                <span class="file-size">@Validator.FormatSize(SelectedFile.Size)</span>
                            </div>
                            <span class="status-pill">Ready</span>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <strong>Careful page removal</strong>
                            <span>Review selected pages before creating the cleaned PDF.</span>
                        </div>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade
                        FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                        FileName="@(SelectedFile?.Name ?? "")"
                        ToolType="DeletePdfPages"
                        OnCancel="Reset" />
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container">
                        <div class="spinner"></div>
                        <h2>Deleting selected pages</h2>
                        <p>Removing pages... preserving the rest... preparing your download...</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete
                     && ResultBytes != null)
                {
                    <AdSlot Size="rectangle" />
                    <div class="result-container">
                        <span class="result-icon">Done</span>
                        <h2>Your cleaned PDF is ready</h2>
                        <p>
                            Successfully removed @DeletedPageCount
                            page(s) from your PDF.
                        </p>
                        <button class="download-button"
                                @onclick="DownloadFile">
                            Download PDF
                        </button>
                        <button class="reset-button"
                                @onclick="Reset">
                            Delete More Pages
                        </button>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container">
                        <span class="error-icon">Issue</span>
                        <h2>We could not delete these pages</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button" @onclick="Reset">
                            Try Again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Delete settings</span>
                    <h2>Choose pages to remove</h2>
                    <p>Marked pages are removed from the new PDF output.</p>
                </div>

                @if (SelectedFile != null && TotalPages > 0 && CurrentState == PageState.Upload)
                {
                    <div class="estimate-card">
                        <span>Document length</span>
                        <strong>@TotalPages pages</strong>
                        <small>@SelectedPages.Count page(s) marked for deletion.</small>
                    </div>
                    <div class="page-grid">
                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var pageNum = i;
                            <button class="page-tile @(SelectedPages.Contains(pageNum) ? "page-tile-selected" : "")"
                                    @onclick="() => TogglePage(pageNum)">
                                @pageNum
                                @if (SelectedPages.Contains(pageNum))
                                {
                                    <span class="page-delete-x">x</span>
                                }
                            </button>
                        }
                    </div>
                    @if (SelectedPages.Any())
                    {
                        <p class="selected-summary">
                            @SelectedPages.Count page(s) selected:
                            @string.Join(", ", SelectedPages.OrderBy(p => p))
                        </p>
                    }
                }
                else if (SelectedFile != null && TotalPages == 0 && CurrentState == PageState.Upload)
                {
                    <div class="processing-container compact">
                        <div class="spinner"></div>
                        <p>Loading page count...</p>
                    </div>
                }

                <div class="value-list">
                    <div><strong>Review before removal</strong><span>Selected pages are clearly marked before processing.</span></div>
                    <div><strong>Clean document output</strong><span>The remaining pages stay in their original order.</span></div>
                    <div><strong>Private processing</strong><span>Your file is handled securely and removed after processing.</span></div>
                </div>

                @if (SelectedFile != null && CurrentState == PageState.Upload && SelectedPages.Any())
                {
                    <button class="process-button"
                            @onclick="ProcessFile">
                        Delete @SelectedPages.Count Page(s)
                    </button>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>
                        Select pages to continue
                    </button>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>Can I delete multiple pages at once?</h3>
            <p>Yes — select as many pages as you want
               to remove and delete them in one click.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with
               no signup required.</p>
        </div>
    </div>
</div>

<style>
