@page "/contact"

<PageTitle>Contact PdfToolStack — Support, Billing, Privacy, and Feedback</PageTitle>
<HeadContent>
    <meta name="description" content="Contact PdfToolStack for support, billing questions, privacy requests, security concerns, bug reports, or feature feedback." />
    <link rel="canonical" href="https://pdftoolstack.com/contact" />
</HeadContent>

<main class="contact-page">
    <section class="contact-hero">
        <div>
            <span class="contact-eyebrow">Contact</span>
            <h1>How can we help?</h1>
            <p>
                Get help with PDF tools, Pro subscriptions, privacy questions, bug reports, and workflow feedback.
            </p>
        </div>
        <div class="contact-response-card">
            <span>Typical response</span>
            <strong>1–2 business days</strong>
            <p>For urgent billing or privacy concerns, use the dedicated email below.</p>
        </div>
    </section>

    <section class="contact-intent-grid" aria-label="Contact options">
        <article class="contact-intent-card">
            <div class="contact-icon">?</div>
            <h2>Support</h2>
            <p>Questions about tools, uploads, downloads, or file processing.</p>
            <a href="mailto:hello@pdftoolstack.com">hello@pdftoolstack.com</a>
        </article>
        <article class="contact-intent-card">
            <div class="contact-icon">$</div>
            <h2>Billing</h2>
            <p>Help with Pro subscriptions, add-ons, checkout, or invoices.</p>
            <a href="mailto:billing@pdftoolstack.com">billing@pdftoolstack.com</a>
        </article>
        <article class="contact-intent-card">
            <div class="contact-icon">✓</div>
            <h2>Privacy/security</h2>
            <p>Privacy requests, security concerns, or document handling questions.</p>
            <a href="mailto:privacy@pdftoolstack.com">privacy@pdftoolstack.com</a>
        </article>
        <article class="contact-intent-card">
            <div class="contact-icon">!</div>
            <h2>Bugs/features</h2>
            <p>Report a broken workflow or suggest a better way to handle PDFs.</p>
            <a href="mailto:bugs@pdftoolstack.com">bugs@pdftoolstack.com</a>
        </article>
    </section>

    <section class="contact-guidance-grid">
        <article class="contact-guidance-card">
            <span class="contact-eyebrow">Fastest help</span>
            <h2>What to include</h2>
            <p>
                For fastest help, include the tool name, browser, file size, and error message. If a workflow failed, describe what step you were on.
            </p>
            <ul>
                <li>Tool name or page URL</li>
                <li>Browser and device</li>
                <li>File size and format</li>
                <li>Screenshot or error message if available</li>
            </ul>
        </article>

        <article class="contact-guidance-card contact-privacy-card">
            <span class="contact-eyebrow">Privacy note</span>
            <h2>Please do not email sensitive documents unless requested.</h2>
            <p>
                Many PDFs contain personal, financial, legal, or client information. Start with a description of the issue and we’ll ask for more only if needed.
            </p>
            <a href="/privacy-policy" class="contact-inline-link">Read privacy policy</a>
        </article>
    </section>

    <section class="contact-final-cta">
        <div>
            <span class="contact-eyebrow">Need a workflow instead?</span>
            <h2>Start with your PDF.</h2>
            <p>Most common document tasks can be completed directly from the tools page.</p>
        </div>
        <div class="contact-actions">
            <a href="/" class="contact-btn contact-btn-primary">Browse tools</a>
            <a href="/pricing" class="contact-btn contact-btn-secondary">View pricing</a>
        </div>
    </section>
</main>
