@page "/contact"

<PageTitle>Contact - PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description" content="Contact PdfToolStack for support, billing, privacy, security, bugs, and product feedback." />
    <link rel="canonical" href="https://pdftoolstack.com/contact" />
</HeadContent>

<main class="trust-page">
    <section class="trust-hero">
        <div>
            <span class="trust-eyebrow">Contact</span>
            <h1>Get help with PdfToolStack.</h1>
            <p>
                Send support, billing, privacy, security, bug, or feedback questions to the support
                email below. Please avoid sending sensitive documents unless we specifically ask.
            </p>
        </div>
        <aside class="trust-summary-card">
            <span>Support email</span>
            <a href="mailto:admin@pdftoolstack.com">admin@pdftoolstack.com</a>
            <small>Typical response times may vary while the product is in active development.</small>
        </aside>
    </section>

    <section class="trust-grid">
        <article class="trust-card">
            <h2>Support</h2>
            <p>
                For upload, processing, or download issues, include the tool name, browser, device,
                file type, approximate file size, and the error message you saw.
            </p>
        </article>

        <article class="trust-card">
            <h2>Billing</h2>
            <p>
                For subscription or checkout questions, include the plan or feature involved. Do
                not send credit card numbers or payment details by email.
            </p>
        </article>

        <article class="trust-card">
            <h2>Privacy and security</h2>
            <p>
                If you have a privacy request, security concern, or document-handling question,
                contact us with a short description. We will ask for more detail only if needed.
            </p>
        </article>

        <article class="trust-card">
            <h2>Product feedback</h2>
            <p>
                We welcome reports about broken workflows, confusing output, missing file formats,
                or ideas that would make PDF work faster and safer.
            </p>
        </article>
    </section>
</main>
