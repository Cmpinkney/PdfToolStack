@page "/merge-pdf/app"
@page "/merge-pdfs-for-submission"
@page "/combine-pdf-files"
@inject CloudPickerService CloudPicker
@inject NavigationManager Navigation
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject SessionUsageService SessionUsage
@inject ToastService Toast
@using PdfToolStack.Web.Components
@using static PdfToolStack.Web.Components.FileUpload

<PageTitle>@(IsSubmissionMode ? "Merge PDFs for Submission — Combine Documents Online | PdfToolStack" : "Merge PDF Files Free Online — Combine PDFs Instantly")</PageTitle>

<HeadContent>
    <meta name="description"
          content="@(IsSubmissionMode
                        ? "Combine multiple PDFs into one file for submission. Perfect for applications, tax returns, and legal filings. Free, no signup."
                        : "Merge multiple PDF files into one document free online. No signup required. Combine PDFs instantly.")" />
    <meta name="keywords" content="merge pdf, combine pdf, join pdf files, merge pdf online free" />
    <link rel="canonical" href="https://pdftoolstack.com/merge-pdf" />
</HeadContent>

<div class="tool-page">

    <AdSlot Size="banner" />

    <div class="tool-container">
        <h1>@(IsSubmissionMode ? "Merge PDFs for Submission" : "Merge PDF Files Online")</h1>
        <p class="tool-subtitle">
            @(IsSubmissionMode
                        ? "Combine all your documents into one PDF — ready for tax filing, job applications, court submissions, or client handoffs. Free, files deleted within 1 hour."
                        : "Combine multiple PDF files into one document for free. No signup required. Files deleted within 1 hour.")
        </p>

        @if (CurrentState == PageState.Upload)
        {
            <div class="merge-upload-area">
                @for (int i = 0; i < UploadedFiles.Count; i++)
                {
                    var index = i;
                    <div class="merge-file-item">
                        <span class="merge-file-number">
                            @(index + 1)
                        </span>
                        <span class="merge-file-name">
                            @UploadedFiles[index].Name
                        </span>
                        <span class="merge-file-size">
                            @FormatFileSize(
                            UploadedFileBytes[index].Length)
                </span>
                <button class="remove-button"
                        @onclick="() => RemoveFile(index)">
                    ✕
                </button>
            </div>
                        }

            @if (UploadedFiles.Count < 10)
            {
                <div class="upload-container">
                    <span class="upload-icon">📄</span>
                    <p>
                        @(UploadedFiles.Count == 0
                                            ? "Upload your first PDF"
                                            : "Add another PDF")
                </p>
                <label class="upload-button">
                    Browse File
                    <InputFile OnChange="HandleFileSelected"
                               accept=".pdf"
                               style="display:none" />
                </label>
                <p class="upload-hint">
                    Maximum 10 files, 25MB each
                </p>
                <div class="cloud-picker-row">
                    <span class="cloud-picker-label">OR IMPORT FROM</span>
                    <div class="cloud-picker-buttons">
                        <button class="cloud-picker-btn" @onclick="PickGoogleDrive" disabled="@_cloudLoading">
                            <svg width="16" height="16" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg"><path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da" /><path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44a9.06 9.06 0 0 0 -1.2 4.5h27.5z" fill="#00ac47" /><path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.502l5.852 11.5z" fill="#ea4335" /><path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d" /><path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc" /><path d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 28h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00" /></svg>
                            Google Drive
                        </button>
                        <button class="cloud-picker-btn" @onclick="PickDropbox" disabled="@_cloudLoading">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#0061FF"><path d="M6 2L0 6l6 4-6 4 6 4 6-4-6-4 6-4L6 2zm12 0l-6 4 6 4-6 4 6 4 6-4-6-4 6-4-6-4zm-6 13l-6 4 6 4 6-4-6-4z" /></svg>
                            Dropbox
                        </button>
                    </div>
                </div>
                @if (_cloudLoading)
                    {
                        <p class="cloud-loading-hint">⏳ Downloading from cloud...</p>
                    }
                    @if (!string.IsNullOrEmpty(_cloudError))
                    {
                        <p class="error-message">@_cloudError</p>
                    }
            </div>
                        }
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <p class="error-message">@ErrorMessage</p>
        }

        @if (UploadedFiles.Count >= 2)
        {
            <button class="process-button"
                    @onclick="ProcessFiles">
                Merge @UploadedFiles.Count PDFs
            </button>
        }
        else if (UploadedFiles.Count == 1)
        {
            <p style="color: var(--gray); margin-top: 1rem;">
                Add at least one more PDF to merge
            </p>
        }
                }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@_largeFileSize"
                              FileName="@_largeFileName"
                              ToolType="MergePdf"
                              OnCancel="Reset" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Merging your PDFs...</p>
            </div>
        }

        @if (CurrentState == PageState.Complete
                && Response != null)
        {
            <AdSlot Size="rectangle" />

            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>Merge Complete!</h2>

                <div class="stats">
                    <div class="stat">
                        <span class="stat-label">Files Merged</span>
                        <span class="stat-value">
                            @MergedFileCount
                        </span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Final Size</span>
                        <span class="stat-value">
                            @FormatFileSize(Response.OutputSizeBytes)
                        </span>
                    </div>
                </div>

                <button class="download-button"
                        @onclick="DownloadFile">
                    Download Merged PDF
                </button>

                <button class="reset-button"
                        @onclick="Reset">
                    Merge More PDFs
                </button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button" @onclick="Reset">
                    Try Again
                </button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
            <h3>How many PDFs can I merge at once?</h3>
            <p>
                You can merge up to 10 PDF files at once.
                Each file can be up to 25MB free or
                500MB with pay-per-file.
            </p>
        </div>

        <div class="faq-item">
            <h3>Will the merged PDF have a watermark?</h3>
            <p>
                No watermarks ever. Your merged PDF is
                completely clean and ready to use.
            </p>
        </div>

        <div class="faq-item">
            <h3>Can I reorder the files before merging?</h3>
            <p>
                Files are merged in the order you upload them.
                Upload them in the order you want them
                combined.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>
                Your files are automatically deleted within
                1 hour. We never store your documents
                permanently.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is this PDF merger free?</h3>
            <p>
                Yes — completely free up to 25MB per file
                with no signup required.
            </p>
        </div>
    </div>
</div>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private List<IBrowserFile> UploadedFiles = new();
    private List<byte[]> UploadedFileBytes = new();
    private ProcessResponse? Response;
    private byte[]? MergedBytes;
    private string? ErrorMessage;
    private bool IsDragging = false;
    private int MergedFileCount = 0;
    private long _largeFileSize = 0;
    private string _largeFileName = string.Empty;
    private bool _cloudLoading = false;
    private string _cloudError = string.Empty;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(
        InputFileChangeEventArgs e)
    {
        ErrorMessage = null;
        var file = e.File;

        if (PaymentService.IsFileTooLargeForFree(file.Size))
        {
            _largeFileSize = file.Size;
            _largeFileName = file.Name;
            CurrentState = PageState.LargeFile;
            StateHasChanged();
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 52428800);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();
            UploadedFiles.Add(file);
            UploadedFileBytes.Add(bytes);
        }
        catch (Exception ex)
        {
            ErrorMessage =
                $"Could not read {file.Name}: {ex.Message}";
        }

        StateHasChanged();
    }

    private void RemoveFile(int index)
    {
        UploadedFiles.RemoveAt(index);
        UploadedFileBytes.RemoveAt(index);
        StateHasChanged();
    }

    private async Task ProcessFiles()
    {
        if (UploadedFileBytes.Count < 2) return;

        CurrentState = PageState.Processing;
        MergedFileCount = UploadedFiles.Count;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();

            for (int i = 0; i < UploadedFileBytes.Count; i++)
            {
                var fileContent = new ByteArrayContent(
                    UploadedFileBytes[i]);
                fileContent.Headers.ContentType =
                    new System.Net.Http.Headers
                        .MediaTypeHeaderValue("application/pdf");
                content.Add(fileContent, "files",
                    UploadedFiles[i].Name);
            }

            Response = await ApiService.MergePdfsAsync(content);

            if (Response != null && Response.IsSuccess)
            {
                MergedBytes = await ApiService
                    .GetMergedBytesAsync();
                CurrentState = PageState.Complete;
            }
            else
            {
                ErrorMessage = Response?.ErrorMessage
                    ?? "Merge failed. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task PickGoogleDrive()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenGoogleDriveAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Google Drive: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task PickDropbox()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenDropboxAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Dropbox: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task LoadCloudFile(string name, string url, string? accessToken)
    {
        var bytes = await CloudPicker.DownloadFileAsync(url, accessToken);
        if (bytes is null || bytes.Length == 0) { _cloudError = "Could not download file. Please try again."; return; }
        // For MergePdf — add to the PDF list
        UploadedFileBytes.Add(bytes);
        UploadedFiles.Add(new CloudBrowserFile(name, bytes));
        Toast.ShowSuccess($"Added {name}");
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (MergedBytes == null) return;

        await JS.InvokeVoidAsync(
            "downloadFile",
            "merged.pdf",
            Convert.ToBase64String(MergedBytes));
        SessionUsage.RecordToolCompletion("Sign PDF");
    }

    private bool IsSubmissionMode =>
        Navigation.Uri.Contains("/merge-pdfs-for-submission",
            StringComparison.OrdinalIgnoreCase) ||
        Navigation.Uri.Contains("/combine-pdf-files",
            StringComparison.OrdinalIgnoreCase);

    private void Reset()
    {
        CurrentState = PageState.Upload;
        UploadedFiles.Clear();
        UploadedFileBytes.Clear();
        Response = null;
        MergedBytes = null;
        ErrorMessage = null;
        MergedFileCount = 0;
        _largeFileSize = 0;
        _largeFileName = string.Empty;
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024)} MB";
    }
}