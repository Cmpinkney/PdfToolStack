@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private List<IBrowserFile> UploadedFiles = new();
    private List<byte[]> UploadedFileBytes = new();
    private ProcessResponse? Response;
    private byte[]? MergedBytes;
    private string? ErrorMessage;
    private int MergedFileCount = 0;
    private long _largeFileSize = 0;
    private string _largeFileName = string.Empty;
    private bool _cloudLoading = false;
    private string _cloudError = string.Empty;

    private long EstimatedOutputBytes =>
        UploadedFileBytes.Sum(bytes => (long)bytes.Length);

    private string GetStepClass(string step)
    {
        if (CurrentState == PageState.Complete)
            return "step complete";

        if (CurrentState == PageState.Processing)
            return step == "Merge" ? "step active" : "step complete";

        if (CurrentState == PageState.Upload && UploadedFiles.Count == 0)
            return step == "Upload" ? "step active" : "step";

        if (CurrentState == PageState.Upload && UploadedFiles.Count > 0)
        {
            if (step == "Upload")
                return "step complete";

            return step == "Arrange" ? "step active" : "step";
        }

        if (CurrentState == PageState.LargeFile)
            return step == "Upload" ? "step active" : "step";

        return "step";
    }

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(
        InputFileChangeEventArgs e)
    {
        ErrorMessage = null;
        var file = e.File;

        if (PaymentService.IsFileTooLargeForFree(file.Size))
        {
            _largeFileSize = file.Size;
            _largeFileName = file.Name;
            CurrentState = PageState.LargeFile;
            StateHasChanged();
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 52428800);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();
            UploadedFiles.Add(file);
            UploadedFileBytes.Add(bytes);
        }
        catch (Exception ex)
        {
            ErrorMessage =
                $"Could not read {file.Name}: {ex.Message}";
        }

        StateHasChanged();
    }

    private void RemoveFile(int index)
    {
        UploadedFiles.RemoveAt(index);
        UploadedFileBytes.RemoveAt(index);
        StateHasChanged();
    }

    private async Task ProcessFiles()
    {
        if (UploadedFileBytes.Count < 2) return;

        CurrentState = PageState.Processing;
        MergedFileCount = UploadedFiles.Count;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();

            for (int i = 0; i < UploadedFileBytes.Count; i++)
            {
                var fileContent = new ByteArrayContent(
                    UploadedFileBytes[i]);
                fileContent.Headers.ContentType =
                    new System.Net.Http.Headers
                        .MediaTypeHeaderValue("application/pdf");
                content.Add(fileContent, "files",
                    UploadedFiles[i].Name);
            }

            Response = await ApiService.MergePdfsAsync(content);

            if (Response != null && Response.IsSuccess)
            {
                MergedBytes = await ApiService
                    .GetMergedBytesAsync();
                CurrentState = PageState.Complete;
            }
            else
            {
                ErrorMessage = Response?.ErrorMessage
                    ?? "Merge failed. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task PickGoogleDrive()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenGoogleDriveAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Google Drive: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task PickDropbox()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenDropboxAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Dropbox: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task LoadCloudFile(string name, string url, string? accessToken)
    {
        var bytes = await CloudPicker.DownloadFileAsync(url, accessToken);
        if (bytes is null || bytes.Length == 0) { _cloudError = "Could not download file. Please try again."; return; }
        // For MergePdf — add to the PDF list
        UploadedFileBytes.Add(bytes);
        UploadedFiles.Add(new CloudBrowserFile(name, bytes));
        Toast.ShowSuccess($"Added {name}");
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (MergedBytes == null) return;

        await JS.InvokeVoidAsync(
            "downloadFile",
            "merged.pdf",
            Convert.ToBase64String(MergedBytes));
        SessionUsage.RecordToolCompletion("Sign PDF");
    }

    private bool IsSubmissionMode =>
        Navigation.Uri.Contains("/merge-pdfs-for-submission",
            StringComparison.OrdinalIgnoreCase) ||
        Navigation.Uri.Contains("/combine-pdf-files",
            StringComparison.OrdinalIgnoreCase);

    private void Reset()
    {
        CurrentState = PageState.Upload;
        UploadedFiles.Clear();
        UploadedFileBytes.Clear();
        Response = null;
        MergedBytes = null;
        ErrorMessage = null;
        MergedFileCount = 0;
        _largeFileSize = 0;
        _largeFileName = string.Empty;
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024)} MB";
    }
}
