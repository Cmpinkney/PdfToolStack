@page "/merge-pdf/app"
@page "/merge-pdfs-for-submission"
@page "/combine-pdf-files"
@inject CloudPickerService CloudPicker
@inject NavigationManager Navigation
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject SessionUsageService SessionUsage
@inject ToastService Toast
@using PdfToolStack.Web.Components
@using static PdfToolStack.Web.Components.FileUpload

<PageTitle>@(IsSubmissionMode ? "Merge PDFs for Submission — Combine Documents Online | PdfToolStack" : "Merge PDF Files Free Online — Combine PDFs Instantly")</PageTitle>

<HeadContent>
    <meta name="description"
          content="@(IsSubmissionMode
                        ? "Combine multiple PDFs into one file for submission. Perfect for applications, tax returns, and legal filings. Free, no signup."
                        : "Merge multiple PDF files into one document free online. No signup required. Combine PDFs instantly.")" />
    <meta name="keywords" content="merge pdf, combine pdf, join pdf files, merge pdf online free" />
    <link rel="canonical" href="https://pdftoolstack.com/merge-pdf" />
</HeadContent>

<div class="tool-page">

    <AdSlot Size="banner" />

    <div class="tool-container">
        <section class="tool-hero">
            <div>
                <div class="trust-row">
                    <span>Secure processing</span>
                    <span>Reorder before merging</span>
                    <span>Deleted in 1 hour</span>
                </div>

                <h1>Merge PDFs <span class="hero-gradient-text">smoothly</span></h1>
                <p class="tool-subtitle">
                    Combine multiple PDFs in the exact order you need. Secure processing,
                    fast download, and files deleted within 1 hour.
                </p>
            </div>
        </section>

        <div class="stepper" aria-label="Merge workflow progress">
            <div class="@GetStepClass("Upload")">
                <span>1</span>
                <strong>Upload</strong>
            </div>
            <div class="@GetStepClass("Arrange")">
                <span>2</span>
                <strong>Arrange</strong>
            </div>
            <div class="@GetStepClass("Merge")">
                <span>3</span>
                <strong>Process</strong>
            </div>
            <div class="@GetStepClass("Download")">
                <span>4</span>
                <strong>Download</strong>
            </div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">File queue</span>
                        <h2>Build your merge order</h2>
                    </div>

                    @if (UploadedFiles.Count > 0)
                    {
                        <div class="queue-helper">
                            <span class="empty-kicker">Merge queue</span>
                            <strong>Files will be merged in this order.</strong>
                            <span>Order files before upload/removal for now.</span>
                        </div>

                        <div class="file-queue">
                            @for (int i = 0; i < UploadedFiles.Count; i++)
                            {
                                var index = i;
                                <div class="file-item">
                                    <span class="file-number">
                                        @(index + 1)
                                    </span>
                                    <div class="file-details">
                                        <span class="file-name">
                                            @UploadedFiles[index].Name
                                        </span>
                                        <span class="file-size">
                                            @FormatFileSize(UploadedFileBytes[index].Length)
                                        </span>
                                        <span class="file-type">
                                            @Path.GetExtension(UploadedFiles[index].Name).TrimStart('.').ToUpperInvariant()
                                        </span>
                                    </div>
                                    <span class="file-status">Ready to process</span>
                                    <button class="remove-button"
                                            aria-label="Remove file"
                                            @onclick="() => RemoveFile(index)">
                                        x
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-kicker">Document assembly</span>
                            <strong>Upload two or more PDFs to start.</strong>
                            <span>Your files will appear here as a clean merge queue.</span>
                        </div>
                    }

                    @if (UploadedFiles.Count < 10)
                    {
                        <div class="upload-container">
                            <span class="upload-icon">PDF</span>
                            <p>
                                @(UploadedFiles.Count == 0
                                    ? "Upload your first PDF"
                                    : "Add another PDF")
                            </p>
                            <label class="upload-button">
                                Browse File
                                <InputFile OnChange="HandleFileSelected"
                                           accept=".pdf"
                                           style="display:none" />
                            </label>
                            <p class="upload-hint">
                                Maximum 10 files, 25MB each
                            </p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <p class="error-message">@ErrorMessage</p>
                    }
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container">
                        <div class="spinner"></div>
                        <h2>Combining your PDFs</h2>
                        <p>Preserving order, keeping original quality, and preparing one polished download.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete
                        && Response != null)
                {
                    <AdSlot Size="rectangle" />

                    <div class="result-container">
                        <span class="result-icon">Ready</span>
                        <h2>Your merged PDF is ready</h2>
                        <p class="result-copy">@MergedFileCount files combined into a single clean PDF.</p>

                        <div class="stats">
                            <div class="stat">
                                <span class="stat-label">Files Merged</span>
                                <span class="stat-value">
                                    @MergedFileCount
                                </span>
                            </div>
                            <div class="stat">
                                <span class="stat-label">Final Size</span>
                                <span class="stat-value">
                                    @FormatFileSize(Response.OutputSizeBytes)
                                </span>
                            </div>
                        </div>

                        <button class="download-button"
                                @onclick="DownloadFile">
                            Download Merged PDF
                        </button>

                        <button class="reset-button"
                                @onclick="Reset">
                            Merge another set
                        </button>

                        <RecentFiles FileName="@($"Merged PDF ({MergedFileCount} files)")"
                                     ToolName="Merge PDF"
                                     OnDownloadAgain="@DownloadFile" />
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container">
                        <span class="error-icon">Merge failed</span>
                        <h2>We could not finish the merge</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button" @onclick="Reset">
                            Try Again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade FileSizeBytes="@_largeFileSize"
                                      FileName="@_largeFileName"
                                      ToolType="MergePdf"
                                      OnCancel="Reset" />
                }
                else
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Merge workflow</span>
                        <h2>Ready to combine</h2>
                        <p>Build a controlled document package with preserved order, secure processing, and one final PDF output.</p>
                    </div>

                    <div class="estimate-card">
                        <span>Estimated final output</span>
                        <strong>@FormatFileSize(EstimatedOutputBytes)</strong>
                        <small>@UploadedFiles.Count file@(UploadedFiles.Count == 1 ? "" : "s") selected</small>
                    </div>

                    <div class="option-list">
                        <span><strong>Order control</strong><small>Files merge in the queue order shown in the workspace.</small></span>
                        <span><strong>Combined output</strong><small>Multiple PDFs become one clean document for submission or sharing.</small></span>
                        <span><strong>Secure processing</strong><small>Files are processed privately and deleted within 1 hour.</small></span>
                    </div>

                    <div class="cloud-row">
                        <span class="cloud-label">Import from cloud</span>
                        <div class="cloud-actions">
                            <button type="button" class="cloud-btn" @onclick="PickDropbox" disabled="@_cloudLoading">
                                <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M7.1 3.2 2 6.5l5.1 3.3 5.1-3.3-5.1-3.3Zm9.8 0-5.1 3.3 5.1 3.3L22 6.5l-5.1-3.3ZM2 13l5.1 3.3 5.1-3.3-5.1-3.3L2 13Zm14.9-3.3L11.8 13l5.1 3.3L22 13l-5.1-3.3ZM12 14.8 7.1 18 12 21.2l4.9-3.2-4.9-3.2Z" fill="#0061FF" />
                                </svg>
                                Dropbox
                            </button>
                            <button type="button" class="cloud-btn" @onclick="PickGoogleDrive" disabled="@_cloudLoading">
                                <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M9.6 3.2 3 14.5h4.5l6.5-11.3H9.6Z" fill="#34A853" />
                                    <path d="M14.1 3.2h-4.5l6.6 11.3h4.5L14.1 3.2Z" fill="#FBBC04" />
                                    <path d="M7.5 14.5 9.8 18.4h10.9L18.4 14.5H7.5Z" fill="#4285F4" />
                                </svg>
                                Google Drive
                            </button>
                        </div>
                    </div>

                    @if (_cloudLoading)
                    {
                        <p class="cloud-status">Importing from cloud...</p>
                    }
                    @if (!string.IsNullOrEmpty(_cloudError))
                    {
                        <p class="cloud-error">@_cloudError</p>
                    }

                    @if (CurrentState == PageState.Upload && UploadedFiles.Count >= 2)
                    {
                        <button class="process-button"
                                @onclick="ProcessFiles">
                            Merge PDFs
                        </button>
                        <div class="secure-note">
                            Secure processing. Files are deleted within 1 hour.
                        </div>
                    }
                    else if (CurrentState == PageState.Upload)
                    {
                        <button class="process-button disabled" disabled>
                            Merge PDFs
                        </button>
                        <p class="action-hint">
                            Add at least two PDFs to enable merging.
                        </p>
                    }
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
            <h3>How many PDFs can I merge at once?</h3>
            <p>
                You can merge up to 10 PDF files at once.
                Each file can be up to 25MB free or
                500MB with pay-per-file.
            </p>
        </div>

        <div class="faq-item">
            <h3>Will the merged PDF have a watermark?</h3>
            <p>
                No watermarks ever. Your merged PDF is
                completely clean and ready to use.
            </p>
        </div>

        <div class="faq-item">
            <h3>Can I reorder the files before merging?</h3>
            <p>
                Files are merged in the order you upload them.
                Upload them in the order you want them
                combined.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>
                Your files are automatically deleted within
                1 hour. We never store your documents
                permanently.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is this PDF merger free?</h3>
            <p>
                Yes — completely free up to 25MB per file
                with no signup required.
            </p>
        </div>
    </div>
</div>

<style>
    .tool-page {
        width: 100%;
        max-width: none;
        min-height: calc(100vh - 72px);
        min-width: 0;
        margin: 0;
        padding: 48px 0 72px;
        box-sizing: border-box;
        background:
            radial-gradient(circle at top left, rgba(109, 40, 217, 0.12), transparent 32%),
            linear-gradient(135deg, #f8f7ff 0%, #eef5ff 100%);
        color: #172033;
    }

    .tool-container {
        width: min(1320px, calc(100% - 64px));
        max-width: 1320px;
        margin: 0 auto;
        padding: 0;
        background: transparent !important;
        border: 0 !important;
        border-radius: 0;
        box-shadow: none !important;
        text-align: left;
        box-sizing: border-box;
    }

    .tool-hero {
        width: 100%;
        max-width: none;
        text-align: left;
        margin-bottom: 24px;
    }

    .tool-hero h1 {
        max-width: 900px;
        margin: 0 0 14px;
        color: #111827;
        font-size: clamp(2.4rem, 3vw, 3.8rem);
        line-height: 1.02;
        letter-spacing: -0.04em;
    }

    .hero-gradient-text {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .tool-subtitle {
        max-width: 760px;
        margin: 0;
        color: #5b6475;
        font-size: 1rem;
        line-height: 1.7;
    }

    .trust-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .trust-row span {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(148, 163, 184, 0.24);
        box-shadow: 0 10px 26px rgba(37, 99, 235, 0.08);
        color: #334155;
        font-size: 0.85rem;
        font-weight: 700;
        padding: 0.45rem 0.8rem;
    }

    .trust-row span::before {
        content: "";
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    }

    .stepper {
        width: 100%;
        max-width: none;
        margin: 0 0 24px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        padding: 8px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.8);
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    }

    .step {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        border-radius: 999px;
        color: #64748b;
        padding: 0.45rem 0.7rem 0.45rem 0.45rem;
        transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .step span {
        display: grid;
        place-items: center;
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 50%;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .step strong {
        font-size: 0.88rem;
        white-space: nowrap;
    }

    .step.active {
        background: linear-gradient(135deg, rgba(109, 93, 252, 0.15), rgba(37, 99, 235, 0.12));
        color: #1e293b;
        box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.12);
    }

    .step.complete {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        color: #ffffff;
    }

    .step.complete span {
        background: rgba(255, 255, 255, 0.22);
        color: #ffffff;
    }

    .workflow-grid {
        width: 100%;
        max-width: none;
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(360px, 0.75fr);
        gap: 28px;
        align-items: start;
    }

    .workspace-card,
    .settings-card {
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(148, 163, 184, 0.18);
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
        width: 100%;
        max-width: none;
        min-width: 0;
        padding: 28px;
        box-sizing: border-box;
    }

    .upload-card,
    .upload-zone,
    .file-upload,
    .dropzone,
    .file-upload-container {
        width: 100%;
        max-width: none;
    }

    .settings-card {
        position: sticky;
        top: 1rem;
    }

    .panel-header {
        margin-bottom: 1rem;
    }

    .panel-header h2 {
        margin: 0.25rem 0 0;
        color: #111827;
        font-size: 1.25rem;
        line-height: 1.2;
    }

    .panel-header p {
        margin: 0.45rem 0 0;
        color: #64748b;
        font-size: 0.92rem;
        line-height: 1.55;
    }

    .panel-eyebrow {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .empty-state,
    .queue-helper {
        display: grid;
        gap: 0.35rem;
        border-radius: 20px;
        background: #f8fafc;
        color: #64748b;
        margin-bottom: 1rem;
        padding: 1rem;
    }

    .empty-state strong,
    .queue-helper strong {
        color: #1e293b;
        font-size: 1.05rem;
    }

    .empty-kicker {
        color: #2563eb;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .file-queue {
        display: grid;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .file-item {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto auto;
        align-items: center;
        gap: 0.8rem;
        border-radius: 18px;
        background:
            linear-gradient(135deg, rgba(109, 93, 252, 0.045), rgba(6, 182, 212, 0.035)),
            #ffffff;
        box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.16), 0 12px 28px rgba(15, 23, 42, 0.05);
        padding: 0.85rem;
    }

    .file-number {
        display: grid;
        place-items: center;
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
        background: #eef2ff;
        color: #4f46e5;
        font-weight: 900;
    }

    .file-details {
        display: grid;
        gap: 0.2rem;
        min-width: 0;
    }

    .file-name {
        color: #172033;
        font-weight: 850;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .file-size {
        color: #64748b;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .file-type {
        display: inline-flex;
        width: fit-content;
        border-radius: 999px;
        background: rgba(255, 255, 255, .82);
        color: #475569;
        font-size: .74rem;
        font-weight: 900;
        padding: .3rem .55rem;
    }

    .file-status {
        border-radius: 999px;
        background: rgba(6, 182, 212, 0.1);
        color: #0e7490;
        font-size: 0.78rem;
        font-weight: 900;
        padding: 0.35rem 0.65rem;
    }

    .remove-button {
        display: grid;
        place-items: center;
        width: 2rem;
        height: 2rem;
        border: 0;
        border-radius: 50%;
        background: #f1f5f9;
        color: #475569;
        cursor: pointer;
        font-weight: 900;
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }

    .remove-button:hover {
        background: #fee2e2;
        color: #b91c1c;
        transform: translateY(-1px);
    }

    .upload-container {
        display: grid;
        justify-items: center;
        gap: 0.75rem;
        border-radius: 24px;
        background: #f8fafc;
        box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.16);
        padding: 1.5rem;
        text-align: center;
    }

    .upload-icon {
        display: grid;
        place-items: center;
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(109, 93, 252, 0.14), rgba(6, 182, 212, 0.12));
        color: #3730a3;
        font-size: 0.88rem;
        font-weight: 900;
    }

    .upload-container p {
        margin: 0;
        color: #475569;
        font-weight: 750;
    }

    .upload-button {
        border-radius: 14px;
        background: #111827;
        color: #ffffff;
        cursor: pointer;
        font-weight: 900;
        padding: 0.8rem 1rem;
    }

    .upload-hint,
    .action-hint {
        color: #64748b;
        font-size: 0.9rem;
        margin: 0.75rem 0 0;
    }

    .estimate-card {
        display: grid;
        gap: 0.25rem;
        border-radius: 22px;
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        color: #ffffff;
        margin-bottom: 1rem;
        padding: 1rem;
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.22);
    }

    .estimate-card span {
        font-size: 0.82rem;
        font-weight: 800;
        opacity: 0.86;
        text-transform: uppercase;
    }

    .estimate-card strong {
        font-size: 2rem;
        line-height: 1.1;
    }

    .estimate-card small {
        font-size: 0.92rem;
        opacity: 0.88;
    }

    .option-list {
        display: grid;
        gap: 0.65rem;
        margin-bottom: 1rem;
    }

    .option-list span {
        display: grid;
        gap: 0.2rem;
        border-radius: 16px;
        background: #f8fafc;
        color: #475569;
        padding: 0.8rem 0.9rem;
    }

    .option-list strong {
        color: #172033;
        font-size: 0.95rem;
    }

    .option-list small {
        color: #64748b;
        font-size: 0.82rem;
        line-height: 1.45;
    }

    .cloud-row {
        display: grid;
        gap: .75rem;
        border: 1px solid rgba(148, 163, 184, .2);
        border-radius: 18px;
        background: rgba(248, 250, 252, .9);
        margin-bottom: 1rem;
        padding: 1rem;
        text-align: center;
    }

    .cloud-label {
        color: #64748b;
        font-size: .72rem;
        font-weight: 950;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .cloud-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .65rem;
    }

    .cloud-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        min-height: 44px;
        border: 1px solid rgba(148, 163, 184, .24);
        border-radius: 14px;
        background: #fff;
        color: #334155;
        cursor: pointer;
        font-size: .86rem;
        font-weight: 900;
        padding: .72rem .9rem;
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

    .cloud-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        border-color: rgba(37, 99, 235, .3);
        box-shadow: 0 12px 24px rgba(37, 99, 235, .1);
    }

    .cloud-btn:disabled,
    .process-button.disabled {
        cursor: not-allowed;
        opacity: 0.58;
    }

    .cloud-icon {
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
    }

    .cloud-status,
    .cloud-error {
        margin: 0 0 1rem;
        font-size: .84rem;
        font-weight: 750;
        line-height: 1.45;
    }

    .cloud-status {
        color: #64748b;
    }

    .cloud-error {
        color: #dc2626;
    }

    .process-button,
    .download-button {
        width: 100%;
        border: 0;
