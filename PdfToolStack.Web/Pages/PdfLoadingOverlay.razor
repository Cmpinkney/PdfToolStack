@if (IsVisible)
{
    <div class="pdf-loading-overlay">
        <div class="pdf-loading-card">
            <div class="pdf-loading-spinner">
                <svg viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="25" cy="25" r="20" fill="none" stroke="var(--primary)" stroke-width="4"
                            stroke-linecap="round" stroke-dasharray="31.4 94.2">
                        <animateTransform attributeName="transform" type="rotate"
                                          dur="0.8s" from="0 25 25" to="360 25 25"
                                          repeatCount="indefinite" />
                    </circle>
                </svg>
            </div>
            <div class="pdf-loading-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                </svg>
            </div>
            <p class="pdf-loading-msg">@Message</p>
            @if (!string.IsNullOrEmpty(SubMessage))
            {
                <p class="pdf-loading-sub">@SubMessage</p>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Message { get; set; } = "Loading PDF...";
    [Parameter] public string? SubMessage { get; set; }
}
