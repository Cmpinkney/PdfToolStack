@page "/pdf-to-word"
@page "/convert-pdf-to-editable-word"
@inject NavigationManager Navigation
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>@(IsEditMode ? "Convert PDF to Editable Word Document Free | PdfToolStack" : "PDF to Word Converter Free Online — Convert PDF to DOCX")</PageTitle>

<HeadContent>
    <meta name="description"
          content="@(IsEditMode
                        ? "Convert your PDF to an editable Word document instantly. Edit text, tables, and formatting. Free, no signup, files deleted in 1 hour."
                        : "Convert PDF to Word document free online. No signup required. Download your DOCX file instantly.")" />
    <meta name="keywords" content="pdf to word, convert pdf to docx, pdf to word converter free" />
    <link rel="canonical" href="https://pdftoolstack.com/pdf-to-word" />
</HeadContent>

<div class="tool-page">

    <AdSlot Size="banner" />

    <div class="tool-container">
        <section class="tool-hero">
            <div>
                <div class="trust-row">
                    <span>Secure processing</span>
                    <span>Editable DOCX</span>
                    <span>Deleted in 1 hour</span>
                </div>

                <h1>Convert PDF to Word <span class="hero-gradient-text">cleanly</span></h1>
                <p class="tool-subtitle">
                    Turn PDFs into editable DOCX files with clean text extraction,
                    preserved structure, and dependable layout conversion.
                </p>
            </div>
        </section>

        <div class="stepper" aria-label="Conversion progress">
            <div class="step @(CurrentState == PageState.Upload && SelectedFile == null ? "active" : SelectedFile != null || CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>1</span>
                <strong>Upload</strong>
            </div>
            <div class="step @(CurrentState == PageState.Upload && SelectedFile != null ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>2</span>
                <strong>Configure</strong>
            </div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">
                <span>3</span>
                <strong>Process</strong>
            </div>
            <div class="step @(CurrentState == PageState.Complete ? "active complete" : "")">
                <span>4</span>
                <strong>Download</strong>
            </div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Upload PDF</span>
                        <h2>Start with your document</h2>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved" />

                    @if (SelectedFile != null)
                    {
                        <div class="file-ready-card">
                            <div class="file-ready-header">
                                <div class="file-ready-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z" />
                                        <polyline points="14 2 14 7 19 7" />
                                        <polyline points="9 14 11 16 15 12" />
                                    </svg>
                                </div>
                                <div>
                                <span class="panel-eyebrow">Ready to process</span>
                                <strong>@SelectedFile.Name</strong>
                                <div class="file-ready-meta">
                                    <span>@Path.GetExtension(SelectedFile.Name).TrimStart('.').ToUpperInvariant()</span>
                                    <span>@FormatFileSize(SelectedFile.Size)</span>
                                </div>
                                <small>Will convert to DOCX</small>
                                </div>
                            </div>
                            <div class="ready-metrics">
                                <span>Editable text</span>
                                <span>Layout preserved</span>
                                <span>DOCX output</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-kicker">Document conversion</span>
                            <strong>Upload a PDF to create a clean editable Word file.</strong>
                            <span>Your conversion profile appears once the document is ready.</span>
                        </div>
                    }
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container">
                        <div class="spinner"></div>
                        <h2>Building your Word document</h2>
                        <p>Extracting text, rebuilding layout, preserving structure, and preparing your DOCX file.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete
                        && Response != null)
                {
                    <AdSlot Size="rectangle" />

                    <div class="result-container">
                        <span class="result-icon">Ready</span>
                        <h2>Your Word document is ready</h2>
                        <p class="result-copy">Download the editable DOCX and continue revising in Word, Google Docs, or your preferred editor.</p>

                        <div class="stats">
                            <div class="stat">
                                <span class="stat-label">
                                    Original PDF Size
                                </span>
                                <span class="stat-value">
                                    @FormatFileSize(Response.OriginalSizeBytes)
                                </span>
                            </div>
                            <div class="stat">
                                <span class="stat-label">
                                    Word Document Size
                                </span>
                                <span class="stat-value">
                                    @FormatFileSize(Response.OutputSizeBytes)
                                </span>
                            </div>
                        </div>

                        <button class="download-button"
                                @onclick="DownloadFile">
                            Download Word Document
                        </button>

                        <button class="reset-button"
                                @onclick="Reset">
                            Convert Another PDF
                        </button>
                        <PostSuccessUpsell ToolName="PDF to Word" ActionPerformed="converted PDF to editable Word document" />

                        <RecentFiles FileName="@(SelectedFile?.Name ?? "Converted PDF")"
                                     ToolName="PDF to Word"
                                     OnDownloadAgain="@DownloadFile" />
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container">
                        <span class="error-icon">Conversion failed</span>
                        <h2>We could not finish the DOCX conversion</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button" @onclick="Reset">
                            Try Again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                                      FileName="@(SelectedFile?.Name ?? "")"
                                      ToolType="PdfToWord"
                                      OnCancel="Reset" />
                }
                else
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Conversion profile</span>
                        <h2>Create editable DOCX</h2>
                        <p>Built for clean document handoff: retained formatting, editable text, and a standard Word output.</p>
                    </div>

                    @if (SelectedFile != null)
                    {
                        <div class="file-summary">
                            <span class="file-name">@SelectedFile.Name</span>
                            <span class="file-size">@FormatFileSize(SelectedFile.Size)</span>
                        </div>
                    }

                    <div class="option-list">
                        <span><strong>Format retention</strong><small>Keeps the original reading order and structure.</small></span>
                        <span><strong>Editable text</strong><small>Converts PDF text into workable DOCX content.</small></span>
                        <span><strong>Layout preserved</strong><small>Maintains headings, spacing, and document flow.</small></span>
                    </div>

                    @if (CurrentState == PageState.Upload && SelectedFile != null)
                    {
                        <button class="process-button"
                                @onclick="ProcessFile">
                            Convert to Word
                        </button>
                        <div class="secure-note">
                            Secure processing. Files are deleted within 1 hour.
                        </div>
                    }
                    else if (CurrentState == PageState.Upload)
                    {
                        <button class="process-button disabled" disabled>
                            Convert to Word
                        </button>
                        <p class="action-hint">Upload a PDF to enable conversion.</p>
                    }
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
            <h3>Is this PDF to Word converter free?</h3>
            <p>
                Yes — completely free up to 25MB with no signup
                required. Larger files available for $0.99.
            </p>
        </div>

        <div class="faq-item">
            <h3>What Word format does it convert to?</h3>
            <p>
                Your PDF is converted to .docx format compatible
                with Microsoft Word, Google Docs, and all modern
                word processors.
            </p>
        </div>

        <div class="faq-item">
            <h3>Will the formatting be preserved?</h3>
            <p>
                Text content is fully preserved. Complex layouts
                with images and tables may require minor
                adjustments after conversion.
            </p>
        </div>

        <div class="faq-item">
            <h3>Is my PDF stored on your servers?</h3>
            <p>
                Your file is automatically deleted within 1 hour.
                We never store your documents permanently.
            </p>
        </div>

        <div class="faq-item">
            <h3>What is the maximum file size?</h3>
            <p>
                Free processing supports files up to 25MB.
                For larger files up to 500MB use our
                pay-per-file option for just $0.99.
            </p>
        </div>
    </div>
</div>

<style>
    .tool-page {
        width: 100%;
        max-width: none;
        min-height: calc(100vh - 72px);
        min-width: 0;
        margin: 0;
        padding: 48px 0 72px;
        box-sizing: border-box;
        background:
            radial-gradient(circle at top left, rgba(109, 40, 217, 0.12), transparent 32%),
            linear-gradient(135deg, #f8f7ff 0%, #eef5ff 100%);
        color: #172033;
    }

    .tool-container {
        width: min(1320px, calc(100% - 64px));
        max-width: 1320px;
        margin: 0 auto;
        padding: 0;
        background: transparent !important;
        border: 0 !important;
        border-radius: 0;
        box-shadow: none !important;
        text-align: left;
        box-sizing: border-box;
    }

    .tool-hero {
        width: 100%;
        max-width: none;
        text-align: left;
        margin-bottom: 24px;
    }

    .tool-hero h1 {
        max-width: 900px;
        margin: 0 0 14px;
        color: #111827;
        font-size: clamp(2.4rem, 3vw, 3.8rem);
        line-height: 1.02;
        letter-spacing: -0.04em;
    }

    .hero-gradient-text {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .tool-subtitle {
        max-width: 760px;
        margin: 0;
        color: #5b6475;
        font-size: 1rem;
        line-height: 1.7;
    }

    .trust-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .trust-row span {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(148, 163, 184, 0.24);
        box-shadow: 0 10px 26px rgba(37, 99, 235, 0.08);
        color: #334155;
        font-size: 0.85rem;
        font-weight: 700;
        padding: 0.45rem 0.8rem;
    }

    .trust-row span::before {
        content: "";
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    }

    .stepper {
        width: 100%;
        max-width: none;
        margin: 0 0 24px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        padding: 8px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.8);
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    }

    .step {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        border-radius: 999px;
        color: #64748b;
        padding: 0.45rem 0.7rem 0.45rem 0.45rem;
        transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .step span {
        display: grid;
        place-items: center;
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 50%;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .step strong {
        font-size: 0.88rem;
        white-space: nowrap;
    }

    .step.active {
        background: linear-gradient(135deg, rgba(109, 93, 252, 0.15), rgba(37, 99, 235, 0.12));
        color: #1e293b;
        box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.12);
    }

    .step.complete {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        color: #ffffff;
    }

    .step.complete span {
        background: rgba(255, 255, 255, 0.22);
        color: #ffffff;
    }

    .workflow-grid {
        width: 100%;
        max-width: none;
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(360px, 0.75fr);
        gap: 28px;
        align-items: start;
    }

    .workspace-card,
    .settings-card {
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(148, 163, 184, 0.18);
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
        width: 100%;
        max-width: none;
        min-width: 0;
        padding: 28px;
        box-sizing: border-box;
    }

    .upload-card,
    .upload-zone,
    .file-upload,
    .dropzone,
    .file-upload-container {
        width: 100%;
        max-width: none;
    }

    .settings-card {
        position: sticky;
        top: 1rem;
    }

    .panel-header {
        margin-bottom: 1rem;
    }

    .panel-header h2 {
        margin: 0.25rem 0 0;
        color: #111827;
        font-size: 1.25rem;
        line-height: 1.2;
    }

    .panel-header p {
        margin: 0.45rem 0 0;
        color: #64748b;
        font-size: 0.92rem;
        line-height: 1.55;
    }

    .panel-eyebrow {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .empty-state {
        display: grid;
        gap: 0.4rem;
        margin-top: 1rem;
        border-radius: 20px;
        background: #f8fafc;
        color: #64748b;
        padding: 1rem;
    }

    .empty-state strong {
        color: #1e293b;
        font-size: 1.1rem;
    }

    .empty-kicker {
        color: #2563eb;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .file-ready-card {
        display: grid;
        gap: 1rem;
        margin-top: 1rem;
        border-radius: 22px;
        background:
            linear-gradient(135deg, rgba(109, 93, 252, 0.1), rgba(6, 182, 212, 0.08)),
            #ffffff;
        border: 1px solid rgba(109, 93, 252, 0.18);
        padding: 1.1rem;
    }

    .file-ready-card strong,
    .file-ready-card small {
        display: block;
    }

    .file-ready-card strong {
        margin-top: 0.3rem;
        color: #111827;
        font-size: 1.05rem;
        overflow-wrap: anywhere;
    }

    .file-ready-card small {
        margin-top: 0.2rem;
        color: #64748b;
        font-weight: 700;
    }

    .ready-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.55rem;
    }

    .ready-metrics span {
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.75);
        color: #334155;
        font-size: 0.8rem;
        font-weight: 900;
        padding: 0.7rem;
        text-align: center;
    }

    .file-summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border-radius: 18px;
        background: #f8fafc;
        padding: 0.9rem 1rem;
        margin-bottom: 1rem;
    }

    .file-summary.wide {
        margin: 1rem 0 0;
    }

    .file-name {
        color: #1e293b;
        font-weight: 800;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .file-size {
        color: #64748b;
        flex: 0 0 auto;
        font-size: 0.9rem;
        font-weight: 700;
    }

    .option-list {
        display: grid;
        gap: 0.65rem;
        margin-bottom: 1rem;
    }

    .option-list span {
        display: grid;
        gap: 0.2rem;
        border-radius: 16px;
        background: #f8fafc;
        color: #475569;
        padding: 0.8rem 0.9rem;
    }

    .option-list strong {
        color: #172033;
        font-size: 0.95rem;
    }

    .option-list small {
        color: #64748b;
        font-size: 0.82rem;
        line-height: 1.45;
    }

    .process-button,
    .download-button {
        width: 100%;
        border: 0;
        border-radius: 16px;
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%);
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.24);
        color: #ffffff;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 900;
        padding: 1rem 1.2rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }

    .process-button:hover:not(:disabled),
    .download-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 44px rgba(37, 99, 235, 0.3);
        filter: saturate(1.08);
    }

    .process-button.disabled {
        cursor: not-allowed;
        filter: grayscale(0.45);
        opacity: 0.58;
    }

    .action-hint {
        color: #64748b;
        font-size: 0.9rem;
        margin: 0.75rem 0 0;
    }

    .processing-container,
    .result-container,
    .error-container {
        display: grid;
        justify-items: center;
        gap: 0.9rem;
        border-radius: 24px;
        background: #f8fafc;
        padding: 2rem;
        text-align: center;
    }

    .processing-container h2,
    .result-container h2,
    .error-container h2 {
        margin: 0;
        color: #111827;
    }

    .processing-container p,
    .result-container p,
    .error-container p {
        max-width: 520px;
        margin: 0;
        color: #64748b;
    }

    .spinner {
        width: 3rem;
        height: 3rem;
        border: 4px solid #dbeafe;
        border-top-color: #6d5dfc;
        border-radius: 50%;
        animation: spin 0.9s linear infinite;
    }

    .result-icon,
    .error-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.4rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.04em;
        padding: 0.55rem 0.8rem;
        text-transform: uppercase;
    }

    .result-icon {
        background: #dcfce7;
        color: #15803d;
    }

    .error-icon {
        background: #fee2e2;
        color: #b91c1c;
    }

    .stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        width: 100%;
    }

    .stat {
        border-radius: 18px;
        background: #ffffff;
        padding: 1rem;
    }

    .stat-label,
    .stat-value {
        display: block;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .stat-value {
        color: #111827;
        font-size: 1.35rem;
        font-weight: 900;
        margin-top: 0.25rem;
    }

    .reset-button {
        border: 0;
        border-radius: 14px;
        background: #eef2ff;
        color: #3730a3;
        cursor: pointer;
        font-weight: 900;
        padding: 0.9rem 1rem;
    }

    .error-message {
        color: #b91c1c;
        font-weight: 750;
    }

    .secure-note {
        margin-top: 0.8rem;
        color: #64748b;
        font-size: 0.82rem;
        font-weight: 800;
        text-align: center;
    }

    .faq-section {
        max-width: 980px;
        margin: 3rem auto 0;
        padding: 0 1.25rem;
    }

    .faq-item {
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        margin-top: 0.9rem;
        padding: 1rem 1.1rem;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 980px) {
        .tool-hero,
        .workflow-grid {
            grid-template-columns: 1fr;
        }

        .tool-container {
            width: min(100%, calc(100% - 24px));
        }

        .tool-hero h1 {
            font-size: clamp(2rem, 8vw, 3rem);
        }

        .settings-card {
            position: static;
        }

        .stepper {
            overflow-x: auto;
            border-radius: 20px;
            grid-template-columns: repeat(4, minmax(130px, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .workspace-card,
        .settings-card {
            border-radius: 22px;
            padding: 1rem;
        }

        .stats {
            grid-template-columns: 1fr;
        }

        .file-summary {
            align-items: flex-start;
            flex-direction: column;
            gap: 0.35rem;
        }

        .ready-metrics {
            grid-template-columns: 1fr;
        }
    }
    .post-success-upsell {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        overflow: hidden;
        width: 100%;
        box-sizing: border-box;
        margin-top: 0.5rem;
        border: 1px solid rgba(109, 93, 252, 0.18);
        border-radius: 18px;
        background:
            radial-gradient(circle at top left, rgba(109, 93, 252, 0.12), transparent 38%),
            linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(239, 246, 255, 0.86));
        box-shadow: 0 14px 34px rgba(37, 99, 235, 0.08);
        padding: 1rem 1rem 1rem 1.15rem;
        text-align: left;
    }

    .post-success-accent {
        position: absolute;
        inset: 0 auto 0 0;
        width: 4px;
        background: linear-gradient(180deg, #6d5dfc 0%, #2563eb 58%, #06b6d4 100%);
    }

    .post-success-copy {
        position: relative;
        min-width: 0;
    }

    .post-success-copy strong {
        display: block;
        color: #111827;
        font-size: 0.98rem;
        font-weight: 950;
        letter-spacing: -0.01em;
        margin-bottom: 0.25rem;
    }

    .post-success-copy p {
        margin: 0 0 0.7rem;
        color: #64748b;
        font-size: 0.88rem;
