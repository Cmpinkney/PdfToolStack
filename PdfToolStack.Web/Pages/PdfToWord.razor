@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private ProcessResponse? Response;
    private byte[]? ProcessedBytes;
    private byte[]? UploadedBytes;
    private string? ErrorMessage;

    private string GetStepClass(PageState state)
    {
        if (CurrentState == PageState.Complete)
            return "step complete";

        if (state == PageState.Upload && CurrentState == PageState.Upload && SelectedFile == null)
            return "step active";

        if (state == PageState.Upload && SelectedFile != null)
            return "step complete";

        if (state == PageState.Processing &&
            (CurrentState == PageState.Processing || (CurrentState == PageState.Upload && SelectedFile != null)))
            return "step active";

        if (state == PageState.Processing && CurrentState == PageState.Complete)
            return "step complete";

        return "step";
    }

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }
        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesVal = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid)
            {
                Toast.ShowError(bytesVal.Message!);
                UploadedBytes = null;
                return;
            }
            if (bytesVal.IsWarning)
                Toast.ShowWarning(bytesVal.Message!);

            SelectedFile = file;
            if (PaymentService.IsFileTooLargeForFree(file.Size))
                CurrentState = PageState.LargeFile;
            else
                Toast.ShowSuccess(
                    $"File ready — {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;
    }

    private async Task ProcessFile()
    {
        if (SelectedFile == null || UploadedBytes == null) return;
        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            Response = await ApiService.ProcessPdfAsync(
                UploadedBytes, SelectedFile.Name,
                ToolType.PdfToWord);
            if (Response != null && Response.IsSuccess)
            {
                ProcessedBytes = UploadedBytes;
                CurrentState = PageState.Complete;
                Toast.ShowSuccess("Converted to Word successfully!");
            }
            else
            {
                ErrorMessage = Response?.ErrorMessage
                    ?? "Conversion failed. Please try again.";
                Toast.ShowError(ErrorMessage);
                CurrentState = PageState.Error;
            }
        }
        catch (TaskCanceledException)
        {
            ErrorMessage = "Processing timed out. Try a smaller file.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Network error — please try again.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ProcessedBytes == null) return;

        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "converted") + ".docx";

        await JS.InvokeVoidAsync(
            "downloadFile",
            fileName,
            Convert.ToBase64String(ProcessedBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private bool IsEditMode =>
    Navigation.Uri.Contains("/convert-pdf-to-editable-word",
        StringComparison.OrdinalIgnoreCase);

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        Response = null;
        ProcessedBytes = null;
        UploadedBytes = null;
        ErrorMessage = null;
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024} KB";
        return $"{bytes / (1024 * 1024)} MB";
    }
}
