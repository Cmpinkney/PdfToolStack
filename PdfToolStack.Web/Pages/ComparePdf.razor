@page "/compare-pdf"
@page "/compare-contracts"
@page "/compare-pdf-documents"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject PdfToolStack.Web.Services.CloudPickerService CloudPicker
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>@(IsContractMode ? "Compare Contracts Online — Find PDF Differences | PdfToolStack" : "Compare PDF Files — Find Differences | PdfToolStack")</PageTitle>

<HeadContent>
    <meta name="description"
          content="@(IsContractMode
                                  ? "Compare two versions of a contract and see exactly what changed. AI-highlighted diff report. Perfect for legal teams and freelancers."
                                  : "Upload two versions of a document and get a highlighted report showing exactly what changed.")" />
    <meta name="keywords" content="compare pdf, pdf diff, pdf comparison tool, find differences in pdf" />
    <link rel="canonical" href="https://pdftoolstack.com/compare-pdf" />
</HeadContent>

<div class="tool-page compare-tool-page">
    <div class="tool-container compare-tool-container">

        <section class="tool-hero compare-tool-hero">
            <div class="trust-row">
                <span>Secure upload</span>
                <span>Side-by-side comparison</span>
                <span>Auto-delete after 1 hour</span>
            </div>
            <h1>Compare PDFs <span class="hero-gradient-text">clearly</span></h1>
            <p>See exactly what changed between two documents in seconds.</p>
        </section>

        <div class="stepper compare-tool-stepper" aria-label="Compare PDF steps">
            <div class="stepper-step active"><span>1</span>Upload</div>
            <div class="stepper-step"><span>2</span>Compare</div>
            <div class="stepper-step"><span>3</span>Review</div>
            <div class="stepper-step"><span>4</span>Download</div>
        </div>

        <AuthorizeView>
            <NotAuthorized>
                <div class="ai-upgrade-card">
                    <div class="ai-upgrade-icon">🔍</div>
                    <h2>Try PDF Compare — 5 free uses</h2>
                    <p>Sign in to get 5 free AI uses per month. Compare any two PDF documents word-by-word and get a highlighted diff report.</p>
                    <div class="ai-upgrade-features">
                        <div class="ai-upgrade-feat">✓ Word-by-word diff report</div>
                        <div class="ai-upgrade-feat">✓ Highlights additions and deletions</div>
                        <div class="ai-upgrade-feat">✓ Perfect for contract redlines</div>
                        <div class="ai-upgrade-feat">✓ 5 free AI uses every month</div>
                    </div>
                    <div class="ai-upgrade-actions">
                        <a href="authentication/login?screen_hint=signup" class="download-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign up free
                        </a>
                        <a href="authentication/login" class="reset-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign in
                        </a>
                    </div>
                </div>
            </NotAuthorized>
            <Authorized>
                @if (!_isPro)
                {
                    <div class="ai-upgrade-card">
                        <div class="ai-upgrade-icon">🔍</div>
                        <h2>Upgrade to Pro to unlock PDF Compare</h2>
                        <p>Compare any two PDF documents word-by-word and spot every change instantly. Available on Pro — $19/month.</p>
                        <div class="ai-upgrade-features">
                            <div class="ai-upgrade-feat">✓ Word-by-word diff report</div>
                            <div class="ai-upgrade-feat">✓ Highlights additions and deletions</div>
                            <div class="ai-upgrade-feat">✓ Perfect for contract redlines</div>
                            <div class="ai-upgrade-feat">✓ All 35+ PDF tools included</div>
                            <div class="ai-upgrade-feat">✓ Unlimited file size</div>
                        </div>
                        <div class="ai-upgrade-actions">
                            <a href="/pricing" class="download-button" style="display:inline-block; text-decoration:none;">
                                Upgrade to Pro — $19/mo
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <section class="workflow-grid compare-tool-workflow">
                        <div class="workspace-card compare-tool-workspace">
                            <div class="compare-workspace-header">
                                <span>Upload documents</span>
                                <h2>Add the original and revised PDFs</h2>
                                <p>Keep each upload slot targeted to the correct version before running the comparison.</p>
                            </div>

                    <div class="compare-grid">

                        <div class="compare-upload-slot">
                            <label class="compare-upload-card @(_originalName != null ? "compare-card-filled" : "")">
                                <InputFile OnChange="e => OnFileSelected(e, true)" accept=".pdf" class="file-input-hidden" />
                                @if (_originalName != null)
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0D9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    <span class="compare-card-filename">@_originalName</span>
                                    <span class="compare-ready-meta"><span>PDF</span><span>@FormatSize(_originalBytes?.Length ?? 0)</span></span>
                                    <span class="compare-ready-state">Ready to process</span>
                                }
                                else
                                {
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                    <span class="compare-card-label">@(IsContractMode ? "Original contract" : "Original version")</span>
                                    <span class="compare-card-hint">Click or drag PDF here</span>
                                }
                            </label>

                            <div class="cloud-row">
                                <span class="cloud-label">Import from cloud</span>
                                <div class="cloud-actions">
                                    <button type="button" class="cloud-btn" @onclick="() => PickDropbox(true)" disabled="@_cloudLoading">
                                        <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M7.1 3.2 2 6.5l5.1 3.3 5.1-3.3-5.1-3.3Zm9.8 0-5.1 3.3 5.1 3.3L22 6.5l-5.1-3.3ZM2 13l5.1 3.3 5.1-3.3-5.1-3.3L2 13Zm14.9-3.3L11.8 13l5.1 3.3L22 13l-5.1-3.3ZM12 14.8 7.1 18 12 21.2l4.9-3.2-4.9-3.2Z" fill="#0061FF" />
                                        </svg>
                                        Dropbox
                                    </button>
                                    <button type="button" class="cloud-btn" @onclick="() => PickGoogleDrive(true)" disabled="@_cloudLoading">
                                        <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M9.6 3.2 3 14.5h4.5l6.5-11.3H9.6Z" fill="#34A853" />
                                            <path d="M14.1 3.2h-4.5l6.6 11.3h4.5L14.1 3.2Z" fill="#FBBC04" />
                                            <path d="M7.5 14.5 9.8 18.4h10.9L18.4 14.5H7.5Z" fill="#4285F4" />
                                        </svg>
                                        Google Drive
                                    </button>
                                </div>
                                @if (_cloudLoading)
                                {
                                    <p class="cloud-status">Importing from cloud...</p>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(_originalCloudError))
                            {
                                <p class="cloud-error">@_originalCloudError</p>
                            }
                        </div>

                        <div class="compare-vs-divider">VS</div>

                        <div class="compare-upload-slot">
                            <label class="compare-upload-card @(_revisedName != null ? "compare-card-filled" : "")">
                                <InputFile OnChange="e => OnFileSelected(e, false)" accept=".pdf" class="file-input-hidden" />
                                @if (_revisedName != null)
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0D9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    <span class="compare-card-filename">@_revisedName</span>
                                    <span class="compare-ready-meta"><span>PDF</span><span>@FormatSize(_revisedBytes?.Length ?? 0)</span></span>
                                    <span class="compare-ready-state">Ready to process</span>
                                }
                                else
                                {
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                    <span class="compare-card-label">@(IsContractMode ? "Revised contract" : "Revised version")</span>
                                    <span class="compare-card-hint">Click or drag PDF here</span>
                                }
                            </label>

                            <div class="cloud-row">
                                <span class="cloud-label">Import from cloud</span>
                                <div class="cloud-actions">
                                    <button type="button" class="cloud-btn" @onclick="() => PickDropbox(false)" disabled="@_cloudLoading">
                                        <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M7.1 3.2 2 6.5l5.1 3.3 5.1-3.3-5.1-3.3Zm9.8 0-5.1 3.3 5.1 3.3L22 6.5l-5.1-3.3ZM2 13l5.1 3.3 5.1-3.3-5.1-3.3L2 13Zm14.9-3.3L11.8 13l5.1 3.3L22 13l-5.1-3.3ZM12 14.8 7.1 18 12 21.2l4.9-3.2-4.9-3.2Z" fill="#0061FF" />
                                        </svg>
                                        Dropbox
                                    </button>
                                    <button type="button" class="cloud-btn" @onclick="() => PickGoogleDrive(false)" disabled="@_cloudLoading">
                                        <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M9.6 3.2 3 14.5h4.5l6.5-11.3H9.6Z" fill="#34A853" />
                                            <path d="M14.1 3.2h-4.5l6.6 11.3h4.5L14.1 3.2Z" fill="#FBBC04" />
                                            <path d="M7.5 14.5 9.8 18.4h10.9L18.4 14.5H7.5Z" fill="#4285F4" />
                                        </svg>
                                        Google Drive
                                    </button>
                                </div>
                                @if (_cloudLoading)
                                {
                                    <p class="cloud-status">Importing from cloud...</p>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(_revisedCloudError))
                            {
                                <p class="cloud-error">@_revisedCloudError</p>
                            }
                        </div>

                </div>

                <div style="margin-top: 1.5rem;">
                    <button class="process-button"
                            style="max-width: 220px;"
                            @onclick="RunCompare"
                            disabled="@(_processing || _originalBytes == null || _revisedBytes == null)">
                        @(_processing
                                                ? "Comparing..."
                                                : IsContractMode ? "Compare Contracts" : "Compare Documents")
                    </button>
                </div>

                @if (_result != null)
                    {
                        <div class="ai-tool-result-card compare-result-card" style="margin-top: 1.5rem;">
                            <span class="compare-result-kicker">Comparison results</span>
                            <h3>✅ Comparison complete</h3>

                            <div class="compare-stats">
                                <div class="compare-stat">
                                    <span class="compare-stat-value added">
                                        +@_result.Value.Added
                                    </span>
                                    <span class="compare-stat-label">words added</span>
                                </div>
                                <div class="compare-stat">
                                    <span class="compare-stat-value removed">
                                        -@_result.Value.Removed
                                    </span>
                                    <span class="compare-stat-label">words removed</span>
                                </div>
                                <div class="compare-stat">
                                    <span class="compare-stat-value">
                                        @_result.Value.Pages
                                    </span>
                                    <span class="compare-stat-label">pages compared</span>
                                </div>
                            </div>

                            @if (_result.Value.Added == 0 && _result.Value.Removed == 0)
                            {
                                <p style="color: var(--success, #16a34a); font-weight: 500; margin-top: 0.75rem;">
                                    ✓ @(IsContractMode ? "Contracts are identical — no differences found." : "Documents are identical — no differences found.")
                                </p>
                            }

                            <button class="download-button"
                                    @onclick="DownloadReport"
                                    style="max-width: 260px; margin-top: 1rem;">
                                ⬇ Download Comparison Report
                            </button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="error-message" style="margin-top: 1rem;">
                            @_error
                        </div>
                    }
                        </div>

                        <aside class="settings-card compare-tool-settings">
                            <div class="compare-settings-header">
                                <span>Compare workflow</span>
                                <h2>How comparison works</h2>
                                <p>Upload both versions, compare changes instantly, then download a detailed report.</p>
                            </div>

                            <div class="compare-guidance-card">
                                <h3>Steps</h3>
                                <div class="compare-guidance-list">
                                    <span>Upload original and revised PDFs</span>
                                    <span>Use Dropbox or Google Drive if needed</span>
                                    <span>Compare changes instantly</span>
                                    <span>Download a detailed report</span>
                                </div>
                            </div>

                            <div class="compare-tip-card">
                                <strong>Tips</strong>
                                <p>Use similar document versions. Comparison works best with text-based PDFs.</p>
                            </div>
                        </aside>
                    </section>
                }
            </Authorized>
        </AuthorizeView>

    </div>
</div>

<style>
    .cloud-row {
        display: grid;
        gap: .75rem;
        margin-top: 1rem;
        border: 1px solid rgba(148, 163, 184, .2);
        border-radius: 18px;
        background: rgba(248, 250, 252, .9);
        padding: 1rem;
        text-align: center;
    }

    .cloud-label {
        color: #64748b;
        font-size: .72rem;
        font-weight: 950;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .cloud-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .65rem;
    }

    .cloud-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        min-height: 44px;
        border: 1px solid rgba(148, 163, 184, .24);
        border-radius: 14px;
        background: #fff;
        color: #334155;
        cursor: pointer;
        font-size: .86rem;
        font-weight: 900;
        padding: .72rem .9rem;
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

    .cloud-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        border-color: rgba(37, 99, 235, .3);
        box-shadow: 0 12px 24px rgba(37, 99, 235, .1);
    }

    .cloud-btn:disabled {
        cursor: not-allowed;
        opacity: .58;
    }

    .cloud-icon {
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
    }

    .cloud-status,
    .cloud-error {
        margin: 0;
        font-size: .84rem;
        font-weight: 750;
        line-height: 1.45;
    }

    .cloud-status {
        color: #64748b;
    }

    .cloud-error {
        margin-top: .75rem;
        color: #dc2626;
    }

    .compare-ready-meta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: .45rem;
        margin-top: .45rem;
    }

    .compare-ready-meta span,
    .compare-ready-state {
        border-radius: 999px;
        font-size: .74rem;
        font-weight: 900;
        padding: .3rem .55rem;
    }

    .compare-ready-meta span {
        background: rgba(255, 255, 255, .82);
        color: #475569;
    }

    .compare-ready-state {
        display: inline-flex;
        width: fit-content;
        margin-top: .5rem;
        background: #dcfce7;
        color: #166534;
    }

    @@media (max-width: 560px) {
        .cloud-actions {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private byte[]? _originalBytes;
    private byte[]? _revisedBytes;
    private string? _originalName;
    private string? _revisedName;
    private bool _isPro = false;
    private bool _processing = false;
    private string _error = string.Empty;
    private bool _cloudLoading;
    private string _originalCloudError = string.Empty;
    private string _revisedCloudError = string.Empty;
    private byte[]? _reportBytes;
    private (int Added, int Removed, int Pages)? _result;

    private bool IsContractMode =>
        Navigation.Uri.Contains("/compare-contracts",
            StringComparison.OrdinalIgnoreCase) ||
        Navigation.Uri.Contains("/compare-pdf-documents",
            StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _isPro = true;
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e, bool isOriginal)
    {
        var file = e.File;
        if (file == null) return;

        await SetCompareFile(file, isOriginal);
    }

    private async Task PickGoogleDrive(bool isOriginal)
    {
        await PickCloudFile(isOriginal, "Google Drive", async () =>
            await CloudPicker.OpenGoogleDriveAsync());
    }

    private async Task PickDropbox(bool isOriginal)
    {
        await PickCloudFile(isOriginal, "Dropbox", async () =>
            await CloudPicker.OpenDropboxAsync());
    }

    private async Task PickCloudFile(
        bool isOriginal,
        string providerName,
        Func<Task<PdfToolStack.Web.Services.CloudPickerService.CloudFileInfo?>> picker)
    {
        SetCloudError(isOriginal, string.Empty);
        _cloudLoading = true;
        StateHasChanged();

        try
        {
            var cloudFile = await picker();
            if (cloudFile == null) return;

            var bytes = await CloudPicker.DownloadFileAsync(
                cloudFile.Url,
                cloudFile.AccessToken);

            if (bytes == null || bytes.Length == 0)
            {
                SetCloudError(isOriginal, $"{providerName}: Could not download the selected file.");
                return;
            }

            await SetCompareFile(
                new CloudBrowserFile(cloudFile.Name, bytes),
                isOriginal);
        }
        catch (Exception ex)
        {
            SetCloudError(isOriginal, $"{providerName}: {ex.Message}");
        }
        finally
        {
            _cloudLoading = false;
            StateHasChanged();
        }
    }

    private void SetCloudError(bool isOriginal, string message)
    {
        if (isOriginal)
            _originalCloudError = message;
        else
            _revisedCloudError = message;
    }

    private async Task SetCompareFile(IBrowserFile file, bool isOriginal)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 52_428_800).CopyToAsync(ms);

        if (isOriginal)
        {
            _originalBytes = ms.ToArray();
            _originalName = file.Name;
        }
        else
        {
            _revisedBytes = ms.ToArray();
            _revisedName = file.Name;
        }

        _result = null;
        _reportBytes = null;
        _error = string.Empty;
        SetCloudError(isOriginal, string.Empty);
    }

    private async Task RunCompare()
    {
        if (_originalBytes == null || _revisedBytes == null) return;

        _processing = true;
        _error = string.Empty;
        _result = null;
        StateHasChanged();

        try
        {
            var (report, added, removed, pages) =
                await ApiService.ComparePdfsAsync(
                    _originalBytes, _originalName ?? "original.pdf",
                    _revisedBytes, _revisedName ?? "revised.pdf");

            if (report != null)
            {
                _reportBytes = report;
                _result = (added, removed, pages);
            }
            else
            {
                _error = "Comparison failed. Please check both files are valid PDFs.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _processing = false;
            StateHasChanged();
        }
    }

    private async Task DownloadReport()
    {
        if (_reportBytes == null) return;
        await JS.InvokeVoidAsync("downloadFile",
            "comparison_report.pdf",
            Convert.ToBase64String(_reportBytes));
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{Math.Round((double)bytes / 1024, 1)} KB";
        return $"{Math.Round((double)bytes / (1024 * 1024), 1)} MB";
    }

    private sealed class CloudBrowserFile : IBrowserFile
    {
        private readonly byte[] _bytes;

        public CloudBrowserFile(string name, byte[] bytes)
        {
            Name = name;
            Size = bytes.Length;
            _bytes = bytes;
            LastModified = DateTimeOffset.UtcNow;
            ContentType = "application/pdf";
        }

        public string Name { get; }
        public DateTimeOffset LastModified { get; }
        public long Size { get; }
        public string ContentType { get; }

        public Stream OpenReadStream(
            long maxAllowedSize = 512000,
            CancellationToken cancellationToken = default)
            => new MemoryStream(_bytes);
    }
}
