@page "/ai-questions"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>AI Questions Generator — Create Quiz from PDF | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="Generate quiz questions from any PDF automatically with AI.
                   Multiple choice, true/false, and open-ended questions.
                   Perfect for teachers and students." />
    <meta name="keywords" content="generate questions from pdf, pdf quiz generator, ai questions from document" />
    <link rel="canonical" href="https://pdftoolstack.com/ai-questions" />
</HeadContent>

<div class="tool-page ai-tool-page">
    <div class="tool-container ai-tool-container">

        <section class="tool-hero ai-tool-hero">
            <div class="trust-row">
                <span>Private processing</span>
                <span>Secure upload</span>
                <span>Auto-delete after 1 hour</span>
            </div>
            <h1>Ask questions about your PDF <span class="hero-gradient-text">instantly</span></h1>
            <p>Use AI to understand, analyze, and transform your documents in seconds.</p>
        </section>

        <div class="stepper ai-tool-stepper" aria-label="AI questions steps">
            <div class="stepper-step active"><span>1</span>Upload</div>
            <div class="stepper-step"><span>2</span>Process</div>
            <div class="stepper-step"><span>3</span>Review</div>
            <div class="stepper-step"><span>4</span>Copy/Download</div>
        </div>

        <AuthorizeView>
            <NotAuthorized>
                <div class="ai-upgrade-card">
                    <div class="ai-upgrade-icon">📝</div>
                    <h2>Try AI Questions Generator — 5 free uses</h2>
                    <p>Sign in to get 5 free AI uses per month. Generate quiz questions from any PDF automatically.</p>
                    <div class="ai-upgrade-features">
                        <div class="ai-upgrade-feat">✓ Generate up to 15 questions</div>
                        <div class="ai-upgrade-feat">✓ Works on any PDF document</div>
                        <div class="ai-upgrade-feat">✓ Copy all questions instantly</div>
                        <div class="ai-upgrade-feat">✓ Perfect for studying and teaching</div>
                    </div>
                    <div class="ai-upgrade-actions">
                        <a href="authentication/login?screen_hint=signup" class="download-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign up free — 5 AI uses included
                        </a>
                        <a href="authentication/login" class="reset-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign in
                        </a>
                    </div>
                </div>
            </NotAuthorized>

            <Authorized>
                <section class="workflow-grid ai-tool-workflow">
                    <div class="workspace-card ai-tool-workspace">
                        @if (CurrentState == PageState.Upload)
                        {
                            <div class="ai-tool-card-header">
                                <span>Upload</span>
                                <h2>Start with study material</h2>
                                <p>Upload a PDF and choose how many questions AI should generate.</p>
                            </div>

                            <FileUpload OnFileSelected="HandleFileSelected"
                                        OnFileRemoved="HandleFileRemoved"
                                        HintText="Upload a PDF document — up to 50MB" />

                            @if (_fileBytes != null)
                            {
                                <button class="process-button ai-tool-primary-cta" @onclick="RunGenerate">
                                    📝 Generate @_questionCount Questions
                                </button>
                            }
                        }

                        @if (CurrentState == PageState.Processing)
                        {
                            <div class="ai-processing-container ai-tool-processing">
                                <div class="ai-processing-icon">📝</div>
                                <h3>AI is generating questions...</h3>
                                <p>Reading your document and creating @_questionCount questions</p>
                                <div class="ai-processing-steps">
                                    <div class="ai-processing-step @(_step >= 1 ? "done" : "")">Reading PDF content</div>
                                    <div class="ai-processing-step @(_step >= 2 ? "done" : "")">Identifying key concepts</div>
                                    <div class="ai-processing-step @(_step >= 3 ? "done" : "")">Generating questions</div>
                                </div>
                            </div>
                        }

                        @if (CurrentState == PageState.Complete && _questions.Any())
                        {
                            <div class="ai-result-card ai-tool-result-card">
                                <div class="ai-result-header">
                                    <div>
                                        <span class="ai-tool-result-kicker">Result</span>
                                        <h2>@_questions.Count questions generated</h2>
                                        <p style="color:var(--text-secondary); font-size:0.875rem;">
                                            @_fileName
                                        </p>
                                    </div>
                                    <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
                                        <button class="download-button"
                                                style="max-width:160px; margin-top:0;"
                                                @onclick="CopyQuestions">
                                            @(_copied ? "✓ Copied!" : "📋 Copy All")
                                        </button>
                                        <button class="reset-button"
                                                style="max-width:140px;"
                                                @onclick="Reset">
                                            Generate More
                                        </button>
                                    </div>
                                </div>

                                <div class="questions-result-list">
                                    @for (int i = 0; i < _questions.Count; i++)
                                    {
                                        var index = i;
                                        <div class="question-result-item">
                                            <span class="question-result-num">@(index + 1)</span>
                                            <span class="question-result-text">@_questions[index]</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (CurrentState == PageState.Error)
                        {
                            @if (_isRateLimit)
                            {
                                <AiLimitBanner IsVisible="true"
                                               IsFreeLimit="@_isFreeLimit"
                                               Limit="@(_isFreeLimit ? 5 : 200)" />
                                <button class="reset-button" style="margin-top:1rem;" @onclick="Reset">Try Again</button>
                            }
                            else
                            {
                                <div class="error-container" role="alert">
                                    <span class="error-icon" aria-hidden="true">❌</span>
                                    <p class="error-message">@_error</p>
                                    <button class="reset-button" @onclick="Reset">Try Again</button>
                                </div>
                            }
                        }
                    </div>

                    <aside class="settings-card ai-tool-settings">
                        <div class="ai-tool-card-header">
                            <span>Question settings</span>
                            <h2>Shape the output</h2>
                            <p>Ask specific questions for better answers and choose a count that fits your lesson or review session.</p>
                        </div>

                        @if (!_isPro && _aiUsed < 5)
                        {
                            <div class="free-uses-banner">
                                <span>✨ @(5 - _aiUsed) of 5 free AI uses remaining this month</span>
                                <a href="/pricing">Upgrade to Pro for 200 AI uses/month →</a>
                            </div>
                        }

                        <div class="questions-count-section">
                            <p class="questions-count-label">How many questions?</p>
                            <div class="questions-count-grid">
                                @foreach (var count in new[] { 3, 5, 8, 10, 15 })
                                {
                                    <button class="questions-count-btn @(_questionCount == count ? "active" : "")"
                                            @onclick="() => _questionCount = count">
                                        @count
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="ai-tool-guidance-card">
                            <h3>Helpful tips</h3>
                            <p>Best for study guides, classroom material, training PDFs, and comprehension checks.</p>
                            <div class="ai-tool-guidance-list">
                                <span>Open-ended comprehension questions</span>
                                <span>Copy-ready output</span>
                                <span>Private processing</span>
                            </div>
                        </div>
                    </aside>
                </section>
            </Authorized>
        </AuthorizeView>

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What types of questions does it generate?</h3>
            <p>Open-ended comprehension questions based on the document content. Ideal for testing understanding of the material.</p>
        </div>
        <div class="faq-item">
            <h3>How many questions can I generate?</h3>
            <p>Between 3 and 15 questions per document. You can regenerate with a different count anytime.</p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored?</h3>
            <p>No. Your PDF is processed in memory and deleted within 1 hour. We never store document contents permanently.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Processing, Complete, Error }
    private PageState CurrentState = PageState.Upload;

    private byte[]? _fileBytes;
    private string? _fileName;
    private bool _isPro;
    private int _aiUsed = 0;
    private bool _copied;
    private int _step = 0;
    private int _questionCount = 5;
    private List<string> _questions = new();
    private string _error = string.Empty;
    private bool _isRateLimit = false;
    private bool _isFreeLimit = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst("sub")?.Value ?? string.Empty;
            var status = await SubService.GetStatusAsync(userId);
            _isPro = status.HasPro;

            if (!_isPro)
            {
                var usage = await ApiService.GetAsync<AiUsageResponse>("api/ai/usage");
                _aiUsed = usage?.Used ?? 0;
            }
        }
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 52_428_800).CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        _fileName = file.Name;
        _questions.Clear();
        _error = string.Empty;
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
        _questions.Clear();
    }

    private async Task RunGenerate()
    {
        if (_fileBytes == null) return;

        CurrentState = PageState.Processing;
        _step = 1;
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            _step = 2; StateHasChanged();

            using var content = new MultipartFormDataContent();
            var fc = new ByteArrayContent(_fileBytes);
            fc.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fc, "file", _fileName ?? "document.pdf");
            content.Add(new StringContent(_questionCount.ToString()), "count");

            var result = await ApiService.PostMultipartWithStatusAsync<QuestionsResponse>(
                "api/ai/questions", content);

            _step = 3; StateHasChanged();

            if (result.IsSuccess && result.Data?.Questions != null && result.Data.Questions.Any())
            {
                _questions = result.Data.Questions;
                CurrentState = PageState.Complete;
            }
            else if (result.IsRateLimit)
            {
                _isRateLimit = true;
                _isFreeLimit = !_isPro;
                CurrentState = PageState.Error;
            }
            else
            {
                _error = "Could not generate questions. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private async Task CopyQuestions()
    {
        var text = string.Join("\n\n",
            _questions.Select((q, i) => $"{i + 1}. {q}"));
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _fileBytes = null;
        _fileName = null;
        _questions.Clear();
        _error = string.Empty;
        _step = 0;
        _copied = false;
        _isRateLimit = false;
        _isFreeLimit = false;
    }

    private class QuestionsResponse
    {
        public List<string> Questions { get; set; } = new();
    }

    private class AiUsageResponse
    {
        public int Used { get; set; }
        public int Limit { get; set; }
    }
}
