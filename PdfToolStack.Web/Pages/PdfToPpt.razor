@page "/pdf-to-ppt"

<PageTitle>PDF to PowerPoint Converter Free Online</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert PDF to PowerPoint presentation free online.
                   No signup required." />
    <meta name="keywords"
          content="pdf to ppt, convert pdf to powerpoint,
                   pdf to pptx free" />
    <link rel="canonical"
          href="https://pdftoolstack.com/pdf-to-ppt" />
</HeadContent>

<div class="tool-page">
    <div class="tool-container">
        <h1>PDF to PowerPoint Converter</h1>
        <p class="tool-subtitle">
            Convert your PDF to an editable PowerPoint
            presentation.
        </p>
        <div class="coming-soon-banner">
            <span class="coming-soon-icon">📽️</span>
            <div>
                <h3>PDF to PowerPoint Coming Soon</h3>
                <p>
                    We are building a converter that
                    accurately maps PDF pages to editable
                    PowerPoint slides.
                </p>
            </div>
        </div>
        <div class="notify-section">
            <h3>Get notified when it launches</h3>
            @if (NotifySubmitted)
            {
                <div class="contact-success">
                    <span>✅</span>
                    <p>We'll notify you when this launches!</p>
                </div>
            }
            else
            {
                <div class="notify-form">
                    <input type="email"
                           class="field-input"
                           style="max-width: 300px;"
                           placeholder="your@email.com"
                           @bind="NotifyEmail" />
                    <button class="process-button"
                            style="max-width: 160px;"
                            @onclick="SubmitNotify">
                        Notify Me
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .tool-page {
        width: 100%;
        max-width: none !important;
        min-height: calc(100vh - 72px);
        margin: 0;
        padding: 48px 0 72px;
        box-sizing: border-box;
        background:
            radial-gradient(circle at top left, rgba(109, 40, 217, 0.12), transparent 32%),
            linear-gradient(135deg, #f8f7ff 0%, #eef5ff 100%);
    }

    .tool-container {
        width: min(1320px, calc(100% - 64px)) !important;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0;
        background: transparent !important;
        border: 0 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        text-align: left;
        box-sizing: border-box;
    }

    @@media (max-width: 980px) {
        .tool-container {
            width: min(100%, calc(100% - 24px)) !important;
        }
    }
</style>

@code {
    private string NotifyEmail = string.Empty;
    private bool NotifySubmitted = false;
    private async Task SubmitNotify()
    {
        if (string.IsNullOrWhiteSpace(NotifyEmail) ||
            !NotifyEmail.Contains('@')) return;
        await Task.Delay(500);
        NotifySubmitted = true;
        StateHasChanged();
    }
}
