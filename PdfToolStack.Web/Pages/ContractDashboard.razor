@code {
    private enum PageState { Upload, Processing, Complete, Error }
    private PageState CurrentState = PageState.Upload;

    private byte[]? _fileBytes;
    private string? _fileName;
    private bool _isPro = false;
    private string _error = string.Empty;
    private bool _isRateLimit = false;
    private bool _isFreeLimit = false;

    private ContractReview? _review;

    protected override async Task OnInitializedAsync()
    {
        var auth = await Auth.GetAuthenticationStateAsync();
        var user = auth.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst("sub")?.Value ?? string.Empty;
            if (!string.IsNullOrEmpty(userId))
            {
                var status = await SubService.GetStatusAsync(userId);
                _isPro = status.HasPro;
            }
        }
    }

    private void HandleFileSelected(IBrowserFile file)
    {
        _fileName = file.Name;
        var task = ReadFileAsync(file);
    }

    private async Task ReadFileAsync(IBrowserFile file)
    {
        using var stream = file.OpenReadStream(maxAllowedSize: 524_288_000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
    }

    private async Task RunAnalysis()
    {
        if (_fileBytes is null) return;

        CurrentState = PageState.Processing;
        _error = string.Empty;
        _isRateLimit = false;
        _isFreeLimit = false;
        StateHasChanged();

        try
        {
            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(_fileBytes), "file", _fileName ?? "contract.pdf");

            var result = await ApiService.PostMultipartWithStatusAsync<ReviewResponse>(
                "api/ai/review", content);

            if (result.IsRateLimit)
            {
                _isRateLimit = true;
                _isFreeLimit = result.ErrorMessage?.Contains("free") == true;
                CurrentState = PageState.Error;
                return;
            }

            if (result.IsSuccess && result.Data?.Json is not null)
            {
                _review = ParseReview(result.Data.Json);
                if (_review is not null)
                {
                    CurrentState = PageState.Complete;
                    Toast.ShowSuccess("Contract analysis complete.");
                }
                else
                {
                    _error = "Could not parse the contract analysis. Please try again.";
                    CurrentState = PageState.Error;
                }
            }
            else
            {
                _error = result.ErrorMessage ?? "Analysis failed. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception)
        {
            _error = "Something went wrong. Please try again.";
            CurrentState = PageState.Error;
        }
    }

    private ContractReview? ParseReview(string json)
    {
        try
        {
            var clean = json.Trim();
            if (clean.StartsWith("```"))
            {
                clean = System.Text.RegularExpressions.Regex.Replace(
                    clean, @"^```[a-z]*\n?", "", System.Text.RegularExpressions.RegexOptions.Multiline);
                clean = clean.Replace("```", "").Trim();
            }
            return JsonSerializer.Deserialize<ContractReview>(clean,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch { return null; }
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _fileBytes = null;
        _fileName = null;
        _review = null;
        _error = string.Empty;
        _isRateLimit = false;
        _isFreeLimit = false;
    }

    private static string GetRiskTitle(string? level) => level?.ToLower() switch
    {
        "high"   => "High Risk — Review Carefully Before Signing",
        "medium" => "Medium Risk — Some Issues Require Attention",
        _        => "Low Risk — Contract Looks Reasonable"
    };

    // ── Inner DTOs ────────────────────────────────────────────────────────────
    private class ReviewResponse
    {
        public string? Json { get; set; }
    }

    private class ContractReview
    {
        public string? Summary { get; set; }
        public string? RiskLevel { get; set; }
        public List<KeyDate>? KeyDates { get; set; }
        public List<Party>? Parties { get; set; }
        public List<Obligation>? Obligations { get; set; }
        public List<RiskyClause>? RiskyClauses { get; set; }
        public List<string>? MissingElements { get; set; }
        public List<string>? Recommendations { get; set; }
    }

    private class KeyDate
    {
        public string? Label { get; set; }
        public string? Date { get; set; }
        public string? Importance { get; set; }
    }

    private class Party
    {
        public string? Role { get; set; }
        public string? Name { get; set; }
    }

    private class Obligation
    {
        public string? Party { get; set; }
        public string? Description { get; set; }
        public bool Critical { get; set; }
    }

    private class RiskyClause
    {
        public string? Title { get; set; }
        public string? Excerpt { get; set; }
        public string? Risk { get; set; }
        public string? Severity { get; set; }
    }
}
