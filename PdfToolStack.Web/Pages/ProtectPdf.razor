@page "/protect-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Protect PDF Free Online — Add Password to PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Add password protection to your PDF free online.
                   Encrypt your PDF with AES-128. No signup required." />
    <meta name="keywords"
          content="protect pdf, add password to pdf,
                   pdf password protection free,encrypt pdf" />
    <link rel="canonical"
          href="https://pdftoolstack.com/protect-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <section class="tool-hero">
            <div class="trust-row">
                <span>Encrypted output</span>
                <span>Password control</span>
                <span>Deleted in 1 hour</span>
            </div>
            <h1>Protect PDF <span class="hero-gradient-text">securely</span></h1>
            <p>
                Add password protection and permissions to your PDF with a polished,
                privacy-minded workflow.
            </p>
        </section>

        <div class="stepper" aria-label="Protect workflow progress">
            <div class="step @(SelectedFile != null || CurrentState != PageState.Upload ? "complete" : "active")">Upload</div>
            <div class="step @(SelectedFile != null && CurrentState == PageState.Upload ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">Configure</div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">Process</div>
            <div class="step @(CurrentState == PageState.Complete ? "complete active" : "")">Download</div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Secure upload</span>
                        <h2>Start with your PDF</h2>
                        <p>Upload a document, then choose passwords and permissions before encryption.</p>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved" />

                    @if (SelectedFile != null)
                    {
                        <div class="file-summary">
                            <div>
                                <span class="file-name">@SelectedFile.Name</span>
                                <span class="file-size">@Validator.FormatSize(SelectedFile.Size)</span>
                            </div>
                            <span class="status-pill">Ready</span>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <strong>Password protected output</strong>
                            <span>Add access control before sharing sensitive documents.</span>
                        </div>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade
                        FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                        FileName="@(SelectedFile?.Name ?? "")"
                        ToolType="ProtectPdf"
                        OnCancel="Reset" />
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container">
                        <div class="spinner"></div>
                        <h2>Protecting your PDF</h2>
                        <p>Encrypting file... applying permissions... preparing your secure download...</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete
                     && ResultBytes != null)
                {
                    <AdSlot Size="rectangle" />
                    <div class="result-container">
                        <span class="result-icon">Done</span>
                        <h2>Your protected PDF is ready</h2>
                        <p>Your PDF has been encrypted with AES-128 password protection.</p>
                        <button class="download-button"
                                @onclick="DownloadFile">
                            Download Protected PDF
                        </button>
                        <button class="reset-button"
                                @onclick="Reset">
                            Protect Another PDF
                        </button>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container">
                        <span class="error-icon">Issue</span>
                        <h2>We could not protect this PDF</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button"
                                @onclick="Reset">
                            Try Again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Protection settings</span>
                    <h2>Control document access</h2>
                    <p>Set an open password and choose what recipients are allowed to do.</p>
                </div>

                @if (SelectedFile != null && CurrentState == PageState.Upload)
                {
                    <div class="field-card">
                        <label>Open Password</label>
                        <input type="password"
                               class="field-input"
                               placeholder="Password to open PDF..."
                               @bind="UserPassword" />
                        <p class="option-hint">Required to open the document</p>
                    </div>
                    <div class="field-card">
                        <label>Owner Password</label>
                        <input type="password"
                               class="field-input"
                               placeholder="Owner password..."
                               @bind="OwnerPassword" />
                        <p class="option-hint">Required to change permissions</p>
                    </div>
                    <div class="field-card">
                        <label>Permissions</label>
                        <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox"
                                       @bind="AllowPrinting" />
                                Allow printing
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox"
                                       @bind="AllowCopying" />
                                Allow copying text
                            </label>
                        </div>
                    </div>
                }

                <div class="value-list">
                    <div><strong>AES-128 encryption</strong><span>Protects the PDF with standard encryption.</span></div>
                    <div><strong>Permission controls</strong><span>Limit printing and copying when needed.</span></div>
                    <div><strong>Secure processing</strong><span>Files are handled privately and removed after processing.</span></div>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage) && CurrentState == PageState.Upload)
                {
                    <p class="error-message">@ErrorMessage</p>
                }

                @if (SelectedFile != null && CurrentState == PageState.Upload)
                {
                    <button class="process-button"
                            @onclick="ProcessFile">
                        Protect PDF
                    </button>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>
                        Upload a PDF to continue
                    </button>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What encryption is used?</h3>
            <p>We use AES-128 encryption which is the
               industry standard for PDF protection.</p>
        </div>
        <div class="faq-item">
            <h3>What is the difference between open and
                owner password?</h3>
            <p>The open password is required to view the
               document. The owner password is required
               to change permissions or remove protection.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no
               signup required.</p>
        </div>
    </div>
</div>

<style>
    .tool-page { width: 100%; min-height: calc(100vh - 72px); padding: 48px 0 72px; background: radial-gradient(circle at top left, rgba(109,40,217,.12), transparent 32%), linear-gradient(135deg, #f8f7ff 0%, #eef5ff 100%); }
    .tool-container { width: min(1320px, calc(100% - 64px)); max-width: 1320px; margin: 0 auto; }
    .tool-hero { width: 100%; max-width: none; margin-bottom: 24px; text-align: left; }
    .tool-hero h1 { max-width: 900px; margin: 0 0 14px; color: #111827; font-size: clamp(2.4rem, 3vw, 3.8rem); line-height: 1.02; letter-spacing: -0.04em; }
    .tool-hero p { max-width: 760px; margin: 0; color: #526173; font-size: 1rem; line-height: 1.7; }
    .hero-gradient-text { background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .trust-row { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 18px; }
    .trust-row span { border: 1px solid rgba(37,99,235,.16); border-radius: 999px; background: rgba(255,255,255,.76); color: #334155; font-size: .83rem; font-weight: 800; padding: .48rem .78rem; box-shadow: 0 10px 30px rgba(15,23,42,.06); }
    .stepper { width: 100%; max-width: none; margin: 0 0 24px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 8px; border-radius: 999px; background: rgba(255,255,255,.8); box-shadow: 0 18px 45px rgba(15,23,42,.08); }
    .step { min-height: 44px; display: flex; align-items: center; justify-content: center; border-radius: 999px; color: #64748b; font-size: .9rem; font-weight: 900; }
    .step.active { background: linear-gradient(135deg, #6d5dfc, #2563eb); color: #fff; box-shadow: 0 12px 26px rgba(37,99,235,.24); }
    .step.complete { background: #eef2ff; color: #3730a3; }
    .workflow-grid { width: 100%; max-width: none; display: grid; grid-template-columns: minmax(0, 1.55fr) minmax(360px, .75fr); gap: 28px; align-items: start; }
    .workspace-card, .settings-card { width: 100%; max-width: none; min-width: 0; box-sizing: border-box; border: 1px solid rgba(148,163,184,.18); border-radius: 24px; background: rgba(255,255,255,.92); box-shadow: 0 20px 50px rgba(15,23,42,.08); padding: 28px; }
    .settings-card { position: sticky; top: 24px; }
    .panel-header { margin-bottom: 20px; }
    .panel-eyebrow { display: inline-flex; margin-bottom: 10px; color: #4f46e5; font-size: .76rem; font-weight: 950; letter-spacing: .08em; text-transform: uppercase; }
    .panel-header h2 { margin: 0 0 8px; color: #111827; font-size: 1.35rem; line-height: 1.2; }
    .panel-header p { margin: 0; color: #64748b; line-height: 1.6; }
    .file-summary, .empty-state, .field-card, .value-list div { border: 1px solid rgba(148,163,184,.16); border-radius: 18px; background: #f8fafc; padding: 16px; }
    .file-summary { display: flex; justify-content: space-between; gap: 16px; align-items: center; margin-top: 18px; }
    .file-name, .file-size, .empty-state strong, .empty-state span, .value-list strong, .value-list span { display: block; }
    .file-name { color: #111827; font-weight: 900; word-break: break-word; }
    .file-size, .empty-state span, .value-list span, .option-hint { color: #64748b; font-size: .9rem; }
    .status-pill { border-radius: 999px; background: #dcfce7; color: #166534; font-size: .78rem; font-weight: 900; padding: .35rem .6rem; white-space: nowrap; }
    .empty-state { margin-top: 18px; }
    .empty-state strong { color: #111827; margin-bottom: 4px; }
    .field-card { margin-bottom: 14px; }
    .field-card label { display: block; margin-bottom: 8px; color: #111827; font-weight: 900; }
    .field-input { width: 100%; box-sizing: border-box; border: 1px solid rgba(148,163,184,.35); border-radius: 14px; background: #fff; color: #111827; padding: .85rem .95rem; }
    .checkbox-group { display: grid; gap: 10px; }
    .checkbox-label { display: flex; align-items: center; gap: 10px; color: #334155; font-weight: 800; }
    .value-list { display: grid; gap: 12px; margin: 18px 0; }
    .value-list strong { color: #111827; margin-bottom: 4px; }
    .process-button, .download-button { width: 100%; border: 0; border-radius: 16px; background: linear-gradient(135deg, #6d5dfc, #2563eb); color: #fff; cursor: pointer; font-weight: 950; padding: 1rem 1.15rem; box-shadow: 0 18px 36px rgba(37,99,235,.25); transition: transform .18s ease, box-shadow .18s ease; }
    .process-button:hover, .download-button:hover { transform: translateY(-2px); box-shadow: 0 24px 45px rgba(37,99,235,.32); }
    .process-button.disabled { cursor: not-allowed; opacity: .58; transform: none; box-shadow: none; }
    .processing-container, .result-container, .error-container { text-align: center; padding: 34px 18px; }
    .spinner { width: 46px; height: 46px; margin: 0 auto 18px; border: 4px solid #e0e7ff; border-top-color: #2563eb; border-radius: 50%; animation: spin 1s linear infinite; }
    .result-icon, .error-icon { display: inline-flex; margin-bottom: 14px; border-radius: 999px; padding: .45rem .7rem; font-size: .82rem; font-weight: 950; }
    .result-icon { background: #dcfce7; color: #166534; }
    .error-icon { background: #fee2e2; color: #991b1b; }
    .result-container h2, .error-container h2, .processing-container h2 { margin: 0 0 10px; color: #111827; }
    .result-container p, .error-container p, .processing-container p { margin: 0 0 18px; color: #64748b; line-height: 1.6; }
    .reset-button { border: 0; border-radius: 14px; background: #eef2ff; color: #3730a3; cursor: pointer; font-weight: 900; padding: .9rem 1rem; }
    .download-button + .reset-button { width: 100%; margin-top: 12px; }
    .error-message { color: #b91c1c; font-weight: 800; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    @@media (max-width: 980px) { .tool-container { width: min(100%, calc(100% - 24px)); } .workflow-grid { grid-template-columns: 1fr; } .settings-card { position: static; } .stepper { overflow-x: auto; border-radius: 20px; grid-template-columns: repeat(4, minmax(130px, 1fr)); } .tool-hero h1 { font-size: clamp(2rem, 8vw, 3rem); } }
</style>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;
    private string UserPassword = string.Empty;
    private string OwnerPassword = string.Empty;
    private bool AllowPrinting = true;
    private bool AllowCopying = false;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }
        if (validation.IsWarning)
            Toast.ShowWarning(validation.Message!);

        try
        {
            using var stream = file.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();

            var bytesVal = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid)
            {
                Toast.ShowError(bytesVal.Message!);
                UploadedBytes = null;
                return;
            }
            if (bytesVal.IsWarning)
                Toast.ShowWarning(bytesVal.Message!);

            if (PaymentService.IsFileTooLargeForFree(file.Size))
            {
                CurrentState = PageState.LargeFile;
                StateHasChanged();
                return;
            }

            SelectedFile = file;
            Toast.ShowSuccess(
                $"File ready — {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null) return;

        if (string.IsNullOrEmpty(UserPassword))
        {
            ErrorMessage =
                "Please enter an open password.";
            return;
        }

        if (string.IsNullOrEmpty(OwnerPassword))
            OwnerPassword = UserPassword;

        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            ResultBytes = await ApiService.ProtectPdfAsync(
                UploadedBytes, SelectedFile!.Name,
                UserPassword, OwnerPassword,
                AllowPrinting, AllowCopying);
            CurrentState = ResultBytes != null
                ? PageState.Complete : PageState.Error;
            if (ResultBytes == null)
                ErrorMessage = "Failed to protect PDF.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "document")
            + "_protected.pdf";
        await JS.InvokeVoidAsync("downloadFile",
            fileName,
            Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
        UserPassword = string.Empty;
        OwnerPassword = string.Empty;
        AllowPrinting = true;
        AllowCopying = false;
    }
}
