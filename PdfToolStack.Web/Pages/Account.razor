@page "/account"
@inject AuthenticationStateProvider Auth
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject PdfToolStack.Web.Services.ApiService ApiService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using PdfToolStack.Application.DTOs

<PageTitle>My Account — PdfToolStack</PageTitle>

<div class="account-page">
    <AuthorizeView>
        <Authorized>
            <!-- Header -->
            <div class="account-header">
                @{
                    var picture = context.User.FindFirst("picture")?.Value;
                }
                @if (!string.IsNullOrEmpty(picture))
                {
                    <img src="@picture" alt="Profile" class="account-avatar-img" />
                }
                else
                {
                    <div class="account-avatar">
                        @(GetInitials(context.User.Identity?.Name))
                    </div>
                }
                <div>
                    <h1>@context.User.Identity?.Name</h1>
                    <p class="account-email">@context.User.FindFirst("email")?.Value</p>
                </div>
                @if (_subStatus?.HasPro == true)
                {
                    <div class="account-pro-badge">⭐ Pro</div>
                }
            </div>

            <!-- Stats row -->
            <div class="account-stats">
                <div class="account-stat-card">
                    <span class="account-stat-num">@(_history?.Count ?? 0)</span>
                    <span class="account-stat-label">Documents processed</span>
                </div>
                <div class="account-stat-card">
                    <span class="account-stat-num">@GetUniqueTools()</span>
                    <span class="account-stat-label">Tools used</span>
                </div>
                <div class="account-stat-card">
                    <span class="account-stat-num">@GetTotalSize()</span>
                    <span class="account-stat-label">Total processed</span>
                </div>
                <div class="account-stat-card">
                    <span class="account-stat-num">@(_subStatus?.HasPro == true ? "Pro" : "Free")</span>
                    <span class="account-stat-label">Current plan</span>
                </div>
            </div>

            <div class="account-grid">

                <!-- Left: Subscription -->
                <div class="account-panel">
                    <div class="account-panel-header">
                        <h2>Subscription</h2>
                    </div>

                    @if (_subStatus == null)
                    {
                        <p class="account-loading">Loading...</p>
                    }
                    else if (_subStatus.HasPro)
                    {
                        <div class="sub-card sub-card-pro">
                            <div class="sub-card-icon">⭐</div>
                            <div class="sub-card-info">
                                <h3>Pro Plan</h3>
                                <p>Unlimited files · All AI tools · No ads</p>
                                @if (_subStatus.CurrentPeriodEnd.HasValue)
                                {
                                    <p class="sub-card-date">
                                        @(_subStatus.CancelAtPeriodEnd ? "Cancels" : "Renews")
                                        on @_subStatus.CurrentPeriodEnd.Value.ToString("MMMM d, yyyy")
                                    </p>
                                }
                            </div>
                        </div>
                        <button class="reset-button" style="width:100%; margin-top:1rem;"
                                @onclick="ManageBilling">
                            Manage Billing
                        </button>
                    }
                    else
                    {
                        <div class="sub-card sub-card-free">
                            <div class="sub-card-icon">🆓</div>
                            <div class="sub-card-info">
                                <h3>Free Plan</h3>
                                <p>25MB limit · Standard tools only</p>
                            </div>
                        </div>
                        <div class="sub-upgrade-list">
                            <p class="sub-upgrade-label">Unlock with Pro:</p>
                            <div class="sub-upgrade-feat">✨ All AI tools</div>
                            <div class="sub-upgrade-feat">📦 Batch processing</div>
                            <div class="sub-upgrade-feat">📁 Unlimited file size</div>
                            <div class="sub-upgrade-feat">📋 30-day history</div>
                        </div>
                        <a href="/pricing" class="download-button"
                           style="display:block; text-align:center; text-decoration:none; margin-top:1rem;">
                            Upgrade to Pro — $19/mo
                        </a>
                    }

                    <!-- Quick links -->
                    <div class="account-quick-links">
                        <h3>Quick links</h3>
                        <a href="/ai-pdf-assist" class="account-quick-link">✨ AI Tools</a>
                        <a href="/extract-invoice-data" class="account-quick-link">🧾 Extract Invoice Data</a>
                        <a href="/batch" class="account-quick-link">📦 Batch Process</a>
                        <a href="/compare-pdf" class="account-quick-link">🔍 Compare PDFs</a>
                        <a href="/pricing" class="account-quick-link">💳 Pricing</a>
                    </div>
                </div>

                <!-- Right: Document History -->
                <div class="account-panel">
                    <div class="account-panel-header">
                        <h2>Recent Documents</h2>
                        @if (_history?.Any() == true)
                        {
                            <span class="account-panel-count">@_history.Count files</span>
                        }
                    </div>

                    @if (_historyLoading)
                    {
                        <div class="account-loading-state">
                            <div class="spinner"></div>
                            <p>Loading your documents...</p>
                        </div>
                    }
                    else if (_history == null || !_history.Any())
                    {
                        <div class="account-empty-state">
                            <div class="account-empty-icon">📄</div>
                            <h3>No documents yet</h3>
                            <p>Your processed documents will appear here. Start by using any tool.</p>
                            <a href="/" class="reset-button"
                               style="display:inline-block; text-decoration:none; max-width:160px;">
                                Browse Tools
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="history-list">
                            @foreach (var item in _history.Take(20))
                            {
                                <div class="history-item">
                                    <div class="history-item-icon" style="background:@GetToolColor(item.ToolType)">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14,2 14,8 20,8" />
                                        </svg>
                                    </div>
                                    <div class="history-item-info">
                                        <span class="history-item-name">@TruncateFileName(item.FileName)</span>
                                        <span class="history-item-meta">
                                            @FormatToolType(item.ToolType) · @FormatFileSize(item.FileSizeBytes)
                                        </span>
                                    </div>
                                    <div class="history-item-date">
                                        @GetRelativeDate(item.ProcessedAt)
                                    </div>
                                </div>
                            }
                        </div>

                        @if (!_subStatus!.HasPro)
                        {
                            <div class="history-pro-nudge">
                                <span>⭐ Pro users get 30-day history.</span>
                                <a href="/pricing">Upgrade →</a>
                            </div>
                        }
                    }
                </div>

            </div>
        </Authorized>
        <NotAuthorized>
            <div class="account-signin-prompt">
                <div class="account-empty-icon">🔐</div>
                <h2>Sign in to view your account</h2>
                <p>Access your document history, manage your subscription, and unlock Pro features.</p>
                <a href="authentication/login" class="download-button"
                   style="display:inline-block; text-decoration:none; max-width:200px;">
                    Sign In
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private string _userId = string.Empty;
    private string _baseUrl = string.Empty;
    private SubscriptionStatusDto? _subStatus;
    private List<DownloadHistoryDto>? _history;
    private bool _historyLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true) return;

        _userId = user.FindFirst("sub")?.Value ?? string.Empty;
        _baseUrl = Navigation.BaseUri.TrimEnd('/');

        await Task.WhenAll(LoadSubscriptionAsync(), LoadHistoryAsync());
    }

    private async Task LoadSubscriptionAsync()
    {
        _subStatus = await SubService.GetStatusAsync(_userId);
        StateHasChanged();
    }

    private async Task LoadHistoryAsync()
    {
        try
        {
            _history = await ApiService
                .GetAsync<List<DownloadHistoryDto>>($"api/subscription/history/{_userId}");
        }
        catch
        {
            _history = new List<DownloadHistoryDto>();
        }
        finally
        {
            _historyLoading = false;
            StateHasChanged();
        }
    }

    private async Task ManageBilling()
    {
        var url = await SubService.CreatePortalSessionAsync(_userId, _baseUrl);
        if (!string.IsNullOrEmpty(url))
            Navigation.NavigateTo(url, forceLoad: true);
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ',
            StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private string GetUniqueTools()
    {
        if (_history == null || !_history.Any()) return "0";
        return _history.Select(h => h.ToolType).Distinct().Count().ToString();
    }

    private string GetTotalSize()
    {
        if (_history == null || !_history.Any()) return "0 KB";
        var total = _history.Sum(h => h.FileSizeBytes);
        return FormatFileSize(total);
    }

    private string GetRelativeDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return date.ToString("MMM d");
    }

    private string GetToolColor(string toolType) => toolType switch
    {
        var t when t.Contains("Compress") => "#E85D04",
        var t when t.Contains("Word") => "#2563EB",
        var t when t.Contains("Merge") => "#0D9488",
        var t when t.Contains("Split") => "#EA580C",
        var t when t.Contains("Sign") => "#D97706",
        var t when t.Contains("Ai") || t.Contains("AI") => "#7C3AED",
        var t when t.Contains("Extract") => "#6D28D9",
        var t when t.Contains("Protect") => "#1E40AF",
        _ => "#4338CA"
    };

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024) return $"{bytes / 1_024.0:F0} KB";
        return $"{bytes} B";
    }

    private static string TruncateFileName(string name)
        => name.Length > 40 ? name[..37] + "..." : name;

    private static string FormatToolType(string toolType)
        => System.Text.RegularExpressions.Regex
            .Replace(toolType, "([A-Z])", " $1").Trim();
}
