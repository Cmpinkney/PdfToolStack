@page "/account"
@inject AuthenticationStateProvider Auth
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject PdfToolStack.Web.Services.ApiService ApiService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using PdfToolStack.Application.DTOs
@using PdfToolStack.Web.Components

<PageTitle>My Account — PdfToolStack</PageTitle>

<div class="acc-root">
    <AuthorizeView>
        <Authorized>
            @{
                var picture = context.User.FindFirst("picture")?.Value;
                var name = context.User.Identity?.Name ?? "User";
                var email = context.User.FindFirst("email")?.Value ?? "";
                var planLabel = _subStatus?.HasTeams == true ? "Teams" : _subStatus?.HasPro == true ? "Pro" : "Free";
                var planColor = _subStatus?.HasTeams == true ? "#0D9488" : _subStatus?.HasPro == true ? "#D97706" : "#6B7280";
            }

            <!-- ── Top profile hero ─────────────────────────────────────────── -->
            <div class="acc-hero">
                <div class="acc-hero-inner">
                    <div class="acc-avatar-wrap">
                        @if (!string.IsNullOrEmpty(picture))
                        {
                            <img src="@picture" alt="@name" class="acc-avatar-img" />
                        }
                        else
                        {
                            <div class="acc-avatar-initials">@GetInitials(name)</div>
                        }
                        <span class="acc-avatar-badge" style="background:@planColor">@planLabel</span>
                    </div>

                    <div class="acc-hero-info">
                        <h1 class="acc-hero-name">@name</h1>
                        <p class="acc-hero-email">@email</p>
                    </div>

                    <div class="acc-hero-stats">
                        <div class="acc-kpi">
                            <span class="acc-kpi-val">@(_history?.Count ?? 0)</span>
                            <span class="acc-kpi-lbl">Documents</span>
                        </div>
                        <div class="acc-kpi-divider"></div>
                        <div class="acc-kpi">
                            <span class="acc-kpi-val">@GetUniqueTools()</span>
                            <span class="acc-kpi-lbl">Tools used</span>
                        </div>
                        <div class="acc-kpi-divider"></div>
                        <div class="acc-kpi">
                            <span class="acc-kpi-val">@GetTotalSize()</span>
                            <span class="acc-kpi-lbl">Processed</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Main grid ───────────────────────────────────────────────── -->
            <div class="acc-grid">

                <!-- LEFT COLUMN -->
                <div class="acc-left">

                    <!-- Subscription card -->
                    <div class="acc-card">
                        <div class="acc-card-header">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" /></svg>
                            <span>Subscription</span>
                        </div>

                        @if (_subStatus == null)
                        {
                            <div class="acc-skeleton-block"></div>
                        }
                        else if (_subStatus.HasPro || _subStatus.HasTeams)
                        {
                            <div class="acc-plan-badge acc-plan-badge--pro">
                                <div class="acc-plan-icon" style="background:@(planColor + "20");color:@planColor">
                                    @if (_subStatus.HasTeams)
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                                    }
                                    else
                                    {
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="@planColor" stroke="none"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" /></svg>
                                    }
                                </div>
                                <div>
                                    <p class="acc-plan-name">@planLabel Plan</p>
                                    <p class="acc-plan-detail">
                                        @if (_subStatus.CurrentPeriodEnd.HasValue)
                                        {
                                            @(_subStatus.CancelAtPeriodEnd ? "Cancels" : "Renews")
                                            @(" on ")
                                            @_subStatus.CurrentPeriodEnd.Value.ToString("MMM d, yyyy")
                                        }
                                        else
                                        {
                                            @("Active subscription")
                                        }
                                    </p>
                                </div>
                            </div>

                            <!-- AI usage meter -->
                            @if (_aiUsage != null)
                            {
                                <div class="acc-usage-block">
                                    <div class="acc-usage-row">
                                        <span class="acc-usage-lbl">AI requests this month</span>
                                        <span class="acc-usage-count">@_aiUsage.Used <span class="acc-usage-limit">/ @_aiUsage.Limit</span></span>
                                    </div>
                                    <div class="acc-usage-track">
                                        <div class="acc-usage-fill" style="width:@(Math.Min(_aiUsage.Percentage, 100))%; background:@GetUsageColor(_aiUsage.Percentage)"></div>
                                    </div>
                                    <span class="acc-usage-remaining">@_aiUsage.Remaining remaining</span>

                                    @if (_purchasedCredits > 0)
                                    {
                                        <div class="acc-credits-badge">
                                            <svg width="11" height="11" viewBox="0 0 16 16" fill="none"><path d="M8 2v5M5 5l3-3 3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                                            +@_purchasedCredits top-up credits
                                        </div>
                                    }

                                    @if (_aiUsage.Percentage >= 80)
                                    {
                                        <button class="acc-topup-btn @(_aiUsage.Percentage >= 100 ? "acc-topup-btn--urgent" : "")" @onclick="ShowTopUp">
                                            @(_aiUsage.Percentage >= 100 ? "Buy more AI credits" : "Running low — top up credits")
                                        </button>
                                    }
                                </div>
                            }

                            <button class="acc-action-btn acc-action-btn--secondary" @onclick="ManageBilling">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                                Manage Billing
                            </button>
                        }
                        else
                        {
                            <!-- Free plan -->
                            <div class="acc-free-plan">
                                <div class="acc-free-header">
                                    <span class="acc-free-tag">Free</span>
                                    <span class="acc-free-limit">25MB · Standard tools</span>
                                </div>
                                <div class="acc-upgrade-features">
                                    @foreach (var feat in new[] { "All AI tools", "Batch processing (20 files)", "Unlimited file size (500MB)", "30-day download history", "PDF Compare", "Priority processing" })
                                    {
                                        <div class="acc-upgrade-feat">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                            @feat
                                        </div>
                                    }
                                </div>
                                <a href="/pricing" class="acc-action-btn acc-action-btn--upgrade">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" /></svg>
                                    Upgrade to Pro — $19/mo
                                </a>
                            </div>
                        }
                    </div>

                    <!-- Teams card (Pro teams only) -->
                    @if (_subStatus?.HasTeams == true)
                    {
                        <div class="acc-card">
                            <div class="acc-card-header">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                                <span>Team</span>
                            </div>
                            <p class="acc-card-desc">Manage your team members, invites, and shared usage.</p>
                            <a href="/team" class="acc-action-btn acc-action-btn--primary">Open Team Dashboard →</a>
                        </div>
                    }

                    <!-- Quick links -->
                    <div class="acc-card">
                        <div class="acc-card-header">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" /><polyline points="13 2 13 9 20 9" /></svg>
                            <span>Quick Access</span>
                        </div>
                        <div class="acc-quicklinks">
                            @foreach (var link in QuickLinks)
                            {
                                <a href="@link.Url" class="acc-quicklink">
                                    <div class="acc-quicklink-icon" style="background:@(link.Color + "20");color:@link.Color">
                                        @((MarkupString)link.IconSvg)
                                    </div>
                                    <span>@link.Label</span>
                                    <svg class="acc-quicklink-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
                                </a>
                            }
                        </div>
                    </div>

                    <!-- Danger zone -->
                    <div class="acc-card acc-card--danger">
                        <div class="acc-card-header">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                            <span style="color:#EF4444">Danger Zone</span>
                        </div>
                        <p class="acc-card-desc">Permanently delete your account and all associated data. This action cannot be undone.</p>
                        <a href="/account/delete" class="acc-action-btn acc-action-btn--danger">Delete My Account</a>
                    </div>

                </div>

                <!-- RIGHT COLUMN — Document History -->
                <div class="acc-right">
                    <div class="acc-card acc-card--full">
                        <div class="acc-card-header acc-card-header--spaced">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" /></svg>
                                <span>Recent Documents</span>
                            </div>
                            @if (_history?.Any() == true)
                            {
                                <span class="acc-history-count">@_history.Count files</span>
                            }
                        </div>

                        @if (_historyLoading)
                        {
                            <div class="acc-loading">
                                <div class="spinner"></div>
                                <p>Loading documents...</p>
                            </div>
                        }
                        else if (_history == null || !_history.Any())
                        {
                            <div class="acc-empty">
                                <div class="acc-empty-icon">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                </div>
                                <h3 class="acc-empty-title">No documents yet</h3>
                                <p class="acc-empty-desc">Your processed files will appear here after you use any tool.</p>
                                <a href="/" class="acc-action-btn acc-action-btn--secondary" style="display:inline-flex;width:auto;text-decoration:none;">Browse Tools</a>
                            </div>
                        }
                        else
                        {
                            <div class="acc-history">
                                @foreach (var item in _history.Take(25))
                                {
                                    <div class="acc-history-row">
                                        <div class="acc-history-icon" style="background:@GetToolColor(item.ToolType)15;color:@GetToolColor(item.ToolType)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                        </div>
                                        <div class="acc-history-info">
                                            <span class="acc-history-name">@TruncateFileName(item.FileName)</span>
                                            <span class="acc-history-meta">
                                                <span class="acc-history-tool" style="color:@GetToolColor(item.ToolType)">@FormatToolType(item.ToolType)</span>
                                                <span>·</span>
                                                <span>@FormatFileSize(item.FileSizeBytes)</span>
                                            </span>
                                        </div>
                                        <div class="acc-history-date">@GetRelativeDate(item.ProcessedAt)</div>
                                    </div>
                                }
                            </div>

                            @if (!(_subStatus?.HasPro == true))
                            {
                                <div class="acc-history-nudge">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" /></svg>
                                    Pro users get full 30-day history.
                                    <a href="/pricing">Upgrade →</a>
                                </div>
                            }
                        }
                    </div>
                </div>

            </div>
        </Authorized>

        <NotAuthorized>
            <div class="acc-signin">
                <div class="acc-signin-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                </div>
                <h2>Sign in to view your account</h2>
                <p>Access your document history, manage your subscription, and unlock Pro features.</p>
                <a href="authentication/login" class="acc-action-btn acc-action-btn--primary" style="display:inline-flex;width:auto;text-decoration:none;max-width:220px;">
                    Sign In
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<!-- Top-up toast -->
@if (_showTopUpSuccess)
{
    <div class="acc-toast">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0D9488" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
        <span><strong>@_topUpCreditsAdded AI credits added!</strong> Credits never expire — start using AI tools now.</span>
        <button @onclick='() => _showTopUpSuccess = false' class="acc-toast-close">✕</button>
    </div>
}

<AiCreditTopUpModal @ref="_topUpModal" />

<style>
    /* ═══════════════════════════════════════════════════════
       Account Page — Enterprise Dashboard
    ═══════════════════════════════════════════════════════ */

    .acc-root {
        max-width: 1160px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
    }

    /* ── Hero ─────────────────────────────────────────────── */
    .acc-hero {
        background: var(--surface, #fff);
        border: 1px solid var(--border, #E5E7EB);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
    }

    .acc-hero-inner {
        display: flex;
        align-items: center;
        gap: 1.75rem;
        flex-wrap: wrap;
    }

    .acc-avatar-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .acc-avatar-img {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--border, #E5E7EB);
    }

    .acc-avatar-initials {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4338CA 0%, #7C3AED 100%);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -.02em;
    }

    .acc-avatar-badge {
        position: absolute;
        bottom: -4px;
        right: -4px;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 0.65rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: .04em;
        text-transform: uppercase;
        border: 2px solid var(--surface, #fff);
    }

    .acc-hero-info {
        flex: 1;
        min-width: 160px;
    }

    .acc-hero-name {
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0 0 .2rem;
        color: var(--text, #111827);
        letter-spacing: -.02em;
    }

    .acc-hero-email {
        font-size: .875rem;
        color: var(--text-muted, #6B7280);
        margin: 0;
    }

    .acc-hero-stats {
        display: flex;
        align-items: center;
        gap: 0;
        margin-left: auto;
        background: var(--bg, #F9FAFB);
        border: 1px solid var(--border, #E5E7EB);
        border-radius: 14px;
        padding: .75rem 1.5rem;
        gap: 1.5rem;
    }

    .acc-kpi {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .15rem;
    }

    .acc-kpi-val {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--text, #111827);
        line-height: 1;
        letter-spacing: -.03em;
    }

    .acc-kpi-lbl {
        font-size: .72rem;
        color: var(--text-muted, #9CA3AF);
        text-transform: uppercase;
        letter-spacing: .05em;
        font-weight: 600;
    }

    .acc-kpi-divider {
        width: 1px;
        height: 32px;
        background: var(--border, #E5E7EB);
    }

    /* ── Grid ─────────────────────────────────────────────── */
    .acc-grid {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    @@media (max-width: 900px) {
        .acc-grid {
            grid-template-columns: 1fr;
        }

        .acc-hero-stats {
            margin-left: 0;
            width: 100%;
            justify-content: space-around;
        }
    }

    .acc-left {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .acc-right {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    /* ── Cards ────────────────────────────────────────────── */
    .acc-card {
        background: var(--surface, #fff);
        border: 1px solid var(--border, #E5E7EB);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
    }

    .acc-card--full {
        height: 100%;
        min-height: 400px;
    }

    .acc-card--danger {
        border-color: #FEE2E2;
        background: #FFFAFA;
    }

    [data-theme="dark"] .acc-card--danger {
        border-color: #450a0a40;
        background: #1c0a0a;
    }

    .acc-card-header {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-muted, #6B7280);
        margin-bottom: 1.25rem;
    }

    .acc-card-header--spaced {
        justify-content: space-between;
    }

    .acc-card-desc {
        font-size: .875rem;
        color: var(--text-muted, #6B7280);
        line-height: 1.5;
        margin: 0 0 1rem;
    }

    /* ── Plan badge ───────────────────────────────────────── */
    .acc-plan-badge {
        display: flex;
        align-items: center;
        gap: .875rem;
        padding: .875rem 1rem;
        background: var(--bg, #F9FAFB);
        border-radius: 12px;
        border: 1px solid var(--border, #E5E7EB);
        margin-bottom: 1rem;
    }

    .acc-plan-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .acc-plan-name {
        font-weight: 700;
        font-size: .95rem;
        color: var(--text, #111827);
        margin: 0 0 .1rem;
    }

    .acc-plan-detail {
        font-size: .78rem;
        color: var(--text-muted, #6B7280);
        margin: 0;
    }

    /* ── AI usage ─────────────────────────────────────────── */
    .acc-usage-block {
        margin-bottom: 1rem;
    }

    .acc-usage-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .4rem;
    }

    .acc-usage-lbl {
        font-size: .78rem;
        color: var(--text-muted, #6B7280);
        font-weight: 500;
    }

    .acc-usage-count {
        font-size: .85rem;
        font-weight: 700;
        color: var(--text, #111827);
    }

    .acc-usage-limit {
        font-weight: 400;
        color: var(--text-muted, #9CA3AF);
    }

    .acc-usage-track {
        height: 6px;
        background: var(--border, #E5E7EB);
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: .4rem;
    }

    .acc-usage-fill {
        height: 100%;
        border-radius: 99px;
        transition: width .5s ease;
    }

    .acc-usage-remaining {
        font-size: .75rem;
        color: var(--text-muted, #9CA3AF);
    }

    .acc-credits-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .72rem;
        font-weight: 600;
        color: #0D9488;
        background: #0D948815;
        border-radius: 6px;
        padding: 2px 8px;
        margin-top: .5rem;
    }

    .acc-topup-btn {
        display: block;
        width: 100%;
        margin-top: .75rem;
        padding: .5rem .875rem;
        border-radius: 8px;
        border: 1.5px solid #D97706;
        background: #D9770610;
        color: #D97706;
        font-size: .8rem;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        transition: all .15s;
    }

        .acc-topup-btn:hover {
            background: #D9770620;
        }

