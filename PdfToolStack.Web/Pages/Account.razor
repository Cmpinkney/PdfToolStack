@code {
    private string _userId = string.Empty;
    private string _baseUrl = string.Empty;
    private SubscriptionStatusDto? _subStatus;
    private List<DownloadHistoryDto>? _history;
    private AiUsageDto? _aiUsage;
    private bool _historyLoading = true;
    private bool _billingLoading = false;
    private string _billingError = string.Empty;
    private int _purchasedCredits = 0;
    private bool _showTopUpSuccess = false;
    private int _topUpCreditsAdded = 0;
    private bool _memoryEnabled = false;
    private bool _memoryLoading = false;
    private bool _showMemoryConfirm = false;
    private AiCreditTopUpModal? _topUpModal;

    private record QuickLinkDef(string Label, string Url, string Color, string IconSvg);

    private List<QuickLinkDef> QuickLinks => new()
    {
        new("AI Tools", "/ai-pdf-assist", "#7C3AED",
            "<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polygon points='12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2'/></svg>"),
        new("Extract Invoice Data", "/extract-invoice-data", "#6D28D9",
            "<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='3' width='18' height='18' rx='2'/><path d='M3 9h18'/><path d='M9 21V9'/></svg>"),
        new("Batch Process", "/batch", "#4338CA",
            "<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z'/></svg>"),
        new("Compare PDFs", "/compare-pdf", "#0D9488",
            "<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='8'/><line x1='21' y1='21' x2='16.65' y2='16.65'/></svg>"),
        new("Review Contract", "/review-contract", "#DC2626",
            "<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/><line x1='16' y1='13' x2='8' y2='13'/></svg>"),
        new("API Keys", "/account/api-keys", "#2563EB",
            "<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4'/></svg>"),
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        if (!user.Identity?.IsAuthenticated ?? true) return;

        _userId = user.FindFirst("sub")?.Value ?? string.Empty;
        _baseUrl = Navigation.BaseUri.TrimEnd('/');

        if (string.IsNullOrEmpty(_userId)) return;

        // Clear any stale cache to ensure accurate status
        SubService.ClearCache();

        await Task.WhenAll(
            LoadSubscriptionAsync(),
            LoadHistoryAsync(),
            LoadAiUsageAsync(),
            LoadMemorySettings());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var topup = query["topup"];
        var sessionId = query["session_id"];
        var creditsStr = query["credits"];

        if (topup == "success" && !string.IsNullOrEmpty(sessionId))
        {
            if (int.TryParse(creditsStr, out var credits))
            {
                try
                {
                    await ApiService.PostAsync<ConfirmTopUpRequest, object>(
                        "api/subscription/topup-credits/confirm",
                        new ConfirmTopUpRequest { SessionId = sessionId });
                    _topUpCreditsAdded = credits;
                    _showTopUpSuccess = true;
                    await LoadAiUsageAsync();
                }
                catch { }
            }
            Navigation.NavigateTo("/account", replace: true);
            StateHasChanged();
        }
    }

    private void ShowTopUp() => _topUpModal?.Show();

    private async Task LoadSubscriptionAsync()
    {
        _subStatus = await SubService.GetStatusAsync(_userId);
        StateHasChanged();
    }

    private async Task LoadHistoryAsync()
    {
        try
        {
            _history = await ApiService.GetAsync<List<DownloadHistoryDto>>($"api/subscription/history/{_userId}");
        }
        catch { _history = new List<DownloadHistoryDto>(); }
        finally
        {
            _historyLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadAiUsageAsync()
    {
        try
        {
            _aiUsage = await ApiService.GetAsync<AiUsageDto>($"api/ai/usage/{_userId}");
            var creditsResult = await ApiService.GetAsync<PurchasedCreditsDto>($"api/subscription/purchased-credits/{_userId}");
            _purchasedCredits = creditsResult?.Remaining ?? 0;
        }
        catch { _aiUsage = null; }
        StateHasChanged();
    }

    private class PurchasedCreditsDto { public int Remaining { get; set; } }
    private class ConfirmTopUpRequest { public string SessionId { get; set; } = string.Empty; }

    private async Task LoadMemorySettings()
    {
        try
        {
            var result = await ApiService.GetAsync<MemorySettingsResponse>(
                "api/user/memory-settings");
            if (result is not null)
                _memoryEnabled = result.Enabled;
        }
        catch { }
    }

    private async Task ToggleMemory()
    {
        if (!_memoryEnabled && !_showMemoryConfirm)
        {
            _showMemoryConfirm = true;
            return;
        }
        _showMemoryConfirm = false;
        _memoryLoading = true;
        StateHasChanged();
        try
        {
            var response = await ApiService.PostAsync<object, MemorySettingsResponse>(
                "api/user/memory-settings",
                new { enabled = !_memoryEnabled });
            if (response is not null)
                _memoryEnabled = response.Enabled;
        }
        catch { }
        finally { _memoryLoading = false; }
    }

    private async Task ConfirmEnableMemory()
    {
        _showMemoryConfirm = false;
        _memoryLoading = true;
        StateHasChanged();
        try
        {
            var response = await ApiService.PostAsync<object, MemorySettingsResponse>(
                "api/user/memory-settings",
                new { enabled = true });
            if (response is not null)
            {
                _memoryEnabled = response.Enabled;
            }
            else
            {
                // Response was null - force true since we sent enabled=true
                _memoryEnabled = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Memory enable error: {ex.Message}");
            // Still optimistically set to true
            _memoryEnabled = true;
        }
        finally
        {
            _memoryLoading = false;
            StateHasChanged();
        }
    }

    private class MemorySettingsResponse
    {
        public bool Enabled { get; set; }
        public DateTime? EnabledAt { get; set; }
    }

    private async Task ManageBilling()
    {
        if (_billingLoading)
        {
            return;
        }

        _billingError = string.Empty;
        _billingLoading = true;

        try
        {
            var url = await SubService.CreatePortalSessionAsync(_userId, _baseUrl);
            if (!string.IsNullOrWhiteSpace(url))
            {
                Navigation.NavigateTo(url, forceLoad: true);
                return;
            }

            _billingError = "Billing portal is not available for this account yet.";
        }
        catch
        {
            _billingError = "Could not open billing right now. Please try again.";
        }
        finally
        {
            _billingLoading = false;
        }
    }

    private string GetUsageColor(double pct) => pct >= 90 ? "#EF4444" : pct >= 70 ? "#D97706" : "#4338CA";

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private string GetUniqueTools()
    {
        if (_history == null || !_history.Any()) return "0";
        return _history.Select(h => h.ToolType).Distinct().Count().ToString();
    }

    private string GetTotalSize()
    {
        if (_history == null || !_history.Any()) return "0 KB";
        return FormatFileSize(_history.Sum(h => h.FileSizeBytes));
    }

    private string GetRelativeDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return date.ToString("MMM d");
    }

    private string GetToolColor(string toolType) => toolType switch
    {
        var t when t.Contains("Compress") => "#E85D04",
        var t when t.Contains("Word") => "#2563EB",
        var t when t.Contains("Merge") => "#0D9488",
        var t when t.Contains("Split") => "#EA580C",
        var t when t.Contains("Sign") => "#D97706",
        var t when t.Contains("Ai") || t.Contains("AI") => "#7C3AED",
        var t when t.Contains("Extract") => "#6D28D9",
        var t when t.Contains("Protect") => "#1E40AF",
        var t when t.Contains("Redact") => "#DC2626",
        _ => "#4338CA"
    };

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024) return $"{bytes / 1_024.0:F0} KB";
        return $"{bytes} B";
    }

    private static string TruncateFileName(string name)
        => name.Length > 42 ? name[..39] + "..." : name;

    private static string FormatToolType(string toolType)
        => System.Text.RegularExpressions.Regex.Replace(toolType, "([A-Z])", " $1").Trim();
}
