@page "/account"
@inject AuthenticationStateProvider Auth
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject PdfToolStack.Web.Services.ApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Authorization
@using PdfToolStack.Application.DTOs

<PageTitle>My Account — PdfToolStack</PageTitle>

<div class="account-page">
    <AuthorizeView>
        <Authorized>
            <!-- Header -->
            <div class="account-header">
                @{
                    var picture = context.User.FindFirst("picture")?.Value;
                }
                @if (!string.IsNullOrEmpty(picture))
                {
                    <img src="@picture" alt="Profile" class="account-avatar-img" />
                }
                else
                {
                    <div class="account-avatar">
                        @(GetInitials(context.User.Identity?.Name))
                    </div>
                }
                <div>
                    <h1>@context.User.Identity?.Name</h1>
                    <p class="account-email">@context.User.FindFirst("email")?.Value</p>
                </div>
                @if (_subStatus?.HasPro == true)
                {
                    <div class="account-pro-badge">Pro</div>
                }
            </div>

            <!-- Stats row -->
            <div class="account-stats">
                <div class="account-stat-card">
                    <span class="account-stat-num">@(_history?.Count ?? 0)</span>
                    <span class="account-stat-label">Documents processed</span>
                </div>
                <div class="account-stat-card">
                    <span class="account-stat-num">@GetUniqueTools()</span>
                    <span class="account-stat-label">Tools used</span>
                </div>
                <div class="account-stat-card">
                    <span class="account-stat-num">@GetTotalSize()</span>
                    <span class="account-stat-label">Total processed</span>
                </div>
                <div class="account-stat-card">
                    <span class="account-stat-num">@(_subStatus?.HasPro == true ? "Pro" : "Free")</span>
                    <span class="account-stat-label">Current plan</span>
                </div>
            </div>

            <div class="account-grid">

                <!-- Left: Subscription -->
                <div class="account-panel">
                    <div class="account-panel-header">
                        <h2>Subscription</h2>
                    </div>

                    @if (_subStatus == null)
                    {
                        <p class="account-loading">Loading...</p>
                    }
                    else if (_subStatus.HasPro)
                    {
                        <div class="sub-card sub-card-pro">
                            <div class="sub-card-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="#D97706" stroke="none">
                                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" />
                                </svg>
                            </div>
                            <div class="sub-card-info">
                                <h3>Pro Plan</h3>
                                <p>Unlimited files · All AI tools · No ads</p>
                                @if (_subStatus.CurrentPeriodEnd.HasValue)
                                {
                                    <p class="sub-card-date">
                                        @(_subStatus.CancelAtPeriodEnd ? "Cancels" : "Renews")
                                        on @_subStatus.CurrentPeriodEnd.Value.ToString("MMMM d, yyyy")
                                    </p>
                                }
                            </div>
                        </div>
                        <button class="reset-button" style="width:100%; margin-top:1rem;"
                                @onclick="ManageBilling">
                            Manage Billing
                        </button>

                        @if (_aiUsage != null)
                        {
                            <div class="ai-usage-meter">
                                <div class="ai-usage-header">
                                    <span class="ai-usage-label">AI requests this month</span>
                                    <span class="ai-usage-count">@_aiUsage.Used / @_aiUsage.Limit</span>
                                </div>
                                <div class="ai-usage-bar">
                                    <div class="ai-usage-fill"
                                         style="width: @(Math.Min(_aiUsage.Percentage, 100))%">
                                    </div>
                                </div>
                                <span class="ai-usage-remaining">
                                    @_aiUsage.Remaining requests remaining
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="sub-card sub-card-free">
                            <div class="sub-card-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="12" y1="8" x2="12" y2="12" />
                                    <line x1="12" y1="16" x2="12.01" y2="16" />
                                </svg>
                            </div>
                            <div class="sub-card-info">
                                <h3>Free Plan</h3>
                                <p>25MB limit · Standard tools only</p>
                            </div>
                        </div>
                        <div class="sub-upgrade-list">
                            <p class="sub-upgrade-label">Unlock with Pro:</p>
                            <div class="sub-upgrade-feat">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" />
                                </svg>
                                All AI tools
                            </div>
                            <div class="sub-upgrade-feat">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                                </svg>
                                Batch processing
                            </div>
                            <div class="sub-upgrade-feat">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                                </svg>
                                Unlimited file size
                            </div>
                            <div class="sub-upgrade-feat">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                    <line x1="16" y1="2" x2="16" y2="6" />
                                    <line x1="8" y1="2" x2="8" y2="6" />
                                    <line x1="3" y1="10" x2="21" y2="10" />
                                </svg>
                                30-day history
                            </div>
                        </div>
                        <a href="/pricing" class="download-button"
                           style="display:block; text-align:center; text-decoration:none; margin-top:1rem;">
                            Upgrade to Pro — $12/mo
                        </a>
                    }

                    <!-- Quick links -->
                    <div class="account-quick-links">
                        <h3>Quick links</h3>
                        <a href="/ai-pdf-assist" class="account-quick-link">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26 12,2" />
                            </svg>
                            AI Tools
                        </a>
                        <a href="/extract-invoice-data" class="account-quick-link">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <path d="M3 9h18" />
                                <path d="M9 21V9" />
                            </svg>
                            Extract Invoice Data
                        </a>
                        <a href="/batch" class="account-quick-link">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                            </svg>
                            Batch Process
                        </a>
                        <a href="/compare-pdf" class="account-quick-link">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8" />
                                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            </svg>
                            Compare PDFs
                        </a>
                        <a href="/pricing" class="account-quick-link">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
                                <line x1="1" y1="10" x2="23" y2="10" />
                            </svg>
                            Pricing
                        </a>
                        <a href="/account/api-keys" class="account-quick-link">
                            🔑 API Keys
                        </a>
                    </div>
                </div>

                <!-- Right: Document History -->
                <div class="account-panel">
                    <div class="account-panel-header" id="documents">
                        <h2>Recent Documents</h2>
                        @if (_history?.Any() == true)
                        {
                            <span class="account-panel-count">@_history.Count files</span>
                        }
                    </div>

                    @if (_historyLoading)
                    {
                        <div class="account-loading-state">
                            <div class="spinner"></div>
                            <p>Loading your documents...</p>
                        </div>
                    }
                    else if (_history == null || !_history.Any())
                    {
                        <div class="account-empty-state">
                            <div class="account-empty-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3;">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                    <polyline points="14,2 14,8 20,8" />
                                    <line x1="16" y1="13" x2="8" y2="13" />
                                    <line x1="16" y1="17" x2="8" y2="17" />
                                </svg>
                            </div>
                            <h3>No documents yet</h3>
                            <p>Your processed documents will appear here. Start by using any tool.</p>
                            <a href="/" class="reset-button"
                               style="display:inline-block; text-decoration:none; max-width:160px;">
                                Browse Tools
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="history-list">
                            @foreach (var item in _history.Take(20))
                            {
                                <div class="history-item">
                                    <div class="history-item-icon" style="background:@GetToolColor(item.ToolType)">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14,2 14,8 20,8" />
                                        </svg>
                                    </div>
                                    <div class="history-item-info">
                                        <span class="history-item-name">@TruncateFileName(item.FileName)</span>
                                        <span class="history-item-meta">
                                            @FormatToolType(item.ToolType) · @FormatFileSize(item.FileSizeBytes)
                                        </span>
                                    </div>
                                    <div class="history-item-date">
                                        @GetRelativeDate(item.ProcessedAt)
                                    </div>
                                </div>
                            }
                        </div>

                        @if (!_subStatus!.HasPro)
                        {
                            <div class="history-pro-nudge">
                                <span>Pro users get 30-day history.</span>
                                <a href="/pricing">Upgrade →</a>
                            </div>
                        }
                    }
                </div>

            </div>

            <!-- Referral Program -->
            <div class="account-section" style="margin-top:2rem;">
                <div class="account-panel" style="max-width:100%;">
                    <div class="account-panel-header">
                        <h2>🎁 Refer a friend — get 1 free month</h2>
                    </div>
                    <p style="font-size:0.9rem;color:var(--text-secondary);margin-bottom:1.25rem;">
                        Share your link. When a friend subscribes to Pro,
                        you get a free month automatically — no code needed.
                    </p>

                    @if (_referralLoading)
                    {
                        <div class="processing-container" style="padding:1rem;">
                            <div class="spinner"></div>
                        </div>
                    }
                    else if (_referralCode != null)
                    {
                        <div style="display:flex;gap:0.75rem;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;">
                            <code style="flex:1;min-width:200px;background:var(--bg-secondary);
                                             padding:0.75rem 1rem;border-radius:8px;
                                             font-size:0.875rem;word-break:break-all;">
                                https://pdftoolstack.com?ref=@_referralCode
                            </code>
                            <button class="sign-action-btn"
                                    style="white-space:nowrap;padding:0.6rem 1.25rem;"
                                    @onclick="CopyReferralLink">
                                @(_copied ? "✓ Copied!" : "Copy link")
                            </button>
                        </div>

                        @if (_referralStats != null)
                        {
                            <div style="display:grid;grid-template-columns:repeat(3,1fr);
                                                gap:1rem;text-align:center;">
                                <div style="background:var(--bg-secondary);
                                                    padding:1rem;border-radius:8px;">
                                    <div style="font-size:1.75rem;font-weight:700;
                                                        color:var(--text-primary);">
                                        @_referralStats.Total
                                    </div>
                                    <div style="font-size:0.75rem;
                                                        color:var(--text-secondary);
                                                        margin-top:0.25rem;">
                                        Links clicked
                                    </div>
                                </div>
                                <div style="background:var(--bg-secondary);
                                                    padding:1rem;border-radius:8px;">
                                    <div style="font-size:1.75rem;font-weight:700;
                                                        color:#2250F4;">
                                        @_referralStats.Converted
                                    </div>
                                    <div style="font-size:0.75rem;
                                                        color:var(--text-secondary);
                                                        margin-top:0.25rem;">
                                        Subscribed
                                    </div>
                                </div>
                                <div style="background:var(--bg-secondary);
                                                    padding:1rem;border-radius:8px;">
                                    <div style="font-size:1.75rem;font-weight:700;
                                                        color:#10b981;">
                                        @_referralStats.Rewarded
                                    </div>
                                    <div style="font-size:0.75rem;
                                                        color:var(--text-secondary);
                                                        margin-top:0.25rem;">
                                        Free months earned
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p style="font-size:0.875rem;color:var(--text-secondary);">
                            Sign in to get your referral link.
                        </p>
                    }
                </div>
            </div>

            <!-- GDPR: account deletion -->
            <div style="margin-top:3rem;padding-top:2rem;
                        border-top:1px solid var(--border-color);
                        text-align:center;">
                <p style="font-size:0.875rem;color:var(--text-secondary);
                           margin-bottom:0.75rem;">
                    Need to remove all your data?
                </p>
                <a href="/account/delete"
                   style="font-size:0.875rem;color:#DC2626;text-decoration:none;">
                    Delete my account
                </a>
            </div>

        </Authorized>
        <NotAuthorized>
            <div class="account-signin-prompt">
                <div class="account-empty-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3;">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                </div>
                <h2>Sign in to view your account</h2>
                <p>Access your document history, manage your subscription, and unlock Pro features.</p>
                <a href="authentication/login" class="download-button"
                   style="display:inline-block; text-decoration:none; max-width:200px;">
                    Sign In
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private string _userId = string.Empty;
    private string _baseUrl = string.Empty;
    private SubscriptionStatusDto? _subStatus;
    private List<DownloadHistoryDto>? _history;
    private AiUsageDto? _aiUsage;
    private bool _historyLoading = true;

    private string? _referralCode;
    private ReferralStatsDto? _referralStats;
    private bool _referralLoading = true;
    private bool _copied = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true) return;

        _userId = user.FindFirst("sub")?.Value ?? string.Empty;
        _baseUrl = Navigation.BaseUri.TrimEnd('/');

        await Task.WhenAll(
            LoadSubscriptionAsync(),
            LoadHistoryAsync(),
            LoadAiUsageAsync(),
            LoadReferralAsync());
    }

    private async Task LoadSubscriptionAsync()
    {
        _subStatus = await SubService.GetStatusAsync(_userId);
        StateHasChanged();
    }

    private async Task LoadHistoryAsync()
    {
        try
        {
            _history = await ApiService
                .GetAsync<List<DownloadHistoryDto>>(
                    $"api/subscription/history/{_userId}");
        }
        catch
        {
            _history = new List<DownloadHistoryDto>();
        }
        finally
        {
            _historyLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadAiUsageAsync()
    {
        try
        {
            _aiUsage = await ApiService
                .GetAsync<AiUsageDto>($"api/ai/usage/{_userId}");
        }
        catch
        {
            _aiUsage = null;
        }
        StateHasChanged();
    }

    private async Task LoadReferralAsync()
    {
        try
        {
            _referralCode = await ApiService.GetReferralCodeAsync();
            _referralStats = await ApiService.GetReferralStatsAsync();
        }
        catch
        {
            _referralCode = null;
            _referralStats = null;
        }
        finally
        {
            _referralLoading = false;
            StateHasChanged();
        }
    }

    private async Task ManageBilling()
    {
        var url = await SubService
            .CreatePortalSessionAsync(_userId, _baseUrl);
        if (!string.IsNullOrEmpty(url))
            Navigation.NavigateTo(url, forceLoad: true);
    }

    private async Task CopyReferralLink()
    {
        if (_referralCode == null) return;
        await JS.InvokeVoidAsync(
            "navigator.clipboard.writeText",
            $"https://pdftoolstack.com?ref={_referralCode}");
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ',
            StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private string GetUniqueTools()
    {
        if (_history == null || !_history.Any()) return "0";
        return _history.Select(h => h.ToolType)
            .Distinct().Count().ToString();
    }

    private string GetTotalSize()
    {
        if (_history == null || !_history.Any()) return "0 KB";
        var total = _history.Sum(h => h.FileSizeBytes);
        return FormatFileSize(total);
    }

    private string GetRelativeDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays}d ago";
        return date.ToString("MMM d");
    }

    private string GetToolColor(string toolType) => toolType switch
    {
        var t when t.Contains("Compress") => "#E85D04",
        var t when t.Contains("Word") => "#2563EB",
        var t when t.Contains("Merge") => "#0D9488",
        var t when t.Contains("Split") => "#EA580C",
        var t when t.Contains("Sign") => "#D97706",
        var t when t.Contains("Ai") || t.Contains("AI") => "#7C3AED",
        var t when t.Contains("Extract") => "#6D28D9",
        var t when t.Contains("Protect") => "#1E40AF",
        _ => "#4338CA"
    };

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1_048_576)
            return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024)
            return $"{bytes / 1_024.0:F0} KB";
        return $"{bytes} B";
    }

    private static string TruncateFileName(string name)
        => name.Length > 40 ? name[..37] + "..." : name;

    private static string FormatToolType(string toolType)
        => System.Text.RegularExpressions.Regex
            .Replace(toolType, "([A-Z])", " $1").Trim();
}
