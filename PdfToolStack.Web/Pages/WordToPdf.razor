    .post-success-benefits span { border: 1px solid rgba(37,99,235,.14); border-radius: 999px; background: rgba(255,255,255,.78); color: #334155; font-size: .74rem; font-weight: 850; padding: .3rem .5rem; }
    .post-success-link { position: relative; border-radius: 14px; background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 65%, #06b6d4 100%); box-shadow: 0 14px 28px rgba(37,99,235,.22); color: #fff; font-size: .84rem; font-weight: 950; padding: .78rem .95rem; text-decoration: none; white-space: nowrap; transition: transform .18s ease, box-shadow .18s ease; }
    .post-success-link:hover { transform: translateY(-1px); box-shadow: 0 18px 34px rgba(37,99,235,.28); }
    @@media (max-width: 700px) { .cloud-actions, .ready-metrics, .post-success-upsell { grid-template-columns: 1fr; } .post-success-link { text-align: center; } }
</style>

@code {
    private bool ShowAdsForCurrentUser = true; // TODO: Hide ads for paid users when subscription state is available here.
    private enum PageState { Upload, Processing, Complete, Error, LargeFile }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? _cloudFileName;
    private string? ErrorMessage;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true") CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidateWordFile(file);
        if (!validation.IsValid) { Toast.ShowError(validation.Message!); return; }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();
            SelectedFile = file;

            if (PaymentService.IsFileTooLargeForFree(file.Size))
                CurrentState = PageState.LargeFile;
            else
                Toast.ShowSuccess($"File ready — {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private void HandleFileRemoved()
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null || SelectedFile == null) return;
        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            ResultBytes = await ApiService.WordToPdfAsync(UploadedBytes, SelectedFile.Name);
            if (ResultBytes != null)
            {
                CurrentState = PageState.Complete;
                Toast.ShowSuccess("Word converted to PDF!");
            }
            else
            {
                ErrorMessage = "Conversion failed. Please try again.";
                Toast.ShowError(ErrorMessage);
                CurrentState = PageState.Error;
            }
        }
        catch (TaskCanceledException)
        {
            ErrorMessage = "Processing timed out. Try a smaller file.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Network error — please try again.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(SelectedFile?.Name ?? "document") + ".pdf";
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
    }

    // ── Cloud pickers ──────────────────────────────────────────────────────
    private bool _cloudLoading = false;
    private string _cloudError = string.Empty;

    private async Task PickGoogleDrive()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenGoogleDriveAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Google Drive: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task PickDropbox()
    {
        _cloudError = string.Empty;
        _cloudLoading = true;
        StateHasChanged();
        try
        {
            var f = await CloudPicker.OpenDropboxAsync();
            if (f != null) await LoadCloudFile(f.Name, f.Url, f.AccessToken);
        }
        catch (Exception ex) { _cloudError = $"Dropbox: {ex.Message}"; }
        finally { _cloudLoading = false; StateHasChanged(); }
    }

    private async Task LoadCloudFile(string name, string url, string? accessToken)
    {
        var bytes = await CloudPicker.DownloadFileAsync(url, accessToken);
        if (bytes is null || bytes.Length == 0) { _cloudError = "Could not download file. Please try again."; return; }
        UploadedBytes = bytes;
        _cloudFileName = name;
        SelectedFile = new CloudBrowserFile(name, bytes);
        Toast.ShowSuccess($"File ready — {Validator.FormatSize(bytes.LongLength)}");
        StateHasChanged();
    }
}
