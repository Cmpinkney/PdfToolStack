    .ready-metrics span { border-radius: 14px; background: rgba(255,255,255,.75); color: #334155; font-size: .8rem; font-weight: 900; padding: .7rem; text-align: center; }
    .value-list { display: grid; gap: 12px; margin: 18px 0; }
