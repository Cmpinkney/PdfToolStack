@page "/word-to-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage
@inject CloudPickerService CloudPicker
@using static PdfToolStack.Web.Components.FileUpload

<SeoHead Title="Word to PDF Converter Online - Convert DOCX to PDF | PdfToolStack"
         Description="Convert Word documents to polished PDFs online. Preserve formatting, share cleaner files, and download securely without installing software."
         CanonicalPath="/word-to-pdf" />

<div class="tool-page">
    <div class="tool-container">
        <section class="tool-hero">
            <div class="trust-row">
                <span>DOCX conversion</span>
                <span>Formatting preserved</span>
                <span>Deleted in 1 hour</span>
            </div>
            <h1>Convert Word to PDF <span class="hero-gradient-text">cleanly</span></h1>
            <p>
                Turn Word documents into polished PDFs that are easier to share,
                archive, and send.
            </p>
        </section>

        <AdPlaceholder ShowAds="ShowAdsForCurrentUser" />

        <div class="stepper" aria-label="Word to PDF workflow progress">
            <div class="step @(SelectedFile != null || CurrentState != PageState.Upload ? "complete" : "active")">
                <span>1</span>
                <strong>Upload</strong>
            </div>
            <div class="step @(SelectedFile != null && CurrentState == PageState.Upload ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")">
                <span>2</span>
                <strong>Configure</strong>
            </div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")">
                <span>3</span>
                <strong>Process</strong>
            </div>
            <div class="step @(CurrentState == PageState.Complete ? "complete active" : "")">
                <span>4</span>
                <strong>Download</strong>
            </div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Word upload</span>
                        <h2>Start with your document</h2>
                        <p>Upload a DOC or DOCX file from your device, Google Drive, or Dropbox.</p>
                    </div>

                    <div class="file-upload-clean">
                        <FileUpload OnFileSelected="HandleFileSelected"
                                    OnFileRemoved="HandleFileRemoved"
                                    Accept=".docx,.doc"
                                    HintText="Supports .docx and .doc files up to 25MB" />
                    </div>

                    <div class="cloud-row">
                        <span class="cloud-label">Import from cloud</span>
                        <div class="cloud-actions">
                            <button type="button" class="cloud-btn" @onclick="PickDropbox" disabled="@_cloudLoading">
                                <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M7.1 3.2 2 6.5l5.1 3.3 5.1-3.3-5.1-3.3Zm9.8 0-5.1 3.3 5.1 3.3L22 6.5l-5.1-3.3ZM2 13l5.1 3.3 5.1-3.3-5.1-3.3L2 13Zm14.9-3.3L11.8 13l5.1 3.3L22 13l-5.1-3.3ZM12 14.8 7.1 18 12 21.2l4.9-3.2-4.9-3.2Z" fill="#0061FF" />
                                </svg>
                                Dropbox
                            </button>
                            <button type="button" class="cloud-btn" @onclick="PickGoogleDrive" disabled="@_cloudLoading">
                                <svg class="cloud-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M9.6 3.2 3 14.5h4.5l6.5-11.3H9.6Z" fill="#34A853" />
                                    <path d="M14.1 3.2h-4.5l6.6 11.3h4.5L14.1 3.2Z" fill="#FBBC04" />
                                    <path d="M7.5 14.5 9.8 18.4h10.9L18.4 14.5H7.5Z" fill="#4285F4" />
                                </svg>
                                Google Drive
                            </button>
                        </div>
                        @if (_cloudLoading)
                        {
                            <p class="cloud-status">Importing from cloud...</p>
                        }
                        @if (!string.IsNullOrEmpty(_cloudError))
                        {
                            <p class="cloud-error">@_cloudError</p>
                        }
                    </div>

                    @if (SelectedFile != null)
                    {
                        <div class="file-ready-card">
                            <div class="file-ready-header">
                                <div class="file-ready-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z" />
                                        <polyline points="14 2 14 7 19 7" />
                                        <polyline points="9 14 11 16 15 12" />
                                    </svg>
                                </div>
                                <div>
                                <span class="panel-eyebrow">Ready to process</span>
                                <strong>@SelectedFile.Name</strong>
                                <div class="file-ready-meta">
                                    <span>@Path.GetExtension(SelectedFile.Name).TrimStart('.').ToUpperInvariant()</span>
                                    <span>@Validator.FormatSize(SelectedFile.Size)</span>
                                </div>
                                <small>Will convert to PDF</small>
                                </div>
                            </div>
                            <div class="ready-metrics">
                                <span>Word source</span>
                                <span>PDF output</span>
                                <span>Share-ready</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-kicker">Document conversion</span>
                            <strong>Upload a Word file to create a polished PDF.</strong>
                            <span>Your conversion profile appears once the document is ready.</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <p class="error-message">@ErrorMessage</p>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                                      FileName="@(SelectedFile?.Name ?? "")"
                                      ToolType="WordToPdf"
                                      OnCancel="Reset" />
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container">
                        <div class="spinner"></div>
                        <h2>Converting your document</h2>
                        <p>Reading Word content... preserving layout... creating your PDF...</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete && ResultBytes != null)
                {
                    <ResultAdPlaceholder ShowAds="ShowAdsForCurrentUser" />
                    <div class="result-container">
                        <span class="result-icon">Done</span>
                        <h2>Your PDF is ready</h2>
                        <p>
                            Your Word document has been converted to PDF successfully.
                        </p>
                        <button class="download-button" @onclick="DownloadFile">Download PDF</button>
                        <button class="reset-button" @onclick="Reset">Convert Another Document</button>
                        <PostSuccessUpsell ToolName="Word to PDF" ActionPerformed="converted document to PDF" />

                        <RecentFiles FileName="@(SelectedFile?.Name ?? "Converted Word document")"
                                     ToolName="Word to PDF"
                                     OnDownloadAgain="@DownloadFile" />
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container">
                        <span class="error-icon">Issue</span>
                        <h2>We could not convert this document</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button" @onclick="Reset">Try Again</button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Conversion profile</span>
                    <h2>Create a polished PDF</h2>
                    <p>Convert Word files into a stable document format ready for sharing.</p>
                </div>

                <div class="value-list">
                    <div><strong>PDF output</strong><span>Creates a downloadable PDF from your Word file.</span></div>
                    <div><strong>Layout retention</strong><span>Preserves text, headings, and tables where possible.</span></div>
                    <div><strong>Cloud imports</strong><span>Use existing Google Drive and Dropbox options.</span></div>
                </div>

                @if (SelectedFile != null && CurrentState == PageState.Upload)
                {
                    <button class="process-button"
                            @onclick="ProcessFile">
                        Convert to PDF
                    </button>
                    <div class="secure-note">
                        Secure processing. Files are deleted within 1 hour.
                    </div>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>
                        Upload a Word file to continue
                    </button>
                }
                @if (CurrentState == PageState.Complete)
                {
                    <SidebarAdPlaceholder ShowAds="ShowAdsForCurrentUser" />
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What Word formats are supported?</h3>
            <p>We support .docx and .doc formats created by Microsoft Word, Google Docs, and LibreOffice.</p>
        </div>
        <div class="faq-item">
            <h3>Will the formatting be preserved?</h3>
            <p>Text, headings, and tables are preserved. Complex layouts may require minor adjustments.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no signup required.</p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored on your servers?</h3>
            <p>Your file is automatically deleted within 1 hour. We never store your documents permanently.</p>
        </div>
    </div>
</div>

<style>
