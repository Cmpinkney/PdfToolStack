@page "/word-to-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Word to PDF Converter Free Online — Convert DOCX to PDF</PageTitle>

<HeadContent>
    <meta name="description"
          content="Convert Word documents to PDF free online.
                   No signup required. Fast and secure DOCX
                   to PDF conversion." />
    <meta name="keywords"
          content="word to pdf, docx to pdf, convert word to pdf
                   free, word document to pdf" />
    <link rel="canonical"
          href="https://pdftoolstack.com/word-to-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />

    <div class="tool-container">
        <h1>Word to PDF Converter</h1>
        <p class="tool-subtitle">
            Convert your Word document to PDF for free.
            No signup required. Files deleted within 1 hour.
        </p>

        @if (CurrentState == PageState.Upload)
        {
            <div class="upload-container">
                <span class="upload-icon">📄</span>
                <p>Upload your Word document (.docx)</p>
                <label class="upload-button">
                    Browse File
                    <InputFile OnChange="HandleFileSelected"
                               accept=".docx,.doc"
                               style="display:none" />
                </label>
                <p class="upload-hint">
                    Supports .docx and .doc files up to 25MB
                </p>
            </div>

            @if (SelectedFile != null)
            {
                <div class="selected-file-info">
                    <span>📄 @SelectedFile.Name</span>
                </div>
                <button class="process-button"
                        @onclick="ProcessFile">
                    Convert to PDF
                </button>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <p class="error-message">@ErrorMessage</p>
            }
        }

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                              FileName="@(SelectedFile?.Name ?? "")"
                              ToolType="WordToPdf"
                              OnCancel="Reset" />
        }

        @if (CurrentState == PageState.Processing)
        {
            <div class="processing-container">
                <div class="spinner"></div>
                <p>Converting your Word document to PDF...</p>
            </div>
        }

        @if (CurrentState == PageState.Complete
                && ResultBytes != null)
        {
            <AdSlot Size="rectangle" />
            <div class="result-container">
                <span class="result-icon">✅</span>
                <h2>Conversion Complete!</h2>
                <p style="color: var(--gray);
                               margin-bottom: 1.5rem;">
                    Your Word document has been converted
                    to PDF successfully.
                </p>
                <button class="download-button"
                        @onclick="DownloadFile">
                    Download PDF
                </button>
                <button class="reset-button"
                        @onclick="Reset">
                    Convert Another Document
                </button>
            </div>
        }

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container">
                <span class="error-icon">❌</span>
                <p class="error-message">@ErrorMessage</p>
                <button class="reset-button" @onclick="Reset">
                    Try Again
                </button>
            </div>
        }
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What Word formats are supported?</h3>
            <p>
                We support .docx and .doc formats created
                by Microsoft Word, Google Docs, and
                LibreOffice.
            </p>
        </div>
        <div class="faq-item">
            <h3>Will the formatting be preserved?</h3>
            <p>
                Text, headings, and tables are preserved.
                Complex layouts may require minor
                adjustments.
            </p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>
                Yes — completely free up to 25MB with no
                signup required.
            </p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored on your servers?</h3>
            <p>
                Your file is automatically deleted within
                1 hour. We never store your documents
                permanently.
            </p>
        </div>
    </div>
</div>

@code {
    private enum PageState
    {
        Upload, Processing, Complete, Error, LargeFile
    }

    private PageState CurrentState = PageState.Upload;
    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;

    [SupplyParameterFromQuery]
    private string? Paid { get; set; }

    protected override void OnInitialized()
    {
        if (Paid == "true")
            CurrentState = PageState.Upload;
    }

    private async Task HandleFileSelected(
    InputFileChangeEventArgs e)
    {
        SelectedFile = null;
        UploadedBytes = null;
        ErrorMessage = null;

        var validation = Validator.ValidateWordFile(e.File);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }

        try
        {
            using var stream = e.File.OpenReadStream(
                maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();
            SelectedFile = e.File;

            if (PaymentService.IsFileTooLargeForFree(e.File.Size))
                CurrentState = PageState.LargeFile;
            else
                Toast.ShowSuccess(
                    $"File ready — {Validator.FormatSize(e.File.Size)}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            UploadedBytes = null;
        }
        StateHasChanged();
    }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null || SelectedFile == null) return;
        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            ResultBytes = await ApiService.WordToPdfAsync(
                UploadedBytes, SelectedFile.Name);
            if (ResultBytes != null)
            {
                CurrentState = PageState.Complete;
                Toast.ShowSuccess("Word converted to PDF!");
            }
            else
            {
                ErrorMessage = "Conversion failed. Please try again.";
                Toast.ShowError(ErrorMessage);
                CurrentState = PageState.Error;
            }
        }
        catch (TaskCanceledException)
        {
            ErrorMessage = "Processing timed out. Try a smaller file.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Network error — please try again.";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
            Toast.ShowError(ErrorMessage);
            CurrentState = PageState.Error;
        }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(
            SelectedFile?.Name ?? "document") + ".pdf";
        await JS.InvokeVoidAsync("downloadFile",
            fileName,
            Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Tool Name");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null;
        UploadedBytes = null;
        ResultBytes = null;
        ErrorMessage = null;
    }
}
