@page "/edit-pdf"
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast

<PageTitle>Edit PDF Free Online — Add Text, Highlight and Annotate PDF | PdfToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Edit PDF files free online. Add text, shapes, highlights and drawings to your PDF. No signup required." />
    <link rel="canonical" href="https://pdftoolstack.com/edit-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">

        <div class="ai-tool-header">
            <div class="ai-tool-badge">✏️ Free Tool</div>
            <h1>Edit PDF Online</h1>
            <p class="tool-subtitle">
                Add text, shapes, highlights and drawings to any PDF.
                Full annotation toolbar with undo/redo built in. No signup required.
            </p>
        </div>

        <div class="how-it-works">
            <div class="hiw-step">
                <div class="hiw-num">1</div>
                <div class="hiw-text"><strong>Upload your PDF</strong><span>Up to 25MB free</span></div>
            </div>
            <div class="hiw-arrow">→</div>
            <div class="hiw-step">
                <div class="hiw-num">2</div>
                <div class="hiw-text"><strong>Edit with toolbar</strong><span>Text, shapes, highlights</span></div>
            </div>
            <div class="hiw-arrow">→</div>
            <div class="hiw-step">
                <div class="hiw-num">3</div>
                <div class="hiw-text"><strong>Download edited PDF</strong><span>Edits saved permanently</span></div>
            </div>
        </div>

        @if (CurrentState == PageState.LargeFile)
        {
            <LargeFileUpgrade FileSizeBytes="@_largeFileSize"
                              FileName="@_largeFileName"
                              ToolType="EditPdf"
                              OnCancel="ResetAll" />
        }
        else if (!_viewerActive)
        {
            <FileUpload OnFileSelected="HandleFileSelected"
                        OnFileRemoved="HandleFileRemoved" />
        }

        <SfPdfViewerShell @ref="_viewer"
                          ResetLabel="Edit Another PDF"
                          Height="85vh"
                          OnReset="ResetAll" />

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container" role="alert">
                <span class="error-icon">❌</span>
                <p class="error-message">@_errorMessage</p>
                <button class="reset-button" @onclick="ResetAll">Try Again</button>
            </div>
        }

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What can I add to my PDF?</h3>
            <p>Text boxes, highlights, underlines, strikethroughs, shapes, images, and freehand ink drawings — all in any color.</p>
        </div>
        <div class="faq-item">
            <h3>Can I undo changes?</h3>
            <p>Yes — full undo and redo is built into the toolbar.</p>
        </div>
        <div class="faq-item">
            <h3>Is my file private?</h3>
            <p>Yes — all editing happens entirely in your browser. Your PDF never leaves your device.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no signup required.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Error, LargeFile }

    private PageState CurrentState = PageState.Upload;
    private SfPdfViewerShell? _viewer;
    private bool _viewerActive = false;
    private string _errorMessage = string.Empty;
    private long _largeFileSize;
    private string _largeFileName = string.Empty;

    private async Task HandleFileSelected(IBrowserFile file)
    {
        CurrentState = PageState.Upload;
        _errorMessage = string.Empty;

        if (PaymentService.IsFileTooLargeForFree(file.Size))
        {
            _largeFileSize = file.Size;
            _largeFileName = file.Name;
            CurrentState = PageState.LargeFile;
            StateHasChanged();
            return;
        }

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid) { Toast.ShowError(validation.Message!); return; }
        if (validation.IsWarning) Toast.ShowWarning(validation.Message!);

        // Read bytes BEFORE any StateHasChanged — IBrowserFile ref invalidated on re-render
        byte[] bytes;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 524_288_000);
            using var ms = new MemoryStream((int)Math.Min(file.Size, int.MaxValue));
            await stream.CopyToAsync(ms);
            bytes = ms.ToArray();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Could not read file: {ex.Message}");
            return;
        }

        // Hide upload, show shell
        _viewerActive = true;
        StateHasChanged();

        var success = await _viewer!.LoadBytesAsync(file.Name, bytes);
        if (!success)
        {
            _viewerActive = false;
            StateHasChanged();
        }
    }

    private void HandleFileRemoved() { }

    private void ResetAll()
    {
        _viewer?.Reset();
        CurrentState = PageState.Upload;
        _viewerActive = false;
        _errorMessage = string.Empty;
    }
}
