@page "/edit-pdf"
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast

<PageTitle>Edit PDF Free Online — Add Text, Highlight and Annotate PDF | PdfToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Edit PDF files free online. Add text, shapes, highlights and drawings to your PDF. No signup required." />
    <link rel="canonical" href="https://pdftoolstack.com/edit-pdf" />
</HeadContent>

<div class="tool-page edit-tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container edit-tool-container">

        <section class="edit-hero">
            <div class="edit-trust-row" aria-label="Edit PDF trust badges">
                <span>Secure upload</span>
                <span>Private editing</span>
                <span>Auto-delete</span>
            </div>
            <h1>Edit PDF <span class="hero-gradient-text">confidently</span></h1>
            <p>
                Add text, shapes, highlights and drawings to any PDF. Use the editor tools to make changes, then download your updated PDF.
            </p>
        </section>

        <div class="edit-stepper" aria-label="Edit PDF workflow">
            <div class="edit-step active"><span>1</span>Upload</div>
            <div class="edit-step"><span>2</span>Edit</div>
            <div class="edit-step"><span>3</span>Review</div>
            <div class="edit-step"><span>4</span>Download</div>
        </div>

        @if (!_viewerActive)
        {
            <section class="edit-workflow-grid">
                <div class="edit-workspace-card">
                    @if (CurrentState == PageState.LargeFile)
                    {
                        <LargeFileUpgrade FileSizeBytes="@_largeFileSize"
                                          FileName="@_largeFileName"
                                          ToolType="EditPdf"
                                          OnCancel="ResetAll" />
                    }
                    else
                    {
                        <FileUpload OnFileSelected="HandleFileSelected"
                                    OnFileRemoved="HandleFileRemoved" />
                    }
                </div>

                <aside class="edit-side-card">
                    <div class="edit-panel-eyebrow">Editor workspace</div>
                    <h2>Make PDF changes in your browser</h2>
                    <p>Upload a PDF, open the editor toolbar, and download the finished document when your edits are ready.</p>
                    <div class="edit-value-list">
                        <span>Text, shapes, highlights, and drawing tools</span>
                        <span>Undo and redo support in the viewer toolbar</span>
                        <span>Your PDF stays private while you edit</span>
                    </div>
                </aside>
            </section>
        }

        <div id="edit-pdf-viewer-anchor" class="viewer-scroll-anchor"></div>

        <section class="edit-viewer-stage @(_viewerActive ? "is-active" : "")">
            @if (_viewerActive)
            {
                <div class="edit-viewer-helper">
                    Use the editor tools to make changes, then download your updated PDF.
                </div>
            }

            <SfPdfViewerShell @ref="_viewer"
                              ResetLabel="Edit Another PDF"
                              Height="85vh"
                              OnReset="ResetAll" />
        </section>

        @if (CurrentState == PageState.Error)
        {
            <div class="error-container" role="alert">
                <span class="error-icon">❌</span>
                <p class="error-message">@_errorMessage</p>
                <button class="reset-button" @onclick="ResetAll">Try Again</button>
            </div>
        }

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What can I add to my PDF?</h3>
            <p>Text boxes, highlights, underlines, strikethroughs, shapes, images, and freehand ink drawings — all in any color.</p>
        </div>
        <div class="faq-item">
            <h3>Can I undo changes?</h3>
            <p>Yes — full undo and redo is built into the toolbar.</p>
        </div>
        <div class="faq-item">
            <h3>Is my file private?</h3>
            <p>Yes — all editing happens entirely in your browser. Your PDF never leaves your device.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no signup required.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Error, LargeFile }

    private PageState CurrentState = PageState.Upload;
    private SfPdfViewerShell? _viewer;
    private bool _viewerActive = false;
    private string _errorMessage = string.Empty;
    private long _largeFileSize;
    private string _largeFileName = string.Empty;

    private async Task HandleFileSelected(IBrowserFile file)
    {
        CurrentState = PageState.Upload;
        _errorMessage = string.Empty;

        if (PaymentService.IsFileTooLargeForFree(file.Size))
        {
            _largeFileSize = file.Size;
            _largeFileName = file.Name;
            CurrentState = PageState.LargeFile;
            StateHasChanged();
            return;
        }

        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid)
        {
            Toast.ShowError(validation.Message!);
            return;
        }

        if (validation.IsWarning)
        {
            Toast.ShowWarning(validation.Message!);
        }

        // Important: do NOT re-render before OpenReadStream().
        byte[] bytes;
        try
        {
            Toast.ShowInfo("Reading your PDF...");

            using var stream = file.OpenReadStream(maxAllowedSize: 524_288_000);
            using var ms = new MemoryStream((int)Math.Min(file.Size, int.MaxValue));
            await stream.CopyToAsync(ms);
            bytes = ms.ToArray();
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Could not read file: {ex.Message}");
                return;
            }

           _viewerActive = true;
            await InvokeAsync(StateHasChanged);

            await Task.Delay(50);
            await JS.InvokeVoidAsync("scrollHelpers.scrollIntoViewById", "edit-pdf-viewer-anchor", false);
            await Task.Delay(50);

            var success = await _viewer!.LoadBytesAsync(file.Name, bytes);
        if (!success)
        {
            _viewerActive = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void HandleFileRemoved() { }

    private void ResetAll()
    {
        _viewer?.Reset();
        CurrentState = PageState.Upload;
        _viewerActive = false;
        _errorMessage = string.Empty;
    }
}
