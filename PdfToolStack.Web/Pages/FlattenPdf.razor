@page "/flatten-pdf"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Flatten PDF Free Online — Make PDF Uneditable</PageTitle>

<HeadContent>
    <meta name="description"
          content="Flatten your PDF free online. Remove form fields
                   and make your PDF uneditable. No signup required." />
    <meta name="keywords"
          content="flatten pdf, make pdf uneditable,
                   pdf flatten online free, flatten pdf form, pdf flattener" />
    <link rel="canonical"
          href="https://pdftoolstack.com/flatten-pdf" />
</HeadContent>

<div class="tool-page">
    <AdSlot Size="banner" />
    <div class="tool-container">
        <section class="tool-hero">
            <div class="trust-row">
                <span>Secure processing</span>
                <span>Make content permanent</span>
                <span>Deleted in 1 hour</span>
            </div>
            <h1>Flatten PDF <span class="hero-gradient-text">securely</span></h1>
            <p class="tool-subtitle">
                Make your PDF uneditable by flattening form fields and annotations into permanent page content.
            </p>
        </section>

        <div class="stepper" aria-label="Flatten workflow progress">
            <div class="step @(CurrentState == PageState.Upload && SelectedFile == null ? "active" : SelectedFile != null || CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")"><span>1</span><strong>Upload</strong></div>
            <div class="step @(CurrentState == PageState.Upload && SelectedFile != null ? "active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete ? "complete" : "")"><span>2</span><strong>Configure</strong></div>
            <div class="step @(CurrentState == PageState.Processing ? "active" : CurrentState == PageState.Complete ? "complete" : "")"><span>3</span><strong>Process</strong></div>
            <div class="step @(CurrentState == PageState.Complete ? "active complete" : "")"><span>4</span><strong>Download</strong></div>
        </div>

        <section class="workflow-grid">
            <div class="workspace-card">
                @if (CurrentState == PageState.Upload)
                {
                    <div class="panel-header">
                        <span class="panel-eyebrow">Upload PDF</span>
                        <h2>Start with your document</h2>
                    </div>

                    <FileUpload OnFileSelected="HandleFileSelected"
                                OnFileRemoved="HandleFileRemoved" />

                    @if (SelectedFile == null)
                    {
                        <div class="empty-state">
                            <span class="empty-kicker">Permanent output</span>
                            <strong>Upload a PDF with forms or annotations.</strong>
                            <span>Flattening locks visible fields and markups into the PDF pages.</span>
                        </div>
                    }
                    else
                    {
                        <div class="file-ready-card">
                            <span class="panel-eyebrow">File ready</span>
                            <strong>@SelectedFile.Name</strong>
                            <small>Ready to flatten into a final, uneditable PDF.</small>
                        </div>
                    }
                }

                @if (CurrentState == PageState.LargeFile)
                {
                    <LargeFileUpgrade
                        FileSizeBytes="@(SelectedFile?.Size ?? 0)"
                        FileName="@(SelectedFile?.Name ?? "")"
                        ToolType="FlattenPdf"
                        OnCancel="Reset" />
                }

                @if (CurrentState == PageState.Processing)
                {
                    <div class="processing-container">
                        <div class="spinner"></div>
                        <h2>Flattening your PDF</h2>
                        <p>Embedding form fields and annotations into the final page content.</p>
                    </div>
                }

                @if (CurrentState == PageState.Complete
                     && ResultBytes != null)
                {
                    <AdSlot Size="rectangle" />
                    <div class="result-container">
                        <span class="result-icon">Ready</span>
                        <h2>Your flattened PDF is ready</h2>
                        <p>All form fields and annotations have been permanently flattened.</p>
                        <button class="download-button"
                                @onclick="DownloadFile">
                            Download Flattened PDF
                        </button>
                        <button class="reset-button"
                                @onclick="Reset">
                            Flatten Another PDF
                        </button>
                    </div>
                }

                @if (CurrentState == PageState.Error)
                {
                    <div class="error-container">
                        <span class="error-icon">Flatten failed</span>
                        <h2>We could not finish flattening</h2>
                        <p class="error-message">@ErrorMessage</p>
                        <button class="reset-button"
                                @onclick="Reset">
                            Try Again
                        </button>
                    </div>
                }
            </div>

            <aside class="settings-card">
                <div class="panel-header">
                    <span class="panel-eyebrow">Flatten settings</span>
                    <h2>Prepare final output</h2>
                    <p>Flattening is designed for final, shareable PDFs where visible content should stay fixed.</p>
                </div>

                <div class="option-list">
                    <span><strong>Lock visible fields</strong><small>Turn filled form fields into page content.</small></span>
                    <span><strong>Keep annotations</strong><small>Make comments, stamps, and markups permanent.</small></span>
                    <span><strong>Final PDF output</strong><small>Create a clean file for sharing or archiving.</small></span>
                </div>

                @if (CurrentState == PageState.Upload && SelectedFile != null)
                {
                    <button class="process-button"
                            @onclick="ProcessFile">
                        Flatten PDF
                    </button>
                    <div class="secure-note">Secure processing. Files are deleted within 1 hour.</div>
                }
                else if (CurrentState == PageState.Upload)
                {
                    <button class="process-button disabled" disabled>Flatten PDF</button>
                    <p class="action-hint">Upload a PDF to enable flattening.</p>
                }
            </aside>
        </section>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What does flattening a PDF do?</h3>
            <p>Flattening merges all form fields and
               annotations into the page content making
               them permanent and uneditable.</p>
        </div>
        <div class="faq-item">
            <h3>Can I unflatten a PDF?</h3>
            <p>No — flattening is permanent and cannot
               be reversed. Make sure to keep a backup
               of the original.</p>
        </div>
        <div class="faq-item">
            <h3>Is this tool free?</h3>
            <p>Yes — completely free up to 25MB with no
               signup required.</p>
        </div>
    </div>
</div>

<style>
    .tool-page { width: 100%; max-width: none; min-height: calc(100vh - 72px); margin: 0; padding: 48px 0 72px; box-sizing: border-box; background: radial-gradient(circle at top left, rgba(109, 40, 217, 0.12), transparent 32%), linear-gradient(135deg, #f8f7ff 0%, #eef5ff 100%); color: #172033; }
    .tool-container { width: min(1320px, calc(100% - 64px)); max-width: 1320px; margin: 0 auto; }
    .tool-hero { margin-bottom: 24px; text-align: left; }
    .tool-hero h1 { max-width: 900px; margin: 0 0 14px; color: #111827; font-size: clamp(2.4rem, 3vw, 3.8rem); line-height: 1.02; letter-spacing: -0.04em; }
    .hero-gradient-text { background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .tool-subtitle { max-width: 760px; margin: 0; color: #5b6475; font-size: 1rem; line-height: 1.7; }
    .trust-row { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 18px; }
    .trust-row span { display: inline-flex; align-items: center; gap: .4rem; border-radius: 999px; background: rgba(255,255,255,.78); border: 1px solid rgba(148,163,184,.24); box-shadow: 0 10px 26px rgba(37,99,235,.08); color: #334155; font-size: .85rem; font-weight: 700; padding: .45rem .8rem; }
    .trust-row span::before { content: ""; width: .45rem; height: .45rem; border-radius: 999px; background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 55%, #06b6d4 100%); box-shadow: 0 0 0 4px rgba(37,99,235,.1); }
