@code {
    private int _invoicesPerWeek = 20;
    private string _hoursSaved = "10.7";
    private string _valueSaved = "$800";

    private record MockRow(string key, string val, bool highlight = false);

    private List<MockRow> _mockRows = new()
    {
        new("Vendor Name",    "Acme Supplies LLC",   true),
        new("Invoice #",      "INV-2024-0847",       true),
        new("Invoice Date",   "April 2, 2024",       false),
        new("Due Date",       "May 2, 2024",         false),
        new("Subtotal",       "$3,800.00",           false),
        new("Tax (12.6%)",    "$480.00",             false),
        new("Total Due",      "$4,280.00",           true),
    };

    private List<string> _headerFields = new()
    {
        "Vendor name & address",
        "Invoice number",
        "Invoice date",
        "Due date",
        "Bill-to name & address",
        "PO / reference number",
        "Payment terms",
    };

    private List<string> _lineItemFields = new()
    {
        "Item description",
        "Quantity",
        "Unit price",
        "Line total",
        "Item SKU / code",
        "Discount (if any)",
        "Notes per line",
    };

    private List<string> _totalFields = new()
    {
        "Subtotal",
        "Tax rate & amount",
        "Shipping / handling",
        "Discounts applied",
        "Total due",
        "Currency",
        "Bank / payment details",
    };

    private void UpdateROI(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _invoicesPerWeek = val;
            var minutesPerMonth = val * 4.33 * 8; // 4.33 weeks/month, 8 min saved each
            var hours = minutesPerMonth / 60.0;
            _hoursSaved = hours.ToString("F1");
            var value = hours * 75;
            _valueSaved = value >= 1000
                ? $"${value / 1000:F1}K"
                : $"${value:F0}";
        }
    }
}
