@page "/ai-summarizer"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@using Microsoft.AspNetCore.Components.Authorization

<SeoHead Title="AI PDF Summarizer Online - Summarize Long PDFs | PdfToolStack"
         Description="Summarize reports, contracts, articles, and long PDFs with AI. Get key points quickly while your documents stay private."
         CanonicalPath="/ai-summarizer" />

<div class="tool-page ai-tool-page">
    <div class="tool-container ai-tool-container">

        <section class="tool-hero ai-tool-hero">
            <div class="trust-row">
                <span>Private processing</span>
                <span>Secure upload</span>
                <span>Auto-delete after 1 hour</span>
            </div>
            <h1>Summarize PDFs <span class="hero-gradient-text">instantly</span></h1>
            <p>Use AI to understand, analyze, and transform your documents in seconds.</p>
        </section>

        <div class="stepper ai-tool-stepper" aria-label="AI summary steps">
            <div class="stepper-step active"><span>1</span>Upload</div>
            <div class="stepper-step"><span>2</span>Process</div>
            <div class="stepper-step"><span>3</span>Review</div>
            <div class="stepper-step"><span>4</span>Copy/Download</div>
        </div>

        <AuthorizeView>
            <NotAuthorized>
                <div class="ai-upgrade-card">
                    <div class="ai-upgrade-icon">✨</div>
                    <h2>Try AI Summarizer — 5 free uses</h2>
                    <p>Sign in to get 5 free AI uses per month. Summarize any PDF instantly with Claude AI.</p>
                    <div class="ai-upgrade-features">
                        <div class="ai-upgrade-feat">✓ Summarize any PDF in seconds</div>
                        <div class="ai-upgrade-feat">✓ Key points and conclusions</div>
                        <div class="ai-upgrade-feat">✓ Works on reports, papers, contracts</div>
                        <div class="ai-upgrade-feat">✓ Up to 50MB per document</div>
                    </div>
                    <div class="ai-upgrade-actions">
                        <a href="authentication/login?screen_hint=signup" class="download-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign up free — 5 AI uses included
                        </a>
                        <a href="authentication/login" class="reset-button"
                           style="display:inline-block; text-decoration:none;">
                            Sign in
                        </a>
                    </div>
                </div>
            </NotAuthorized>

            <Authorized>
                <section class="workflow-grid ai-tool-workflow">
                    <div class="workspace-card ai-tool-workspace">
                        @if (CurrentState == PageState.Upload)
                        {
                            <div class="ai-tool-card-header">
                                <span>Upload</span>
                                <h2>Start with a PDF</h2>
                                <p>Upload a report, contract, paper, or manual and generate a concise summary.</p>
                            </div>

                            <FileUpload OnFileSelected="HandleFileSelected"
                                        OnFileRemoved="HandleFileRemoved"
                                        HintText="Upload a PDF document — up to 50MB" />

                            @if (_fileBytes != null)
                            {
                                <button class="process-button ai-tool-primary-cta" @onclick="RunSummarize">
                                    ✨ Summarize with AI
                                </button>
                            }
                        }

                        @if (CurrentState == PageState.Processing)
                        {
                            <div class="ai-processing-container ai-tool-processing">
                                <div class="ai-processing-icon">✨</div>
                                <h3>AI is reading your document...</h3>
                                <p>Extracting key points and main arguments</p>
                                <div class="ai-processing-steps">
                                    <div class="ai-processing-step @(_step >= 1 ? "done" : "")">Reading PDF content</div>
                                    <div class="ai-processing-step @(_step >= 2 ? "done" : "")">Identifying key points</div>
                                    <div class="ai-processing-step @(_step >= 3 ? "done" : "")">Generating summary</div>
                                </div>
                            </div>
                        }

                        @if (CurrentState == PageState.Complete && !string.IsNullOrEmpty(_summary))
                        {
                            <div class="ai-result-card ai-tool-result-card">
                                <div class="ai-result-header">
                                    <div>
                                        <span class="ai-tool-result-kicker">Result</span>
                                        <h2>Summary complete</h2>
                                        <p style="color:var(--text-secondary); font-size:0.875rem;">
                                            @_fileName
                                        </p>
                                    </div>
                                    <button class="reset-button"
                                            style="max-width:140px;"
                                            @onclick="Reset">
                                        Summarize Another
                                    </button>
                                </div>
                                <div class="ai-summary-body">
                                    @_summary
                                </div>
                            </div>
                        }

                        @if (CurrentState == PageState.Error)
                        {
                            @if (_isRateLimit)
                            {
                                <AiLimitBanner IsVisible="true"
                                               IsFreeLimit="@_isFreeLimit"
                                               Limit="@(_isFreeLimit ? 5 : 200)" />
                                <button class="reset-button" style="margin-top:1rem;" @onclick="Reset">Try Again</button>
                            }
                            else
                            {
                                <div class="error-container" role="alert">
                                    <span class="error-icon" aria-hidden="true">❌</span>
                                    <p class="error-message">@_error</p>
                                    <button class="reset-button" @onclick="Reset">Try Again</button>
                                </div>
                            }
                        }
                    </div>

                    <aside class="settings-card ai-tool-settings">
                        <div class="ai-tool-card-header">
                            <span>Summary settings</span>
                            <h2>Get the important parts faster</h2>
                            <p>Summaries work best on structured documents with readable text.</p>
                        </div>

                        @if (!_isPro && _aiUsed < 5)
                        {
                            <div class="free-uses-banner">
                                <span>✨ @(5 - _aiUsed) of 5 free AI uses remaining this month</span>
                                <a href="/pricing">Upgrade to Pro for 200 AI uses/month →</a>
                            </div>
                        }

                        <div class="ai-tool-guidance-card">
                            <h3>Helpful tips</h3>
                            <p>Use this for reports, contracts, research papers, manuals, and long PDFs where you need the main argument quickly.</p>
                            <div class="ai-tool-guidance-list">
                                <span>Key points and conclusions</span>
                                <span>Readable summary output</span>
                                <span>Private processing</span>
                            </div>
                        </div>
                    </aside>
                </section>
            </Authorized>
        </AuthorizeView>

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What types of PDFs can it summarize?</h3>
            <p>Any text-based PDF — reports, research papers, contracts, manuals, articles. Scanned image PDFs may have reduced accuracy.</p>
        </div>
        <div class="faq-item">
            <h3>How long does it take?</h3>
            <p>Usually 10–30 seconds depending on document length. Longer documents take slightly more time.</p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored?</h3>
            <p>No. Your PDF is processed in memory and deleted within 1 hour. We never store document contents permanently.</p>
        </div>
    </div>
</div>

@code {
    private enum PageState { Upload, Processing, Complete, Error }
    private PageState CurrentState = PageState.Upload;

    private byte[]? _fileBytes;
    private string? _fileName;
    private bool _isPro;
    private int _aiUsed = 0;
    private int _step = 0;
    private string _summary = string.Empty;
    private string _error = string.Empty;
    private bool _isRateLimit = false;
    private bool _isFreeLimit = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst("sub")?.Value ?? string.Empty;
            var status = await SubService.GetStatusAsync(userId);
            _isPro = status.HasPro;

            if (!_isPro)
            {
                var usage = await ApiService.GetAsync<AiUsageResponse>("api/ai/usage");
                _aiUsed = usage?.Used ?? 0;
            }
        }
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 52_428_800).CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        _fileName = file.Name;
        _summary = string.Empty;
        _error = string.Empty;
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
    }

    private async Task RunSummarize()
    {
        if (_fileBytes == null) return;

        CurrentState = PageState.Processing;
        _step = 1;
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            _step = 2; StateHasChanged();

            using var content = new MultipartFormDataContent();
            var fc = new ByteArrayContent(_fileBytes);
            fc.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fc, "file", _fileName ?? "document.pdf");

            var result = await ApiService.PostMultipartWithStatusAsync<SummarizeResponse>(
                "api/ai/summarize", content);

            _step = 3; StateHasChanged();

            if (result.IsSuccess && result.Data?.Summary != null)
            {
                _summary = result.Data.Summary;
                CurrentState = PageState.Complete;
            }
            else if (result.IsRateLimit)
            {
                _isRateLimit = true;
                _isFreeLimit = !_isPro;
                CurrentState = PageState.Error;
            }
            else
            {
                _error = "Summarization failed. Please try again.";
                CurrentState = PageState.Error;
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
            CurrentState = PageState.Error;
        }

        StateHasChanged();
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _fileBytes = null;
        _fileName = null;
        _summary = string.Empty;
        _error = string.Empty;
        _step = 0;
        _isRateLimit = false;
        _isFreeLimit = false;
    }

    private class SummarizeResponse
    {
        public string Summary { get; set; } = string.Empty;
    }

    private class AiUsageResponse
    {
        public int Used { get; set; }
        public int Limit { get; set; }
    }
}
