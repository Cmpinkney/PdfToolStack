@page "/extract-invoice-data"
@page "/pdf-to-excel-extractor"
@page "/extract-data-from-pdf"
@inject ApiService ApiService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject AuthenticationStateProvider Auth
@inject IJSRuntime JS
@inject ToastService Toast
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Json

<PageTitle>Extract Data from PDF Invoice — PDF to Excel | PdfToolStack</PageTitle>

<HeadContent>
    <meta name="description"
          content="Extract invoice data from PDF to Excel automatically.
                   AI reads vendor, amounts, line items and exports to
                   spreadsheet in seconds. No manual entry." />
    <link rel="canonical"
          href="https://pdftoolstack.com/extract-invoice-data" />
</HeadContent>

<div class="tool-page extract-invoice-tool-page">
    <div class="tool-container extract-invoice-container">

        <section class="tool-hero extract-invoice-hero">
            <div class="trust-row">
                <span>Secure upload</span>
                <span>Structured output</span>
                <span>Auto-delete</span>
            </div>
            <h1>Extract invoice data <span class="hero-gradient-text">accurately</span></h1>
            <p>
                Turn invoices, contracts, and PDFs into structured data and Excel instantly.
            </p>
        </section>

        <div class="stepper extract-invoice-stepper" aria-label="Extraction steps">
            <div class="stepper-step active">
                <span>1</span>
                Upload
            </div>
            <div class="stepper-step">
                <span>2</span>
                Extract
            </div>
            <div class="stepper-step">
                <span>3</span>
                Review
            </div>
            <div class="stepper-step">
                <span>4</span>
                Export
            </div>
        </div>

        <AuthorizeView>
            <NotAuthorized>
                <div class="ai-upgrade-card">
                    <div class="ai-upgrade-icon">📊</div>
                    <h2>Try AI Invoice Extractor — 5 free uses</h2>
                    <p>Sign in to get 5 free AI uses per month. Extract invoice data to Excel automatically.</p>
                    <div class="ai-upgrade-features">
                        <div class="ai-upgrade-feat">✓ Invoice &amp; contract extraction</div>
                        <div class="ai-upgrade-feat">✓ Export directly to Excel</div>
                        <div class="ai-upgrade-feat">✓ Vendor, amounts, line items</div>
                        <div class="ai-upgrade-feat">✓ Files deleted within 1 hour</div>
                    </div>
                    <div class="ai-upgrade-actions">
                        <a href="authentication/login?screen_hint=signup" class="download-button" style="display:inline-block; text-decoration:none;">
                            Sign up free — 5 AI uses included
                        </a>
                        <a href="authentication/login" class="reset-button" style="display:inline-block; text-decoration:none;">
                            Sign in
                        </a>
                    </div>
                </div>
            </NotAuthorized>

            <Authorized>
                <section class="workflow-grid extract-invoice-workflow">
                    <div class="workspace-card extract-invoice-workspace">
                        @if (CurrentState == PageState.Upload)
                        {
                            <div class="extract-workspace-header">
                                <span class="extract-workspace-kicker">Upload document</span>
                                <h2>Start with an invoice, contract, or form</h2>
                                <p>Import a PDF and PdfToolStack will prepare it for structured AI extraction.</p>
                            </div>

                            <FileUpload OnFileSelected="HandleFileSelected"
                                        OnFileRemoved="HandleFileRemoved"
                                        HintText="Upload a PDF invoice, contract, or form — up to 50MB" />

                            @if (_fileBytes != null)
                            {
                                <button class="process-button extract-primary-cta" @onclick="RunExtract">
                                    ✨ Extract Data with AI
                                </button>
                            }
                        }

                        @if (CurrentState == PageState.Processing)
                        {
                            <div class="ai-processing-container extract-processing-card">
                                <div class="ai-processing-icon">✨</div>
                                <h3>AI is reading your document...</h3>
                                <p>Extracting fields, amounts, and line items</p>
                                <div class="ai-processing-steps">
                                    <div class="ai-processing-step @(_step >= 1 ? "done" : "")">Reading PDF text</div>
                                    <div class="ai-processing-step @(_step >= 2 ? "done" : "")">Identifying fields</div>
                                    <div class="ai-processing-step @(_step >= 3 ? "done" : "")">Structuring data</div>
                                    <div class="ai-processing-step @(_step >= 4 ? "done" : "")">Building Excel file</div>
                                </div>
                            </div>
                        }

                        @if (CurrentState == PageState.Complete && _extractedJson != null)
                        {
                            <div class="extract-results-card">
                                <div class="extract-results">
                                    <div class="extract-results-header">
                                        <div>
                                            <span class="extract-workspace-kicker">Extracted data</span>
                                            <h2>Review and export your structured results.</h2>
                                            <p style="color:var(--text-secondary); font-size:0.875rem;">
                                                @_fields.Count fields extracted from @_fileName
                                            </p>
                                        </div>
                                        <div class="extract-results-actions">
                                            @if (_excelReady)
                                            {
                                                <button class="download-button" @onclick="DownloadExcel">
                                                    ⬇ Download Excel
                                                </button>
                                            }
                                            <button class="reset-button" @onclick="Reset">
                                                Extract Another
                                            </button>
                                        </div>
                                    </div>

                                    <div class="extract-confidence-row">
                                        <div class="extract-confidence-badge">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                 stroke="currentColor" stroke-width="2.5"
                                                 stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="20,6 9,17 4,12" />
                                            </svg>
                                            95%+ field confidence
                                        </div>
                                        <span class="extract-type-tag">@_type.ToUpper()</span>
                                    </div>

                                    <div class="extract-spreadsheet-wrap">
                                        <div class="extract-spreadsheet-header">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                 stroke="currentColor" stroke-width="2"
                                                 stroke-linecap="round" stroke-linejoin="round"
                                                 style="color:var(--success);">
                                                <rect x="3" y="3" width="18" height="18" rx="1" />
                                                <path d="M3 9h18" />
                                                <path d="M9 21V9" />
                                            </svg>
                                            Extracted Data Preview
                                            <span style="margin-left:auto; font-size:0.72rem; color:var(--text-muted); font-weight:400;">
                                                Matches your Excel download exactly
                                            </span>
                                        </div>
                                        <div class="extract-spreadsheet-table-wrap">
                                            <table class="extract-spreadsheet-table">
                                                <thead>
                                                    <tr>
                                                        <th class="extract-sheet-col-a">Field</th>
                                                        <th class="extract-sheet-col-b">Value</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var field in _fields)
                                                    {
                                                        <tr class="extract-sheet-row">
                                                            <td class="extract-sheet-label">@field.Key</td>
                                                            <td class="extract-sheet-value">@field.Value</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>

                                    @if (_lineItems.Any())
                                    {
                                        <div class="extract-line-items">
                                            <div class="extract-spreadsheet-header">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                     stroke="currentColor" stroke-width="2"
                                                     stroke-linecap="round" stroke-linejoin="round"
                                                     style="color:var(--success);">
                                                    <rect x="3" y="3" width="18" height="18" rx="1" />
                                                    <path d="M3 9h18" />
                                                    <path d="M9 21V9" />
                                                </svg>
                                                Line Items
                                            </div>
                                            <div class="extract-spreadsheet-table-wrap">
                                                <table class="extract-spreadsheet-table">
                                                    <thead>
                                                        <tr>
                                                            <th style="text-align:left; width:40%;">Description</th>
                                                            <th style="text-align:center;">Qty</th>
                                                            <th style="text-align:right;">Unit Price</th>
                                                            <th style="text-align:right;">Total</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in _lineItems)
                                                        {
                                                            <tr class="extract-sheet-row">
                                                                <td class="extract-sheet-value" style="text-align:left;">@item.GetValueOrDefault("description")</td>
                                                                <td class="extract-sheet-value" style="text-align:center;">@item.GetValueOrDefault("quantity")</td>
                                                                <td class="extract-sheet-value" style="text-align:right;">@item.GetValueOrDefault("unitPrice")</td>
                                                                <td class="extract-sheet-value extract-sheet-total" style="text-align:right;">@item.GetValueOrDefault("total")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    }

                                    @if (_fraudResult is not null)
                                    {
                                        <div class="extract-fraud-panel extract-fraud-panel--@_fraudResult.RiskLevel.ToLower()">
                                            <div class="extract-fraud-header">
                                                <div class="extract-fraud-icon">@GetRiskIcon(_fraudResult.RiskLevel)</div>
                                                <div class="extract-fraud-content">
                                                    <p class="extract-fraud-eyebrow">FRAUD RISK ANALYSIS</p>
                                                    <h3 class="extract-fraud-title">@GetRiskTitle(_fraudResult.RiskLevel)</h3>
                                                    <p class="extract-fraud-meta">@_historyCount previous @(_historyCount == 1 ? "invoice" : "invoices") on record for this vendor</p>
                                                </div>
                                                <div class="extract-fraud-score extract-fraud-score--@_fraudResult.RiskLevel.ToLower()">
                                                    <span class="extract-fraud-score__num">@_fraudResult.RiskScore</span>
                                                    <span class="extract-fraud-score__label">/ 100</span>
                                                </div>
                                            </div>
                                            <div class="extract-fraud-recommendation">
                                                <p>@_fraudResult.Recommendation</p>
                                            </div>
                                            @if (_fraudResult.Flags?.Count > 0)
                                            {
                                                <div class="extract-fraud-flags">
                                                    @foreach (var flag in _fraudResult.Flags.OrderBy(f => GetSeverityOrder(f.Severity)))
                                                    {
                                                        <div class="extract-fraud-flag extract-fraud-flag--@flag.Severity.ToLower()">
                                                            <div class="extract-fraud-flag__header">
                                                                <span class="extract-fraud-flag__badge">@flag.Severity</span>
                                                                <span class="extract-fraud-flag__category">@FormatCategory(flag.Category)</span>
                                                            </div>
                                                            <p class="extract-fraud-flag__desc">@flag.Description</p>
                                                            <p class="extract-fraud-flag__action">→ @flag.Recommendation</p>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="extract-fraud-clean">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                                    <p>No fraud indicators detected. This invoice matches your vendor's historical patterns.</p>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (_isPro && _extractedJson is not null && !_isFraudChecking)
                                    {
                                        <div class="extract-fraud-cta">
                                            <div class="extract-fraud-cta__text">
                                                <p class="extract-fraud-eyebrow">PRO FEATURE</p>
                                                <p class="extract-fraud-cta__title">Run fraud detection on this invoice</p>
                                                <p class="extract-fraud-cta__desc">Check for amount anomalies, bank account changes, math errors, and duplicate invoices.</p>
                                            </div>
                                            <button class="process-button" @onclick="RunFraudCheckOnly">
                                                🔍 Run Fraud Check
                                            </button>
                                        </div>
                                    }
                                    else if (_isFraudChecking)
                                    {
                                        <div class="extract-fraud-cta">
                                            <div class="extract-fraud-cta__text">
                                                <p class="extract-fraud-eyebrow">ANALYZING</p>
                                                <p class="extract-fraud-cta__title">Running fraud analysis...</p>
                                            </div>
                                            <div class="processing-dots"><span></span><span></span><span></span></div>
                                        </div>
                                    }

                                    @if (_excelReady)
                                    {
                                        <div class="extract-download-cta">
                                            <div class="extract-download-cta-text">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                                     stroke="currentColor" stroke-width="2"
                                                     stroke-linecap="round" stroke-linejoin="round"
                                                     style="color:var(--success); flex-shrink:0;">
                                                    <rect x="3" y="3" width="18" height="18" rx="1" />
                                                    <path d="M3 9h18" />
                                                    <path d="M9 21V9" />
                                                </svg>
                                                <div>
                                                    <strong>Looks right? Download your Excel file.</strong>
                                                    <p>Professional accounting layout — ready for QuickBooks, Xero, or Excel.</p>
                                                </div>
                                            </div>
                                            <button class="download-button"
                                                    style="max-width:200px; margin-top:0;"
                                                    @onclick="DownloadExcel">
                                                ⬇ Download Excel
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (CurrentState == PageState.Error)
                        {
                            @if (_isRateLimit)
                            {
                                <AiLimitBanner IsVisible="true"
                                               IsFreeLimit="@_isFreeLimit"
                                               Limit="@(_isFreeLimit ? 5 : 200)" />
                                <button class="reset-button" style="margin-top:1rem;" @onclick="Reset">Try Again</button>
                            }
                            else
                            {
                                <div class="error-container" role="alert">
                                    <span class="error-icon" aria-hidden="true">❌</span>
                                    <p class="error-message">@_error</p>
                                    @if (!string.IsNullOrWhiteSpace(_textPreview))
                                    {
                                        <details class="extract-guidance-card">
                                            <summary>Extracted text preview</summary>
                                            <p>@_textPreview</p>
                                        </details>
                                    }
                                    <button class="reset-button" @onclick="Reset">Try Again</button>
                                </div>
                            }
                        }
                    </div>

                    <aside class="settings-card extract-invoice-settings">
                        <div class="extract-settings-header">
                            <span class="extract-workspace-kicker">AI extraction</span>
                            <h2>Extraction settings</h2>
                            <p>Choose the document pattern that best matches your file.</p>
                        </div>

                        @if (!_isPro && _aiUsed < 5)
                        {
                            <div class="free-uses-banner">
                                <span>✨ @(5 - _aiUsed) of 5 free AI uses remaining this month</span>
                                <a href="/pricing">Upgrade to Pro for 200 AI uses/month →</a>
                            </div>
                        }

                        <div class="extract-type-section">
                            <p class="extract-type-label">What type of document are you extracting?</p>
                            <div class="extract-type-grid">
                                <button class="extract-type-btn @(_type == "invoice" ? "active" : "")"
                                        @onclick='() => _type = "invoice"'>
                                    <span class="extract-type-icon">🧾</span>
                                    <span class="extract-type-name">Invoice</span>
                                    <span class="extract-type-desc">Vendor, amounts, line items</span>
                                </button>
                                <button class="extract-type-btn @(_type == "contract" ? "active" : "")"
                                        @onclick='() => _type = "contract"'>
                                    <span class="extract-type-icon">📋</span>
                                    <span class="extract-type-name">Contract</span>
                                    <span class="extract-type-desc">Parties, dates, obligations</span>
                                </button>
                                <button class="extract-type-btn @(_type == "general" ? "active" : "")"
                                        @onclick='() => _type = "general"'>
                                    <span class="extract-type-icon">📄</span>
                                    <span class="extract-type-name">General Form</span>
                                    <span class="extract-type-desc">Any structured document</span>
                                </button>
                            </div>
                        </div>

                        <div class="extract-explainer-card">
                            <h3>What this does</h3>
                            <p>Extracts structured fields and line items into a spreadsheet-ready format.</p>
                            <div class="extract-explainer-list">
                                <span>Vendor and customer details</span>
                                <span>Dates, totals, and tax fields</span>
                                <span>Line items for Excel export</span>
                            </div>
                        </div>

                        <div class="extract-fraud-advertise">
                            <p class="extract-fraud-advertise__title">Invoice Fraud Detection</p>
                            @if (_isPro)
                            {
                                <span class="extract-fraud-advertise__badge">Pro — Active</span>
                            }
                            else
                            {
                                <span class="extract-fraud-advertise__badge extract-fraud-advertise__badge--upgrade">Pro feature</span>
                            }
                            <p class="extract-fraud-advertise__desc">After extraction, run AI fraud analysis to catch:</p>
                            <ul class="extract-fraud-advertise__list">
                                <li>Amount anomalies vs vendor history</li>
                                <li>Bank account changes</li>
                                <li>Math errors in totals</li>
                                <li>Duplicate invoice numbers</li>
                                <li>Unusual invoice dates</li>
                            </ul>
                            @if (!_isPro)
                            {
                                <a href="/pricing" class="extract-fraud-advertise__cta">Upgrade to Pro →</a>
                            }
                        </div>

                        <div class="extract-guidance-card">
                            Upload a document and run extraction to generate Excel output.
                        </div>
                    </aside>
                </section>
            </Authorized>
        </AuthorizeView>

    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <h3>What types of documents can it extract?</h3>
            <p>Invoices, purchase orders, contracts, forms, receipts, and any structured PDF document. The AI adapts to the document type you select.</p>
        </div>
        <div class="faq-item">
            <h3>How accurate is the extraction?</h3>
            <p>Very accurate for standard invoices and forms — typically 95%+ field accuracy. Complex or handwritten documents may need minor review.</p>
        </div>
        <div class="faq-item">
            <h3>Is my document stored anywhere?</h3>
            <p>No. Your PDF is processed in memory and deleted within 1 hour. We never store document contents on our servers permanently.</p>
        </div>
        <div class="faq-item">
            <h3>What does the Excel output look like?</h3>
            <p>Each extracted field gets its own row with a label and value. Line items appear in a structured table. Ready to paste into your accounting software.</p>
        </div>
    </div>
</div>

<style>
    .extract-fraud-panel { border-radius: 10px; border: 1.5px solid var(--border-subtle); overflow: hidden; margin: 20px 0; }
    .extract-fraud-panel--critical { border-color: rgba(231,76,60,.4); }
    .extract-fraud-panel--high { border-color: rgba(230,126,34,.4); }
    .extract-fraud-panel--medium { border-color: rgba(243,156,18,.4); }
    .extract-fraud-panel--low { border-color: rgba(39,174,96,.4); }
    .extract-fraud-header { display:flex; align-items:center; gap:14px; padding:18px 20px; background:var(--surface-strong); border-bottom:1px solid var(--border-subtle); }
    .extract-fraud-icon { font-size:2rem; flex-shrink:0; }
    .extract-fraud-content { flex:1; min-width:0; }
    .extract-fraud-eyebrow { margin:0 0 3px; font-size:.7rem; font-weight:900; letter-spacing:.1em; color:var(--text-muted); text-transform:uppercase; }
    .extract-fraud-title { margin:0 0 4px; font-size:1.05rem; font-weight:900; color:var(--text-primary); }
    .extract-fraud-meta { margin:0; font-size:.82rem; color:var(--text-muted); }
    .extract-fraud-score { display:flex; flex-direction:column; align-items:center; padding:10px 16px; border-radius:8px; background:var(--surface); flex-shrink:0; }
    .extract-fraud-score__num { font-size:2rem; font-weight:900; line-height:1; }
    .extract-fraud-score__label { font-size:.72rem; color:var(--text-muted); font-weight:600; }
    .extract-fraud-score--low .extract-fraud-score__num { color:#27ae60; }
    .extract-fraud-score--medium .extract-fraud-score__num { color:#f39c12; }
    .extract-fraud-score--high .extract-fraud-score__num { color:#e67e22; }
    .extract-fraud-score--critical .extract-fraud-score__num { color:#e74c3c; }
    .extract-fraud-recommendation { padding:12px 20px; border-bottom:1px solid var(--border-subtle); }
    .extract-fraud-recommendation p { margin:0; font-size:.92rem; font-weight:600; color:var(--text-primary); line-height:1.5; }
    .extract-fraud-flags { display:grid; }
    .extract-fraud-flag { padding:12px 20px; border-bottom:1px solid var(--border-subtle); }
    .extract-fraud-flag:last-child { border-bottom:none; }
    .extract-fraud-flag--critical { background:rgba(231,76,60,.04); }
    .extract-fraud-flag--high { background:rgba(230,126,34,.04); }
    .extract-fraud-flag--medium { background:rgba(243,156,18,.04); }
    .extract-fraud-flag__header { display:flex; align-items:center; gap:8px; margin-bottom:6px; }
    .extract-fraud-flag__badge { font-size:.7rem; font-weight:900; letter-spacing:.06em; padding:2px 8px; border-radius:4px; color:#fff; }
    .extract-fraud-flag--critical .extract-fraud-flag__badge { background:#e74c3c; }
    .extract-fraud-flag--high .extract-fraud-flag__badge { background:#e67e22; }
    .extract-fraud-flag--medium .extract-fraud-flag__badge { background:#f39c12; }
    .extract-fraud-flag--low .extract-fraud-flag__badge { background:#95a5a6; }
    .extract-fraud-flag__category { font-size:.85rem; font-weight:700; color:var(--text-primary); }
    .extract-fraud-flag__desc { margin:0 0 5px; font-size:.88rem; color:var(--text-primary); line-height:1.5; }
    .extract-fraud-flag__action { margin:0; font-size:.82rem; color:var(--text-muted); font-style:italic; }
    .extract-fraud-clean { display:flex; align-items:center; gap:10px; padding:14px 20px; }
    .extract-fraud-clean p { margin:0; font-size:.9rem; font-weight:600; color:#27ae60; }
    .extract-fraud-cta { display:flex; align-items:center; justify-content:space-between; gap:16px; padding:18px 20px; border:1px solid var(--border-subtle); border-radius:10px; background:var(--surface-strong); margin:20px 0; flex-wrap:wrap; }
    .extract-fraud-cta__title { margin:4px 0 6px; font-size:1rem; font-weight:900; color:var(--text-primary); }
    .extract-fraud-cta__desc { margin:0; font-size:.85rem; color:var(--text-muted); }
    .processing-dots { display:flex; gap:6px; }
    .processing-dots span { width:8px; height:8px; border-radius:50%; background:var(--brand-accent-blue); animation:bounce 1.2s infinite; }
    .processing-dots span:nth-child(2) { animation-delay:.2s; }
    .processing-dots span:nth-child(3) { animation-delay:.4s; }
    .extract-fraud-advertise { margin-top:14px; padding:16px 18px; border-radius:12px; background:var(--surface-strong); }
    .extract-fraud-advertise__title { margin:0 0 6px; font-size:.95rem; font-weight:700; color:var(--text-primary); }
    .extract-fraud-advertise__badge { display:inline-block; padding:2px 8px; border-radius:20px; background:var(--brand-accent-blue); color:#fff; font-size:.68rem; font-weight:900; letter-spacing:.06em; margin-bottom:10px; }
    .extract-fraud-advertise__badge--upgrade { background:transparent; color:var(--brand-accent-blue); border:1px solid var(--brand-accent-blue); }
    .extract-fraud-advertise__desc { margin:0 0 8px; font-size:.88rem; color:var(--text-muted); line-height:1.5; }
    .extract-fraud-advertise__list { margin:0 0 12px; padding-left:0; list-style:none; display:grid; gap:6px; }
    .extract-fraud-advertise__list li { font-size:.88rem; color:var(--text-primary); font-weight:600; display:flex; align-items:center; gap:8px; }
    .extract-fraud-advertise__list li::before { content:"●"; color:var(--brand-accent-blue); font-size:.5rem; flex-shrink:0; }
    .extract-fraud-advertise__cta { display:inline-block; margin-top:4px; font-size:.85rem; font-weight:800; color:var(--brand-accent-blue); text-decoration:none; }
    .extract-fraud-advertise__cta:hover { text-decoration:underline; }
</style>

@code {
    private enum PageState { Upload, Processing, Complete, Error }
    private PageState CurrentState = PageState.Upload;

    private byte[]? _fileBytes;
    private string? _fileName;
    private string _type = "invoice";
    private bool _isPro = false;
    private int _aiUsed = 0;
    private int _step = 0;
    private string _error = string.Empty;
    private bool _isRateLimit = false;
    private bool _isFreeLimit = false;
    private string? _extractedJson;
    private List<KeyValuePair<string, string>> _fields = new();
    private List<Dictionary<string, string>> _lineItems = new();
    private byte[]? _excelBytes;
    private bool _excelReady = false;
    private string _textPreview = string.Empty;
    private bool _ocrFallbackUsed = false;
    private string? _ocrWarning;
    private FraudAnalysisDto? _fraudResult;
    private int _historyCount;
    private bool _isFraudChecking;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst("sub")?.Value ?? string.Empty;
            var status = await SubService.GetStatusAsync(userId);
            _isPro = status.HasPro;

            if (!_isPro)
            {
                var usage = await ApiService.GetAsync<AiUsageResponse>("api/ai/usage");
                _aiUsed = usage?.Used ?? 0;
            }
        }
    }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 52_428_800).CopyToAsync(ms);
        _fileBytes = ms.ToArray();
        _fileName = file.Name;
        _extractedJson = null;
        _excelReady = false;
        _fields.Clear();
        _lineItems.Clear();
        _error = string.Empty;
        _textPreview = string.Empty;
        _ocrFallbackUsed = false;
        _ocrWarning = null;
    }

    private void HandleFileRemoved()
    {
        _fileBytes = null;
        _fileName = null;
    }

    private async Task RunExtract()
    {
        if (_fileBytes == null) return;

        CurrentState = PageState.Processing;
        _step = 1;
        StateHasChanged();

        try
        {
            await Task.Delay(600);
            _step = 2; StateHasChanged();

            var (json, error) = await PostExtractAsync("api/ai/extract");

            if (error != null)
            {
                _error = error;
                CurrentState = PageState.Error;
                return;
            }

            _extractedJson = json;
            ParseFields(json!);
            _step = 3; StateHasChanged();

            await Task.Delay(400);
            _step = 4; StateHasChanged();

            var (excelBytes, _) = await PostExtractBytesAsync("api/ai/extract/excel");
            if (excelBytes != null)
            {
                _excelBytes = excelBytes;
                _excelReady = true;
            }

            CurrentState = PageState.Complete;
            Toast.ShowSuccess("Data extracted successfully!");
        }
        catch (Exception ex)
        {
            _error = $"Extraction failed: {ex.Message}";
            CurrentState = PageState.Error;
            Toast.ShowError(_error);
        }

        StateHasChanged();
    }

    private async Task<(string? Json, string? Error)> PostExtractAsync(string endpoint)
    {
        using var content = new MultipartFormDataContent();
        var fc = new ByteArrayContent(_fileBytes!);
        fc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
        content.Add(fc, "file", _fileName ?? "document.pdf");

        var result = await ApiService.PostMultipartWithStatusAsync<ExtractResponse>(
            $"{endpoint}?type={_type}", content);

        if (!result.IsSuccess || result.Data == null)
        {
            var backendError = TryLoadExtractionError(result.ErrorBody);
            var message = !string.IsNullOrWhiteSpace(backendError)
                ? backendError
                : result.ErrorMessage;

            return (null, string.IsNullOrWhiteSpace(message)
                ? "Extraction failed. Please try again."
                : message);
        }

        _textPreview = result.Data.ExtractedTextPreview ??
            result.Data.TextPreview ??
            string.Empty;
        _ocrFallbackUsed = result.Data.OcrFallbackUsed;
        _ocrWarning = result.Data.OcrWarning;

        return (result.Data.Json, null);
    }

    private string? TryLoadExtractionError(string errorBody)
    {
        if (string.IsNullOrWhiteSpace(errorBody))
            return null;

        try
        {
            using var doc = JsonDocument.Parse(errorBody);
            var root = doc.RootElement;
            string? backendError = null;

            if (root.TryGetProperty("error", out var error) &&
                error.ValueKind == JsonValueKind.String)
            {
                backendError = error.GetString();
            }
            else if (root.TryGetProperty("message", out var message) &&
                message.ValueKind == JsonValueKind.String)
            {
                backendError = message.GetString();
            }

            if (TryGetStringProperty(root, "extractedTextPreview", out var extractedPreview) ||
                TryGetStringProperty(root, "textPreview", out extractedPreview))
            {
                _textPreview = extractedPreview;
            }

            if (root.TryGetProperty("ocrFallbackUsed", out var ocrUsed) &&
                (ocrUsed.ValueKind == JsonValueKind.True ||
                 ocrUsed.ValueKind == JsonValueKind.False))
            {
                _ocrFallbackUsed = ocrUsed.GetBoolean();
            }

            if (root.TryGetProperty("ocrWarning", out var warning) &&
                warning.ValueKind == JsonValueKind.String)
            {
                _ocrWarning = warning.GetString();
            }

            return backendError;
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private static bool TryGetStringProperty(
        JsonElement root,
        string name,
        out string value)
    {
        value = string.Empty;

        if (!root.TryGetProperty(name, out var property) ||
            property.ValueKind != JsonValueKind.String)
        {
            return false;
        }

        value = property.GetString() ?? string.Empty;
        return !string.IsNullOrWhiteSpace(value);
    }

    private async Task<(byte[]? Bytes, string? Error)> PostExtractBytesAsync(string endpoint)
    {
        using var content = new MultipartFormDataContent();
        var fc = new ByteArrayContent(_fileBytes!);
        fc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
        content.Add(fc, "file", _fileName ?? "document.pdf");

        var bytes = await ApiService.PostMultipartBytesAsync(
            $"{endpoint}?type={_type}", content);

        return (bytes, bytes == null ? "Excel export failed." : null);
    }

    private void ParseFields(string json)
    {
        try
        {
            var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            var skip = new HashSet<string> { "lineItems" };

            foreach (var prop in root.EnumerateObject())
            {
                if (skip.Contains(prop.Name)) continue;
                if (prop.Value.ValueKind == JsonValueKind.Null) continue;
                if (prop.Value.ValueKind == JsonValueKind.Array) continue;
                _fields.Add(new KeyValuePair<string, string>(
                    ToLabel(prop.Name), prop.Value.ToString()));
            }

            if (root.TryGetProperty("lineItems", out var items) &&
                items.ValueKind == JsonValueKind.Array)
            {
                foreach (var item in items.EnumerateArray())
                {
                    var dict = new Dictionary<string, string>();
                    foreach (var p in item.EnumerateObject())
                        if (p.Value.ValueKind != JsonValueKind.Null)
                            dict[p.Name] = p.Value.ToString();
                    _lineItems.Add(dict);
                }
            }
        }
        catch { }
    }

    private async Task DownloadExcel()
    {
        if (_excelBytes == null) return;
        var name = $"extracted_{_type}_{DateTime.Now:yyyyMMdd}.xlsx";
        await JS.InvokeVoidAsync("downloadFile", name, Convert.ToBase64String(_excelBytes));
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        _fileBytes = null;
        _fileName = null;
        _extractedJson = null;
        _excelReady = false;
        _excelBytes = null;
        _fields.Clear();
        _lineItems.Clear();
        _error = string.Empty;
        _textPreview = string.Empty;
        _ocrFallbackUsed = false;
        _ocrWarning = null;
        _step = 0;
        _isRateLimit = false;
        _isFreeLimit = false;
    }

    private async Task RunFraudCheckOnly()
    {
        if (_fileBytes is null) return;
        _isFraudChecking = true;
        StateHasChanged();

        try
        {
            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(_fileBytes), "file", _fileName ?? "document.pdf");

            var result = await ApiService.PostMultipartWithStatusAsync<FraudCheckResponse>(
                "api/ai/fraud-check", content);

            if (result.IsSuccess && result.Data is not null)
            {
                _fraudResult = result.Data.FraudAnalysis;
                _historyCount = result.Data.HistoryCount;
            }
            else
            {
                Toast.ShowError(result.ErrorMessage ?? "Fraud check failed. Please try again.");
            }
        }
        catch
        {
            Toast.ShowError("Fraud check failed. Please try again.");
        }
        finally
        {
            _isFraudChecking = false;
        }
    }

    private static string GetRiskIcon(string level) => level?.ToUpper() switch
    {
        "CRITICAL" => "🚨",
        "HIGH"     => "⚠️",
        "MEDIUM"   => "⚡",
        _          => "✅"
    };

    private static string GetRiskTitle(string level) => level?.ToUpper() switch
    {
        "CRITICAL" => "Critical Risk — Hold Payment Immediately",
        "HIGH"     => "High Risk — Contact Vendor Before Paying",
        "MEDIUM"   => "Medium Risk — Verify Before Processing",
        _          => "Low Risk — Invoice Looks Normal"
    };

    private static int GetSeverityOrder(string s) => s?.ToUpper() switch
    {
        "CRITICAL" => 0, "HIGH" => 1, "MEDIUM" => 2, _ => 3
    };

    private static string FormatCategory(string cat) =>
        cat?.Replace("_", " ") switch
        {
            "BANK CHANGE"          => "Bank Account Change",
            "AMOUNT ANOMALY"       => "Amount Anomaly",
            "DATE ANOMALY"         => "Date Anomaly",
            "MATH ERROR"           => "Math Error",
            "SEQUENCE GAP"         => "Invoice Sequence Gap",
            "DUPLICATE"            => "Possible Duplicate",
            "VENDOR INCONSISTENCY" => "Vendor Inconsistency",
            "TAX ERROR"            => "Tax Calculation Error",
            var other              => other ?? cat ?? string.Empty
        };

    private class FraudCheckResponse
    {
        public System.Text.Json.JsonElement ExtractedInvoice { get; set; }
        public FraudAnalysisDto FraudAnalysis { get; set; } = new();
        public string Vendor { get; set; } = string.Empty;
        public int HistoryCount { get; set; }
    }

    private class FraudAnalysisDto
    {
        public int RiskScore { get; set; }
        public string RiskLevel { get; set; } = "LOW";
        public string Recommendation { get; set; } = string.Empty;
        public List<FraudFlagDto> Flags { get; set; } = new();
    }

    private class FraudFlagDto
    {
        public string Category { get; set; } = string.Empty;
        public string Severity { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Recommendation { get; set; } = string.Empty;
    }

    private static string ToLabel(string camelCase) =>
        System.Text.RegularExpressions.Regex
            .Replace(camelCase, "([A-Z])", " $1")
            .Trim();

    private class ExtractResponse
    {
        public string Json { get; set; } = string.Empty;
        public string ExtractionType { get; set; } = string.Empty;
        public string? ExtractedTextPreview { get; set; }
        public string? TextPreview { get; set; }
        public bool OcrFallbackUsed { get; set; }
        public string? OcrWarning { get; set; }
    }

    private class AiUsageResponse
    {
        public int Used { get; set; }
        public int Limit { get; set; }
    }
}
