@page "/number-pages"
@inject ApiService ApiService
@inject IJSRuntime JS
@inject PaymentService PaymentService
@inject FileValidationService Validator
@inject ToastService Toast
@inject SessionUsageService SessionUsage

<PageTitle>Add Page Numbers to PDF Free Online | PdfToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Add page numbers to your PDF free online. Choose position, font, style and starting number. Instant preview. No signup required." />
    <meta name="keywords" content="number pdf pages, add page numbers to pdf, pdf page numbers free, pdf pagination" />
    <link rel="canonical" href="https://pdftoolstack.com/number-pages" />
</HeadContent>

<div class="np-page">
    <section class="np-shell">
        <div class="np-hero">
            <div>
                <span class="np-eyebrow">PDF workspace</span>
                <h1 class="np-title">Add Page Numbers in <span class="hero-gradient-text">seconds</span></h1>
                <p class="np-subtitle">Place clean, consistent page numbers with a live preview before downloading your finished PDF.</p>
            </div>
            <div class="np-trust-row" aria-label="Privacy and security">
                <span class="np-trust-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                    Secure upload
                </span>
                <span class="np-trust-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /></svg>
                    Auto-delete
                </span>
                <span class="np-trust-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                    Private processing
                </span>
            </div>
        </div>

        <div class="np-stepper" aria-label="Progress">
            <div class="np-step @(CurrentState == PageState.Upload || CurrentState == PageState.LargeFile ? "np-step--active" : "np-step--done")"><span>1</span>Upload</div>
            <div class="np-step @(CurrentState == PageState.Editor ? "np-step--active" : CurrentState == PageState.Processing || CurrentState == PageState.Complete || CurrentState == PageState.Error ? "np-step--done" : "")"><span>2</span>Configure</div>
            <div class="np-step @(CurrentState == PageState.Processing ? "np-step--active" : CurrentState == PageState.Complete || CurrentState == PageState.Error ? "np-step--done" : "")"><span>3</span>Process</div>
            <div class="np-step @(CurrentState == PageState.Complete ? "np-step--active" : "")"><span>4</span>Download</div>
        </div>
    </section>

    <AdPlaceholder ShowAds="ShowAdsForCurrentUser" />

    <!-- ── UPLOAD STATE ──────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Upload || CurrentState == PageState.LargeFile)
    {
        <div class="np-upload-hero">
            <div class="np-upload-header">
                <h2 class="np-upload-title">Upload your document</h2>
                <p class="np-upload-copy">Your original PDF stays untouched. We create a numbered copy when you download.</p>
                <div class="np-chips">
                    <span class="np-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Fully customizable — position, style &amp; format
                    </span>
                    <span class="np-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        Instant preview — see changes in real-time
                    </span>
                    <span class="np-chip">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                        100% secure — files deleted in 1 hour
                    </span>
                </div>
            </div>

            @if (CurrentState == PageState.LargeFile)
            {
                <LargeFileUpgrade FileSizeBytes="@(SelectedFile?.Size ?? 0)" FileName="@(SelectedFile?.Name ?? "")" ToolType="NumberPages" OnCancel="Reset" />
            }
            else
            {
                <div class="np-upload-area">
                    <FileUpload OnFileSelected="HandleFileSelected" OnFileRemoved="HandleFileRemoved" />
                    @if (SelectedFile != null)
                    {
                        <button class="np-open-btn" @onclick="OpenEditor">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                            Open workspace
                        </button>
                    }
                </div>
            }
            <aside class="np-upload-inspector">
                <div class="np-settings-title">Configuration preview</div>
                <div class="np-feature-list">
                    <div>
                        <strong>Visual placement</strong>
                        <span>Pick any corner, edge, or center position.</span>
                    </div>
                    <div>
                        <strong>Live page check</strong>
                        <span>Preview the selected page before processing.</span>
                    </div>
                    <div>
                        <strong>Clean numbered copy</strong>
                        <span>Your download is generated as a separate PDF.</span>
                    </div>
                </div>
                <div class="np-mini-preview" aria-hidden="true">
                    <div class="np-mini-page">
                        <span>1</span>
                        <i></i><i></i><i></i><i></i><i></i>
                    </div>
                </div>
            </aside>
        </div>
    }

    <!-- ── EDITOR STATE ──────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Editor)
    {
        <!-- Top bar -->
        <div class="np-topbar">
            <div class="np-topbar-left">
                <button class="np-back-btn" @onclick="Reset">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                    Back
                </button>
                <span class="np-filename">@(SelectedFile?.Name ?? "document.pdf")</span>
                @if (TotalPages > 0)
                {
                    <span class="np-page-chip">@TotalPages pages</span>
                }
            </div>
            <div class="np-topbar-center">
                <button class="np-nav-btn" @onclick="PrevPage" disabled="@(PreviewPage <= 1)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <span class="np-page-label">Page <strong>@PreviewPage</strong> of @TotalPages</span>
                <button class="np-nav-btn" @onclick="NextPage" disabled="@(PreviewPage >= TotalPages)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
            <div class="np-topbar-right">
                <label class="np-preview-toggle">
                    Show preview
                    <input type="checkbox" @bind="_showPreview" />
                </label>
            </div>
        </div>

        <!-- Editor body -->
        <div class="np-editor">

            <!-- Page thumbnail sidebar -->
            <div class="np-thumbs">
                <div class="np-thumbs-label">Pages</div>
                @for (int p = 1; p <= TotalPages; p++)
                {
                    var pg = p;
                    <div class="np-thumb @(PreviewPage == pg ? "np-thumb--active" : "")" @onclick="() => GoToPage(pg)">
                        <div class="np-thumb-doc">
                            <div class="np-thumb-page">
                                <div class="np-thumb-lines">
                                    <div class="np-thumb-line"></div>
                                    <div class="np-thumb-line" style="width:70%"></div>
                                    <div class="np-thumb-line"></div>
                                    <div class="np-thumb-line" style="width:80%"></div>
                                </div>
                                <span class="np-thumb-pgnum @(Position.Contains("top") ? "np-thumb-pgnum--top" : "np-thumb-pgnum--bottom")">
                                    @(StartNumber + pg - 1)
                                </span>
                            </div>
                        </div>
                        <span class="np-thumb-num">@pg</span>
                    </div>
                }
            </div>

            <!-- Preview canvas -->
            <div class="np-preview-area">
                @if (_showPreview && UploadedBytes != null)
                {
                    <div class="np-preview-hint">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                        Live preview — page numbers update as you change settings
                    </div>
                    <div class="np-preview-wrap">
                        <canvas id="npPdfCanvas" style="display:block;max-width:100%;border-radius:6px;box-shadow:0 8px 32px rgba(0,0,0,.35);"></canvas>
                        <!-- Overlaid page number indicator -->
                        <div class="np-preview-number @GetPositionClass()" style="font-family:@FontFamily;font-size:@(FontSize + 2)px;color:@FontColor">
                            @GetPreviewNumber()
                        </div>
                    </div>
                }
                else
                {
                    <div class="np-preview-placeholder">
                        <div class="np-preview-mock">
                            <div class="np-mock-lines">
                                <div class="np-mock-line" style="width:85%"></div>
                                <div class="np-mock-line" style="width:70%"></div>
                                <div class="np-mock-line" style="width:90%"></div>
                                <div class="np-mock-line" style="width:60%"></div>
                                <div class="np-mock-line" style="width:80%"></div>
                                <div class="np-mock-line" style="width:75%"></div>
                                <div class="np-mock-line" style="width:88%"></div>
                            </div>
                            <div class="np-mock-number @GetPositionClass()" style="font-family:@FontFamily;font-size:@FontSize px;color:@FontColor">
                                @GetPreviewNumber()
                            </div>
                        </div>
                        <p class="np-preview-placeholder-hint">Enable "Show preview" to see your PDF</p>
                    </div>
                }
            </div>

            <!-- Settings panel -->
            <div class="np-settings">
                <div class="np-settings-title">Page Number Settings</div>

                <!-- Position 3x3 grid -->
                <div class="np-setting-group">
                    <label class="np-setting-label">Position</label>
                    <div class="np-position-grid">
                        @foreach (var pos in Positions)
                        {
                            <button class="np-pos-btn @(Position == pos.Value ? "np-pos-btn--active" : "")"
                                    title="@pos.Label"
                                    @onclick="() => SelectPosition(pos.Value)">
                                <div class="np-pos-dot @GetPosDotClass(pos.Value)"></div>
                            </button>
                        }
                    </div>
                </div>

                <!-- Start number -->
                <div class="np-setting-group">
                    <label class="np-setting-label">Start numbering from</label>
                    <div class="np-number-input-wrap">
                        <button class="np-num-btn" @onclick="() => StartNumber = Math.Max(1, StartNumber - 1)">−</button>
                        <input type="number" class="np-number-input" min="1" max="999"
                               @bind="StartNumber" @bind:event="oninput" />
                        <button class="np-num-btn" @onclick="() => StartNumber = Math.Min(999, StartNumber + 1)">+</button>
                    </div>
                </div>

                <!-- Number style -->
                <div class="np-setting-group">
                    <label class="np-setting-label">Number style</label>
                    <select class="np-select" @bind="NumberStyle">
                        <option value="numeric">1, 2, 3, ...</option>
                        <option value="roman">i, ii, iii, ...</option>
                        <option value="Roman">I, II, III, ...</option>
                        <option value="alpha">a, b, c, ...</option>
                        <option value="page-of">Page 1 of @TotalPages</option>
                    </select>
                </div>

                <!-- Font -->
                <div class="np-setting-group">
                    <label class="np-setting-label">Font</label>
                    <div class="np-font-row">
                        <select class="np-select" style="flex:1" @bind="FontFamily">
                            <option value="Helvetica">Helvetica</option>
                            <option value="Times New Roman">Times New Roman</option>
                            <option value="Courier">Courier</option>
                            <option value="Arial">Arial</option>
                        </select>
                        <select class="np-select np-select--small" @bind="FontSize">
                            @foreach (var s in new[] { 8, 9, 10, 11, 12, 14 })
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                        <input type="color" class="np-color-picker" @bind="FontColor" title="Font color" />
                    </div>
                </div>

                <!-- Margin -->
                <div class="np-setting-group">
                    <label class="np-setting-label">Margin from edge</label>
                    <div class="np-margin-row">
                        <input type="range" class="np-slider" min="5" max="40" @bind="MarginMm" @bind:event="oninput" />
                        <span class="np-margin-val">@MarginMm mm</span>
                    </div>
                </div>

                <!-- Apply to -->
                <div class="np-setting-group">
                    <label class="np-setting-label">Apply to</label>
                    <div class="np-apply-row">
                        <label class="np-radio">
                            <input type="radio" name="apply" value="all" checked="@(ApplyTo == "all")"
                                   @onchange='() => ApplyTo = "all"' />
                            All pages
                        </label>
                        <label class="np-radio">
                            <input type="radio" name="apply" value="specific" checked="@(ApplyTo == "specific")"
                                   @onchange='() => ApplyTo = "specific"' />
                            Specific pages
                        </label>
                    </div>
                    @if (ApplyTo == "specific")
                    {
                        <input class="np-pages-input" placeholder="e.g. 1-3, 5, 7-10"
                               @bind="SpecificPages" />
                    }
                </div>

                <!-- CTA -->
                <button class="np-apply-btn" @onclick="ProcessFile">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Add Page Numbers &amp; Download
                </button>
                <p class="np-no-cc">No credit card required</p>

                <div class="np-tip">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    <span>
                        Need different numbering for sections?
                        <button class="np-tip-link">Try Advanced Mode</button>
                    </span>
                </div>
            </div>
        </div>
    }

    <!-- ── PROCESSING STATE ──────────────────────────────────────────── -->
    @if (CurrentState == PageState.Processing)
    {
        <div class="np-processing">
            <div class="np-processing-card">
                <div class="np-processing-ring"></div>
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4338CA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="position:absolute"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                <h2>Adding page numbers...</h2>
                <p>Applying to all @TotalPages pages</p>
                <div class="np-progress"><div class="np-progress-fill"></div></div>
            </div>
        </div>
    }

    <!-- ── COMPLETE STATE ────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Complete && ResultBytes != null)
    {
        <div class="np-complete">
            <div class="np-complete-card">
                <div class="np-complete-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <h2>Page Numbers Added!</h2>
                <p>@TotalPages pages numbered starting from @StartNumber</p>
                <button class="np-download-btn" @onclick="DownloadFile">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Download PDF
                </button>
                <button class="np-restart-btn" @onclick="Reset">Number Another PDF</button>
            </div>
        </div>
        <ResultAdPlaceholder ShowAds="ShowAdsForCurrentUser" />
    }

    <!-- ── ERROR STATE ───────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Error)
    {
        <div class="np-complete">
            <div class="np-complete-card">
                <div class="np-complete-icon" style="background:#FEE2E2;">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <h2>Something went wrong</h2>
                <p style="color:var(--text-muted,#6B7280)">@ErrorMessage</p>
                <button class="np-restart-btn" @onclick="Reset">Try Again</button>
            </div>
        </div>
    }

    <!-- ── FAQ ──────────────────────────────────────────────────────── -->
    @if (CurrentState == PageState.Upload)
    {
        <div class="np-faq">
            <h2>Frequently Asked Questions</h2>
            @foreach (var (q, a) in new[] {
                ("Where can I place page numbers?", "You can place page numbers at any of 9 positions: top-left, top-center, top-right, middle-left, middle-right, bottom-left, bottom-center, or bottom-right."),
                ("Can I start from a number other than 1?", "Yes — set any starting number. Useful for documents that are part of a larger set."),
                ("Can I number only specific pages?", "Yes — use Specific Pages mode and enter ranges like 1-3, 5, 7-10."),
                ("Is this tool free?", "Yes — completely free up to 25MB with no signup required."),
                })
            {
                <details class="np-faq-item">
                    <summary>@q</summary>
                    <p>@a</p>
                </details>
            }
        </div>
    }

</div>

<style>
    /* ════════════════════════════════════════════════════════
       Add Page Numbers — Enterprise Editor
    ════════════════════════════════════════════════════════ */
    .np-page {
        min-height: 100vh;
    }

    /* ── Upload hero ──────────────────────────────────────── */
    .np-upload-hero {
        max-width: 680px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 3rem;
    }

    .np-upload-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .np-title {
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        font-weight: 800;
        color: var(--text, #111827);
        letter-spacing: -.03em;
        margin: 0 0 .75rem;
    }

    .np-title-accent {
        color: #4338CA;
    }

    .np-subtitle {
        font-size: 1rem;
        color: var(--text-muted, #6B7280);
        line-height: 1.6;
        margin: 0 0 1.25rem;
    }

    .np-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        justify-content: center;
    }

    .np-chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-size: .75rem;
        font-weight: 500;
        color: var(--text-muted, #6B7280);
        background: var(--bg, #F9FAFB);
        border: 1px solid var(--border, #E5E7EB);
        padding: 4px 12px;
        border-radius: 20px;
    }

    .np-upload-area {
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }

    .np-open-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        width: 100%;
        padding: .875rem;
        background: linear-gradient(135deg, #4338CA 0%, #6D28D9 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: .95rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .15s, transform .15s;
    }

        .np-open-btn:hover {
            opacity: .92;
            transform: translateY(-1px);
        }

    /* ── Top bar ──────────────────────────────────────────── */
    .np-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .625rem 1.25rem;
        background: var(--surface, #fff);
        border-bottom: 1px solid var(--border, #E5E7EB);
        gap: 1rem;
        position: sticky;
        top: 64px;
        z-index: 50;
    }

    .np-topbar-left {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .np-topbar-center {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .np-topbar-right {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .np-back-btn {
        display: flex;
        align-items: center;
        gap: .3rem;
        padding: .375rem .75rem;
        border-radius: 8px;
        border: 1px solid var(--border, #E5E7EB);
        background: var(--bg, #F9FAFB);
        color: var(--text, #374151);
        font-size: .8rem;
        font-weight: 500;
        cursor: pointer;
    }

        .np-back-btn:hover {
            background: var(--border, #E5E7EB);
        }

    .np-filename {
        font-size: .82rem;
        font-weight: 600;
        color: var(--text, #374151);
        max-width: 220px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .np-page-chip {
        font-size: .72rem;
        font-weight: 600;
        background: var(--bg, #F3F4F6);
        border: 1px solid var(--border, #E5E7EB);
        padding: 2px 8px;
        border-radius: 20px;
        color: var(--text-muted, #6B7280);
    }

    .np-nav-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border, #E5E7EB);
        background: var(--bg, #F9FAFB);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .np-nav-btn:hover:not(:disabled) {
            background: var(--border, #E5E7EB);
        }

        .np-nav-btn:disabled {
            opacity: .35;
            cursor: not-allowed;
        }

    .np-page-label {
        font-size: .82rem;
        color: var(--text-muted, #6B7280);
        white-space: nowrap;
    }

        .np-page-label strong {
            color: var(--text, #111827);
        }

    .np-preview-toggle {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .78rem;
        color: var(--text-muted, #6B7280);
        cursor: pointer;
    }

    /* ── Editor layout ────────────────────────────────────── */
    .np-editor {
        display: grid;
        grid-template-columns: 80px 1fr 260px;
        min-height: calc(100vh - 130px);
    }

    @@media (max-width: 900px) {
        .np-editor {
            grid-template-columns: 70px 1fr;
        }

        .np-settings {
            display: none;
        }
    }

    /* Thumbnails */
    .np-thumbs {
        border-right: 1px solid var(--border, #E5E7EB);
        background: var(--bg, #F9FAFB);
        padding: .75rem .4rem;
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .np-thumbs-label {
        font-size: .62rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        font-weight: 700;
        color: var(--text-muted, #9CA3AF);
        text-align: center;
        margin-bottom: .25rem;
    }

    .np-thumb {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .2rem;
        padding: .35rem .2rem;
        border-radius: 6px;
        cursor: pointer;
        border: 1.5px solid transparent;
        transition: background .1s;
    }

        .np-thumb:hover {
            background: var(--border, #E5E7EB20);
        }

    .np-thumb--active {
        border-color: #4338CA;
        background: #EDE9FE15;
    }

    .np-thumb-num {
        font-size: .6rem;
        color: var(--text-muted, #9CA3AF);
        font-weight: 600;
    }

    .np-thumb--active .np-thumb-num {
        color: #4338CA;
    }

    .np-thumb-page {
        position: relative;
        width: 36px;
        height: 46px;
        background: var(--surface, #fff);
        border: 1.5px solid var(--border, #E5E7EB);
        border-radius: 3px;
        padding: 4px 3px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow: hidden;
    }

    .np-thumb--active .np-thumb-page {
        border-color: #4338CA;
    }

    .np-thumb-lines {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex: 1;
    }

    .np-thumb-line {
        height: 2px;
        background: var(--border, #E5E7EB);
        border-radius: 1px;
        width: 100%;
    }

    .np-thumb-pgnum {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-size: 5px;
        font-weight: 700;
        color: #4338CA;
        white-space: nowrap;
        line-height: 1;
    }

    .np-thumb-pgnum--bottom {
        bottom: 3px;
    }

    .np-thumb-pgnum--top {
        top: 3px;
    }

    /* Preview area */
    .np-preview-area {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: #525659;
        padding: 1.5rem 1rem;
        gap: .75rem;
    }

    .np-preview-hint {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .72rem;
        color: rgba(255,255,255,.6);
        background: rgba(0,0,0,.3);
        padding: 4px 12px;
        border-radius: 20px;
    }

    .np-preview-wrap {
        position: relative;
        display: inline-block;
    }

    /* Page number overlay on preview */
    .np-preview-number {
        position: absolute;
        font-weight: 600;
        pointer-events: none;
        padding: 2px 6px;
        background: rgba(67,56,202,.15);
        border-radius: 4px;
        border: 1px dashed rgba(67,56,202,.4);
        white-space: nowrap;
    }

    .np-pos-tl {
        top: 12px;
        left: 12px;
    }

    .np-pos-tc {
        top: 12px;
        left: 50%;
        transform: translateX(-50%);
    }

    .np-pos-tr {
        top: 12px;
        right: 12px;
    }

    .np-pos-bl {
        bottom: 12px;
        left: 12px;
    }

    .np-pos-bc {
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
    }

    .np-pos-br {
        bottom: 12px;
        right: 12px;
    }

    .np-pos-ml {
        top: 50%;
        left: 12px;
        transform: translateY(-50%);
    }

    .np-pos-mr {
        top: 50%;
        right: 12px;
        transform: translateY(-50%);
    }

    /* Mock preview placeholder */
    .np-preview-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .75rem;
        width: 100%;
        max-width: 480px;
    }

    .np-preview-placeholder-hint {
        font-size: .72rem;
        color: rgba(255,255,255,.5);
    }

    .np-preview-mock {
        position: relative;
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 6px;
        padding: 2rem 2rem 3rem;
        box-shadow: 0 8px 32px rgba(0,0,0,.35);
        min-height: 320px;
    }

    .np-mock-lines {
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .np-mock-line {
        height: 10px;
        background: #E5E7EB;
        border-radius: 4px;
    }

    .np-mock-number {
        position: absolute;
        font-weight: 600;
        pointer-events: none;
        padding: 2px 6px;
        background: rgba(67,56,202,.1);
        border-radius: 4px;
        border: 1px dashed rgba(67,56,202,.4);
    }

    /* Settings panel */
    .np-settings {
        border-left: 1px solid var(--border, #E5E7EB);
        background: var(--surface, #fff);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        overflow-y: auto;
    }

    .np-settings-title {
        font-size: .78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-muted, #6B7280);
        padding-bottom: .625rem;
        border-bottom: 1px solid var(--border, #E5E7EB);
    }

    .np-setting-group {
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .np-setting-label {
        font-size: .75rem;
        font-weight: 600;
        color: var(--text, #374151);
    }

    /* 3x3 Position grid */
    .np-position-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .3rem;
        background: var(--bg, #F9FAFB);
        border: 1px solid var(--border, #E5E7EB);
        border-radius: 12px;
        padding: .5rem;
    }

    .np-pos-btn {
        aspect-ratio: 1;
        border-radius: 8px;
        border: 1.5px solid var(--border, #E5E7EB);
        background: var(--surface, #fff);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .12s;
        padding: .35rem;
    }

        .np-pos-btn:hover {
            border-color: #4338CA;
            background: #EDE9FE20;
        }

    .np-pos-btn--active {
        border-color: #4338CA;
        background: #EDE9FE;
    }

    .np-pos-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--border, #D1D5DB);
        transition: background .12s;
    }

    .np-pos-btn--active .np-pos-dot {
        background: #4338CA;
    }

    .np-pos-btn:hover .np-pos-dot {
        background: #6D28D9;
    }

    /* Number input */
    .np-number-input-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--border, #E5E7EB);
        border-radius: 8px;
        overflow: hidden;
        background: var(--bg, #F9FAFB);
    }

    .np-num-btn {
        width: 36px;
        height: 36px;
        border: none;
        background: var(--bg, #F3F4F6);
        color: var(--text, #374151);
        font-size: 1.1rem;
        cursor: pointer;
        transition: background .1s;
    }

        .np-num-btn:hover {
            background: var(--border, #E5E7EB);
        }

    .np-number-input {
        flex: 1;
        border: none;
        background: transparent;
        text-align: center;
        font-size: .9rem;
        font-weight: 600;
        color: var(--text, #111827);
        padding: .375rem 0;
        outline: none;
    }

    /* Font row */
    .np-font-row {
        display: flex;
        gap: .4rem;
        align-items: center;
    }

    .np-select {
        padding: .45rem .625rem;
        border: 1.5px solid var(--border, #E5E7EB);
        border-radius: 8px;
        font-size: .8rem;
        background: var(--bg, #F9FAFB);
        color: var(--text, #111827);
        cursor: pointer;
        flex: 1;
    }

    .np-select--small {
        flex: 0 0 52px;
    }

    .np-color-picker {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid var(--border, #E5E7EB);
        padding: 2px;
        cursor: pointer;
        background: none;
        flex-shrink: 0;
    }

    /* Margin slider */
    .np-margin-row {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .np-slider {
        flex: 1;
        accent-color: #4338CA;
    }

    .np-margin-val {
        font-size: .78rem;
        font-weight: 600;
        color: var(--text, #374151);
        white-space: nowrap;
        min-width: 40px;
        text-align: right;
    }

    /* Apply to */
    .np-apply-row {
        display: flex;
        gap: 1rem;
    }

    .np-radio {
        display: flex;
        align-items: center;
        gap: .35rem;
        font-size: .82rem;
        color: var(--text, #374151);
        cursor: pointer;
    }

    .np-pages-input {
        width: 100%;
        padding: .5rem .75rem;
        border: 1.5px solid var(--border, #E5E7EB);
        border-radius: 8px;
        font-size: .82rem;
        background: var(--bg, #F9FAFB);
        color: var(--text, #111827);
        box-sizing: border-box;
    }

        .np-pages-input::placeholder {
            color: var(--text-muted, #9CA3AF);
        }

        .np-pages-input:focus {
            outline: none;
            border-color: #4338CA;
        }

    /* Apply btn */
    .np-apply-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        width: 100%;
        padding: .75rem 1rem;
        background: linear-gradient(135deg, #4338CA 0%, #6D28D9 100%);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: .88rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .15s, transform .15s;
    }

        .np-apply-btn:hover {
            opacity: .92;
            transform: translateY(-1px);
        }

    .np-no-cc {
        font-size: .7rem;
        color: var(--text-muted, #9CA3AF);
        text-align: center;
        margin: 0;
    }

    .np-tip {
        display: flex;
        align-items: flex-start;
        gap: .4rem;
        font-size: .72rem;
        color: var(--text-muted, #9CA3AF);
        padding: .5rem .625rem;
        background: var(--bg, #F9FAFB);
        border-radius: 8px;
        border: 1px solid var(--border, #E5E7EB);
        line-height: 1.4;
    }

    .np-tip-link {
        background: none;
        border: none;
        color: #4338CA;
        font-size: .72rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: underline;
        padding: 0;
    }

    /* ── Processing ───────────────────────────────────────── */
    .np-processing {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        padding: 2rem;
    }

    .np-processing-card {
        position: relative;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .875rem;
        max-width: 320px;
    }

    .np-processing-ring {
        position: absolute;
        top: -22px;
        left: 50%;
        transform: translateX(-50%);
        width: 72px;
        height: 72px;
        border-radius: 50%;
        border: 3px solid #EDE9FE;
        border-top-color: #4338CA;
        animation: np-spin .9s linear infinite;
    }

    @@keyframes np-spin {
        to {
            transform: translateX(-50%) rotate(360deg);
        }
    }

    .np-processing-card h2 {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 2.5rem 0 0;
        color: var(--text,#111827);
    }

    .np-processing-card p {
        font-size: .875rem;
        color: var(--text-muted,#6B7280);
        margin: 0;
    }

    .np-progress {
        width: 240px;
        height: 4px;
        background: var(--border, #E5E7EB);
        border-radius: 99px;
        overflow: hidden;
    }

    .np-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #4338CA, #6D28D9);
        border-radius: 99px;
        animation: np-prog 2.5s ease-in-out forwards;
    }

    @@keyframes np-prog {
        from {
            width: 0;
        }

        to {
            width: 88%;
        }
    }

    /* ── Complete ─────────────────────────────────────────── */
    .np-complete {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        padding: 2rem;
    }

    .np-complete-card {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        max-width: 380px;
    }

    .np-complete-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #DCFCE7;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .np-complete-card h2 {
        font-size: 1.4rem;
        font-weight: 800;
        margin: 0;
        color: var(--text,#111827);
    }

    .np-complete-card p {
        font-size: .875rem;
        color: var(--text-muted,#6B7280);
        margin: 0;
    }

    .np-download-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        width: 100%;
        padding: .875rem 1.5rem;
        background: linear-gradient(135deg, #16A34A, #15803D);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: .95rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity .15s, transform .15s;
    }

        .np-download-btn:hover {
            opacity: .92;
            transform: translateY(-1px);
        }

    .np-restart-btn {
        background: none;
        border: none;
        color: var(--text-muted, #6B7280);
        font-size: .85rem;
        cursor: pointer;
        text-decoration: underline;
    }

    /* ── FAQ ──────────────────────────────────────────────── */
    .np-faq {
        max-width: 640px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
    }

        .np-faq h2 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--text,#111827);
        }

    .np-faq-item {
        border: 1px solid var(--border,#E5E7EB);
        border-radius: 12px;
        padding: .875rem 1.1rem;
        margin-bottom: .5rem;
        background: var(--surface,#fff);
    }

        .np-faq-item summary {
            font-weight: 600;
            font-size: .875rem;
            color: var(--text,#111827);
            cursor: pointer;
            list-style: none;
        }

            .np-faq-item summary::-webkit-details-marker {
                display: none;
            }

        .np-faq-item p {
            font-size: .82rem;
            color: var(--text-muted,#6B7280);
            line-height: 1.6;
            margin: .625rem 0 0;
        }

    /* ── SaaS facelift overrides ─────────────────────────── */
    .np-page {
        min-height: 100vh;
        background:
            radial-gradient(circle at 15% 0%, rgba(20, 184, 166, .12), transparent 34%),
            radial-gradient(circle at 92% 8%, rgba(79, 70, 229, .12), transparent 30%),
            linear-gradient(180deg, #F8FAFC 0%, #EEF2F7 100%);
        color: #111827;
        padding: 1.5rem;
    }

    .np-shell,
    .np-upload-hero,
    .np-editor,
    .np-processing,
    .np-complete,
    .np-faq {
        max-width: 1180px;
        margin-left: auto;
        margin-right: auto;
    }

    .np-shell {
        margin-bottom: 1rem;
    }

    .np-hero {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .np-eyebrow,
    .np-panel-kicker {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        color: #0F766E;
        background: #CCFBF1;
        border: 1px solid rgba(15, 118, 110, .16);
        border-radius: 999px;
        padding: .28rem .65rem;
        font-size: .72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: .75rem;
    }

    .np-title {
        font-size: clamp(2rem, 4vw, 3.35rem);
        letter-spacing: 0;
        line-height: 1;
        margin-bottom: .8rem;
        color: #0F172A;
    }

    .np-title-accent {
        color: #4F46E5;
    }

    .hero-gradient-text {
        background: linear-gradient(135deg, #2563EB 0%, #4F46E5 48%, #7C3AED 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .np-subtitle {
        max-width: 660px;
        color: #475569;
        font-size: 1.02rem;
        margin-bottom: 0;
    }

    .np-trust-row,
    .np-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .55rem;
    }

    .np-trust-row {
        justify-content: flex-end;
        min-width: 320px;
    }

    .np-trust-badge,
    .np-chip {
        display: inline-flex;
        align-items: center;
        gap: .42rem;
        color: #334155;
        background: rgba(255, 255, 255, .78);
        border: 1px solid rgba(148, 163, 184, .34);
        box-shadow: 0 10px 26px rgba(15, 23, 42, .06);
        border-radius: 999px;
        padding: .45rem .7rem;
        font-size: .78rem;
        font-weight: 700;
    }

    .np-trust-badge svg,
    .np-open-btn svg,
    .np-back-btn svg,
    .np-nav-btn svg,
    .np-preview-hint svg,
    .np-apply-btn svg,
    .np-download-btn svg,
    .np-tip svg,
    .np-state-icon svg {
        width: 1rem;
        height: 1rem;
        flex-shrink: 0;
    }

    .np-stepper {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .65rem;
        padding: .65rem;
        border-radius: 18px;
        background: rgba(255, 255, 255, .72);
        border: 1px solid rgba(148, 163, 184, .28);
        box-shadow: 0 20px 55px rgba(15, 23, 42, .08);
        backdrop-filter: blur(14px);
    }

    .np-step {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        min-height: 42px;
        border-radius: 12px;
        color: #64748B;
        font-size: .82rem;
        font-weight: 800;
        background: transparent;
    }

    .np-step span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 999px;
        color: #64748B;
        background: #E2E8F0;
        font-size: .72rem;
    }

    .np-step--active {
        color: #FFFFFF;
        background: linear-gradient(135deg, #0F172A, #4F46E5);
        box-shadow: 0 12px 26px rgba(79, 70, 229, .22);
    }

    .np-step--active span {
        color: #0F172A;
        background: #FFFFFF;
    }

    .np-step--done {
        color: #0F766E;
        background: rgba(204, 251, 241, .55);
    }

    .np-step--done span {
        color: #FFFFFF;
        background: #0F766E;
    }

    .np-upload-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(300px, .8fr);
        gap: 1rem;
        padding: 0;
    }

    .np-upload-header,
    .np-upload-area,
    .np-upload-inspector,
    .np-settings,
    .np-preview-card,
    .np-processing-card,
    .np-complete-card {
        background: rgba(255, 255, 255, .86);
        border: 1px solid rgba(148, 163, 184, .24);
        box-shadow: 0 24px 70px rgba(15, 23, 42, .09);
        backdrop-filter: blur(18px);
    }

    .np-upload-header {
        grid-column: 1 / -1;
        text-align: left;
        margin: 0;
        border-radius: 22px;
        padding: 1.2rem;
    }

    .np-upload-title {
        margin: 0 0 .35rem;
        color: #0F172A;
        font-size: 1.25rem;
        font-weight: 850;
        letter-spacing: 0;
    }

    .np-upload-copy {
        margin: 0 0 1rem;
        color: #64748B;
        font-size: .92rem;
    }

    .np-upload-area,
    .np-upload-inspector {
        border-radius: 26px;
        padding: 1rem;
    }

    .np-upload-area .upload-container {
        border-radius: 20px;
        border-color: rgba(79, 70, 229, .24);
        background: linear-gradient(180deg, #FFFFFF, #F8FAFC);
    }

    .np-open-btn,
    .np-apply-btn {
        min-height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #0F172A 0%, #4F46E5 48%, #14B8A6 100%);
        box-shadow: 0 16px 34px rgba(79, 70, 229, .28);
    }

    .np-upload-inspector {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .np-feature-list {
        display: grid;
        gap: .75rem;
    }

    .np-feature-list div {
        padding: .85rem;
        border-radius: 16px;
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
    }

    .np-feature-list strong,
    .np-feature-list span {
        display: block;
    }

    .np-feature-list strong {
        color: #0F172A;
        font-size: .88rem;
        margin-bottom: .18rem;
    }

    .np-feature-list span {
        color: #64748B;
        font-size: .78rem;
        line-height: 1.5;
    }

    .np-mini-preview {
        display: flex;
        justify-content: center;
        padding: 1rem;
        border-radius: 18px;
