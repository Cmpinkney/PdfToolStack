@code {
    private bool ShowAdsForCurrentUser = true; // TODO: Hide ads for paid users when subscription state is available here.
    private enum PageState { Upload, Editor, Processing, Complete, Error, LargeFile }
    private PageState CurrentState = PageState.Upload;

    private IBrowserFile? SelectedFile;
    private byte[]? UploadedBytes;
    private byte[]? ResultBytes;
    private string? ErrorMessage;

    // Settings
    private string Position = "bottom-center";
    private int StartNumber = 1;
    private string NumberStyle = "numeric";
    private string FontFamily = "Helvetica";
    private int FontSize = 10;
    private string FontColor = "#000000";
    private int MarginMm = 15;
    private string ApplyTo = "all";
    private string SpecificPages = string.Empty;

    // Editor state
    private int TotalPages = 0;
    private int PreviewPage = 1;
    private bool _showPreview = true;

    [SupplyParameterFromQuery] private string? Paid { get; set; }
    protected override void OnInitialized() { if (Paid == "true") CurrentState = PageState.Upload; }

    private record PositionDef(string Value, string Label);
    private readonly PositionDef[] Positions = new[]
    {
        new PositionDef("top-left",      "Top Left"),
        new PositionDef("top-center",    "Top Center"),
        new PositionDef("top-right",     "Top Right"),
        new PositionDef("middle-left",   "Middle Left"),
        new PositionDef("center",        "Center"),
        new PositionDef("middle-right",  "Middle Right"),
        new PositionDef("bottom-left",   "Bottom Left"),
        new PositionDef("bottom-center", "Bottom Center"),
        new PositionDef("bottom-right",  "Bottom Right"),
    };

    private string GetPositionClass() => Position switch
    {
        "top-left" => "np-pos-tl",
        "top-center" => "np-pos-tc",
        "top-right" => "np-pos-tr",
        "middle-left" => "np-pos-ml",
        "middle-right" => "np-pos-mr",
        "bottom-left" => "np-pos-bl",
        "bottom-center" => "np-pos-bc",
        "bottom-right" => "np-pos-br",
        _ => "np-pos-bc",
    };

    private string GetPosDotClass(string pos) => Position == pos ? "np-pos-dot" : "np-pos-dot";

    private string GetPreviewNumber()
    {
        var n = StartNumber + PreviewPage - 1;
        return NumberStyle switch
        {
            "roman" => ToRoman(n).ToLower(),
            "Roman" => ToRoman(n),
            "alpha" => ((char)('a' + (n - 1) % 26)).ToString(),
            "page-of" => $"Page {n} of {TotalPages}",
            _ => n.ToString(),
        };
    }

    private static string ToRoman(int n)
    {
        if (n <= 0) return n.ToString();
        var vals = new[] { 1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1 };
        var syms = new[] { "M", "CM", "D", "CD", "C", "XC", "L", "XL", "X", "IX", "V", "IV", "I" };
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < vals.Length; i++)
            while (n >= vals[i]) { sb.Append(syms[i]); n -= vals[i]; }
        return sb.ToString();
    }

    private void SelectPosition(string pos) { Position = pos; }

    private async Task HandleFileSelected(IBrowserFile file)
    {
        SelectedFile = null; UploadedBytes = null; ErrorMessage = null;
        var validation = Validator.ValidatePdfFile(file);
        if (!validation.IsValid) { Toast.ShowError(validation.Message!); return; }
        if (validation.IsWarning) Toast.ShowWarning(validation.Message!);
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 524288000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            UploadedBytes = ms.ToArray();
            var bytesVal = Validator.ValidatePdfBytes(UploadedBytes);
            if (!bytesVal.IsValid) { Toast.ShowError(bytesVal.Message!); UploadedBytes = null; return; }
            if (PaymentService.IsFileTooLargeForFree(file.Size)) { CurrentState = PageState.LargeFile; StateHasChanged(); return; }
            SelectedFile = file;
            Toast.ShowSuccess($"File ready — {Validator.FormatSize(file.Size)}");
        }
        catch (Exception ex) { Toast.ShowError($"Could not read file: {ex.Message}"); UploadedBytes = null; }
        StateHasChanged();
    }

    private void HandleFileRemoved() { SelectedFile = null; UploadedBytes = null; }

    private async Task OpenEditor()
    {
        if (UploadedBytes == null) return;
        TotalPages = await ApiService.GetPageCountAsync(UploadedBytes, SelectedFile!.Name);
        PreviewPage = 1;
        CurrentState = PageState.Editor;
        StateHasChanged();
        if (_showPreview)
            await JS.InvokeVoidAsync("renderNpPreview", Convert.ToBase64String(UploadedBytes), PreviewPage);
    }

    private async Task GoToPage(int page)
    {
        if (page == PreviewPage) return;
        PreviewPage = page;
        if (_showPreview && UploadedBytes != null)
            await JS.InvokeVoidAsync("renderNpPreview", Convert.ToBase64String(UploadedBytes), page);
    }

    private async Task PrevPage() { if (PreviewPage > 1) await GoToPage(PreviewPage - 1); }
    private async Task NextPage() { if (PreviewPage < TotalPages) await GoToPage(PreviewPage + 1); }

    private async Task ProcessFile()
    {
        if (UploadedBytes == null) return;
        CurrentState = PageState.Processing;
        StateHasChanged();
        try
        {
            ResultBytes = await ApiService.NumberPagesAsync(UploadedBytes, SelectedFile!.Name, Position, StartNumber);
            CurrentState = ResultBytes != null ? PageState.Complete : PageState.Error;
            if (ResultBytes == null) ErrorMessage = "Failed to add page numbers. Please try again.";
        }
        catch (Exception ex) { ErrorMessage = $"Error: {ex.Message}"; CurrentState = PageState.Error; }
        StateHasChanged();
    }

    private async Task DownloadFile()
    {
        if (ResultBytes == null) return;
        var fileName = Path.GetFileNameWithoutExtension(SelectedFile?.Name ?? "document") + "_numbered.pdf";
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(ResultBytes));
        SessionUsage.RecordToolCompletion("Number Pages");
    }

    private void Reset()
    {
        CurrentState = PageState.Upload;
        SelectedFile = null; UploadedBytes = null; ResultBytes = null;
        ErrorMessage = null; TotalPages = 0; PreviewPage = 1;
        Position = "bottom-center"; StartNumber = 1;
        NumberStyle = "numeric"; FontFamily = "Helvetica";
        FontSize = 10; FontColor = "#000000"; MarginMm = 15;
        ApplyTo = "all"; SpecificPages = string.Empty;
    }
}
