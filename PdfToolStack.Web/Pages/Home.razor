@page "/"
@inject IJSRuntime JS

<PageTitle>PdfToolStack — AI-Powered PDF Tools for Small Teams</PageTitle>

<HeadContent>
    <meta name="description"
          content="Extract invoice data, compare contracts, summarize documents — powered by AI. Plus 35+ PDF tools. Free to start, Pro at $19/month." />
    <meta name="keywords"
          content="ai pdf tools, extract invoice data, compare pdf, pdf summarizer, compress pdf, merge pdf, sign pdf" />
    <link rel="canonical" href="https://pdftoolstack.com" />
</HeadContent>

<div class="home-page">

    <div class="hero-section">
        <div class="hero-badge">✨ Powered by Claude AI</div>
        <h1>The PDF workspace for<br /><span>small teams</span></h1>
        <p>
            Extract invoice data, compare contracts, summarize documents —
            plus 35+ standard PDF tools. Privacy-first. Files deleted in 1 hour.
        </p>
        <div class="hero-cta-row">
            <a href="/pricing" class="hero-cta-primary">Start free — $19/mo Pro</a>
            <a href="/ai-pdf-assist" class="hero-cta-secondary">See AI tools →</a>
        </div>
        <div class="hero-search">
            <span class="hero-search-icon">🔍</span>
            <input type="text"
                   placeholder="Search tools — compress, sign, extract invoice..."
                   @bind="HeroSearch"
                   @bind:event="oninput" />
        </div>
    </div>

    <div class="trust-bar">
        <div class="trust-item">🔒 256-bit encryption</div>
        <div class="trust-divider"></div>
        <div class="trust-item">🗑️ Files deleted in 1 hour</div>
        <div class="trust-divider"></div>
        <div class="trust-item">🚫 No data training</div>
        <div class="trust-divider"></div>
        <div class="trust-item">⚡ No signup required</div>
    </div>

    <div class="tools-section">

        @if (!string.IsNullOrWhiteSpace(HeroSearch))
        {
            <div class="tools-category">
                <div class="tools-category-title">Search results</div>
                <div class="tools-grid">
                    @foreach (var tool in SearchResults)
                    {
                        <a href="@tool.Url" class="tool-card">
                            <div class="tool-icon-tile" style="background:@tool.Color;">
                                @((MarkupString)tool.SvgIcon)
                            </div>
                            <h3>@tool.Name</h3>
                            <p>@tool.Description</p>
                        </a>
                    }
                    @if (!SearchResults.Any())
                    {
                        <p style="color:var(--text-muted); font-size:0.9rem; grid-column:1/-1;">
                            No tools found for "@HeroSearch"
                        </p>
                    }
                </div>
            </div>
        }
        else
        {
            <!-- AI Tools -->
            <div class="tools-category ai-category">
                <div class="tools-category-title ai-category-title">
                    ✨ AI Tools
                    <span class="pro-label">Pro</span>
                </div>
                <div class="tools-grid ai-tools-grid">

                    <a href="/extract-invoice-data" class="tool-card tool-card-ai featured-ai-card">
                        <div class="tool-icon-tile" style="background:#6D28D9;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <path d="M3 9h18" />
                                <path d="M9 21V9" />
                                <path d="M15 14h3" />
                                <path d="M15 17h2" />
                            </svg>
                        </div>
                        <h3>Extract Invoice Data</h3>
                        <p>AI reads invoice → exports to Excel. No manual entry.</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/chat-with-pdf" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#7C3AED;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                            </svg>
                        </div>
                        <h3>Chat with PDF</h3>
                        <p>Ask your document anything</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/ai-summarizer" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#4F46E5;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="8" y1="6" x2="21" y2="6" />
                                <line x1="8" y1="12" x2="21" y2="12" />
                                <line x1="8" y1="18" x2="15" y2="18" />
                                <path d="M3 6l1 1 2-3" />
                                <path d="M3 12l1 1 2-3" />
                                <path d="M3 18l1 1 2-3" />
                            </svg>
                        </div>
                        <h3>AI Summarizer</h3>
                        <p>Key points in seconds</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/compare-pdf" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#8B5CF6;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h4" />
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                                <line x1="12" y1="3" x2="12" y2="21" />
                                <line x1="6" y1="9" x2="9" y2="9" />
                                <line x1="15" y1="9" x2="18" y2="9" />
                                <line x1="6" y1="13" x2="9" y2="13" />
                            </svg>
                        </div>
                        <h3>Compare PDFs</h3>
                        <p>Word-level diff report</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/ai-questions" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#A855F7;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10" />
                                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
                                <line x1="12" y1="17" x2="12.01" y2="17" />
                            </svg>
                        </div>
                        <h3>AI Questions</h3>
                        <p>Generate quiz questions</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/batch" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#5B21B6;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
                            </svg>
                        </div>
                        <h3>Batch Process</h3>
                        <p>20 files at once → ZIP</p>
                        <span class="tool-card-badge pro-badge">Pro</span>
                    </a>

                </div>
            </div>

            <!-- Popular fixes -->
            <div class="tools-category">
                <div class="tools-category-title">Popular fixes</div>
                <div class="popular-fixes-grid">

                    <a href="/compress-for-email" class="tool-card featured-fix">
                        <span class="featured-fix-badge">Most Used</span>
                        <div class="tool-icon-tile" style="background:#E85D04;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                <polyline points="7,10 12,15 17,10" />
                                <line x1="12" y1="15" x2="12" y2="3" />
                            </svg>
                        </div>
                        <h3>Fix PDF Too Large for Email</h3>
                        <p>Make your PDF email-ready in seconds</p>
                    </a>

                    <a href="/sign-contract" class="tool-card">
                        <div class="tool-icon-tile" style="background:#D97706;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 17c3-3 3-7 6-7s3 4 6 4 3-3 6-3" />
                                <line x1="3" y1="21" x2="21" y2="21" />
                            </svg>
                        </div>
                        <h3>Sign a Contract</h3>
                        <p>Electronic signature, legally binding</p>
                    </a>

                    <a href="/merge-pdfs-for-submission" class="tool-card">
                        <div class="tool-icon-tile" style="background:#0D9488;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M8 3H5a2 2 0 0 0-2 2v3m16 0V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3m8 0h3a2 2 0 0 0 2-2v-3" />
                                <line x1="12" y1="8" x2="12" y2="16" />
                                <line x1="8" y1="12" x2="16" y2="12" />
                            </svg>
                        </div>
                        <h3>Combine PDFs for Submission</h3>
                        <p>Tax filing, applications, legal docs</p>
                    </a>

                    <a href="/redact-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#DC2626;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                                <rect x="6" y="12" width="12" height="3" rx="1" fill="rgba(255,255,255,0.4)" stroke="white" stroke-width="1.5" />
                                <line x1="6" y1="17" x2="12" y2="17" />
                            </svg>
                        </div>
                        <h3>Remove Sensitive Information</h3>
                        <p>Permanently redact private data</p>
                    </a>

                </div>
            </div>

            <!-- Compress & Convert -->
            <div class="tools-category">
                <div class="tools-category-title">Compress &amp; Convert</div>
                <div class="tools-grid">

                    <a href="/compress-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#E85D04;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                <polyline points="7,10 12,15 17,10" />
                                <line x1="12" y1="15" x2="12" y2="3" />
                            </svg>
                        </div>
                        <h3>Compress PDF</h3>
                        <p>Reduce file size</p>
                    </a>

                    <a href="/pdf-to-word" class="tool-card">
                        <div class="tool-icon-tile" style="background:#2563EB;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                                <path d="M9 13l1.5 4L12 14l1.5 3L15 13" />
                            </svg>
                        </div>
                        <h3>PDF to Word</h3>
                        <p>Convert to DOCX</p>
                    </a>

                    <a href="/word-to-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#1D4ED8;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                                <line x1="12" y1="12" x2="12" y2="18" />
                                <polyline points="9,15 12,18 15,15" />
                            </svg>
                        </div>
                        <h3>Word to PDF</h3>
                        <p>DOCX to PDF</p>
                    </a>

                    <a href="/ppt-to-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#C2410C;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="3" width="20" height="14" rx="2" />
                                <line x1="8" y1="21" x2="16" y2="21" />
                                <line x1="12" y1="17" x2="12" y2="21" />
                            </svg>
                        </div>
                        <h3>PPT to PDF</h3>
                        <p>Presentation to PDF</p>
                    </a>

                    <a href="/excel-to-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#15803D;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="1" />
                                <path d="M3 9h18" />
                                <path d="M9 21V9" />
                            </svg>
                        </div>
                        <h3>Excel to PDF</h3>
                        <p>Spreadsheet to PDF</p>
                    </a>

                    <a href="/jpg-to-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#0891B2;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <circle cx="8.5" cy="8.5" r="1.5" fill="white" stroke="none" />
                                <polyline points="21,15 16,10 5,21" />
                            </svg>
                        </div>
                        <h3>JPG to PDF</h3>
                        <p>Images to PDF</p>
                    </a>

                    <a href="/pdf-to-jpg" class="tool-card">
                        <div class="tool-icon-tile" style="background:#0369A1;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                                <circle cx="10" cy="14" r="2" stroke="white" />
                                <path d="M20 17l-3-3-2 2-1-1-3 3" />
                            </svg>
                        </div>
                        <h3>PDF to JPG</h3>
                        <p>Pages to images</p>
                    </a>

                    <a href="/pdf-to-excel" class="tool-card">
                        <div class="tool-icon-tile" style="background:#166534;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                                <path d="M8 13l2.5 4L13 13l2.5 4" />
                            </svg>
                        </div>
                        <h3>PDF to Excel</h3>
                        <p>Tables to XLSX</p>
                    </a>

                    <a href="/converter" class="tool-card">
                        <div class="tool-icon-tile" style="background:#7C3AED;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="17,1 21,5 17,9" />
                                <path d="M3 11V9a4 4 0 0 1 4-4h14" />
                                <polyline points="7,23 3,19 7,15" />
                                <path d="M21 13v2a4 4 0 0 1-4 4H3" />
                            </svg>
                        </div>
                        <h3>All Converters</h3>
                        <p>View all options</p>
                    </a>

                </div>
            </div>

            <!-- Edit & Annotate -->
            <div class="tools-category">
                <div class="tools-category-title">Edit &amp; Annotate</div>
                <div class="tools-grid">

                    <a href="/edit-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#4338CA;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 20h9" />
                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                            </svg>
                        </div>
                        <h3>Edit PDF</h3>
                        <p>Add text and shapes</p>
                    </a>

                    <a href="/pdf-annotator" class="tool-card">
                        <div class="tool-icon-tile" style="background:#BE185D;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                <rect x="9" y="9" width="12" height="3" rx="1" fill="rgba(255,255,255,0.35)" stroke="white" stroke-width="1.5" />
                                <rect x="9" y="15" width="8" height="3" rx="1" fill="rgba(255,255,255,0.35)" stroke="white" stroke-width="1.5" />
                            </svg>
                        </div>
                        <h3>PDF Annotator</h3>
                        <p>Highlight and markup</p>
                    </a>

                    <a href="/sign-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#D97706;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 17c3-3 3-7 6-7s3 4 6 4 3-3 6-3" />
                                <line x1="3" y1="21" x2="21" y2="21" />
                            </svg>
                        </div>
                        <h3>Sign PDF</h3>
                        <p>Electronic signature</p>
                    </a>

                    <a href="/fill-pdf-form" class="tool-card">
                        <div class="tool-icon-tile" style="background:#0D9488;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <path d="M3 9h18" />
                                <path d="M3 15h18" />
                                <path d="M9 3v18" />
                            </svg>
                        </div>
                        <h3>Fill PDF Form</h3>
                        <p>Complete form fields</p>
                    </a>

                    <a href="/watermark-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#9333EA;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2L2 7l10 5 10-5-10-5z" />
                                <path d="M2 17l10 5 10-5" />
                                <path d="M2 12l10 5 10-5" />
                            </svg>
                        </div>
                        <h3>Watermark PDF</h3>
                        <p>Add watermark text</p>
                    </a>

                    <a href="/number-pages" class="tool-card">
                        <div class="tool-icon-tile" style="background:#2563EB;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                                <line x1="8" y1="17" x2="16" y2="17" />
                                <path d="M10 11h1v3" />
                                <path d="M13 11h2v1.5l-2 1.5h2" />
                            </svg>
                        </div>
                        <h3>Number Pages</h3>
                        <p>Add page numbers</p>
                    </a>

                    <a href="/redact-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#DC2626;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                                <rect x="6" y="12" width="12" height="3" rx="1" fill="rgba(255,255,255,0.4)" stroke="white" stroke-width="1.5" />
                                <line x1="6" y1="17" x2="12" y2="17" />
                            </svg>
                        </div>
                        <h3>Redact PDF</h3>
                        <p>Remove sensitive info</p>
                    </a>

                    <a href="/crop-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#0369A1;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="6" y1="2" x2="6" y2="16" />
                                <line x1="2" y1="6" x2="16" y2="6" />
                                <rect x="6" y="6" width="14" height="14" rx="1" />
                            </svg>
                        </div>
                        <h3>Crop PDF</h3>
                        <p>Trim page areas</p>
                    </a>

                </div>
            </div>

            <!-- Organize -->
            <div class="tools-category">
                <div class="tools-category-title">Organize</div>
                <div class="tools-grid">

                    <a href="/merge-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#0D9488;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M8 3H5a2 2 0 0 0-2 2v3m16 0V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3m8 0h3a2 2 0 0 0 2-2v-3" />
                                <line x1="12" y1="8" x2="12" y2="16" />
                                <line x1="8" y1="12" x2="16" y2="12" />
                            </svg>
                        </div>
                        <h3>Merge PDF</h3>
                        <p>Combine PDFs</p>
                    </a>

                    <a href="/split-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#EA580C;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M8 3H5a2 2 0 0 0-2 2v3m16 0V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3m8 0h3a2 2 0 0 0 2-2v-3" />
                                <line x1="8" y1="12" x2="16" y2="12" />
                            </svg>
                        </div>
                        <h3>Split PDF</h3>
                        <p>Separate pages</p>
                    </a>

                    <a href="/organize-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#7C3AED;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="3" width="9" height="10" rx="1" />
