@page "/"
@inject IJSRuntime JS

<SeoHead Title="Free Online PDF Tools, AI PDF Tools &amp; Converters | PdfToolStack"
         Description="Compress, merge, split, convert, sign, redact, OCR, and summarize PDFs online. Fast privacy-minded PDF tools with no install and free tools to start."
         CanonicalPath="/" />

<HeadContent>
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "FAQPage",
      "@@id": "https://pdftoolstack.com/#faq",
      "mainEntity": [
        {
          "@@type": "Question",
          "name": "Is PdfToolStack free to use?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Many basic PDF tools are free to start. Advanced AI and batch workflows may require a paid plan."
          }
        },
        {
          "@@type": "Question",
          "name": "Do I need to install software?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "No. PdfToolStack runs in your browser, so you can work with PDFs without installing a desktop app."
          }
        },
        {
          "@@type": "Question",
          "name": "How long are uploaded files kept?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Temporary files are automatically deleted after one hour. PdfToolStack is designed for short-lived processing."
          }
        },
        {
          "@@type": "Question",
          "name": "Can I use PdfToolStack for scanned PDFs?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Yes. Use PDF OCR to make scanned documents searchable before summarizing, translating, or converting."
          }
        },
        {
          "@@type": "Question",
          "name": "Which formats can I convert?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "PdfToolStack supports PDF, Word, Excel, PowerPoint, JPG, scanned PDFs, tables, and invoices."
          }
        },
        {
          "@@type": "Question",
          "name": "Can teams use PdfToolStack for business documents?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Yes. Teams use it for contracts, invoices, reports, forms, client packets, security, and batch tasks."
          }
        },
        {
          "@@type": "Question",
          "name": "Are the AI PDF tools useful for long documents?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Yes. AI tools can summarize, answer questions, compare drafts, review contracts, and extract data."
          }
        },
        {
          "@@type": "Question",
          "name": "Where should I start if I am not sure which tool I need?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Use homepage search or browse AI, security, organizer, converter, and business tool collections."
          }
        }
      ]
    }
    </script>
</HeadContent>

<div class="home-page">

    <div class="hero-section hero-split-layout">
        <div class="hero-split-text">
            <div class="hero-no-trials-badge">Free PDF tools. No signup required.</div>
            <h1>Fix your PDF<br /><span class="hero-gradient-text">in seconds.</span></h1>
            <p>
                Compress, convert, redact, and edit PDFs instantly.
                No installs. No hassle.
            </p>
            <div class="hero-cta-row">
                <a href="#tools" class="hero-cta-primary">Start with your PDF</a>
                <a href="#tools" class="hero-cta-secondary">Browse tools ↓</a>
            </div>
            <div class="hero-stats-row">
                <div class="hero-stat">
                    <span class="hero-stat-num">35+</span>
                    <span class="hero-stat-label">PDF tools</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">AI</span>
                    <span class="hero-stat-label">AI-powered</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">$0</span>
                    <span class="hero-stat-label">to start</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">1hr</span>
                    <span class="hero-stat-label">file deletion</span>
                </div>
            </div>
        </div>

        <div class="hero-split-illustration" aria-hidden="true">
            <svg width="100%" viewBox="0 0 780 480" role="img" xmlns="http://www.w3.org/2000/svg">
                <title>Upload, process, and download PDFs with PdfToolStack</title>
                <desc>A workflow board showing a PDF upload, workflow choice, secure processing, and a finished download.</desc>

                <defs>
                    <linearGradient id="workflow-bg" x1="76" y1="50" x2="704" y2="430" gradientUnits="userSpaceOnUse">
                        <stop stop-color="#FFFFFF" stop-opacity="0.92" />
                        <stop offset="0.5" stop-color="#EEF2FF" stop-opacity="0.86" />
                        <stop offset="1" stop-color="#E0F2FE" stop-opacity="0.9" />
                    </linearGradient>
                    <linearGradient id="workflow-gradient" x1="0" y1="0" x2="1" y2="1">
                        <stop stop-color="#6D5DFC" />
                        <stop offset="0.55" stop-color="#2563EB" />
                        <stop offset="1" stop-color="#06B6D4" />
                    </linearGradient>
                    <linearGradient id="workflow-soft" x1="0" y1="0" x2="1" y2="1">
                        <stop stop-color="#F8FAFC" />
                        <stop offset="1" stop-color="#EEF2FF" />
                    </linearGradient>
                    <filter id="workflow-shadow" x="-20%" y="-30%" width="140%" height="170%" color-interpolation-filters="sRGB">
                        <feDropShadow dx="0" dy="18" stdDeviation="18" flood-color="#1E1B4B" flood-opacity="0.14" />
                    </filter>
                    <filter id="workflow-soft-shadow" x="-30%" y="-40%" width="160%" height="190%" color-interpolation-filters="sRGB">
                        <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#2563EB" flood-opacity="0.12" />
                    </filter>
                    <pattern id="workflow-dot-grid" width="28" height="28" patternUnits="userSpaceOnUse">
                        <circle cx="14" cy="14" r="1" fill="#A5B4FC" opacity="0.32" />
                    </pattern>
                </defs>

                <style>
                    @@keyframes workflow-chip-cycle {
                        0%, 18% {
                            opacity: 1;
                            transform: translateY(-3px);
                        }

                        24%, 100% {
                            opacity: .62;
                            transform: translateY(0);
                        }
                    }

                    @@keyframes workflow-progress {
                        0% {
                            transform: scaleX(0.08);
                        }

                        58% {
                            transform: scaleX(1);
                        }

                        100% {
                            transform: scaleX(1);
                        }
                    }

                    @@keyframes workflow-pulse {
                        0%, 100% {
                            opacity: .2;
                            transform: scale(.98);
                        }

                        50% {
                            opacity: .42;
                            transform: scale(1.04);
                        }
                    }

                    @@keyframes workflow-check {
                        0%, 68% {
                            opacity: 0;
                            transform: translateY(8px) scale(.92);
                        }

                        76%, 100% {
                            opacity: 1;
                            transform: translateY(0) scale(1);
                        }
                    }

                    @@keyframes workflow-line {
                        0% {
                            stroke-dashoffset: 420;
                        }

                        70%, 100% {
                            stroke-dashoffset: 0;
                        }
                    }

                    @@keyframes workflow-shimmer {
                        0% {
                            transform: translateX(-140px);
                            opacity: 0;
                        }

                        30% {
                            opacity: .62;
                        }

                        70%, 100% {
                            transform: translateX(170px);
                            opacity: 0;
                        }
                    }

                    @@keyframes workflow-float {
                        0%, 100% {
                            transform: translateY(0);
                        }

                        50% {
                            transform: translateY(-6px);
                        }
                    }

                    .workflow-card {
                        filter: url(#workflow-shadow);
                    }

                    .workflow-stage {
                        animation: workflow-float 6.4s ease-in-out infinite;
                    }

                    .workflow-stage-upload {
                        animation-delay: 0s;
                    }

                    .workflow-stage-process {
                        animation-delay: .35s;
                    }

                    .workflow-stage-output {
                        animation-delay: .7s;
                    }

                    .workflow-connector {
                        stroke-dasharray: 420;
                        stroke-dashoffset: 420;
                        animation: workflow-line 6.4s ease-in-out infinite;
                    }

                    .workflow-chip {
                        opacity: .62;
                        transform-box: fill-box;
                        transform-origin: center;
                    }

                    .workflow-chip-1 {
                        animation: workflow-chip-cycle 6.4s ease-in-out infinite;
                    }

                    .workflow-chip-2 {
                        animation: workflow-chip-cycle 6.4s ease-in-out infinite;
                        animation-delay: 1.6s;
                    }

                    .workflow-chip-3 {
                        animation: workflow-chip-cycle 6.4s ease-in-out infinite;
                        animation-delay: 3.2s;
                    }

                    .workflow-chip-4 {
                        animation: workflow-chip-cycle 6.4s ease-in-out infinite;
                        animation-delay: 4.8s;
                    }

                    .workflow-progress-fill {
                        transform-box: fill-box;
                        transform-origin: left center;
                        animation: workflow-progress 6.4s ease-in-out infinite;
                    }

                    .workflow-secure-glow {
                        animation: workflow-pulse 3.2s ease-in-out infinite;
                        transform-box: fill-box;
                        transform-origin: center;
                    }

                    .workflow-checkmark {
                        animation: workflow-check 6.4s ease-in-out infinite;
                        transform-box: fill-box;
                        transform-origin: center;
                    }

                    .workflow-shimmer {
                        animation: workflow-shimmer 3.2s ease-in-out infinite;
                    }

                    .workflow-badge {
                        filter: url(#workflow-soft-shadow);
                    }

                    @@media (prefers-reduced-motion: reduce) {
                        .workflow-stage,
                        .workflow-connector,
                        .workflow-chip,
                        .workflow-progress-fill,
                        .workflow-secure-glow,
                        .workflow-checkmark,
                        .workflow-shimmer {
                            animation: none !important;
                        }

                        .workflow-chip-1,
                        .workflow-checkmark {
                            opacity: 1;
                        }
                    }
                </style>

