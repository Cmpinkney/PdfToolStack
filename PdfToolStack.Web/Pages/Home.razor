                    <text x="356" y="361" font-family="Inter, system-ui, sans-serif" font-size="10.5" font-weight="600" fill="#64748B">Encrypted transfer</text>
                    <rect x="318" y="377" width="188" height="8" rx="4" fill="#E2E8F0" />
                    <rect class="workflow-progress-fill" x="318" y="377" width="188" height="8" rx="4" fill="url(#workflow-gradient)" />
                    <rect class="workflow-shimmer" x="318" y="377" width="48" height="8" rx="4" fill="#FFFFFF" opacity="0.5" />
