    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var refCode = query["ref"];

        if (!string.IsNullOrEmpty(refCode))
        {
            await ApiService.TrackReferralAsync(refCode);
            await JS.InvokeVoidAsync("sessionStorage.setItem", "ref", refCode);
        }
    }

    private IEnumerable<ToolInfo> SearchResults =>
        string.IsNullOrWhiteSpace(HeroSearch)
            ? Enumerable.Empty<ToolInfo>()
            : AllTools.Where(t =>
                t.Name.Contains(HeroSearch, StringComparison.OrdinalIgnoreCase) ||
                t.Description.Contains(HeroSearch, StringComparison.OrdinalIgnoreCase));
}

