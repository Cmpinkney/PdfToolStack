                    <text x="623" y="322" font-family="Inter, system-ui, sans-serif" font-size="10.5" font-weight="600" fill="#64748B" text-anchor="middle">Clean result file</text>
                </g>

                <g class="workflow-badge">
                    <rect x="72" y="386" width="124" height="34" rx="17" fill="#FFFFFF" stroke="#C7D2FE" />
                    <circle cx="92" cy="403" r="9" fill="#EEF2FF" />
