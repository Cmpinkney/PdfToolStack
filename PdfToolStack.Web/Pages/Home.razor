                    <text x="250" y="407" font-family="Inter, system-ui, sans-serif" font-size="10.5" font-weight="700" fill="#0369A1">Deleted in 1hr</text>
                </g>
                <g class="workflow-badge">
                    <rect x="362" y="386" width="142" height="34" rx="17" fill="#FFFFFF" stroke="#DDD6FE" />
                    <circle cx="382" cy="403" r="9" fill="#F5F3FF" />
                    <path d="M377 403H387M382 398V408" stroke="#7C3AED" stroke-width="1.7" stroke-linecap="round" />
                    <text x="398" y="407" font-family="Inter, system-ui, sans-serif" font-size="10.5" font-weight="700" fill="#6D28D9">No signup needed</text>
                </g>
            </svg>
        </div>
    </div>

    <section class="home-command-center" id="tools">
        <div class="home-section-heading home-section-heading--center">
            <span>Command center</span>
            <h2>Find the right workflow instantly</h2>
            <p>Search by task, file problem, or document goal.</p>
        </div>

        <div class="tools-search-wrap home-command-search">
            <span class="hero-search-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </span>
            <input type="text"
                   placeholder="Search tools — compress for email, sign contract, extract invoice..."
                   @bind="HeroSearch"
                   @bind:event="oninput" />
        </div>

        <div class="home-command-hints" aria-hidden="true">
            <span>Compress</span>
            <span>Convert</span>
            <span>Redact</span>
            <span>Sign</span>
            <span>Extract data</span>
        </div>
    </section>

    <div class="trust-bar">
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            Private processing
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3,6 5,6 21,6" />
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
            </svg>
            Secure upload
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                <line x1="1" y1="1" x2="23" y2="23" />
            </svg>
            Auto-delete after 1 hour
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12,6 12,12 16,14" />
            </svg>
            No permanent storage
        </div>
    </div>


    <div class="founder-statement">
        <div class="founder-avatar">C</div>
        <div class="founder-quote-wrap">
            <blockquote class="founder-quote">
                "I built PdfToolStack because I was tired of hitting a paywall every time I needed to
                do something simple with a PDF. No free trials, no forced signups — just tools that
                work, for professionals who have actual work to do."
            </blockquote>
            <p class="founder-attr">— Chrystal, PdfToolStack</p>
        </div>
    </div>

    <RecentFiles DisplayOnly="true"
                 Title="Continue your work"
                 Description="Pick up from your recent document workflows on this device." />

    <div class="tools-section">

        @if (!string.IsNullOrWhiteSpace(HeroSearch))
        {
            <div class="tools-category home-search-results">
                <div class="home-section-heading">
                    <span>Search results</span>
                    <h2>Matching workflows</h2>
                    <p>Jump straight into the tool that fits your document goal.</p>
                </div>
                <div class="tools-grid">
                    @foreach (var tool in SearchResults)
                    {
                        <a href="@tool.Url" class="tool-card">
                            <div class="tool-icon-tile" style="background:@tool.Color;">
                                @((MarkupString)tool.SvgIcon)
                            </div>
                            <h3>@tool.Name</h3>
                            <p>@tool.Description</p>
                        </a>
                    }
                    @if (!SearchResults.Any())
                    {
                        <p style="color:var(--text-muted); font-size:0.9rem; grid-column:1/-1;">
                            No tools found for "@HeroSearch"
                        </p>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="tools-category popular-workflows-section">
                <div class="popular-workflows-header home-section-heading">
                    <span>Popular workflows</span>
                    <h2>Start with a common document workflow</h2>
                    <p>Choose the outcome you need and jump straight into the right tool.</p>
