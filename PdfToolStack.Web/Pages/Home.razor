@page "/"
@inject IJSRuntime JS

<PageTitle>PdfToolStack — Do More With Your Documents</PageTitle>

<HeadContent>
    <meta name="description"
          content="Compress, convert, sign, and extract data from PDFs — powered by AI. 35+ free tools, no signup required." />
    <meta name="keywords"
          content="ai pdf tools, extract invoice data, compare pdf, pdf summarizer, compress pdf, merge pdf, sign pdf" />
    <link rel="canonical" href="https://pdftoolstack.com" />
</HeadContent>

<div class="home-page">

    <div class="hero-section hero-split-layout">
        <div class="hero-split-text">
            <div class="hero-no-trials-badge">✨ No free trials. Ever.</div>
            <h1>Do more with<br /><span class="hero-gradient-text">your documents.</span></h1>
            <p>
                Compress, convert, sign, and extract data —
                powered by AI. Free to start, no signup required.
            </p>
            <div class="hero-cta-row">
                <a href="#tools" class="hero-cta-primary">Try free — no signup</a>
                <a href="/pricing" class="hero-cta-secondary">See Pro plans →</a>
            </div>
            <div class="hero-stats-row">
                <div class="hero-stat">
                    <span class="hero-stat-num">35+</span>
                    <span class="hero-stat-label">PDF tools</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">AI</span>
                    <span class="hero-stat-label">AI-powered</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">$0</span>
                    <span class="hero-stat-label">to start</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">1hr</span>
                    <span class="hero-stat-label">file deletion</span>
                </div>
            </div>
        </div>

        <div class="hero-split-illustration" aria-hidden="true">
            <svg width="100%" viewBox="0 0 780 480" role="img" xmlns="http://www.w3.org/2000/svg">
                <title>PdfToolStack — all your PDF tools in one place</title>
                <desc>PDF tools orbiting a central document hub</desc>

                <defs>
                    <marker id="ap" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
                        <path d="M2 2L8 5L2 8" fill="none" stroke="#7F77DD" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </marker>
                    <pattern id="dot" width="28" height="28" patternUnits="userSpaceOnUse">
                        <circle cx="14" cy="14" r="1" fill="#C8C6C0" opacity="0.45" />
                    </pattern>
                </defs>

                <style>
                    @@keyframes spin-cw {
                        from {
                            transform: rotate(0deg);
                        }

                        to {
                            transform: rotate(360deg);
                        }
                    }

                    @@keyframes spin-ccw {
                        from {
                            transform: rotate(0deg);
                        }

                        to {
                            transform: rotate(-360deg);
                        }
                    }

                    @@keyframes pulse {
                        0%, 100% {
                            opacity: .12;
                        }

                        50% {
                            opacity: .22;
                        }
                    }

                    @@keyframes fadein {
                        from {
                            opacity: 0;
                            transform: translateY(5px);
                        }

                        to {
                            opacity: 1;
                            transform: translateY(0);
                        }
                    }

                    @@keyframes ring-cw {
                        from {
                            stroke-dashoffset: 0;
                        }

                        to {
                            stroke-dashoffset: -660;
                        }
                    }

                    @@keyframes ring-ccw {
                        from {
                            stroke-dashoffset: 0;
                        }

                        to {
                            stroke-dashoffset: 970;
                        }
                    }

                    .inner-orbit {
                        animation: spin-cw 11s linear infinite;
                        transform-origin: 340px 190px;
                    }

                    .inner-card {
                        animation: spin-ccw 11s linear infinite;
                        transform-origin: 0px 0px;
                    }

                    .outer-orbit {
                        animation: spin-ccw 18s linear infinite;
                        transform-origin: 340px 190px;
                    }

                    .outer-card {
                        animation: spin-cw 18s linear infinite;
                        transform-origin: 0px 0px;
                    }

                    .ring-a {
                        animation: ring-cw 22s linear infinite;
                        transform-origin: 340px 190px;
                    }

                    .ring-b {
                        animation: ring-ccw 34s linear infinite;
                        transform-origin: 340px 190px;
                    }

                    .glow {
                        animation: pulse 3.2s ease-in-out infinite;
                    }

                    .badge {
                        animation: fadein .5s ease-out both;
                    }

                    .b1 {
                        animation-delay: .05s;
                    }

                    .b2 {
                        animation-delay: .15s;
                    }

                    .b3 {
                        animation-delay: .28s;
                    }

                    .b4 {
                        animation-delay: .42s;
                    }
                </style>

                <!-- Background dot grid -->
                <rect width="680" height="400" fill="url(#dot)" />
                <line x1="0" y1="60" x2="680" y2="60" stroke="#E0EEF8" stroke-width="0.4" />
                <line x1="0" y1="340" x2="680" y2="340" stroke="#E0EEF8" stroke-width="0.4" />
                <line x1="100" y1="0" x2="100" y2="400" stroke="#E0EEF8" stroke-width="0.4" />
                <line x1="580" y1="0" x2="580" y2="400" stroke="#E0EEF8" stroke-width="0.4" />

                <!-- Glow rings -->
                <circle class="glow" cx="340" cy="190" r="170" fill="#534AB7" opacity="0.07" />
                <circle class="glow" cx="340" cy="190" r="115" fill="#185FA5" opacity="0.09" style="animation-delay:.9s" />
                <circle class="glow" cx="340" cy="190" r="68" fill="#534AB7" opacity="0.11" style="animation-delay:1.8s" />

                <!-- Spinning dashed rings -->
                <circle class="ring-a" cx="340" cy="190" r="105" fill="none" stroke="#85B7EB" stroke-width="1" stroke-dasharray="4 10" stroke-linecap="round" />
                <circle class="ring-b" cx="340" cy="190" r="154" fill="none" stroke="#AFA9EC" stroke-width="1" stroke-dasharray="4 14" stroke-linecap="round" />
                <!-- Static reference circles -->
                <circle cx="340" cy="190" r="105" fill="none" stroke="#D3D1C7" stroke-width="0.35" />
                <circle cx="340" cy="190" r="154" fill="none" stroke="#D3D1C7" stroke-width="0.35" />

                <!-- ═══════════════════════════════════════
                     INNER ORBIT — Compress · Sign · Merge
                     r=105, CW 11s, cards counter-rotate CCW
                     Compress (340, 85) · Sign (431,243) · Merge (249,243)
                ═══════════════════════════════════════ -->
                <g class="inner-orbit">

                    <!-- Compress -->
                    <g transform="translate(340,85)">
                        <g class="inner-card">
                            <rect x="-34" y="-28" width="68" height="56" rx="13" fill="white" stroke="#B5D4F4" stroke-width="1.5" />
                            <g stroke="#378ADD" stroke-width="1.8" stroke-linecap="round" fill="none">
                                <line x1="-13" y1="-11" x2="-5" y2="-4" />
                                <line x1=" 13" y1="-11" x2=" 5" y2="-4" />
                                <line x1="-13" y1=" 11" x2="-5" y2=" 4" />
                                <line x1=" 13" y1=" 11" x2=" 5" y2=" 4" />
                            </g>
                            <polygon points="-15,-14 -7,-14 -15,-6" fill="#378ADD" />
                            <polygon points=" 15,-14  7,-14  15,-6" fill="#378ADD" />
                            <polygon points="-15, 14 -7, 14 -15, 6" fill="#378ADD" />
                            <polygon points=" 15, 14  7, 14  15, 6" fill="#378ADD" />
                            <text x="0" y="24" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600" fill="#185FA5" text-anchor="middle">Compress</text>
                        </g>
                    </g>

                    <!-- Sign -->
                    <g transform="translate(431,243)">
                        <g class="inner-card">
                            <rect x="-34" y="-28" width="68" height="56" rx="13" fill="white" stroke="#FAC775" stroke-width="1.5" />
                            <path d="M-16,4 Q-6,-10 2,4 Q10,16 18,4" stroke="#EF9F27" stroke-width="2.2" fill="none" stroke-linecap="round" />
                            <line x1="-18" y1="12" x2="18" y2="12" stroke="#FAC775" stroke-width="1.2" />
                            <text x="0" y="24" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600" fill="#854F0B" text-anchor="middle">Sign</text>
                        </g>
                    </g>

                    <!-- Merge -->
                    <g transform="translate(249,243)">
                        <g class="inner-card">
                            <rect x="-34" y="-28" width="68" height="56" rx="13" fill="white" stroke="#9FE1CB" stroke-width="1.5" />
                            <rect x="-18" y="-14" width="13" height="18" rx="3" fill="#9FE1CB" />
                            <rect x="-5" y="-14" width="13" height="18" rx="3" fill="#5DCAA5" />
                            <path d="M-11,4 L0,12 L11,4" stroke="#1D9E75" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                            <rect x="-7" y="11" width="14" height="4" rx="2" fill="#1D9E75" />
                            <text x="0" y="24" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600" fill="#0F6E56" text-anchor="middle">Merge</text>
                        </g>
                    </g>

                </g>

                <!-- ═══════════════════════════════════════
                     OUTER ORBIT — AI Review · Convert · Extract · Split
                     r=154, CCW 18s, cards counter-rotate CW
                     Top(340,36) · Right(494,190) · Bottom(340,344) · Left(186,190)
                ═══════════════════════════════════════ -->
                <g class="outer-orbit">

                    <!-- AI Review -->
                    <g transform="translate(340,36)">
                        <g class="outer-card">
                            <rect x="-36" y="-27" width="72" height="54" rx="13" fill="white" stroke="#C0DD97" stroke-width="1.5" />
                            <circle cx="-4" cy="-5" r="10" fill="none" stroke="#639922" stroke-width="1.8" />
                            <line x1="4" y1="3" x2="12" y2="10" stroke="#639922" stroke-width="2.2" stroke-linecap="round" />
                            <circle cx="7" cy="-15" r="2.5" fill="#EF9F27" />
                            <circle cx="12" cy="-10" r="1.5" fill="#EF9F27" opacity=".6" />
                            <text x="0" y="23" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600" fill="#3B6D11" text-anchor="middle">AI review</text>
                        </g>
                    </g>

                    <!-- Convert -->
                    <g transform="translate(494,190)">
                        <g class="outer-card">
                            <rect x="-36" y="-27" width="72" height="54" rx="13" fill="white" stroke="#CECBF6" stroke-width="1.5" />
                            <path d="M-10,-10 A13,13 0 0,1 13,3" stroke="#7F77DD" stroke-width="1.8" fill="none" stroke-linecap="round" marker-end="url(#ap)" />
                            <path d="M10,10  A13,13 0 0,1 -13,-3" stroke="#7F77DD" stroke-width="1.8" fill="none" stroke-linecap="round" marker-end="url(#ap)" />
                            <text x="0" y="23" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600" fill="#3C3489" text-anchor="middle">Convert</text>
                        </g>
                    </g>

                    <!-- Extract -->
                    <g transform="translate(340,344)">
                        <g class="outer-card">
                            <rect x="-36" y="-27" width="72" height="54" rx="13" fill="white" stroke="#F5C4B3" stroke-width="1.5" />
                            <rect x="-18" y="-16" width="36" height="24" rx="3" fill="#FAECE7" stroke="#F0997B" stroke-width="1" />
                            <line x1="-18" y1="-8" x2="18" y2="-8" stroke="#F0997B" stroke-width="0.8" />
                            <line x1="-18" y1="0" x2="18" y2="0" stroke="#F0997B" stroke-width="0.8" />
                            <line x1="0" y1="-16" x2="0" y2="8" stroke="#F0997B" stroke-width="0.8" />
                            <text x="0" y="23" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600" fill="#993C1D" text-anchor="middle">Extract</text>
                        </g>
                    </g>

                    <!-- Split -->
                    <g transform="translate(186,190)">
                        <g class="outer-card">
                            <rect x="-36" y="-27" width="72" height="54" rx="13" fill="white" stroke="#B5D4F4" stroke-width="1.5" />
                            <rect x="-8" y="-16" width="16" height="20" rx="3" fill="#85B7EB" />
                            <path d="M0,4 L-14,14 M0,4 L14,14" stroke="#378ADD" stroke-width="1.8" fill="none" stroke-linecap="round" />
                            <rect x="-20" y="13" width="14" height="10" rx="2" fill="#B5D4F4" />
                            <rect x="6" y="13" width="14" height="10" rx="2" fill="#B5D4F4" />
                            <text x="0" y="23" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600" fill="#185FA5" text-anchor="middle">Split</text>
                        </g>
                    </g>

                </g>

                <!-- Center hub -->
                <circle cx="340" cy="190" r="62" fill="#F0EFFE" stroke="#AFA9EC" stroke-width="1.5" />
                <circle cx="340" cy="190" r="55" fill="white" stroke="#CECBF6" stroke-width="1" />
                <rect x="316" y="162" width="36" height="46" rx="6" fill="white" stroke="#AFA9EC" stroke-width="1.2" />
                <path d="M316,162 L316,174 L328,174 L328,162 Z" fill="#7F77DD" />
                <path d="M340,162 L340,174 L328,174 Z" fill="#534AB7" opacity=".5" />
                <rect x="322" y="179" width="24" height="3" rx="1.5" fill="#AFA9EC" />
                <rect x="322" y="186" width="20" height="3" rx="1.5" fill="#D3D1C7" />
                <rect x="322" y="193" width="22" height="3" rx="1.5" fill="#D3D1C7" />
                <rect x="322" y="200" width="16" height="3" rx="1.5" fill="#D3D1C7" />
                <text x="340" y="222" font-family="system-ui,sans-serif" font-size="10" font-weight="600" fill="#534AB7" text-anchor="middle">your docs</text>

                <!-- Corner badges -->
                <g class="badge b1">
                    <rect x="18" y="18" width="132" height="30" rx="15" fill="white" stroke="#B5D4F4" stroke-width="1.2" />
                    <circle cx="38" cy="33" r="9" fill="#E6F1FB" />
                    <rect x="33" y="30" width="10" height="2.5" rx="1.2" fill="#378ADD" />
                    <rect x="33" y="34.5" width="7" height="2.5" rx="1.2" fill="#85B7EB" />
                    <text x="54" y="38" font-family="system-ui,sans-serif" font-size="10.5" font-weight="600" fill="#185FA5">35+ PDF tools</text>
                </g>
                <g class="badge b2">
                    <rect x="530" y="18" width="132" height="30" rx="15" fill="white" stroke="#C0DD97" stroke-width="1.2" />
                    <circle cx="550" cy="33" r="9" fill="#EAF3DE" />
                    <path d="M545,33 L549,37 L556,28" stroke="#639922" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                    <text x="566" y="38" font-family="system-ui,sans-serif" font-size="10.5" font-weight="600" fill="#3B6D11">Privacy-first</text>
                </g>
                <g class="badge b3">
                    <rect x="18" y="352" width="148" height="30" rx="15" fill="white" stroke="#9FE1CB" stroke-width="1.2" />
                    <circle cx="38" cy="367" r="9" fill="#E1F5EE" />
                    <path d="M33,367 L38,362 L43,367" stroke="#1D9E75" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                    <text x="54" y="372" font-family="system-ui,sans-serif" font-size="10.5" font-weight="600" fill="#0F6E56">No signup needed</text>
                </g>
                <g class="badge b4">
                    <rect x="514" y="352" width="148" height="30" rx="15" fill="white" stroke="#FAC775" stroke-width="1.2" />
                    <circle cx="534" cy="367" r="9" fill="#FAEEDA" />
                    <rect x="529" y="363" width="10" height="8" rx="2" fill="none" stroke="#EF9F27" stroke-width="1.4" />
                    <line x1="529" y1="367" x2="539" y2="367" stroke="#EF9F27" stroke-width="0.9" />
                    <text x="550" y="372" font-family="system-ui,sans-serif" font-size="10.5" font-weight="600" fill="#854F0B">Deleted in 1hr</text>
                </g>

            </svg>
        </div>
    </div>

    <div class="trust-bar">
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            256-bit encryption
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3,6 5,6 21,6" />
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
            </svg>
            Files deleted in 1 hour
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                <line x1="1" y1="1" x2="23" y2="23" />
            </svg>
            No data training
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12,6 12,12 16,14" />
            </svg>
            No signup required
        </div>
    </div>


    <div class="founder-statement">
        <div class="founder-avatar">S</div>
        <div class="founder-quote-wrap">
            <blockquote class="founder-quote">
                "I built PdfToolStack because I was tired of hitting a paywall every time I needed to
                do something simple with a PDF. No free trials, no forced signups — just tools that
                work, for professionals who have actual work to do."
            </blockquote>
            <p class="founder-attr">— Chrystal, PdfToolStack</p>
        </div>
    </div>

    <div class="tools-section" id="tools">

        <div class="tools-search-wrap">
            <span class="hero-search-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </span>
            <input type="text"
                   placeholder="Search tools — compress, sign, extract invoice..."
                   @bind="HeroSearch"
                   @bind:event="oninput" />
        </div>

        @if (!string.IsNullOrWhiteSpace(HeroSearch))
        {
            <div class="tools-category">
                <div class="tools-category-title">Search results</div>
                <div class="tools-grid">
                    @foreach (var tool in SearchResults)
                    {
                        <a href="@tool.Url" class="tool-card">
                            <div class="tool-icon-tile" style="background:@tool.Color;">
                                @((MarkupString)tool.SvgIcon)
                            </div>
                            <h3>@tool.Name</h3>
                            <p>@tool.Description</p>
                        </a>
                    }
                    @if (!SearchResults.Any())
                    {
                        <p style="color:var(--text-muted); font-size:0.9rem; grid-column:1/-1;">
                            No tools found for "@HeroSearch"
                        </p>
                    }
                </div>
            </div>
        }
        else
        {
            <!-- AI Tools -->
            <div class="tools-category">
                <div class="tools-category-title">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--primary);">
                        <path d="M12 3c.5 1.5 1.5 2.5 3 3-1.5.5-2.5 1.5-3 3-.5-1.5-1.5-2.5-3-3 1.5-.5 2.5-1.5 3-3z" fill="currentColor" fill-opacity="0.2" />
                        <path d="M5 7c.3.8.8 1.4 1.5 1.5C5.8 8.8 5.3 9.4 5 10c-.3-.6-.8-1.2-1.5-1.5C4.2 8.2 4.7 7.6 5 7z" fill="currentColor" fill-opacity="0.6" />
                        <path d="M18 14c.3.8.8 1.4 1.5 1.5-.7.3-1.2.8-1.5 1.5-.3-.7-.8-1.2-1.5-1.5.7-.3 1.2-.8 1.5-1.5z" fill="currentColor" fill-opacity="0.6" />
                    </svg>
                    AI Tools
                    <span class="pro-label">Pro</span>
                </div>
                <div class="tools-grid ai-tools-grid">

                    <a href="/invoice-data-extraction" class="tool-card tool-card-ai featured-ai-card">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="3" fill="#4F46E5" fill-opacity="0.2" /><rect x="3" y="3" width="18" height="18" rx="3" stroke="#4F46E5" stroke-width="1.5" /><path d="M3 8.5H21" stroke="#4F46E5" stroke-width="1.5" /><path d="M9 8.5V21" stroke="#4F46E5" stroke-width="1.5" /><path d="M13 13H18" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /><path d="M13 17H16" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /></svg>
                        </div>
                        <h3>Extract Invoice Data</h3>
                        <p>AI reads invoice → exports to Excel. No manual entry.</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/chat-pdf" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="#4F46E5" xmlns="http://www.w3.org/2000/svg"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" fill="#4F46E5" /></svg>
                        </div>
                        <h3>Chat with PDF</h3>
                        <p>Ask your document anything</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

