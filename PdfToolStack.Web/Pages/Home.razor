@page "/"
@inject IJSRuntime JS

<PageTitle>PdfToolStack — Do More With Your Documents</PageTitle>

<HeadContent>
    <meta name="description"
          content="Compress, convert, sign, and extract data from PDFs — powered by AI. 35+ free tools, no signup required." />
    <meta name="keywords"
          content="ai pdf tools, extract invoice data, compare pdf, pdf summarizer, compress pdf, merge pdf, sign pdf" />
    <link rel="canonical" href="https://pdftoolstack.com" />
</HeadContent>

<div class="home-page">

    <div class="hero-section hero-split-layout">
        <div class="hero-split-text">
            <div class="hero-no-trials-badge">✨ No free trials. Ever.</div>
            <h1>Do more with<br /><span class="hero-gradient-text">your documents.</span></h1>
            <p>
                Compress, convert, sign, and extract data —
                powered by AI. Free to start, no signup required.
            </p>
            <div class="hero-cta-row">
                <a href="/" class="hero-cta-primary">Try free — no signup</a>
                <a href="/pricing" class="hero-cta-secondary">See Pro plans →</a>
            </div>
            <div class="hero-stats-row">
                <div class="hero-stat">
                    <span class="hero-stat-num">35+</span>
                    <span class="hero-stat-label">PDF tools</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">AI</span>
                    <span class="hero-stat-label">Claude-powered</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">$0</span>
                    <span class="hero-stat-label">to start</span>
                </div>
                <div class="hero-stat-divider"></div>
                <div class="hero-stat">
                    <span class="hero-stat-num">1hr</span>
                    <span class="hero-stat-label">file deletion</span>
                </div>
            </div>
        </div>
        <div class="hero-split-illustration" aria-hidden="true">
            <svg viewBox="0 0 320 220" width="100%" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="18" y="14" width="110" height="142" rx="8" fill="#EFF6FF" stroke="#2250F4" stroke-width="1.5" />
                <rect x="30" y="34" width="66" height="7" rx="3.5" fill="#2250F4" fill-opacity="0.55" />
                <rect x="30" y="48" width="88" height="4" rx="2" fill="#2250F4" fill-opacity="0.2" />
                <rect x="30" y="58" width="78" height="4" rx="2" fill="#2250F4" fill-opacity="0.2" />
                <rect x="30" y="68" width="82" height="4" rx="2" fill="#2250F4" fill-opacity="0.2" />
                <rect x="30" y="86" width="66" height="7" rx="3.5" fill="#0D9488" fill-opacity="0.5" />
                <rect x="30" y="100" width="88" height="4" rx="2" fill="#0D9488" fill-opacity="0.18" />
                <rect x="30" y="110" width="72" height="4" rx="2" fill="#0D9488" fill-opacity="0.18" />
                <rect x="30" y="120" width="80" height="4" rx="2" fill="#0D9488" fill-opacity="0.18" />
                <rect x="58" y="36" width="110" height="142" rx="8" fill="#EEF2FF" stroke="#4F46E5" stroke-width="1.5" />
                <rect x="70" y="56" width="66" height="7" rx="3.5" fill="#4F46E5" fill-opacity="0.55" />
                <rect x="70" y="70" width="88" height="4" rx="2" fill="#4F46E5" fill-opacity="0.2" />
                <rect x="70" y="80" width="78" height="4" rx="2" fill="#4F46E5" fill-opacity="0.2" />
                <rect x="70" y="90" width="82" height="4" rx="2" fill="#4F46E5" fill-opacity="0.2" />
                <rect x="70" y="108" width="66" height="7" rx="3.5" fill="#4F46E5" fill-opacity="0.35" />
                <rect x="70" y="122" width="88" height="4" rx="2" fill="#4F46E5" fill-opacity="0.15" />
                <rect x="70" y="132" width="72" height="4" rx="2" fill="#4F46E5" fill-opacity="0.15" />
                <circle cx="232" cy="100" r="44" fill="#E1F5EE" stroke="#0D9488" stroke-width="1.5" />
                <path d="M215 100l12 12 24-24" stroke="#0D9488" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M170 100 L186 100" stroke="#2250F4" stroke-width="1.5" stroke-dasharray="4 3" />
                <circle cx="170" cy="100" r="3.5" fill="#2250F4" />
                <rect x="192" y="158" width="88" height="30" rx="7" fill="#2250F4" />
                <text x="236" y="178" text-anchor="middle" fill="#fff" font-size="11" font-weight="600" font-family="system-ui, sans-serif">AI Processed ✓</text>
                <rect x="240" y="38" width="68" height="22" rx="11" fill="#EEF2FF" stroke="#4F46E5" stroke-width="1" />
                <text x="274" y="53" text-anchor="middle" fill="#4F46E5" font-size="10" font-weight="600" font-family="system-ui, sans-serif">Claude AI</text>
                <rect x="10" y="168" width="76" height="22" rx="11" fill="#E1F5EE" stroke="#0D9488" stroke-width="1" />
                <text x="48" y="183" text-anchor="middle" fill="#0D9488" font-size="10" font-weight="600" font-family="system-ui, sans-serif">No signup</text>
            </svg>
        </div>
    </div>

    <div class="trust-bar">
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            256-bit encryption
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3,6 5,6 21,6" />
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
            </svg>
            Files deleted in 1 hour
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                <line x1="1" y1="1" x2="23" y2="23" />
            </svg>
            No data training
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12,6 12,12 16,14" />
            </svg>
            No signup required
        </div>
    </div>


    <div class="founder-statement">
        <div class="founder-avatar">C</div>
        <div class="founder-quote-wrap">
            <blockquote class="founder-quote">
                "I built PdfToolStack because I was tired of hitting a paywall every time I needed to
                do something simple with a PDF. No free trials, no forced signups — just tools that
                work, for professionals who have actual work to do."
            </blockquote>
            <p class="founder-attr">— Chrystal, PdfToolStack</p>
        </div>
    </div>

    <div class="tools-section">

        <div class="tools-search-wrap">
            <span class="hero-search-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </span>
            <input type="text"
                   placeholder="Search tools — compress, sign, extract invoice..."
                   @bind="HeroSearch"
                   @bind:event="oninput" />
        </div>

        @if (!string.IsNullOrWhiteSpace(HeroSearch))
        {
            <div class="tools-category">
                <div class="tools-category-title">Search results</div>
                <div class="tools-grid">
                    @foreach (var tool in SearchResults)
                    {
                        <a href="@tool.Url" class="tool-card">
                            <div class="tool-icon-tile" style="background:@tool.Color;">
                                @((MarkupString)tool.SvgIcon)
                            </div>
                            <h3>@tool.Name</h3>
                            <p>@tool.Description</p>
                        </a>
                    }
                    @if (!SearchResults.Any())
                    {
                        <p style="color:var(--text-muted); font-size:0.9rem; grid-column:1/-1;">
                            No tools found for "@HeroSearch"
                        </p>
                    }
                </div>
            </div>
        }
        else
        {
            <!-- AI Tools -->
            <div class="tools-category">
                <div class="tools-category-title">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--primary);">
                        <path d="M12 3c.5 1.5 1.5 2.5 3 3-1.5.5-2.5 1.5-3 3-.5-1.5-1.5-2.5-3-3 1.5-.5 2.5-1.5 3-3z" fill="currentColor" fill-opacity="0.2" />
                        <path d="M5 7c.3.8.8 1.4 1.5 1.5C5.8 8.8 5.3 9.4 5 10c-.3-.6-.8-1.2-1.5-1.5C4.2 8.2 4.7 7.6 5 7z" fill="currentColor" fill-opacity="0.6" />
                        <path d="M18 14c.3.8.8 1.4 1.5 1.5-.7.3-1.2.8-1.5 1.5-.3-.7-.8-1.2-1.5-1.5.7-.3 1.2-.8 1.5-1.5z" fill="currentColor" fill-opacity="0.6" />
                    </svg>
                    AI Tools
                    <span class="pro-label">Pro</span>
                </div>
                <div class="tools-grid ai-tools-grid">

                    <a href="/extract-invoice-data" class="tool-card tool-card-ai featured-ai-card">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="3" fill="#4F46E5" fill-opacity="0.2" /><rect x="3" y="3" width="18" height="18" rx="3" stroke="#4F46E5" stroke-width="1.5" /><path d="M3 8.5H21" stroke="#4F46E5" stroke-width="1.5" /><path d="M9 8.5V21" stroke="#4F46E5" stroke-width="1.5" /><path d="M13 13H18" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /><path d="M13 17H16" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /></svg>
                        </div>
                        <h3>Extract Invoice Data</h3>
                        <p>AI reads invoice → exports to Excel. No manual entry.</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/chat-with-pdf" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="#4F46E5" xmlns="http://www.w3.org/2000/svg"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" fill="#4F46E5" /></svg>
                        </div>
                        <h3>Chat with PDF</h3>
                        <p>Ask your document anything</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/ai-summarizer" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 6H21" stroke="#4F46E5" stroke-width="2.5" stroke-linecap="round" /><path d="M8 12H21" stroke="#4F46E5" stroke-width="2.5" stroke-linecap="round" /><path d="M8 18H15" stroke="#4F46E5" stroke-width="2.5" stroke-linecap="round" /><circle cx="3.5" cy="6" r="1.5" fill="#4F46E5" /><circle cx="3.5" cy="12" r="1.5" fill="#4F46E5" /><circle cx="3.5" cy="18" r="1.5" fill="#4F46E5" /></svg>
                        </div>
                        <h3>AI Summarizer</h3>
                        <p>Key points in seconds</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/compare-pdf" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="3" width="8" height="18" rx="2" fill="#4F46E5" fill-opacity="0.3" stroke="#4F46E5" stroke-width="1.5" /><rect x="14" y="3" width="8" height="18" rx="2" fill="#4F46E5" fill-opacity="0.3" stroke="#4F46E5" stroke-width="1.5" /><path d="M12 3V21" stroke="#4F46E5" stroke-width="1.5" stroke-dasharray="2 2" /></svg>
                        </div>
                        <h3>Compare PDFs</h3>
                        <p>Word-level diff report</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/ai-questions" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" fill="#4F46E5" fill-opacity="0.2" stroke="#4F46E5" stroke-width="1.5" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /><circle cx="12" cy="17" r="1" fill="#4F46E5" /></svg>
                        </div>
                        <h3>AI Questions</h3>
                        <p>Generate quiz questions</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/batch" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 12H5.5L9 3L15 21L18.5 12H22" stroke="#4F46E5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        <h3>Batch Process</h3>
                        <p>20 files at once → ZIP</p>
                        <span class="tool-card-badge pro-badge">Pro</span>
                    </a>

                    <a href="/review-contract" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="#4F46E5" fill-opacity="0.25" stroke="#4F46E5" stroke-width="1.5" /><polyline points="14,2 14,8 20,8" stroke="#4F46E5" stroke-width="1.5" fill="none" /><path d="M9 13h6" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /><path d="M9 17h4" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /><circle cx="18.5" cy="18.5" r="3.5" fill="#4F46E5" fill-opacity="0.9" /><path d="M17 18.5h3M18.5 17v3" stroke="#4F46E5" stroke-width="1.8" stroke-linecap="round" /></svg>
                        </div>
                        <h3>AI Contract Reviewer</h3>
                        <p>Catch risky clauses before you sign</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                    <a href="/ai-rewrite" class="tool-card tool-card-ai">
                        <div class="tool-icon-tile" style="background:#EEF2FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" fill="#4F46E5" fill-opacity="0.9" /><path d="M12 20h9" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" /></svg>
                        </div>
                        <h3>AI Rewriter</h3>
                        <p>Rewrite, rephrase, change tone</p>
                        <span class="tool-card-badge ai">AI</span>
                    </a>

                </div>

                <!-- Popular fixes -->
                <div class="tools-category">
                    <div class="tools-category-title">Popular fixes</div>
                    <div class="popular-fixes-grid">

                        <a href="/compress-for-email" class="tool-card featured-fix">
                            <span class="featured-fix-badge">Most Used</span>
                            <div class="tool-icon-tile" style="background:#EFF6FF;">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /><path d="M12 3V15M7 10L12 15L17 10" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                            </div>
                            <h3>Fix PDF Too Large for Email</h3>
                            <p>Make your PDF email-ready in seconds</p>
                        </a>

                        <a href="/sign-contract" class="tool-card">
                            <div class="tool-icon-tile" style="background:#EFF6FF;">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 17c3-3 3-7 6-7s3 4 6 4 3-3 6-3" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /><line x1="3" y1="21" x2="21" y2="21" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /></svg>
                            </div>
                            <h3>Sign a Contract</h3>
                            <p>Electronic signature, legally binding</p>
                        </a>

                        <a href="/merge-pdfs-for-submission" class="tool-card">
                            <div class="tool-icon-tile" style="background:#EFF6FF;">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 3H5a2 2 0 0 0-2 2v3m16 0V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3m8 0h3a2 2 0 0 0 2-2v-3" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /><path d="M12 8V16M8 12H16" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /></svg>
                            </div>
                            <h3>Combine PDFs for Submission</h3>
                            <p>Tax filing, applications, legal docs</p>
                        </a>

                        <a href="/redact-pdf" class="tool-card">
                            <div class="tool-icon-tile" style="background:#EFF6FF;">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="#2250F4" fill-opacity="0.2" stroke="#2250F4" stroke-width="1.5" /><polyline points="14,2 14,8 20,8" stroke="#2250F4" stroke-width="1.5" fill="none" /><rect x="6" y="11.5" width="12" height="3.5" rx="1" fill="#2250F4" /><path d="M6 18H10" stroke="#2250F4" stroke-width="2" stroke-linecap="round" /></svg>
                            </div>
                            <h3>Remove Sensitive Information</h3>
                            <p>Permanently redact private data</p>
                        </a>

                    </div>
                </div>
            </div>
            <!-- Compress & Convert -->
            <div class="tools-category">
                <div class="tools-category-title">Compress &amp; Convert</div>
                <div class="tools-grid">

                    <a href="/compress-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#EFF6FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /><path d="M12 3V15M7 10L12 15L17 10" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        <h3>Compress PDF</h3>
                        <p>Reduce file size</p>
                    </a>

                    <a href="/pdf-to-word" class="tool-card">
                        <div class="tool-icon-tile" style="background:#EFF6FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="#2250F4" fill-opacity="0.2" stroke="#2250F4" stroke-width="1.5" /><polyline points="14,2 14,8 20,8" stroke="#2250F4" stroke-width="1.5" fill="none" /><path d="M9 13l1.5 4L12 14l1.5 3L15 13" stroke="#2250F4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        <h3>PDF to Word</h3>
                        <p>Convert to DOCX</p>
                    </a>

                    <a href="/word-to-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#EFF6FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" fill="#2250F4" fill-opacity="0.2" stroke="#2250F4" stroke-width="1.5" /><polyline points="14,2 14,8 20,8" stroke="#2250F4" stroke-width="1.5" fill="none" /><path d="M12 12V18M9 15L12 18L15 15" stroke="#2250F4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        <h3>Word to PDF</h3>
                        <p>DOCX to PDF</p>
                    </a>

                    <a href="/ppt-to-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#EFF6FF;">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="3" width="20" height="14" rx="2" fill="#2250F4" fill-opacity="0.2" stroke="#2250F4" stroke-width="1.5" /><line x1="8" y1="21" x2="16" y2="21" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /><line x1="12" y1="17" x2="12" y2="21" stroke="#2250F4" stroke-width="2.5" stroke-linecap="round" /></svg>
                        </div>
                        <h3>PPT to PDF</h3>
                        <p>Presentation to PDF</p>
                    </a>

                    <a href="/excel-to-pdf" class="tool-card">
                        <div class="tool-icon-tile" style="background:#EFF6FF;">
