                    <text x="108" y="407" font-family="Inter, system-ui, sans-serif" font-size="10.5" font-weight="700" fill="#4338CA">Privacy-first</text>
                </g>
                <g class="workflow-badge">
                    <rect x="214" y="386" width="130" height="34" rx="17" fill="#FFFFFF" stroke="#BAE6FD" />
                    <circle cx="234" cy="403" r="9" fill="#E0F2FE" />
