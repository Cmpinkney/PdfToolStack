<section class="ai-workflow-hero" aria-label="AI document intelligence workflow visualization">
    <div class="ai-workflow-shell">
        <nav class="ai-workflow-steps" aria-label="Workflow steps">
            <span>Upload PDF</span>
            <span class="is-active">AI Analyze</span>
            <span>Extract Data</span>
            <span>Generate Insights</span>
        </nav>

        <div class="ai-workflow-stage">
            <svg class="ai-workflow-connectors" viewBox="0 0 616 554" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                <defs>
                    <filter id="workflowLineGlow" x="-20%" y="-80%" width="140%" height="260%" color-interpolation-filters="sRGB">
                        <feGaussianBlur stdDeviation="1.35" result="blur" />
                        <feMerge>
                            <feMergeNode in="blur" />
                            <feMergeNode in="SourceGraphic" />
                        </feMerge>
                    </filter>
                    <filter id="workflowDotGlow" x="-160%" y="-160%" width="420%" height="420%" color-interpolation-filters="sRGB">
                        <feGaussianBlur stdDeviation="1.5" result="blur" />
                        <feMerge>
                            <feMergeNode in="blur" />
                            <feMergeNode in="SourceGraphic" />
                        </feMerge>
                    </filter>
                    <marker id="workflowArrowSummary" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="workflow-arrowhead workflow-arrowhead--summary" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                    <marker id="workflowArrowData" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="workflow-arrowhead workflow-arrowhead--data" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                    <marker id="workflowArrowCharts" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="workflow-arrowhead workflow-arrowhead--charts" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                    <marker id="workflowArrowInsights" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="workflow-arrowhead workflow-arrowhead--insights" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                </defs>

                <path class="workflow-line workflow-line--summary" id="workflowPathSummary" d="M242 188 C283 188 306 148 356 147" marker-end="url(#workflowArrowSummary)" />
                <path class="workflow-line workflow-line--data" id="workflowPathData" d="M242 258 C282 258 309 256 356 256" marker-end="url(#workflowArrowData)" />
                <path class="workflow-line workflow-line--charts" id="workflowPathCharts" d="M242 326 C284 326 306 363 356 364" marker-end="url(#workflowArrowCharts)" />
                <path class="workflow-line workflow-line--insights" id="workflowPathInsights" d="M242 392 C282 392 304 470 356 472" marker-end="url(#workflowArrowInsights)" />

                <g class="workflow-source-dots" filter="url(#workflowDotGlow)">
                    <circle class="workflow-source-dot workflow-source-dot--summary" cx="242" cy="188" r="3" />
                    <circle class="workflow-source-dot workflow-source-dot--data" cx="242" cy="258" r="3" />
                    <circle class="workflow-source-dot workflow-source-dot--charts" cx="242" cy="326" r="3" />
                    <circle class="workflow-source-dot workflow-source-dot--insights" cx="242" cy="392" r="3" />
                </g>

                <g class="workflow-particles">
                    <circle r="2" class="workflow-particle workflow-particle--summary" filter="url(#workflowDotGlow)">
                        <animateMotion dur="5.6s" repeatCount="indefinite" begin="0s">
                            <mpath href="#workflowPathSummary" />
                        </animateMotion>
                    </circle>
                    <circle r="2" class="workflow-particle workflow-particle--data" filter="url(#workflowDotGlow)">
                        <animateMotion dur="5.9s" repeatCount="indefinite" begin=".4s">
                            <mpath href="#workflowPathData" />
                        </animateMotion>
                    </circle>
                    <circle r="2" class="workflow-particle workflow-particle--charts" filter="url(#workflowDotGlow)">
                        <animateMotion dur="6.2s" repeatCount="indefinite" begin=".8s">
                            <mpath href="#workflowPathCharts" />
                        </animateMotion>
                    </circle>
                    <circle r="2" class="workflow-particle workflow-particle--insights" filter="url(#workflowDotGlow)">
                        <animateMotion dur="6.5s" repeatCount="indefinite" begin="1.2s">
                            <mpath href="#workflowPathInsights" />
                        </animateMotion>
                    </circle>
                </g>
            </svg>

            <article class="workflow-document-card" aria-label="Uploaded PDF document">
                <div class="workflow-document-header">
                    <div class="workflow-pdf-mark" aria-hidden="true">
                        <span>PDF</span>
                    </div>
                    <span class="workflow-status">AI reading</span>
                </div>

                <div class="workflow-document-body">
                    <div class="workflow-scan" aria-hidden="true"></div>
                    <span class="workflow-doc-line workflow-doc-line--wide"></span>
                    <span class="workflow-doc-line"></span>
                    <span class="workflow-doc-line workflow-doc-line--short"></span>
                    <div class="workflow-doc-chart" aria-hidden="true">
                        <svg viewBox="0 0 180 72">
                            <path class="workflow-chart-grid" d="M8 58H172M8 42H172M8 26H172M8 10H172" />
                            <path class="workflow-chart-fill" d="M10 58 C28 50 34 39 52 42 C70 45 76 26 94 28 C114 30 120 16 136 18 C152 20 158 12 170 10 V64 H10Z" />
                            <path class="workflow-chart-line" d="M10 58 C28 50 34 39 52 42 C70 45 76 26 94 28 C114 30 120 16 136 18 C152 20 158 12 170 10" />
                        </svg>
                    </div>
                </div>

                <div class="workflow-file-meta">
                    <strong>Annual_Report_Q2.pdf</strong>
                    <span>2.4 MB</span>
                </div>
                <p>42 pages scanned for summaries, tables, charts, and risk signals.</p>
                <div class="workflow-document-progress" aria-hidden="true"><span></span></div>
            </article>

            <div class="workflow-output-stack">
                <article class="workflow-output-card workflow-output-card--summary">
                    <div class="workflow-output-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M5 6h14M5 12h11M5 18h7" />
                        </svg>
                    </div>
                    <div class="workflow-output-copy">
                        <span>AI Summary</span>
                        <strong>Revenue up 18%, margin stable</strong>
                        <div class="workflow-output-loader" aria-hidden="true"><i></i></div>
                    </div>
                    <div class="workflow-output-meter" aria-hidden="true"><span></span></div>
                </article>

                <article class="workflow-output-card workflow-output-card--data">
                    <div class="workflow-output-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="4" y="4" width="16" height="16" rx="3" />
                            <path d="M4 10h16M10 4v16" />
                        </svg>
                    </div>
                    <div class="workflow-output-copy">
                        <span>Extracted Data</span>
                        <strong>128 rows exported to XLSX</strong>
                        <div class="workflow-output-loader" aria-hidden="true"><i></i></div>
                    </div>
                    <div class="workflow-output-meter" aria-hidden="true"><span></span></div>
                </article>

                <article class="workflow-output-card workflow-output-card--charts">
                    <div class="workflow-mini-chart" aria-hidden="true">
                        <svg viewBox="0 0 120 52">
                            <path class="workflow-mini-grid" d="M4 42H116M4 26H116M4 10H116" />
                            <path class="workflow-mini-fill" d="M8 38 C24 34 30 24 44 28 C58 32 64 16 78 18 C94 20 100 8 114 10 V48 H8Z" />
                            <path class="workflow-mini-line" d="M8 38 C24 34 30 24 44 28 C58 32 64 16 78 18 C94 20 100 8 114 10" />
                        </svg>
                    </div>
                    <div class="workflow-output-copy">
                        <span>Key Charts</span>
                        <strong>3 trends detected</strong>
                        <div class="workflow-output-loader" aria-hidden="true"><i></i></div>
                    </div>
                    <div class="workflow-output-meter" aria-hidden="true"><span></span></div>
                </article>

                <article class="workflow-output-card workflow-output-card--insights">
                    <div class="workflow-output-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 3c.5 1.8 1.7 3 3.5 3.5C13.7 7 12.5 8.2 12 10c-.5-1.8-1.7-3-3.5-3.5C10.3 6 11.5 4.8 12 3Z" />
                            <path d="M18 13c.35 1.2 1.1 2 2.3 2.3C19.1 15.6 18.35 16.4 18 17.6c-.35-1.2-1.1-2-2.3-2.3C16.9 15 17.65 14.2 18 13Z" />
                            <path d="M7 12c.3 1 .95 1.65 1.95 1.95C7.95 14.25 7.3 14.9 7 15.9c-.3-1-.95-1.65-1.95-1.95C6.05 13.65 6.7 13 7 12Z" />
                        </svg>
                    </div>
                    <div class="workflow-output-copy">
                        <span>Important Insights</span>
                        <strong>5 review flags prioritized</strong>
                        <div class="workflow-output-loader" aria-hidden="true"><i></i></div>
                    </div>
                    <div class="workflow-output-meter" aria-hidden="true"><span></span></div>
                </article>
            </div>
        </div>
    </div>
</section>

<style>
    .ai-workflow-hero {
        width: 100%;
        min-width: 0;
        --summary: #8b5cf6;
        --data: #2563eb;
        --charts: #14b8a6;
        --insights: #f97316;
        --ink: #111827;
        --muted: #64748b;
        --line: rgba(148, 163, 184, 0.2);
    }

    .ai-workflow-shell {
        position: relative;
        width: min(616px, 100%);
        aspect-ratio: 616 / 554;
        min-height: 0;
        margin-inline: auto;
        overflow: hidden;
        border: 1px solid rgba(226, 232, 240, 0.72);
        border-radius: 24px;
        background:
            radial-gradient(circle at 74% 16%, rgba(6, 182, 212, 0.09), transparent 34%),
            radial-gradient(circle at 32% 46%, rgba(139, 92, 246, 0.11), transparent 34%),
            linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(246, 249, 255, 0.88) 54%, rgba(248, 251, 255, 0.96));
        box-shadow: 0 28px 74px rgba(15, 23, 42, 0.12);
        isolation: isolate;
    }

    .ai-workflow-shell::before {
        content: "";
        position: absolute;
        inset: 74px 30px 28px;
        background-image: radial-gradient(circle, rgba(99, 102, 241, 0.18) 1px, transparent 1.2px);
        background-size: 18px 18px;
        mask-image: linear-gradient(180deg, transparent, #000 18%, #000 88%, transparent);
        pointer-events: none;
        z-index: -1;
    }

    .ai-workflow-steps {
        position: absolute;
        top: 14px;
        left: 22px;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0;
        width: calc(100% - 44px);
        max-width: none;
        min-height: 42px;
        margin: 0;
        padding: 5px 18px;
        border: 1px solid rgba(226, 232, 240, 0.86);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
    }

    .ai-workflow-steps span {
        position: relative;
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        border-radius: 999px;
        color: #475569;
        font-size: 0.73rem;
        font-weight: 850;
        letter-spacing: 0.01em;
        padding: 0.32rem 0.46rem;
        white-space: nowrap;
    }

    .ai-workflow-steps span:not(:last-child) {
        margin-right: 28px;
    }

    .ai-workflow-steps span:not(:last-child)::after {
        content: "\2192";
        position: absolute;
        top: 50%;
        right: -20px;
        transform: translateY(-52%);
        color: #64748b;
        font-size: 0.74rem;
        font-weight: 900;
        opacity: 0.74;
    }

    .ai-workflow-steps .is-active {
        border: 1px solid rgba(139, 92, 246, 0.16);
        background: rgba(238, 242, 255, 0.9);
        color: #4f46e5;
        box-shadow: 0 0 0 1px rgba(139, 92, 246, 0.08), 0 10px 28px rgba(139, 92, 246, 0.16);
        animation: workflowStepPulse 3.2s ease-in-out infinite;
    }

    .ai-workflow-stage {
        position: absolute;
        inset: 0;
        z-index: 2;
        width: 100%;
        height: 100%;
        aspect-ratio: auto;
        min-height: 0;
        margin-top: 0;
    }

    .ai-workflow-connectors {
        position: absolute;
        inset: 0;
        width: 100% !important;
        height: 100% !important;
        overflow: visible;
        filter: none !important;
        pointer-events: none;
        z-index: 4;
    }

    .workflow-line {
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 2;
        stroke-dasharray: 3.5 8;
        stroke-dashoffset: 0;
        opacity: 0.84;
        filter: url(#workflowLineGlow);
        animation: workflowLineTravel 4.8s linear infinite;
    }

    .workflow-arrowhead--summary,
    .workflow-line--summary { stroke: var(--summary); }
    .workflow-arrowhead--data,
    .workflow-line--data { stroke: var(--data); animation-delay: -0.6s; }
    .workflow-arrowhead--charts,
    .workflow-line--charts { stroke: var(--charts); animation-delay: -1.2s; }
    .workflow-arrowhead--insights,
    .workflow-line--insights { stroke: var(--insights); animation-delay: -1.8s; }

    .workflow-arrowhead {
        stroke: none;
    }

    .workflow-arrowhead--summary { fill: var(--summary); }
    .workflow-arrowhead--data { fill: var(--data); }
    .workflow-arrowhead--charts { fill: var(--charts); }
    .workflow-arrowhead--insights { fill: var(--insights); }

    .workflow-particle--summary { fill: var(--summary); }
    .workflow-particle--data { fill: var(--data); }
    .workflow-particle--charts { fill: var(--charts); }
    .workflow-particle--insights { fill: var(--insights); }

    .workflow-source-dot--summary { fill: var(--summary); }
    .workflow-source-dot--data { fill: var(--data); }
    .workflow-source-dot--charts { fill: var(--charts); }
    .workflow-source-dot--insights { fill: var(--insights); }

    .workflow-source-dot {
        opacity: 0.92;
    }

    .workflow-particle {
        opacity: 0.42;
    }

    .workflow-particles {
        display: none;
    }

    .workflow-document-card,
    .workflow-output-card {
        backdrop-filter: blur(20px) saturate(135%);
        -webkit-backdrop-filter: blur(20px) saturate(135%);
    }

    .workflow-document-card {
        position: absolute;
        left: 4.2%;
        top: 27.1%;
        z-index: 3;
        width: 35%;
        height: 61.2%;
        min-width: 0;
        border: 1px solid rgba(226, 232, 240, 0.82);
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 22px 52px rgba(15, 23, 42, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.96);
        padding: 26px 18px 24px;
        animation: workflowFloat 7.2s ease-in-out infinite;
        will-change: transform;
    }

    .workflow-document-card::before {
        content: "";
        position: absolute;
        inset: 1px;
        border-radius: 23px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.58), transparent 46%);
        pointer-events: none;
    }

    .workflow-document-card > * {
        position: relative;
    }

    .workflow-document-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 32px;
    }

    .workflow-pdf-mark {
        position: relative;
        display: grid;
        place-items: center;
        width: 24px;
        height: 28px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.48);
        border-radius: 6px;
        background:
            linear-gradient(145deg, rgba(255, 255, 255, 0.2), transparent 31%),
            linear-gradient(135deg, #ff6f61 0%, #ef3f3f 44%, #c91f1f 100%);
        box-shadow:
            0 8px 16px rgba(220, 38, 38, 0.22),
            inset 0 1px 0 rgba(255, 255, 255, 0.34);
        color: #ffffff;
    }

    .workflow-pdf-mark::before {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 8px;
        height: 8px;
        border-bottom-left-radius: 3px;
        background: rgba(255, 255, 255, 0.72);
        clip-path: polygon(0 0, 100% 0, 100% 100%);
    }

    .workflow-pdf-mark span {
        margin-top: 4px;
        color: #ffffff;
        font-size: 0.38rem;
        font-weight: 950;
        letter-spacing: 0;
        text-shadow: 0 1px 2px rgba(127, 29, 29, 0.35);
    }

    .workflow-status {
        display: inline-flex;
        align-items: center;
        min-height: 25px;
        border: 1px solid rgba(16, 185, 129, 0.14);
        border-radius: 999px;
        background: rgba(236, 253, 245, 0.86);
        color: #047857;
        font-size: 0.66rem;
        font-weight: 850;
        padding: 0.22rem 0.5rem;
        white-space: nowrap;
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.14);
        animation: workflowStatusPulse 3.6s ease-in-out infinite;
    }

    .workflow-document-body {
        position: relative;
        min-height: 150px;
        overflow: hidden;
        border: 0;
        border-radius: 0;
        background: transparent;
        box-shadow: none;
        padding: 0;
    }

    .workflow-scan {
        position: absolute;
        left: 0;
        right: 0;
        top: -24%;
        height: 48px;
        background:
            linear-gradient(180deg, transparent, rgba(6, 182, 212, 0.08), transparent),
            linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.52), transparent);
        border-top: 1px solid rgba(6, 182, 212, 0.16);
        border-bottom: 1px solid rgba(37, 99, 235, 0.1);
        box-shadow: 0 0 16px rgba(6, 182, 212, 0.08);
        animation: workflowScan 4.2s ease-in-out infinite;
    }

    .workflow-doc-line {
        display: block;
        width: 76%;
        height: 7px;
        margin-left: 0;
        margin-bottom: 10px;
        border-radius: 999px;
        background: #e2e8f0;
    }

    .workflow-doc-line--wide {
        width: 87%;
        background: #c7d2fe;
    }

    .workflow-doc-line--short {
        width: 57%;
    }

    .workflow-doc-chart {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 8px;
        height: 81px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.9), rgba(240, 253, 250, 0.82));
        padding: 12px;
    }

    .workflow-doc-chart svg,
    .workflow-mini-chart svg {
        width: 100% !important;
        height: 100% !important;
        overflow: visible;
        filter: none !important;
    }

    .workflow-chart-grid,
    .workflow-chart-line,
    .workflow-chart-fill,
    .workflow-mini-grid,
    .workflow-mini-line,
    .workflow-mini-fill {
        fill: none;
        stroke-linecap: round;
    }

    .workflow-chart-grid,
    .workflow-mini-grid {
        stroke: rgba(148, 163, 184, 0.28);
        stroke-width: 1;
    }

    .workflow-chart-fill,
    .workflow-mini-fill {
        fill: rgba(37, 99, 235, 0.09);
        stroke: none;
    }

    .workflow-chart-line {
        stroke: var(--data);
        stroke-width: 3.2;
        stroke-dasharray: 245;
        stroke-dashoffset: 0;
        animation: workflowChartPulse 4.6s ease-in-out infinite;
    }

    .workflow-file-meta {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: baseline;
        gap: 4px;
        margin-top: 7px;
    }

    .workflow-file-meta strong {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        overflow-wrap: normal;
        color: var(--ink);
        font-size: 0.66rem;
        line-height: 1.25;
    }

    .workflow-file-meta span {
        color: var(--muted);
        font-size: 0.54rem;
        font-weight: 850;
        white-space: nowrap;
    }

    .workflow-document-card p {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 0.68rem;
        line-height: 1.55;
    }

    .workflow-document-progress {
        height: 5px;
        overflow: hidden;
        margin-top: 12px;
        border-radius: 999px;
        background: rgba(226, 232, 240, 0.88);
    }

    .workflow-document-progress span {
        display: block;
        width: 68%;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--summary), var(--data), var(--charts));
        box-shadow: 0 0 10px rgba(37, 99, 235, 0.14);
        transform-origin: left center;
        animation: workflowProgress 4.4s ease-in-out infinite;
    }

    .workflow-output-stack {
        position: absolute;
        top: 18%;
        right: 3.1%;
        z-index: 3;
        display: grid;
        grid-template-rows: none;
        align-content: start;
        gap: 14px;
        width: 40.3%;
        height: auto;
    }

    .workflow-output-card {
        --accent: var(--summary);
        position: relative;
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr) 32px;
        align-items: center;
        gap: 14px;
        min-width: 0;
        min-height: 94px;
        height: 94px;
        overflow: visible;
        border: 1px solid rgba(226, 232, 240, 0.72);
        border-radius: 17px;
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.96);
        padding: 16px 14px;
        transform: none;
        opacity: 1;
        transition: transform 360ms ease, box-shadow 360ms ease, border-color 360ms ease;
    }

    .workflow-output-card:hover {
        border-color: color-mix(in srgb, var(--accent) 24%, rgba(226, 232, 240, 0.72));
        box-shadow: 0 20px 44px rgba(15, 23, 42, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.96);
    }

    .workflow-output-card--data {
        --accent: var(--data);
        animation-delay: 0.12s;
    }

    .workflow-output-card--charts {
        --accent: var(--charts);
        animation-delay: 0.2s;
    }

    .workflow-output-card--insights {
        --accent: var(--insights);
        animation-delay: 0.28s;
    }

    .workflow-output-icon,
    .workflow-mini-chart {
        display: grid;
        place-items: center;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: color-mix(in srgb, var(--accent) 10%, white);
        color: var(--accent);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

