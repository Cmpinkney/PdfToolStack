@inject AuthenticationStateProvider Auth
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@using Microsoft.AspNetCore.Components.Authorization

@if (IsVisible && _isAuthenticated && !_isPro)
{
    <div class="ad-slot ad-slot-@Size">
        @if (IsAdSenseApproved)
        {
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
                 data-ad-slot="XXXXXXXXXX"
                 data-ad-format="auto"
                 data-full-width-responsive="true">
            </ins>
        }
        else
        {
            <div class="ad-placeholder">
                <span>Advertisement</span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Size { get; set; } = "banner";
    [Parameter] public bool IsVisible { get; set; } = true;

    private bool IsAdSenseApproved = false;
    private bool _isPro = false;
    private bool _isAuthenticated = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;

        _isAuthenticated = user.Identity?.IsAuthenticated == true;

        if (_isAuthenticated)
        {
            var userId = user.FindFirst("sub")?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                var status = await SubService.GetStatusAsync(userId);
                _isPro = status.HasPro;
            }
        }
    }
}