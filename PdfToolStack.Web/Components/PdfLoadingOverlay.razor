@if (IsVisible)
{
    <div class="pdf-loading-overlay">
        <div class="pdf-loading-card">
            <div class="pdf-loading-spinner"></div>
            <p class="pdf-loading-msg">@Message</p>
            @if (!string.IsNullOrEmpty(SubMessage))
            {
                <p class="pdf-loading-sub">@SubMessage</p>
            }
        </div>
    </div>
}

<style>
    .pdf-loading-spinner {
        width: 36px;
        height: 36px;
        border: 3.5px solid rgba(34, 80, 244, 0.15);
        border-top-color: var(--primary, #2250F4);
        border-radius: 50%;
        animation: pts-spin 0.75s linear infinite;
        margin: 0 auto 1.25rem;
        will-change: transform;
    }

    @@keyframes pts-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Message { get; set; } = "Loading PDF...";
    [Parameter] public string? SubMessage { get; set; }
}