@if (ShowAds)
{
    <div class="ad-placeholder ad-placeholder--@Variant @Class" role="complementary" aria-label="Advertisement">
        <span>Advertisement</span>
    </div>
}

@code {
    [Parameter] public bool ShowAds { get; set; }
    [Parameter] public string Variant { get; set; } = "banner";
    [Parameter] public string? Class { get; set; }
}
