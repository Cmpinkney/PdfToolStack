@inject NavigationManager Navigation

@if (_metadata is not null)
{
    <HeadContent>
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="PdfToolStack" />
        <meta property="og:title" content="@_metadata.Title" />
        <meta property="og:description" content="@_metadata.Description" />
        <meta property="og:url" content="@_metadata.Url" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content="@_metadata.Title" />
        <meta name="twitter:description" content="@_metadata.Description" />
    </HeadContent>
}

@code {
    private const string SiteUrl = "https://pdftoolstack.com";
    private SeoMetadata? _metadata;

    [Parameter]
    public RouteData? RouteData { get; set; }

    protected override void OnParametersSet()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var route = "/" + relativePath.Split('?', '#')[0].Trim('/');

        if (route == "/")
        {
            _metadata = null;
            return;
        }

        _metadata = MetadataByRoute.TryGetValue(route, out var metadata)
            ? metadata
            : null;
    }

    private static SeoMetadata Metadata(string path, string title, string description) =>
        new(title, description, $"{SiteUrl}{path}");

    private static readonly IReadOnlyDictionary<string, SeoMetadata> MetadataByRoute =
        new Dictionary<string, SeoMetadata>(StringComparer.OrdinalIgnoreCase)
        {
            ["/about"] = Metadata("/about", "About PdfToolStack - Privacy-Minded PDF Tools", "Learn about PdfToolStack and the practical online tools built for compressing, converting, signing, organizing, securing, and reviewing PDFs."),
            ["/contact"] = Metadata("/contact", "Contact PdfToolStack Support", "Contact PdfToolStack for product support, billing questions, privacy requests, security reports, bug details, and feature feedback."),
            ["/security"] = Metadata("/security", "PdfToolStack Security and Privacy", "See how PdfToolStack protects document workflows with encrypted transfers, temporary processing, automatic deletion, and Azure infrastructure."),
            ["/privacy-policy"] = Metadata("/privacy-policy", "PdfToolStack Privacy Policy", "Read the PdfToolStack Privacy Policy covering file processing, temporary deletion, account data, analytics, and support requests."),
            ["/terms-and-conditions"] = Metadata("/terms-and-conditions", "PdfToolStack Terms of Service", "Read the PdfToolStack Terms of Service for acceptable use, document processing, paid features, and support information."),
            ["/cookie-policy"] = Metadata("/cookie-policy", "PdfToolStack Cookie Policy", "Read how PdfToolStack uses essential cookies, preferences, analytics, advertising settings, and browser controls."),
            ["/batch"] = Metadata("/batch", "Batch PDF Processing Online - Process Multiple Files", "Process multiple PDFs at once with PdfToolStack. Batch compress, convert, merge, and organize files for faster document workflows."),
            ["/rotate-pdf"] = Metadata("/rotate-pdf", "Rotate PDF Online Free - Fix Page Orientation", "Rotate one page or every page in a PDF online. Fix sideways scans and download the corrected file quickly."),
            ["/delete-pdf-pages"] = Metadata("/delete-pdf-pages", "Delete PDF Pages Online Free - Remove Pages", "Remove unwanted pages from a PDF online. Pick the pages to delete and download a cleaner document in seconds."),
            ["/extract-pdf-pages"] = Metadata("/extract-pdf-pages", "Extract PDF Pages Online Free - Pick Pages", "Extract selected pages from a PDF into a new file online. Keep only the pages you need without installing software."),
            ["/organize-pdf"] = Metadata("/organize-pdf", "Organize PDF Pages Online - Reorder and Rotate", "Rearrange, rotate, and clean up PDF pages online. Organize documents before sharing, filing, or submitting."),
            ["/crop-pdf"] = Metadata("/crop-pdf", "Crop PDF Online Free - Trim PDF Pages", "Crop PDF pages online to remove margins, white space, and unwanted areas. Auto-crop or adjust pages manually."),
            ["/watermark-pdf"] = Metadata("/watermark-pdf", "Watermark PDF Online Free - Add Text Watermarks", "Add text watermarks to PDF pages online. Mark drafts, confidential files, and shared documents quickly."),
            ["/flatten-pdf"] = Metadata("/flatten-pdf", "Flatten PDF Online Free - Lock Annotations", "Flatten a PDF online to lock form fields, annotations, and edits into the document before sharing or printing."),
            ["/edit-pdf"] = Metadata("/edit-pdf", "Edit PDF Online Free - Add Text and Markup", "Edit PDF files online by adding text, shapes, highlights, and drawings. No install required."),
            ["/pdf-annotator"] = Metadata("/pdf-annotator", "PDF Annotator Online Free - Highlight and Mark Up PDFs", "Annotate PDFs online with highlights, underlines, strikethroughs, and freehand notes for review workflows."),
            ["/fill-pdf-form"] = Metadata("/fill-pdf-form", "Fill PDF Form Online Free - Complete PDF Forms", "Fill out PDF forms online, add the details you need, and download the completed document without installing software."),
            ["/number-pages"] = Metadata("/number-pages", "Add Page Numbers to PDF Online Free", "Add page numbers to a PDF online. Choose position, font, style, and starting number before downloading."),
            ["/pdf-reader"] = Metadata("/pdf-reader", "PDF Reader Online Free - View PDFs in Browser", "Open and read PDF files online in your browser with a fast, simple viewer for review and sharing."),
            ["/lock-pdf"] = Metadata("/lock-pdf", "Lock PDF Online - Password Protect PDF Files", "Password protect PDF files online with secure encryption for contracts, HR files, financial documents, and sensitive sharing."),
            ["/unlock-pdf"] = Metadata("/unlock-pdf", "Unlock PDF Online - Remove PDF Password", "Remove a known PDF password online so you can open, edit, and share your document more easily."),
            ["/redact-pdf"] = Metadata("/redact-pdf", "Redact PDF Online - Remove Sensitive Information", "Permanently redact sensitive information from PDFs online before sharing confidential documents."),
            ["/sign-pdf"] = Metadata("/sign-pdf", "Sign PDF Online Free - Add an Electronic Signature", "Add an electronic signature to a PDF online. Draw your signature, place it on the document, and download."),
            ["/pdf-to-jpg"] = Metadata("/pdf-to-jpg", "PDF to JPG Converter Online Free - PDF Pages to Images", "Convert PDF pages to JPG images online. Export pages as image files quickly without installing software."),
            ["/jpg-to-pdf"] = Metadata("/jpg-to-pdf", "JPG to PDF Converter Online Free - Images to PDF", "Convert JPG images into a PDF online. Combine photos, scans, and images into one shareable document."),
            ["/pdf-to-excel"] = Metadata("/pdf-to-excel", "PDF to Excel Converter Online - Extract Tables", "Convert PDF tables and data into Excel spreadsheets online. Extract structured information from documents faster."),
            ["/excel-to-pdf"] = Metadata("/excel-to-pdf", "Excel to PDF Converter Online - Convert XLSX to PDF", "Convert Excel spreadsheets to PDF online while preserving a clean layout for sharing and printing."),
            ["/ppt-to-pdf"] = Metadata("/ppt-to-pdf", "PPT to PDF Converter Online - PowerPoint to PDF", "Convert PowerPoint presentations to PDF online for easier sharing, printing, and archiving."),
            ["/translate-pdf"] = Metadata("/translate-pdf", "Translate PDF Online - AI PDF Translation", "Translate text-based PDFs online with AI while preserving readable document structure where possible."),
            ["/compare-pdf"] = Metadata("/compare-pdf", "Compare PDF Files Online - Find Document Differences", "Compare two PDF files online to find document differences, contract edits, and changed sections quickly."),
            ["/review-contract"] = Metadata("/review-contract", "AI Contract Reviewer Online - Review Contracts Faster", "Upload a contract for AI-assisted review that can flag risks, dates, obligations, and unusual clauses. Not legal advice."),
            ["/extract-invoice-data"] = Metadata("/extract-invoice-data", "Extract Invoice Data from PDF to Excel Online", "Extract invoice fields, totals, line items, and dates from PDF invoices into Excel using AI-assisted document processing."),
            ["/ai-rewrite"] = Metadata("/ai-rewrite", "AI PDF Rewriter Online - Rewrite PDF Content", "Rewrite, simplify, and improve PDF text with AI for clearer document drafts and faster editing."),
            ["/ai-questions"] = Metadata("/ai-questions", "AI Questions Generator - Create Questions from PDFs", "Generate study questions, quizzes, and review prompts from PDF content with AI."),
            ["/ai-pdf-assist"] = Metadata("/ai-pdf-assist", "AI PDF Tools - Summarize, Chat, Extract, Translate", "Use AI tools for PDFs to summarize, chat with documents, rewrite text, translate content, and extract data."),
            ["/converter"] = Metadata("/converter", "PDF Converter Online - Convert To and From PDF", "Convert documents, images, spreadsheets, and presentations to and from PDF with fast online converters."),
            ["/ai-pdf-tools"] = Metadata("/ai-pdf-tools", "AI PDF Tools Online - Summarize, Chat, Translate PDFs", "Explore AI PDF tools for summarizing, chatting with, translating, rewriting, and extracting information from documents."),
            ["/pdf-security-tools"] = Metadata("/pdf-security-tools", "PDF Security Tools - Lock, Unlock, Redact PDFs", "Secure PDFs online with tools to lock, unlock, redact, and prepare sensitive documents for sharing."),
            ["/pdf-organizer-tools"] = Metadata("/pdf-organizer-tools", "PDF Organizer Tools - Merge, Split, Reorder, Rotate PDFs", "Organize PDF pages online with merge, split, rotate, delete, extract, and reorder tools."),
            ["/business-pdf-tools"] = Metadata("/business-pdf-tools", "Business PDF Tools - Contracts, Invoices, Batch Workflows", "Use business PDF tools for contracts, invoices, batch processing, data extraction, signatures, and secure sharing."),
        };

    private sealed record SeoMetadata(string Title, string Description, string Url);
}
