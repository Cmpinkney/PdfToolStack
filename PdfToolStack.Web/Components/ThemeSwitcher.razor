@inject IJSRuntime JS

<button class="theme-toggle"
        @onclick="Toggle"
        aria-label="@(IsDark ? "Switch to light mode" : "Switch to dark mode")"
        aria-pressed="@(IsDark ? "true" : "false")">
    <span class="theme-toggle-icon" aria-hidden="true">@(IsDark ? "☀️" : "🌙")</span>
    <span class="theme-toggle-label">@(IsDark ? "Light" : "Dark")</span>
</button>

@code {
    private bool IsDark = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("getTheme");
            IsDark = theme == "dark";
            StateHasChanged();
        }
    }

    private async Task Toggle()
    {
        IsDark = !IsDark;
        await JS.InvokeVoidAsync("setTheme", IsDark ? "dark" : "light");
        StateHasChanged();
    }
}