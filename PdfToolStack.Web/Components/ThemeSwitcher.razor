@inject IJSRuntime JS

<div class="theme-toggle" @onclick="Toggle" title="@(IsDark ? "Switch to light mode" : "Switch to dark mode")">
    <span class="theme-toggle-icon">@(IsDark ? "☀️" : "🌙")</span>
    <span class="theme-toggle-label">@(IsDark ? "Light" : "Dark")</span>
</div>

@code {
    private bool IsDark = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("getTheme");
            IsDark = theme == "dark";
            StateHasChanged();
        }
    }

    private async Task Toggle()
    {
        IsDark = !IsDark;
        await JS.InvokeVoidAsync("setTheme",
            IsDark ? "dark" : "light");
        StateHasChanged();
    }
}