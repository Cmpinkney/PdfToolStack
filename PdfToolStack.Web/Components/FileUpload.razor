@using PdfToolStack.Web.Services
@inject CloudPickerService CloudPicker
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div id="@_dropZoneId"
     class="upload-container @(IsDragging ? "dragging" : "")"
     @ondragover="HandleDragOver"
     @ondragover:preventDefault="true"
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop"
     @ondrop:preventDefault="true">

    @if (SelectedFile == null)
    {
        <svg class="upload-icon-svg" width="40" height="40" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round"
             style="color:var(--text-muted); margin-bottom:0.75rem;">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14,2 14,8 20,8" />
            <line x1="12" y1="13" x2="12" y2="19" />
            <polyline points="9,16 12,19 15,16" />
        </svg>

        <p style="color:var(--text-secondary); margin-bottom:0.75rem;">
            Drag and drop your file here or
        </p>

        <label class="upload-button">
            Browse File
            <InputFile OnChange="HandleFileSelected"
                       accept="@Accept"
                       style="display:none" />
        </label>

        <p class="upload-hint">@HintText</p>

        <div class="cloud-row">
            <span class="cloud-label">Import from cloud</span>
            <div class="cloud-actions">
                <button type="button"
                        class="cloud-btn"
                        @onclick="HandleDropbox"
                        disabled="@_cloudLoading">
                    <svg class="cloud-icon" viewBox="0 0 24 24">
                        <path d="M7.1 3.2 2 6.5l5.1 3.3 5.1-3.3-5.1-3.3Zm9.8 0-5.1 3.3 5.1 3.3L22 6.5l-5.1-3.3ZM2 13l5.1 3.3 5.1-3.3-5.1-3.3L2 13Zm14.9-3.3L11.8 13l5.1 3.3L22 13l-5.1-3.3ZM12 14.8 7.1 18 12 21.2l4.9-3.2-4.9-3.2Z"
                              fill="#0061FF" />
                    </svg>
                    <span>Dropbox</span>
                </button>

                <button type="button"
                        class="cloud-btn"
                        @onclick="HandleGoogleDrive"
                        disabled="@_cloudLoading">
                    <svg class="cloud-icon" viewBox="0 0 24 24">
                        <path d="M9.6 3.2 3 14.5h4.5l6.5-11.3H9.6Z" fill="#34A853" />
                        <path d="M14.1 3.2h-4.5l6.6 11.3h4.5L14.1 3.2Z" fill="#FBBC04" />
                        <path d="M7.5 14.5 9.8 18.4h10.9L18.4 14.5H7.5Z" fill="#4285F4" />
                    </svg>
                    <span>Google Drive</span>
                </button>

            </div>
        </div>

        @if (_cloudLoading)
        {
            <p class="cloud-status">Importing from cloud...</p>
        }

        @if (!string.IsNullOrEmpty(_cloudError))
        {
            <p class="cloud-error">@_cloudError</p>
        }
    }
    else
    {
        <div class="upload-ready-card">
            <div class="upload-ready-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z" />
                    <polyline points="14 2 14 7 19 7" />
                    <polyline points="9 14 11 16 15 12" />
                </svg>
            </div>
            <div class="upload-ready-copy">
                <span class="upload-ready-state">Ready to process</span>
                <strong>@SelectedFile.Name</strong>
                <div class="upload-ready-meta">
                    <span>@GetFileType(SelectedFile.Name)</span>
                    <span>@FormatFileSize(SelectedFile.Size)</span>
                </div>
                <small>@EffectiveActionSummary</small>
            </div>
        </div>
        <button class="reset-button upload-ready-remove" @onclick="RemoveFile">
            Remove
        </button>
    }

    <TrustSignals />
</div>

<style>
    .cloud-row {
        display: grid;
        gap: .75rem;
        margin-top: 1rem;
        border: 1px solid rgba(148, 163, 184, .2);
        border-radius: 18px;
        background: rgba(248, 250, 252, .9);
        padding: 1rem;
        text-align: center;
    }

    .cloud-label {
        color: #64748b;
        font-size: .72rem;
        font-weight: 950;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .cloud-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .65rem;
    }

    .cloud-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        min-height: 44px;
        border: 1px solid rgba(148, 163, 184, .24);
        border-radius: 14px;
        background: #fff;
        color: #334155;
        cursor: pointer;
        font-size: .86rem;
        font-weight: 900;
        padding: .72rem .9rem;
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

    .cloud-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        border-color: rgba(37, 99, 235, .3);
        box-shadow: 0 12px 24px rgba(37, 99, 235, .1);
    }

    .cloud-btn:disabled {
        cursor: not-allowed;
        opacity: .58;
    }

    .cloud-icon {
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
    }

    .cloud-status,
    .cloud-error {
        margin: 0;
        font-size: .84rem;
        font-weight: 750;
        line-height: 1.45;
    }

    .cloud-status {
        color: #64748b;
    }

    .cloud-error {
        color: #dc2626;
    }

    .upload-ready-card {
        display: flex;
        align-items: center;
        gap: .9rem;
        width: 100%;
        max-width: 520px;
        margin: 0 auto .9rem;
        border: 1px solid rgba(34, 197, 94, .18);
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(240, 253, 244, .9), rgba(239, 246, 255, .9));
        padding: 1rem;
        text-align: left;
    }

    .upload-ready-icon {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        flex: 0 0 auto;
        border-radius: 16px;
        background: #dcfce7;
        color: #15803d;
    }

    .upload-ready-icon svg {
        width: 28px;
        height: 28px;
    }

    .upload-ready-copy {
        min-width: 0;
    }

    .upload-ready-state {
        display: inline-flex;
        width: fit-content;
        margin-bottom: .35rem;
        border-radius: 999px;
        background: #dcfce7;
        color: #166534;
        font-size: .72rem;
        font-weight: 950;
        padding: .28rem .55rem;
    }

    .upload-ready-copy strong {
        display: block;
        overflow-wrap: anywhere;
        color: var(--text, #111827);
        font-size: .98rem;
        font-weight: 900;
        line-height: 1.3;
    }

    .upload-ready-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        margin-top: .45rem;
    }

    .upload-ready-meta span {
        border-radius: 999px;
        background: rgba(255, 255, 255, .78);
        color: #475569;
        font-size: .76rem;
        font-weight: 850;
        padding: .3rem .55rem;
    }

    .upload-ready-copy small {
        display: block;
        margin-top: .45rem;
        color: #64748b;
        font-size: .84rem;
        font-weight: 700;
        line-height: 1.45;
    }

    .upload-ready-remove {
        max-width: 120px;
    }

    .file-ready-header {
        display: flex;
        align-items: flex-start;
        gap: .9rem;
        min-width: 0;
    }

    .file-ready-icon {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        flex: 0 0 auto;
        border-radius: 16px;
        background: #eef2ff;
        color: #2563eb;
        box-shadow: inset 0 0 0 1px rgba(37, 99, 235, .12);
    }

    .file-ready-icon svg {
        width: 28px;
        height: 28px;
    }

    .file-ready-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        margin-top: .45rem;
    }

    .file-ready-meta span {
        border-radius: 999px;
        background: rgba(255, 255, 255, .78);
        color: #475569;
        font-size: .76rem;
        font-weight: 850;
        padding: .3rem .55rem;
    }

    @@media (max-width: 560px) {
        .cloud-actions {
            grid-template-columns: 1fr;
        }
    }
</style>

