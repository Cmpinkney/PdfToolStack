    // ── File input ────────────────────────────────────────────────────────

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        SelectedFile = e.File;

        if (SelectedFile != null)
        {
            await OnFileSelected.InvokeAsync(SelectedFile);
        }
    }

    private void HandleDragOver() => IsDragging = true;
    private void HandleDragLeave() => IsDragging = false;

    private async Task HandleDrop(DragEventArgs e)
    {
        IsDragging = false;
        StateHasChanged();

        try
        {
            var fileData = await JS.InvokeAsync<DroppedFileData>(
                "getDroppedFile", _dropZoneId);

            if (fileData is null || fileData.Bytes is null) return;

            var bytes = Convert.FromBase64String(fileData.Bytes);
            var file = new CloudBrowserFile(fileData.Name, bytes);
            SelectedFile = file;
            await OnFileSelected.InvokeAsync(file);
        }
        catch
        {
            // Silently ignore — user can use Browse File instead
        }
    }

    private async Task RemoveFile()
    {
        SelectedFile = null;
        await OnFileRemoved.InvokeAsync();
    }

    // ── Cloud pickers ─────────────────────────────────────────────────────

    private async Task HandleGoogleDrive()
    {
        await RunCloudPicker("Google Drive", async () =>
        {
            var file = await CloudPicker.OpenGoogleDriveAsync();
            if (file is null) return;
            await DownloadAndSetFile(file.Name, file.Url, file.AccessToken);
        });
    }

    private async Task HandleDropbox()
    {
        await RunCloudPicker("Dropbox", async () =>
        {
            var file = await CloudPicker.OpenDropboxAsync();
            if (file is null) return;
            await DownloadAndSetFile(file.Name, file.Url, file.AccessToken);
        });
    }

