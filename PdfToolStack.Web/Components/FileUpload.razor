    // ── Shared helpers ────────────────────────────────────────────────────

    private async Task RunCloudPicker(string providerName, Func<Task> action)
    {
        _cloudError = string.Empty;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            _cloudError = $"{providerName} error: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task DownloadAndSetFile(
        string name, string url, string? accessToken)
    {
        _cloudLoading = true;
        StateHasChanged();

        try
        {
            var bytes = await CloudPicker.DownloadFileAsync(url, accessToken);

            if (bytes is null || bytes.Length == 0)
            {
                _cloudError = "Could not download the file. Please try again.";
                return;
            }

            var file = new CloudBrowserFile(name, bytes);
            SelectedFile = file;
            await OnFileSelected.InvokeAsync(file);
        }
        finally
        {
            _cloudLoading = false;
            StateHasChanged();
        }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024)
            return $"{Math.Round((double)bytes / 1024, 1)} KB";
        return $"{Math.Round((double)bytes / (1024 * 1024), 1)} MB";
    }

    private static string GetFileType(string fileName)
    {
        var extension = Path.GetExtension(fileName);
        if (string.IsNullOrWhiteSpace(extension))
            return "File";

        return extension.TrimStart('.').ToUpperInvariant();
    }

    private string GetDefaultActionSummary()
    {
        var route = Navigation
            .ToBaseRelativePath(Navigation.Uri)
            .Split('?', '#')[0]
            .Trim('/')
            .ToLowerInvariant();

        return route switch
        {
            "word-to-pdf" or "ppt-to-pdf" or "excel-to-pdf" => "Will convert to PDF",
            "pdf-to-word" => "Will convert to DOCX",
            "pdf-to-excel" => "Will extract tables to Excel",
            "pdf-to-jpg" => "Will convert pages to JPG",
            "compress-pdf" => "Will compress this PDF",
            "split-pdf" => "Will split selected pages",
            "merge-pdf" => "Will add to the merge queue",
            "delete-pdf-pages" => "Will remove selected pages",
            "extract-pdf-pages" => "Will extract selected pages",
            "rotate-pdf" => "Will apply rotation settings",
            "watermark-pdf" => "Will add a watermark",
            "lock-pdf" => "Will lock this PDF with password protection",
            "protect-pdf" => "Will add password protection",
            "unlock-pdf" => "Will remove supported protections",
            "flatten-pdf" => "Will flatten forms and annotations",
            "crop-pdf" => "Will crop selected pages",
            "edit-pdf" => "Will open in the PDF editor",
            "pdf-ocr" => "Will make this PDF searchable",
            "translate-pdf" => "Will translate this PDF",
            "chat-with-pdf" => "Ready to chat with this PDF",
            "ai-summarizer" => "Will summarize this document",
            "ai-questions" => "Ready for document questions",
            "ai-rewrite" => "Will rewrite selected content",
            "review-contract" => "Will review this contract",
            "extract-invoice-data" => "Will extract invoice data",
            _ => "Ready for next step"
        };
    }

    // ── Private types ─────────────────────────────────────────────────────

    //private sealed record OneDriveFileSelection(string Name, string Url, long Size);

    /// <summary>
    /// Adapts downloaded cloud file bytes to IBrowserFile so existing
    /// tool pages receive the same type regardless of upload source.
    /// </summary>
    public sealed class CloudBrowserFile : IBrowserFile
    {
        private readonly byte[] _bytes;

        public CloudBrowserFile(string name, byte[] bytes)
        {
            Name = name;
            Size = bytes.Length;
            _bytes = bytes;
            LastModified = DateTimeOffset.UtcNow;
            ContentType = "application/pdf";
        }

        public string Name { get; }
        public DateTimeOffset LastModified { get; }
        public long Size { get; }
        public string ContentType { get; }

        public Stream OpenReadStream(
            long maxAllowedSize = 512000,
            CancellationToken cancellationToken = default)
            => new MemoryStream(_bytes);
    }
    private sealed record DroppedFileData(string Name, string Bytes);
}
