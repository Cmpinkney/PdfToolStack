@using PdfToolStack.Web.Services
@inject CloudPickerService CloudPicker
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div id="@_dropZoneId"
     class="upload-container @(IsDragging ? "dragging" : "")"
     @ondragover="HandleDragOver"
     @ondragover:preventDefault="true"
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop"
     @ondrop:preventDefault="true">

    @if (SelectedFile == null)
    {
        <svg class="upload-icon-svg" width="40" height="40" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round"
             style="color:var(--text-muted); margin-bottom:0.75rem;">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14,2 14,8 20,8" />
            <line x1="12" y1="13" x2="12" y2="19" />
            <polyline points="9,16 12,19 15,16" />
        </svg>

        <p style="color:var(--text-secondary); margin-bottom:0.75rem;">
            Drag and drop your file here or
        </p>

        <label class="upload-button">
            Browse File
            <InputFile OnChange="HandleFileSelected"
                       accept="@Accept"
                       style="display:none" />
        </label>

        <p class="upload-hint">@HintText</p>

        <!-- Cloud Storage Pickers -->
        <div class="cloud-picker-row">
            <span class="cloud-picker-label">Or import from</span>
            <div class="cloud-picker-buttons">
                <button class="cloud-picker-btn"
                        @onclick="HandleGoogleDrive"
                        disabled="@_cloudLoading">
                    <svg class="cloud-icon" viewBox="0 0 24 24">
                        <path d="M9.6 3.2 3 14.5h4.5l6.5-11.3H9.6Z" fill="#34A853" />
                        <path d="M14.1 3.2h-4.5l6.6 11.3h4.5L14.1 3.2Z" fill="#FBBC04" />
                        <path d="M7.5 14.5 9.8 18.4h10.9L18.4 14.5H7.5Z" fill="#4285F4" />
                    </svg>
                    <span>Google Drive</span>
                </button>

                <button class="cloud-picker-btn"
                        @onclick="HandleDropbox"
                        disabled="@_cloudLoading">
                    <svg class="cloud-icon" viewBox="0 0 24 24">
                        <path d="M7.1 3.2 2 6.5l5.1 3.3 5.1-3.3-5.1-3.3Zm9.8 0-5.1 3.3 5.1 3.3L22 6.5l-5.1-3.3ZM2 13l5.1 3.3 5.1-3.3-5.1-3.3L2 13Zm14.9-3.3L11.8 13l5.1 3.3L22 13l-5.1-3.3ZM12 14.8 7.1 18 12 21.2l4.9-3.2-4.9-3.2Z"
                              fill="#0061FF" />
                    </svg>
                    <span>Dropbox</span>
                </button>

               @*  <button class="cloud-picker-btn"
                        @onclick="HandleOneDrive"
                        disabled="@_cloudLoading"
                        title="Import from OneDrive">
                    <svg width="22" height="22" viewBox="0 0 24 24">
                        <path d="M20.7 11.4c-.1-.6-.3-1.1-.6-1.6A5.6 5.6 0 0 0 14.7 7a5.5 5.5 0 0 0-4.6 2.5 3.3 3.3 0 0 0-1.4-.3A3.3 3.3 0 0 0 5.4 12a3.3 3.3 0 0 0 .1.7A4 4 0 0 0 4 16a4 4 0 0 0 4 4h12a4 4 0 0 0 .7-7.9z" fill="#0364B8" />
                    </svg>
                    OneDrive
                </button> *@

            </div>
        </div>

        @if (_cloudLoading)
        {
            <p style="font-size:0.85rem; color:var(--text-muted); margin-top:0.75rem;">
                ⏳ Downloading file from cloud...
            </p>
        }

        @if (!string.IsNullOrEmpty(_cloudError))
        {
            <p style="font-size:0.85rem; color:var(--danger); margin-top:0.75rem;">
                @_cloudError
            </p>
        }
    }
    else
    {
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
             stroke="var(--success)" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round"
             style="margin-bottom:0.5rem;">
            <polyline points="20,6 9,17 4,12" />
        </svg>
        <p style="font-size:0.95rem; font-weight:600; color:var(--text); margin:0.5rem 0 0.25rem;">
            @SelectedFile.Name
        </p>
        <p style="font-size:0.85rem; color:var(--text-muted); margin-bottom:0.75rem;">
            @FormatFileSize(SelectedFile.Size)
        </p>
        <button class="reset-button" style="max-width:120px;" @onclick="RemoveFile">
            Remove
        </button>
    }
</div>

@code {
    [Parameter] public EventCallback<IBrowserFile> OnFileSelected { get; set; }
    [Parameter] public EventCallback OnFileRemoved { get; set; }
    [Parameter] public string Accept { get; set; } = ".pdf";
    [Parameter] public string HintText { get; set; } = "Up to 25MB free · 500MB with Pro";

    private IBrowserFile? SelectedFile;
    private bool IsDragging;
    private bool _cloudLoading;
    //private bool _handledOneDriveCallback;
    private string _cloudError = string.Empty;
    private readonly string _dropZoneId =
    $"dropzone-{Guid.NewGuid():N}";

