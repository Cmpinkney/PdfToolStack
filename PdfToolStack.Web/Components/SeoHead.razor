@using PdfToolStack.Domain.Configuration
@inject IProductContext Product

<PageTitle>@Title</PageTitle>

<HeadContent>
    @if (NoIndex)
    {
        <meta name="robots" content="noindex,follow" />
    }
    <meta name="description" content="@Description" />
    <link rel="canonical" href="@ResolvedCanonicalUrl" />
    <meta property="og:type" content="@ResolvedType" />
    <meta property="og:site_name" content="@Product.SiteName" />
    <meta property="og:title" content="@Title" />
    <meta property="og:description" content="@Description" />
    <meta property="og:url" content="@ResolvedCanonicalUrl" />
    <meta name="twitter:card" content="@ResolvedTwitterCard" />
    <meta name="twitter:title" content="@Title" />
    <meta name="twitter:description" content="@Description" />
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <meta property="og:image" content="@ResolvedImageUrl" />
        <meta name="twitter:image" content="@ResolvedImageUrl" />
    }
</HeadContent>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public string CanonicalPath { get; set; } = "/";

    [Parameter]
    public string? CanonicalUrl { get; set; }

    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public string? Type { get; set; }

    [Parameter]
    public string? TwitterCard { get; set; }

    [Parameter]
    public bool NoIndex { get; set; }

    private string ResolvedCanonicalUrl =>
        !string.IsNullOrWhiteSpace(CanonicalUrl)
            ? CanonicalUrl
            : Product.ResolveUrl(NormalizePath(CanonicalPath));

    private string? ResolvedImageUrl =>
        string.IsNullOrWhiteSpace(ImageUrl)
            ? null
            : ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                ? ImageUrl
                : Product.ResolveUrl(NormalizePath(ImageUrl));

    private string ResolvedType =>
        string.IsNullOrWhiteSpace(Type)
            ? Product.DefaultSeoType
            : Type;

    private string ResolvedTwitterCard =>
        string.IsNullOrWhiteSpace(TwitterCard)
            ? Product.DefaultTwitterCard
            : TwitterCard;

    private static string NormalizePath(string path)
    {
        if (string.IsNullOrWhiteSpace(path) || path == "/")
        {
            return "/";
        }

        return path.StartsWith('/') ? path : $"/{path}";
    }
}
