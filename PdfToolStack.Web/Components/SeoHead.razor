<PageTitle>@Title</PageTitle>

<HeadContent>
    @if (NoIndex)
    {
        <meta name="robots" content="noindex,follow" />
    }
    <meta name="description" content="@Description" />
    <link rel="canonical" href="@ResolvedCanonicalUrl" />
    <meta property="og:type" content="@Type" />
    <meta property="og:site_name" content="PdfToolStack" />
    <meta property="og:title" content="@Title" />
    <meta property="og:description" content="@Description" />
    <meta property="og:url" content="@ResolvedCanonicalUrl" />
    <meta name="twitter:card" content="@TwitterCard" />
    <meta name="twitter:title" content="@Title" />
    <meta name="twitter:description" content="@Description" />
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <meta property="og:image" content="@ResolvedImageUrl" />
        <meta name="twitter:image" content="@ResolvedImageUrl" />
    }
</HeadContent>

@code {
    private const string SiteUrl = "https://pdftoolstack.com";

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public string CanonicalPath { get; set; } = "/";

    [Parameter]
    public string? CanonicalUrl { get; set; }

    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public string Type { get; set; } = "website";

    [Parameter]
    public string TwitterCard { get; set; } = "summary";

    [Parameter]
    public bool NoIndex { get; set; }

    private string ResolvedCanonicalUrl =>
        !string.IsNullOrWhiteSpace(CanonicalUrl)
            ? CanonicalUrl
            : $"{SiteUrl}{NormalizePath(CanonicalPath)}";

    private string? ResolvedImageUrl =>
        string.IsNullOrWhiteSpace(ImageUrl)
            ? null
            : ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                ? ImageUrl
                : $"{SiteUrl}{NormalizePath(ImageUrl)}";

    private static string NormalizePath(string path)
    {
        if (string.IsNullOrWhiteSpace(path) || path == "/")
        {
            return "/";
        }

        return path.StartsWith('/') ? path : $"/{path}";
    }
}
