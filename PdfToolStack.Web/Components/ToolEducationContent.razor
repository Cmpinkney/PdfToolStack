@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject NavigationManager Navigation

@if (_content is not null)
{
    <section class="tool-education-band" aria-labelledby="tool-education-title">
        <div class="tool-education-container">
            <div class="tool-education-header">
                <span class="tool-education-eyebrow">@_content.Eyebrow</span>
                <h2 id="tool-education-title">@_content.Title</h2>
                <p>@_content.Intro</p>
            </div>

            <div class="tool-education-grid">
                <article class="tool-education-card">
                    <h3>Common use cases</h3>
                    <ul>
                        @foreach (var item in _content.UseCases)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </article>

                <article class="tool-education-card">
                    <h3>How to use this tool</h3>
                    <ol>
                        @foreach (var step in _content.Steps)
                        {
                            <li>@step</li>
                        }
                    </ol>
                </article>

                <article class="tool-education-card">
                    <h3>Example scenarios</h3>
                    <ul>
                        @foreach (var scenario in _content.Scenarios)
                        {
                            <li>@scenario</li>
                        }
                    </ul>
                </article>

                <article class="tool-education-card tool-education-card--security">
                    <h3>Security and privacy</h3>
                    <p>@_content.SecurityNote</p>
                    <p>
                        Review the <a href="/privacy-policy">Privacy Policy</a>,
                        <a href="/security">Security page</a>, and
                        <a href="/cookie-policy">Cookie Policy</a> for more details.
                    </p>
                </article>
            </div>

            <div class="tool-education-related" aria-label="Related PdfToolStack pages">
                <span>Related tools and guides</span>
                <div>
                    @foreach (var link in _content.RelatedLinks)
                    {
                        <a href="@link.Url">@link.Label</a>
                    }
                </div>
            </div>

            <div class="tool-education-faqs">
                <h3>@_content.FaqTitle</h3>
                <div class="tool-education-faq-grid">
                    @foreach (var faq in _content.Faqs)
                    {
                        <details class="tool-education-faq">
                            <summary>@faq.Question</summary>
                            <p>@faq.Answer</p>
                        </details>
                    }
                </div>
            </div>
        </div>
    </section>
}

@code {
    private ToolContent? _content;

    protected override void OnInitialized()
    {
        SetContentForCurrentRoute();
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SetContentForCurrentRoute();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SetContentForCurrentRoute()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var route = "/" + relativePath.Split('?', '#')[0].Trim('/');

        if (route == "/")
        {
            _content = null;
            return;
        }

        if (RouteAliases.TryGetValue(route, out var canonicalRoute))
        {
            route = canonicalRoute;
        }

        _content = ToolContentByRoute.TryGetValue(route, out var content)
            ? content
            : null;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private static ToolContent Tool(
        string eyebrow,
        string title,
        string intro,
        string[] useCases,
        string[] steps,
        string[] scenarios,
        string securityNote,
        Link[] relatedLinks,
        Faq[] faqs,
        string faqTitle = "Frequently asked questions") =>
        new(eyebrow, title, intro, useCases, steps, scenarios, securityNote, relatedLinks, faqs, faqTitle);

