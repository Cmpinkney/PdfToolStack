@inject PaymentService PaymentService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using PdfToolStack.Web.Services

<div class="upgrade-banner">

    @if (PaymentService.IsTestModeEnabled)
    {
        <div class="test-mode-badge">Test Mode</div>
    }

    <div class="upgrade-icon">🚀</div>

    <div class="upgrade-content">
        <h3>@Title</h3>
        <p>
            @if (PaymentService.IsTestModeEnabled)
            {
                <span>
                    Your file is
                    <strong>@PaymentService.FormatFileSize(FileSizeBytes)</strong>.
                    The free limit is temporarily set to
                    <strong>@PaymentService.FormatFileSize(PaymentService.FreeTierMaxBytes)</strong>
                    for testing. Upgrade to Pro to process any file up to 500MB.
                </span>
            }
            else
            {
                <span>
                    Your file is
                    <strong>@PaymentService.FormatFileSize(FileSizeBytes)</strong>.
                    Free processing is limited to
                    <strong>@PaymentService.FormatFileSize(PaymentService.FreeTierMaxBytes)</strong>.
                    Upgrade to Pro to process files up to 500MB.
                </span>
            }
        </p>

        <p class="upgrade-price">
            Unlock with <strong class="price-highlight">Pro — $12/month</strong>
        </p>

        <div class="upgrade-features">
            <span>✅ Files up to 500MB</span>
            <span>✅ All 35+ PDF tools</span>
            <span>✅ All AI tools</span>
            <span>✅ Batch processing</span>
            <span>✅ No ads</span>
            <span>✅ Cancel anytime</span>
        </div>
    </div>

    <div class="upgrade-actions">
        <button class="process-button upgrade-btn"
                @onclick="HandleUpgrade">
            Upgrade to Pro
        </button>
        <button class="reset-button"
                @onclick="HandleSecondaryAction">
            @SecondaryButtonText
        </button>
    </div>

</div>

@code {
    [Parameter] public long FileSizeBytes { get; set; }
    [Parameter] public string FileName { get; set; } = string.Empty;
    [Parameter] public string ToolType { get; set; } = string.Empty;
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string Title { get; set; } = "This file is over the free limit";
    [Parameter] public string Message { get; set; } = "This file is above the free processing limit.";
    [Parameter] public string PrimaryButtonText { get; set; } = "Upgrade to Pro";
    [Parameter] public string SecondaryButtonText { get; set; } = "Return to upload";

    private void HandleUpgrade()
    {
        // Pass return URL so user lands back on the tool after subscribing
        var returnUrl = Uri.EscapeDataString(Navigation.Uri);
        Navigation.NavigateTo($"/pricing?from={returnUrl}", forceLoad: false);
    }

    private async Task HandleSecondaryAction()
    {
        if (OnCancel.HasDelegate)
            await OnCancel.InvokeAsync();
    }
}
