@inject PaymentService PaymentService
@inject PdfToolStack.Web.Services.SubscriptionService SubService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider Auth
@using Microsoft.AspNetCore.Components.Authorization
@using PdfToolStack.Domain.Configuration
@using PdfToolStack.Web.Services
@inject IProductContext Product

<div class="upgrade-shell">
    <div class="upgrade-card">
        <div class="upgrade-icon" aria-hidden="true">PDF</div>

        <div class="upgrade-content">
            <span class="upgrade-eyebrow">Large file detected</span>
            <h3>Your file is too large for free processing</h3>
            <p class="upgrade-subtext">
                Upgrade to process larger files instantly with no limits.
            </p>

            <div class="upgrade-file-note">
                <span>@FileName</span>
                <strong>@PaymentService.FormatFileSize(FileSizeBytes)</strong>
                <small>Free limit: @PaymentService.FormatFileSize(PaymentService.FreeTierMaxBytes)</small>
            </div>

            <div class="upgrade-benefits" aria-label="Upgrade benefits">
                <div>
                    <strong>Process larger files</strong>
                    <span>Upload documents beyond the free size limit.</span>
                </div>
                <div>
                    <strong>Faster processing</strong>
                    <span>Keep moving through high-volume document work.</span>
                </div>
                <div>
                    <strong>No waiting limits</strong>
                    <span>Use the tools without slowing down your workflow.</span>
                </div>
            </div>

            <div class="upgrade-options">
                <div class="upgrade-option upgrade-option-pro">
                    <div>
                        <div class="upgrade-option-badge upgrade-option-badge-pro">Best value</div>
                        <div class="upgrade-option-price">$19<span>/mo</span></div>
                        <div class="upgrade-option-desc">Unlimited file size, all AI tools, batch processing, and no ads.</div>
                    </div>
                    <button class="upgrade-primary-button"
                            @onclick="HandleUpgrade"
                            disabled="@(_isLoading)">
                        @(_isLoading && _activeAction == "pro" ? "Redirecting..." : "Upgrade to Pro")
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(LargeFilePriceId))
                {
                    <div class="upgrade-option upgrade-option-onetime">
                        <div>
                            <div class="upgrade-option-badge">One-time unlock</div>
                            <div class="upgrade-option-price">$1.99</div>
                            <div class="upgrade-option-desc">Process this one file up to 500MB with no subscription.</div>
                        </div>
                        <button class="upgrade-secondary-pay-button"
                                @onclick="UnlockLargeFile"
                                disabled="@(_isLoading)">
                            @(_isLoading && _activeAction == "onetime" ? "Redirecting..." : "Unlock this file")
                        </button>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="upgrade-error">@_error</p>
            }

            <div class="upgrade-footer">
                <span>Secure &bull; Private &bull; Files auto-deleted</span>
                <button class="upgrade-text-button"
                        @onclick="HandleSecondaryAction"
                        disabled="@_isLoading">
                    Use a smaller file
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .upgrade-shell {
        display: flex;
        justify-content: center;
        width: 100%;
        padding: 1.5rem 0;
    }

    .upgrade-card {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 1.25rem;
        width: min(760px, 100%);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 28px;
        background:
            radial-gradient(circle at top left, rgba(109, 93, 252, 0.14), transparent 34%),
            rgba(255, 255, 255, 0.96);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
        padding: clamp(1.25rem, 3vw, 2rem);
    }

    .upgrade-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 4rem;
        height: 4rem;
        border-radius: 1.25rem;
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 60%, #06b6d4 100%);
        color: #fff;
        font-size: .92rem;
        font-weight: 950;
        letter-spacing: .03em;
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.28);
    }

    .upgrade-content {
        min-width: 0;
    }

    .upgrade-eyebrow {
        display: inline-flex;
        margin-bottom: .6rem;
        color: #4f46e5;
        font-size: .76rem;
        font-weight: 950;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .upgrade-content h3 {
        margin: 0;
        color: #111827;
        font-size: clamp(1.65rem, 3vw, 2.35rem);
        line-height: 1.05;
        letter-spacing: -0.035em;
    }

    .upgrade-subtext {
        max-width: 34rem;
        margin: .75rem 0 1.1rem;
        color: #526173;
        font-size: 1rem;
        line-height: 1.65;
    }

    .upgrade-file-note {
        display: grid;
        gap: .25rem;
        margin-bottom: 1rem;
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 18px;
        background: #f8fafc;
        padding: .95rem 1rem;
    }

    .upgrade-file-note span {
        overflow-wrap: anywhere;
        color: #334155;
        font-weight: 850;
    }

    .upgrade-file-note strong {
        color: #111827;
        font-size: 1.15rem;
    }

    .upgrade-file-note small {
        color: #64748b;
    }

    .upgrade-benefits {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .upgrade-benefits div,
    .upgrade-option {
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 18px;
        background: rgba(248, 250, 252, 0.9);
        padding: .95rem;
    }

    .upgrade-benefits strong,
    .upgrade-benefits span {
        display: block;
    }

    .upgrade-benefits strong {
        color: #111827;
        font-size: .92rem;
        margin-bottom: .3rem;
    }

    .upgrade-benefits span {
        color: #64748b;
        font-size: .84rem;
        line-height: 1.45;
    }

    .upgrade-options {
        display: grid;
        gap: .8rem;
        margin: 1rem 0;
    }

    .upgrade-option {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 1rem;
    }

    .upgrade-option-pro {
        background: linear-gradient(135deg, #eef2ff 0%, #ecfeff 100%);
        border-color: rgba(37, 99, 235, 0.22);
    }

    .upgrade-option-badge {
        display: inline-flex;
        margin-bottom: .35rem;
        border-radius: 999px;
        background: #fff;
        color: #4f46e5;
        font-size: .72rem;
        font-weight: 950;
        letter-spacing: .05em;
        padding: .32rem .55rem;
        text-transform: uppercase;
    }

    .upgrade-option-badge-pro {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .upgrade-option-price {
        color: #111827;
        font-size: 1.6rem;
        font-weight: 950;
        letter-spacing: -0.03em;
    }

    .upgrade-option-price span {
        color: #64748b;
        font-size: .92rem;
        font-weight: 800;
    }

    .upgrade-option-desc {
        max-width: 28rem;
        color: #64748b;
        font-size: .9rem;
        line-height: 1.5;
    }

    .upgrade-primary-button,
    .upgrade-secondary-pay-button {
        border: 0;
        border-radius: 16px;
        cursor: pointer;
        font-weight: 950;
        padding: .95rem 1.15rem;
        white-space: nowrap;
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .upgrade-primary-button {
        background: linear-gradient(135deg, #6d5dfc 0%, #2563eb 60%, #06b6d4 100%);
        color: #fff;
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.28);
    }

    .upgrade-primary-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 24px 45px rgba(37, 99, 235, 0.34);
    }

    .upgrade-secondary-pay-button {
        background: #eef2ff;
        color: #3730a3;
    }

    .upgrade-primary-button:disabled,
    .upgrade-secondary-pay-button:disabled,
    .upgrade-text-button:disabled {
        cursor: not-allowed;
        opacity: .62;
        transform: none;
        box-shadow: none;
    }

    .upgrade-error {
        border-radius: 14px;
        background: #fee2e2;
        color: #991b1b;
        font-weight: 850;
        padding: .85rem 1rem;
    }

    .upgrade-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: .75rem;
        color: #64748b;
        font-size: .9rem;
        font-weight: 800;
    }

    .upgrade-text-button {
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: #3730a3;
        cursor: pointer;
        font-weight: 950;
        padding: .6rem .75rem;
    }

    .upgrade-text-button:hover {
        background: #eef2ff;
    }

    @@media (max-width: 760px) {
        .upgrade-card {
            grid-template-columns: 1fr;
        }

        .upgrade-benefits,
        .upgrade-option {
            grid-template-columns: 1fr;
        }

        .upgrade-primary-button,
        .upgrade-secondary-pay-button {
            width: 100%;
        }

        .upgrade-footer {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>

@code {
    [Parameter] public long FileSizeBytes { get; set; }
    [Parameter] public string FileName { get; set; } = string.Empty;
    [Parameter] public string ToolType { get; set; } = string.Empty;
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string Title { get; set; } = "This file is over the free limit";
    [Parameter] public string PrimaryButtonText { get; set; } = "Upgrade to Pro";
    [Parameter] public string SecondaryButtonText { get; set; } = "Return to upload";

    /// <summary>
    /// Pass from the parent page: load from api/subscription/addons.
    /// If null, the $1.99 button is hidden and only Pro upgrade is shown.
    /// </summary>
    [Parameter] public string? LargeFilePriceId { get; set; }

    /// <summary>
    /// Pass from the parent page: load from api/subscription/plans.
    /// If null, Pro upgrade falls back to /pricing page navigation.
    /// </summary>
    [Parameter] public string? ProMonthlyPriceId { get; set; }

    private bool _isLoading;
    private string _activeAction = string.Empty;
    private string? _error;
    private string _userId = string.Empty;
    private string _userEmail = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirst("sub")?.Value ?? string.Empty;
        _userEmail = user.FindFirst("email")?.Value ?? string.Empty;
    }

    private async Task UnlockLargeFile()
    {
        if (string.IsNullOrWhiteSpace(LargeFilePriceId)) return;

        if (string.IsNullOrEmpty(_userId))
        {
            Navigation.NavigateTo("authentication/login");
            return;
        }

        _isLoading = true;
        _activeAction = "onetime";
        _error = null;
        StateHasChanged();

        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var returnPath = new Uri(Navigation.Uri).PathAndQuery;

            var url = await SubService.CreateAddonCheckoutSessionAsync(
                LargeFilePriceId,
                "large_file",
                _userId,
                _userEmail,
                baseUrl,
                returnPath);

            if (!string.IsNullOrEmpty(url))
            {
                Navigation.NavigateTo(url, forceLoad: true);
            }
            else
            {
                _error = $"Could not start checkout. Please try again or email {Product.SupportEmail}.";
            }
        }
        catch
        {
            _error = $"Something went wrong. Please email {Product.SupportEmail}.";
        }
        finally
        {
            _isLoading = false;
            _activeAction = string.Empty;
            StateHasChanged();
        }
    }

    private async Task HandleUpgrade()
    {
        if (string.IsNullOrEmpty(_userId))
        {
            Navigation.NavigateTo("authentication/login");
            return;
        }

        if (string.IsNullOrEmpty(ProMonthlyPriceId))
        {
            var returnUrl = Uri.EscapeDataString(Navigation.Uri);
            Navigation.NavigateTo($"/pricing?from={returnUrl}");
            return;
        }

        _isLoading = true;
        _activeAction = "pro";
        _error = null;
        StateHasChanged();

        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var url = await SubService.CreateCheckoutSessionAsync(
                ProMonthlyPriceId, _userId, _userEmail, baseUrl);

            if (!string.IsNullOrEmpty(url))
            {
                Navigation.NavigateTo(url, forceLoad: true);
            }
            else
            {
                _error = $"Could not start checkout. Please try again or email {Product.SupportEmail}.";
            }
        }
        catch
        {
            _error = $"Something went wrong. Please email {Product.SupportEmail}.";
        }
        finally
        {
            _isLoading = false;
            _activeAction = string.Empty;
            StateHasChanged();
        }
    }

    private async Task HandleSecondaryAction()
    {
        if (OnCancel.HasDelegate)
            await OnCancel.InvokeAsync();
    }
}
