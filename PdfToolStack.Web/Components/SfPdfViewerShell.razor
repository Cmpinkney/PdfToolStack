@using Syncfusion.Blazor.SfPdfViewer
@inject IJSRuntime JS
@inject FileValidationService Validator
@inject ToastService Toast
@implements IDisposable

@if (!string.IsNullOrEmpty(_fileName))
{
    <div class="annotator-toolbar-row">
        <span class="annotator-filename">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
            </svg>
            @_fileName
        </span>
        <button class="reset-button" style="max-width:220px;" @onclick="HandleReset">
            @ResetLabel
        </button>
    </div>
}

@if (_isLoading)
{
    <div class="sf-viewport-loading-overlay" role="status" aria-live="polite" aria-label="Preparing PDF editor">
        <div class="sf-viewport-loading-card">
            <div class="sf-viewport-loading-mark" aria-hidden="true">
                <span></span>
            </div>
            <div>
                <p class="sf-viewport-loading-title">Preparing your PDF editor...</p>
                <p class="sf-viewport-loading-copy">This may take a few seconds for larger files.</p>
            </div>
        </div>
    </div>
}

<div class="sf-viewer-area @(_showArea ? "" : "sf-viewer-area-hidden") @(_isLoading ? "is-loading" : "")"
     id="@_wrapperId">

    <PdfLoadingOverlay IsVisible="@_isLoading"
                       Message="@_loadingMessage"
                       SubMessage="@_loadingSubMessage" />

    @if (_pdfData != null)
    {
        <div class="sf-viewer-wrap @(_showViewer ? "sf-viewer-visible" : "sf-viewer-hidden")">
            <SfPdfViewer2 DocumentPath="@_pdfData"
                          Height="@Height"
                          Width="100%">
                @if (ToolbarItems != null)
                {
                    <PdfViewerToolbarSettings ToolbarItems="@ToolbarItems" />
                }
            </SfPdfViewer2>
        </div>
    }
</div>

@code {
    [Parameter] public string ResetLabel { get; set; } = "Open Another PDF";
    [Parameter] public string Height { get; set; } = "85vh";
    [Parameter] public EventCallback OnReset { get; set; }
    [Parameter] public List<ToolbarItem>? ToolbarItems { get; set; }

    private string? _pdfData;
    private string? _fileName;
    private bool _isLoading = false;
    private bool _showViewer = false;
    private bool _showArea = false;

    private string _loadingMessage = "Loading PDF...";
    private string _loadingSubMessage = "Just a moment";

    private readonly string _wrapperId = $"sfshell-{Guid.NewGuid():N}";
    private DotNetObjectReference<SfPdfViewerShell>? _dotNetRef;
    private CancellationTokenSource? _loadingCts;

    public async Task<bool> LoadBytesAsync(string fileName, byte[] bytes)
    {
        Reset();

        var bytesVal = Validator.ValidatePdfBytes(bytes);
        if (!bytesVal.IsValid)
        {
            Toast.ShowError(bytesVal.Message!);
            return false;
        }

        _loadingCts = new CancellationTokenSource();

        _fileName = fileName;
        _showArea = true;
        _showViewer = false;
        _isLoading = true;
        _loadingMessage = "Loading PDF...";
        _loadingSubMessage = $"Preparing {fileName} ({Validator.FormatSize(bytes.Length)})";

        // Let the overlay render before heavy work starts
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        _ = RunLoadingStagesAsync(_loadingCts.Token);

        try
        {
            _loadingMessage = "Preparing viewer...";
            _loadingSubMessage = "Converting document for display";
            await InvokeAsync(StateHasChanged);
            await Task.Delay(25);

            // In Blazor WASM, giving the UI a chance to paint matters more than Task.Run here
            var base64 = Convert.ToBase64String(bytes);

            _pdfData = await JS.InvokeAsync<string>(
                "pdfInterop.createBlobUrlFromBase64",
                base64
            );

            _loadingMessage = "Opening annotator...";
            _loadingSubMessage = "Initializing PDF viewer";
            await InvokeAsync(StateHasChanged);

            // Give the component one render cycle so SfPdfViewer2 mounts
            await Task.Yield();
            await InvokeAsync(StateHasChanged);
            await Task.Delay(100);

            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("sfViewerObserver.start", _wrapperId, _dotNetRef);

            return true;
        }
        catch (Exception ex)
        {
            _loadingCts?.Cancel();
            _isLoading = false;
            _showViewer = false;
            _showArea = false;
            _pdfData = null;

            await InvokeAsync(StateHasChanged);
            Toast.ShowError($"Could not load PDF viewer: {ex.Message}");
            return false;
        }
    }

    private async Task RunLoadingStagesAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(1200, token);
            if (token.IsCancellationRequested) return;

            _loadingMessage = "Rendering PDF pages...";
            _loadingSubMessage = "This can take a moment for large or scanned files";
            await InvokeAsync(StateHasChanged);

            await Task.Delay(3500, token);
            if (token.IsCancellationRequested) return;

            _loadingMessage = "Still working...";
            _loadingSubMessage = "Large, image-heavy, or scanned PDFs can take longer to open";
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
            // Expected on successful load/reset
        }
    }

    [JSInvokable]
    public async Task OnViewerReady()
    {
        _loadingCts?.Cancel();

        _showViewer = true;
        _isLoading = false;

        await InvokeAsync(StateHasChanged);
        Toast.ShowSuccess($"Ready — {_fileName}");
    }

    public void Reset()
    {
        _loadingCts?.Cancel();
        _loadingCts?.Dispose();
        _loadingCts = null;

        //  Revoke blob URL (fire-and-forget safe)
        if (!string.IsNullOrEmpty(_pdfData))
        {
            try
            {
                _ = JS.InvokeVoidAsync("pdfInterop.revokeBlobUrl", _pdfData);
            }
            catch { }
        }

        try { JS.InvokeVoidAsync("sfViewerObserver.stop"); } catch { }

        _dotNetRef?.Dispose();
        _dotNetRef = null;

        _pdfData = null;
        _fileName = null;
        _isLoading = false;
        _showViewer = false;
        _showArea = false;

        _loadingMessage = "Loading PDF...";
        _loadingSubMessage = "Just a moment";
    }

    private async Task HandleReset()
    {
        Reset();
        await InvokeAsync(StateHasChanged);
        await OnReset.InvokeAsync();
    }

    public void Dispose()
    {
        _loadingCts?.Cancel();
        _loadingCts?.Dispose();

        try { JS.InvokeVoidAsync("sfViewerObserver.stop"); } catch { }

        _dotNetRef?.Dispose();
    }
}
