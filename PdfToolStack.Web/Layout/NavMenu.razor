@using PdfToolStack.Web.Components
@inject IJSRuntime JS

<nav class="navbar" id="mainNavbar">

    <a href="/" class="nav-brand" aria-label="PdfToolStack home">
        <div class="nav-logo-wrap">
            <!-- Icon: stacked docs + teal checkmark -->
            <svg class="nav-logo-icon" width="32" height="38" viewBox="0 0 28 38" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="8" y="6" width="20" height="26" rx="3" fill="#4F46E5" opacity="0.35" />
                <rect x="4" y="3" width="20" height="26" rx="3" fill="#2250F4" opacity="0.65" />
                <rect x="0" y="0" width="20" height="26" rx="3" fill="#2250F4" />
                <rect x="4" y="6" width="12" height="2.5" rx="1.2" fill="white" opacity="0.95" />
                <rect x="4" y="11" width="10" height="2.5" rx="1.2" fill="white" opacity="0.6" />
                <rect x="4" y="16" width="11" height="2.5" rx="1.2" fill="white" opacity="0.6" />
                <circle cx="18" cy="30" r="8" fill="#0D9488" />
                <polyline points="13,30 16.5,33.5 23,25" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <!-- Wordmark: pure HTML so font always renders -->
            <div class="nav-logo-wordmark">
                <div class="nav-logo-name">Pdf<span>Tool</span>Stack</div>
                <div class="nav-logo-tagline">COMPRESS · SIGN · EXTRACT</div>
            </div>
        </div>
    </a>

    <a href="/ai-pdf-assist" class="nav-link nav-link-ai">
        AI Tools
    </a>
    <a href="/compress-pdf" class="nav-link">Compress</a>
    <a href="/converter" class="nav-link">Convert</a>
    <a href="/merge-pdf" class="nav-link">Merge</a>
    <a href="/split-pdf" class="nav-link">Split</a>
    <a href="/edit-pdf" class="nav-link">Edit</a>
    <a href="/sign-pdf" class="nav-link">Sign</a>
    <a href="/batch" class="nav-link">Batch</a>
    <a href="/pricing" class="nav-link">Pricing</a>

    <div class="nav-search">
        <span class="nav-search-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
        </span>
        <input type="text"
               placeholder="Search tools..."
               @bind="SearchQuery"
               @bind:event="oninput"
               @onfocus="ShowResults"
               @onblur="HideResultsDelayed"
               aria-label="Search PDF tools" />
        @if (ShowSearchResults && FilteredTools.Any())
        {
            <div class="search-results" role="listbox" aria-label="Search results">
                @foreach (var tool in FilteredTools.Take(6))
                {
                    <a class="search-result-item"
                       href="@tool.Url"
                       role="option"
                       @onclick="ClearSearch">
                        <span class="search-result-icon" aria-hidden="true">
                            @tool.Icon
                        </span>
                        <div class="search-result-info">
                            <div class="search-result-name">@tool.Name</div>
                            <div class="search-result-desc">@tool.Description</div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <div class="navbar-right">
        <LoginDisplay />
    </div>

    <button class="hamburger"
            @onclick="ToggleMobileMenu"
            aria-label="@(MobileMenuOpen ? "Close menu" : "Open menu")"
            aria-expanded="@MobileMenuOpen">
        <span></span>
        <span></span>
        <span></span>
    </button>
</nav>

<div class="mobile-menu @(MobileMenuOpen ? "open" : "")" role="navigation" aria-label="Mobile navigation">
    <div class="mobile-section-title">PDF Tools</div>
    <a href="/compress-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🗜️ Compress PDF</a>
    <a href="/pdf-to-word" class="mobile-nav-link" @onclick="CloseMobileMenu">📝 PDF to Word</a>
    <a href="/word-to-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">📄 Word to PDF</a>
    <a href="/merge-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🔗 Merge PDF</a>
    <a href="/split-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">✂️ Split PDF</a>
    <a href="/converter" class="mobile-nav-link" @onclick="CloseMobileMenu">🔄 All Converters</a>

    <div class="mobile-section-title">Edit &amp; Annotate</div>
    <a href="/edit-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🖊️ Edit PDF</a>
    <a href="/sign-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">✒️ Sign PDF</a>
    <a href="/redact-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🔒 Redact PDF</a>
    <a href="/pdf-annotator" class="mobile-nav-link" @onclick="CloseMobileMenu">🖍️ Annotator</a>
    <a href="/watermark-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">💧 Watermark</a>

    <div class="mobile-section-title">Organize</div>
    <a href="/organize-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">📋 Organize PDF</a>
    <a href="/delete-pdf-pages" class="mobile-nav-link" @onclick="CloseMobileMenu">🗑️ Delete Pages</a>
    <a href="/extract-pdf-pages" class="mobile-nav-link" @onclick="CloseMobileMenu">📌 Extract Pages</a>
    <a href="/rotate-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🔄 Rotate PDF</a>
    <a href="/batch" class="mobile-nav-link" @onclick="CloseMobileMenu">📦 Batch Process</a>

    <div class="mobile-section-title">Security</div>
    <a href="/protect-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🔐 Protect PDF</a>
    <a href="/unlock-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🔓 Unlock PDF</a>
    <a href="/flatten-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">📄 Flatten PDF</a>

    <div class="mobile-section-title">AI Tools</div>
    <a href="/ai-pdf-assist" class="mobile-nav-link" @onclick="CloseMobileMenu">🤖 AI PDF Assist</a>
    <a href="/chat-with-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">💬 Chat with PDF</a>
    <a href="/ai-summarizer" class="mobile-nav-link" @onclick="CloseMobileMenu">✨ AI Summarizer</a>
    <a href="/compare-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🔍 Compare PDF</a>
    <a href="/extract-invoice-data" class="mobile-nav-link" @onclick="CloseMobileMenu">📊 Extract Invoice Data</a>
    <a href="/review-contract" class="mobile-nav-link" @onclick="CloseMobileMenu">⚖️ Contract Reviewer</a>
    <a href="/ai-rewrite" class="mobile-nav-link" @onclick="CloseMobileMenu">✍️ AI Rewriter</a>
    <a href="/translate-pdf" class="mobile-nav-link" @onclick="CloseMobileMenu">🌍 Translate PDF</a>
    <a href="/invoice-data-extraction" class="nav-link">Invoice Extraction</a>
</div>

@code {
    private bool MobileMenuOpen = false;
    private string SearchQuery = string.Empty;
    private bool ShowSearchResults = false;

    private record ToolInfo(string Name, string Description,
        string Url, string Icon);

    private List<ToolInfo> AllTools = new()
    {
        new("Compress PDF", "Reduce PDF file size", "/compress-pdf", "🗜️"),
        new("PDF to Word", "Convert PDF to Word", "/pdf-to-word", "📝"),
        new("Word to PDF", "Convert Word to PDF", "/word-to-pdf", "📄"),
        new("Merge PDF", "Combine multiple PDFs", "/merge-pdf", "🔗"),
        new("Split PDF", "Split PDF into pages", "/split-pdf", "✂️"),
        new("Rotate PDF", "Rotate PDF pages", "/rotate-pdf", "🔄"),
        new("Edit PDF", "Add text and shapes", "/edit-pdf", "🖊️"),
        new("Sign PDF", "Electronic signature", "/sign-pdf", "✒️"),
        new("Redact PDF", "Remove sensitive info", "/redact-pdf", "🔒"),
        new("PDF Annotator", "Highlight and markup", "/pdf-annotator", "🖍️"),
        new("Watermark PDF", "Add watermark", "/watermark-pdf", "💧"),
        new("Fill PDF Form", "Fill form fields", "/fill-pdf-form", "✍️"),
        new("Organize PDF", "Rearrange pages", "/organize-pdf", "📋"),
        new("Delete Pages", "Remove PDF pages", "/delete-pdf-pages", "🗑️"),
        new("Extract Pages", "Extract PDF pages", "/extract-pdf-pages", "📌"),
        new("Number Pages", "Add page numbers", "/number-pages", "🔢"),
        new("Flatten PDF", "Make PDF uneditable", "/flatten-pdf", "📄"),
        new("Protect PDF", "Add password", "/protect-pdf", "🔐"),
        new("Unlock PDF", "Remove password", "/unlock-pdf", "🔓"),
        new("JPG to PDF", "Images to PDF", "/jpg-to-pdf", "🖼️"),
        new("PPT to PDF", "PowerPoint to PDF", "/ppt-to-pdf", "📊"),
        new("Excel to PDF", "Spreadsheet to PDF", "/excel-to-pdf", "📈"),
        new("PDF to JPG", "PDF pages to images", "/pdf-to-jpg", "🖼️"),
        new("PDF to Excel", "Extract tables to Excel", "/pdf-to-excel", "📈"),
        new("PDF Reader", "View PDFs online", "/pdf-reader", "📖"),
        new("Translate PDF", "Translate PDF content", "/translate-pdf", "🌍"),
        new("AI PDF Assist", "AI document processing", "/ai-pdf-assist", "🤖"),
        new("Chat with PDF", "Ask your PDF questions", "/chat-with-pdf", "💬"),
        new("AI Summarizer", "Summarize PDF with AI", "/ai-summarizer", "✨"),
        new("AI Questions", "Generate quiz questions", "/ai-questions", "📝"),
        new("PDF OCR", "Make scans searchable", "/pdf-ocr", "🔍"),
        new("PDF Scanner", "Scan to PDF", "/pdf-scanner", "📱"),
        new("Compare PDF", "Find differences between PDFs", "/compare-pdf", "🔍"),
        new("Extract Invoice Data", "AI extracts invoice to Excel", "/extract-invoice-data", "📊"),
        new("Batch Process", "Process 20 files at once", "/batch", "📦"),
        new("Compress for Email", "Fix PDF too large for email", "/compress-for-email", "🗜️"),
        new("Sign Contract", "Sign contracts online", "/sign-contract", "✒️"),
        new("Merge for Submission", "Combine PDFs for filing", "/merge-pdfs-for-submission", "🔗"),
        new("Compare Contracts", "Find differences in contracts", "/compare-contracts", "🔍"),
        new("AI Rewriter", "Rewrite PDF content with AI", "/ai-rewrite", "✍️"),
    };

    private IEnumerable<ToolInfo> FilteredTools =>
        string.IsNullOrWhiteSpace(SearchQuery)
            ? Enumerable.Empty<ToolInfo>()
            : AllTools.Where(t =>
                t.Name.Contains(SearchQuery,
                    StringComparison.OrdinalIgnoreCase) ||
                t.Description.Contains(SearchQuery,
                    StringComparison.OrdinalIgnoreCase));

    private void ToggleMobileMenu() =>
        MobileMenuOpen = !MobileMenuOpen;

    private void CloseMobileMenu() =>
        MobileMenuOpen = false;

    private void ShowResults() =>
        ShowSearchResults = true;

    private async Task HideResultsDelayed()
    {
        await Task.Delay(200);
        ShowSearchResults = false;
        StateHasChanged();
    }

    private void ClearSearch()
    {
        SearchQuery = string.Empty;
        ShowSearchResults = false;
        MobileMenuOpen = false;
    }
}
