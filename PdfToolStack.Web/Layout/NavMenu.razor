@using PdfToolStack.Web.Components
@inject IJSRuntime JS

<nav class="navbar" id="mainNavbar">

    <a href="/" class="nav-brand" aria-label="PdfToolStack home">
        <img src="/images/pdftoolstack-logo-full.png" alt="PdfToolStack" class="brand-logo" />
        @*
        <div class="brand-logo">
            <svg class="brand-mark" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                    <linearGradient id="ptsBrandGradientNav" x1="7" y1="4" x2="25" y2="27" gradientUnits="userSpaceOnUse">
                        <stop stop-color="#6D5DFC" />
                        <stop offset="0.55" stop-color="#2563EB" />
                        <stop offset="1" stop-color="#06B6D4" />
                    </linearGradient>
                </defs>
                <rect x="10" y="5" width="15" height="20" rx="4" fill="#A5B4FC" opacity="0.58" />
                <rect x="6" y="3" width="16" height="21" rx="4" fill="url(#ptsBrandGradientNav)" />
                <path d="M10 10h8M10 15h6" stroke="white" stroke-width="1.9" stroke-linecap="round" opacity="0.9" />
                <path d="M22.5 19.2l5 2v3.5c0 3.2-2.1 5-5 6-2.9-1-5-2.8-5-6v-3.5l5-2Z" fill="#10B981" />
                <path d="M20 24.7l1.7 1.7 3.4-3.7" stroke="white" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
            <span class="brand-text">PdfTool<span class="brand-accent">Stack</span></span>
        </div>
        *@
    </a>

    <!-- Desktop nav links -->
    <a href="/ai-pdf-assist" class="nav-link nav-link-ai">AI Tools</a>
    <a href="/compress-pdf" class="nav-link nav-link-tool">Compress</a>
    <a href="/converter" class="nav-link nav-link-tool">Convert</a>
    <a href="/merge-pdf" class="nav-link nav-link-tool">Merge</a>
    <a href="/split-pdf" class="nav-link nav-link-tool">Split</a>
    <a href="/edit-pdf" class="nav-link nav-link-tool">Edit</a>
    <a href="/sign-pdf" class="nav-link nav-link-tool">Sign</a>
    <a href="/batch" class="nav-link nav-link-tool">Batch</a>
    <a href="/pricing" class="nav-link">Pricing</a>
    <a href="/about" class="nav-link">About</a>
    <a href="/contact" class="nav-link">Contact</a>

    <div class="nav-search">
        <span class="nav-search-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
        </span>
        <input type="text"
               placeholder="Search tools..."
               @bind="SearchQuery"
               @bind:event="oninput"
               @onfocus="ShowResults"
               @onblur="HideResultsDelayed"
               aria-label="Search PDF tools" />
        @if (ShowSearchResults && FilteredTools.Any())
        {
            <div class="search-results" role="listbox" aria-label="Search results">
                @foreach (var tool in FilteredTools.Take(6))
                {
                    <a class="search-result-item" href="@tool.Url" role="option" @onclick="ClearSearch">
                        <span class="search-result-icon" aria-hidden="true">@tool.Icon</span>
                        <div class="search-result-info">
                            <div class="search-result-name">@tool.Name</div>
                            <div class="search-result-desc">@tool.Description</div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <div class="navbar-right">
        <LoginDisplay />

        <button class="hamburger @(MobileMenuOpen ? "is-open" : "")"
                @onclick="ToggleMobileMenu"
                aria-label="@(MobileMenuOpen ? "Close menu" : "Open menu")"
                aria-expanded="@MobileMenuOpen">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</nav>

<!-- Mobile overlay backdrop -->
@if (MobileMenuOpen)
{
    <div class="mob-backdrop" @onclick="CloseMobileMenu"></div>
}

<!-- Mobile drawer -->
<div class="mob-drawer @(MobileMenuOpen ? "mob-drawer--open" : "")" role="navigation" aria-label="Mobile navigation">

    <!-- Drawer header -->
    <div class="mob-header">
        <img src="/images/pdftoolstack-logo-full.png" alt="PdfToolStack" class="brand-logo brand-logo-mobile" />
        @*
        <div class="brand-logo brand-logo-mobile" aria-label="PdfToolStack menu">
            <svg class="brand-mark" width="28" height="28" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                    <linearGradient id="ptsBrandGradientMobile" x1="7" y1="4" x2="25" y2="27" gradientUnits="userSpaceOnUse">
                        <stop stop-color="#6D5DFC" />
                        <stop offset="0.55" stop-color="#2563EB" />
                        <stop offset="1" stop-color="#06B6D4" />
                    </linearGradient>
                </defs>
                <rect x="10" y="5" width="15" height="20" rx="4" fill="#A5B4FC" opacity="0.58" />
                <rect x="6" y="3" width="16" height="21" rx="4" fill="url(#ptsBrandGradientMobile)" />
                <path d="M10 10h8M10 15h6" stroke="white" stroke-width="1.9" stroke-linecap="round" opacity="0.9" />
                <path d="M22.5 19.2l5 2v3.5c0 3.2-2.1 5-5 6-2.9-1-5-2.8-5-6v-3.5l5-2Z" fill="#10B981" />
                <path d="M20 24.7l1.7 1.7 3.4-3.7" stroke="white" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
            <span class="brand-text">PdfTool<span class="brand-accent">Stack</span></span>
        </div>
        *@
        <button class="mob-close" @onclick="CloseMobileMenu" aria-label="Close menu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        </button>
    </div>

    <!-- Quick links row -->
    <div class="mob-quick-row">
        <a href="/ai-pdf-assist" class="mob-quick-btn mob-quick-ai" @onclick="CloseMobileMenu">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c.5 1.5 1.5 2.5 3 3-1.5.5-2.5 1.5-3 3-.5-1.5-1.5-2.5-3-3 1.5-.5 2.5-1.5 3-3z" /><path d="M5 7c.3.8.8 1.4 1.5 1.5C5.8 8.8 5.3 9.4 5 10c-.3-.6-.8-1.2-1.5-1.5C4.2 8.2 4.7 7.6 5 7z" /></svg>
            AI Tools
        </a>
        <a href="/pricing" class="mob-quick-btn" @onclick="CloseMobileMenu">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
            Pricing
        </a>
        <a href="/account" class="mob-quick-btn" @onclick="CloseMobileMenu">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
            Account
        </a>
    </div>

    <div class="mob-divider"></div>

    <!-- Accordion: AI Tools -->
    <div class="mob-section">
        <button class="mob-section-header @(OpenSection == "ai" ? "mob-section-header--open" : "")"
                @onclick='() => ToggleSection("ai")'>
            <div class="mob-section-header-left">
                <span class="mob-section-icon mob-section-icon--ai">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c.5 1.5 1.5 2.5 3 3-1.5.5-2.5 1.5-3 3-.5-1.5-1.5-2.5-3-3 1.5-.5 2.5-1.5 3-3z" fill="currentColor" fill-opacity="0.3" /></svg>
                </span>
                <span>AI Tools</span>
                <span class="mob-section-badge">Pro</span>
            </div>
            <svg class="mob-chevron @(OpenSection == "ai" ? "mob-chevron--open" : "")" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6,9 12,15 18,9" /></svg>
        </button>
        @if (OpenSection == "ai")
        {
            <div class="mob-section-body">
                <a href="/ai-pdf-assist" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🤖</span><div><div class="mob-link-name">AI PDF Assist</div><div class="mob-link-desc">All-in-one AI document tools</div></div></a>
                <a href="/chat-with-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">💬</span><div><div class="mob-link-name">Chat with PDF</div><div class="mob-link-desc">Ask your document anything</div></div></a>
                <a href="/ai-summarizer" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">✨</span><div><div class="mob-link-name">AI Summarizer</div><div class="mob-link-desc">Key points in seconds</div></div></a>
                <a href="/compare-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔍</span><div><div class="mob-link-name">Compare PDFs</div><div class="mob-link-desc">Word-level diff report</div></div></a>
                <a href="/extract-invoice-data" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📊</span><div><div class="mob-link-name">Extract Invoice Data</div><div class="mob-link-desc">PDF invoice → Excel instantly</div></div></a>
                <a href="/review-contract" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">⚖️</span><div><div class="mob-link-name">Contract Reviewer</div><div class="mob-link-desc">Catch risky clauses with AI</div></div></a>
                <a href="/contract-dashboard" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📋</span><div><div class="mob-link-name">Contract Dashboard</div><div class="mob-link-desc">Full risk dashboard for contracts</div></div></a>
                <a href="/ai-rewrite" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">✍️</span><div><div class="mob-link-name">AI Rewriter</div><div class="mob-link-desc">Rewrite and change tone</div></div></a>
                <a href="/translate-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🌍</span><div><div class="mob-link-name">Translate PDF</div><div class="mob-link-desc">Translate to any language</div></div></a>
            </div>
        }
    </div>

    <!-- Accordion: Convert -->
    <div class="mob-section">
        <button class="mob-section-header @(OpenSection == "convert" ? "mob-section-header--open" : "")"
                @onclick='() => ToggleSection("convert")'>
            <div class="mob-section-header-left">
                <span class="mob-section-icon mob-section-icon--blue">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17,1 21,5 17,9" /><path d="M3 11V9a4 4 0 0 1 4-4h14" /><polyline points="7,23 3,19 7,15" /><path d="M21 13v2a4 4 0 0 1-4 4H3" /></svg>
                </span>
                <span>Compress &amp; Convert</span>
            </div>
            <svg class="mob-chevron @(OpenSection == "convert" ? "mob-chevron--open" : "")" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6,9 12,15 18,9" /></svg>
        </button>
        @if (OpenSection == "convert")
        {
            <div class="mob-section-body">
                <a href="/compress-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🗜️</span><div><div class="mob-link-name">Compress PDF</div><div class="mob-link-desc">Reduce file size</div></div></a>
                <a href="/compress-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📧</span><div><div class="mob-link-name">Fix PDF for Email</div><div class="mob-link-desc">Make it email-ready</div></div></a>
                <a href="/pdf-to-word" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📝</span><div><div class="mob-link-name">PDF to Word</div><div class="mob-link-desc">Convert to editable DOCX</div></div></a>
                <a href="/word-to-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📄</span><div><div class="mob-link-name">Word to PDF</div><div class="mob-link-desc">DOCX to PDF</div></div></a>
                <a href="/pdf-to-jpg" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🖼️</span><div><div class="mob-link-name">PDF to JPG</div><div class="mob-link-desc">Pages to images</div></div></a>
                <a href="/jpg-to-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🖼️</span><div><div class="mob-link-name">JPG to PDF</div><div class="mob-link-desc">Images to PDF</div></div></a>
                <a href="/pdf-to-excel" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📈</span><div><div class="mob-link-name">PDF to Excel</div><div class="mob-link-desc">Tables to XLSX</div></div></a>
                <a href="/ppt-to-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📊</span><div><div class="mob-link-name">PPT to PDF</div><div class="mob-link-desc">Presentation to PDF</div></div></a>
                <a href="/converter" class="mob-link mob-link--more" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔄</span><div><div class="mob-link-name">All Converters</div><div class="mob-link-desc">View every format option</div></div></a>
            </div>
        }
    </div>

    <!-- Accordion: Edit & Annotate -->
    <div class="mob-section">
        <button class="mob-section-header @(OpenSection == "edit" ? "mob-section-header--open" : "")"
                @onclick='() => ToggleSection("edit")'>
            <div class="mob-section-header-left">
                <span class="mob-section-icon mob-section-icon--violet">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" /></svg>
                </span>
                <span>Edit &amp; Sign</span>
            </div>
            <svg class="mob-chevron @(OpenSection == "edit" ? "mob-chevron--open" : "")" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6,9 12,15 18,9" /></svg>
        </button>
        @if (OpenSection == "edit")
        {
            <div class="mob-section-body">
                <a href="/edit-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🖊️</span><div><div class="mob-link-name">Edit PDF</div><div class="mob-link-desc">Add text and shapes</div></div></a>
                <a href="/sign-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">✒️</span><div><div class="mob-link-name">Sign PDF</div><div class="mob-link-desc">Electronic signature</div></div></a>
                <a href="/sign-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📋</span><div><div class="mob-link-name">Sign a Contract</div><div class="mob-link-desc">Electronic signature</div></div></a>
                <a href="/pdf-annotator" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🖍️</span><div><div class="mob-link-name">PDF Annotator</div><div class="mob-link-desc">Highlight and markup</div></div></a>
                <a href="/watermark-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">💧</span><div><div class="mob-link-name">Watermark PDF</div><div class="mob-link-desc">Add watermark text</div></div></a>
                <a href="/redact-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔒</span><div><div class="mob-link-name">Redact PDF</div><div class="mob-link-desc">Remove sensitive info</div></div></a>
                <a href="/fill-pdf-form" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📝</span><div><div class="mob-link-name">Fill PDF Form</div><div class="mob-link-desc">Complete form fields</div></div></a>
                <a href="/number-pages" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔢</span><div><div class="mob-link-name">Number Pages</div><div class="mob-link-desc">Add page numbers</div></div></a>
            </div>
        }
    </div>

    <!-- Accordion: Organize -->
    <div class="mob-section">
        <button class="mob-section-header @(OpenSection == "organize" ? "mob-section-header--open" : "")"
                @onclick='() => ToggleSection("organize")'>
            <div class="mob-section-header-left">
                <span class="mob-section-icon mob-section-icon--teal">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="9" height="10" rx="1" /><rect x="13" y="3" width="9" height="6" rx="1" /><rect x="13" y="13" width="9" height="8" rx="1" /><rect x="2" y="17" width="9" height="4" rx="1" /></svg>
                </span>
                <span>Organize</span>
            </div>
            <svg class="mob-chevron @(OpenSection == "organize" ? "mob-chevron--open" : "")" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6,9 12,15 18,9" /></svg>
        </button>
        @if (OpenSection == "organize")
        {
            <div class="mob-section-body">
                <a href="/merge-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔗</span><div><div class="mob-link-name">Merge PDF</div><div class="mob-link-desc">Combine multiple PDFs</div></div></a>
                <a href="/split-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">✂️</span><div><div class="mob-link-name">Split PDF</div><div class="mob-link-desc">Separate pages</div></div></a>
                <a href="/organize-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📋</span><div><div class="mob-link-name">Organize PDF</div><div class="mob-link-desc">Reorder pages</div></div></a>
                <a href="/extract-pdf-pages" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📌</span><div><div class="mob-link-name">Extract Pages</div><div class="mob-link-desc">Pick specific pages</div></div></a>
                <a href="/delete-pdf-pages" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🗑️</span><div><div class="mob-link-name">Delete Pages</div><div class="mob-link-desc">Remove pages</div></div></a>
                <a href="/rotate-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔄</span><div><div class="mob-link-name">Rotate PDF</div><div class="mob-link-desc">Fix page orientation</div></div></a>
                <a href="/batch" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📦</span><div><div class="mob-link-name">Batch Process</div><div class="mob-link-desc">20 files at once → ZIP</div></div></a>
            </div>
        }
    </div>

    <!-- Accordion: Security -->
    <div class="mob-section">
        <button class="mob-section-header @(OpenSection == "security" ? "mob-section-header--open" : "")"
                @onclick='() => ToggleSection("security")'>
            <div class="mob-section-header-left">
                <span class="mob-section-icon mob-section-icon--slate">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                </span>
                <span>Security</span>
            </div>
            <svg class="mob-chevron @(OpenSection == "security" ? "mob-chevron--open" : "")" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6,9 12,15 18,9" /></svg>
        </button>
        @if (OpenSection == "security")
        {
            <div class="mob-section-body">
                <a href="/lock-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔐</span><div><div class="mob-link-name">Lock PDF</div><div class="mob-link-desc">Password protect files</div></div></a>
                <a href="/unlock-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔓</span><div><div class="mob-link-name">Unlock PDF</div><div class="mob-link-desc">Remove password</div></div></a>
                <a href="/flatten-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">📄</span><div><div class="mob-link-name">Flatten PDF</div><div class="mob-link-desc">Make uneditable</div></div></a>
                <a href="/redact-pdf" class="mob-link" @onclick="CloseMobileMenu"><span class="mob-link-icon">🔒</span><div><div class="mob-link-name">Redact PDF</div><div class="mob-link-desc">Permanently remove sensitive data</div></div></a>
            </div>
        }
    </div>

    <div class="mob-divider"></div>

    <!-- Bottom links -->
    <div class="mob-bottom-links">
        <a href="/pricing" class="mob-bottom-link" @onclick="CloseMobileMenu">Pricing</a>
        <a href="/about" class="mob-bottom-link" @onclick="CloseMobileMenu">About</a>
        <a href="/blog" class="mob-bottom-link" @onclick="CloseMobileMenu">Blog</a>
        <a href="/contact" class="mob-bottom-link" @onclick="CloseMobileMenu">Contact</a>
        <a href="/privacy-policy" class="mob-bottom-link" @onclick="CloseMobileMenu">Privacy</a>
        <a href="/terms-and-conditions" class="mob-bottom-link" @onclick="CloseMobileMenu">Terms</a>
        <a href="/cookie-policy" class="mob-bottom-link" @onclick="CloseMobileMenu">Cookies</a>
        <a href="/security" class="mob-bottom-link" @onclick="CloseMobileMenu">Security</a>
    </div>

</div>

@code {
    private bool MobileMenuOpen = false;
    private string SearchQuery = string.Empty;
    private bool ShowSearchResults = false;
    private string OpenSection = string.Empty;

    private record ToolInfo(string Name, string Description, string Url, string Icon);

    private List<ToolInfo> AllTools = new()
    {
        new("Compress PDF",         "Reduce PDF file size",              "/compress-pdf",            "🗜️"),
        new("PDF to Word",          "Convert PDF to Word",               "/pdf-to-word",             "📝"),
        new("Word to PDF",          "Convert Word to PDF",               "/word-to-pdf",             "📄"),
