    private IEnumerable<ToolInfo> FilteredTools =>
        string.IsNullOrWhiteSpace(SearchQuery)
            ? Enumerable.Empty<ToolInfo>()
            : AllTools.Where(t =>
                t.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                t.Description.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    private void ToggleMobileMenu()
    {
        MobileMenuOpen = !MobileMenuOpen;
        if (!MobileMenuOpen) OpenSection = string.Empty;
    }

    private void CloseMobileMenu()
    {
        MobileMenuOpen = false;
        OpenSection = string.Empty;
    }

    private void ToggleSection(string section) =>
        OpenSection = OpenSection == section ? string.Empty : section;

    private void ShowResults() => ShowSearchResults = true;

    private async Task HideResultsDelayed()
    {
        await Task.Delay(200);
        ShowSearchResults = false;
        StateHasChanged();
    }

    private void ClearSearch()
    {
        SearchQuery = string.Empty;
        ShowSearchResults = false;
        MobileMenuOpen = false;
    }
