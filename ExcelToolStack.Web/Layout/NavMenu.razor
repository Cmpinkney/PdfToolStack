@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<nav class="xl-navbar" id="xlNavbar">
    <div class="xl-navbar-inner">
        <a href="/" class="xl-navbar-brand">
            <div class="xl-logo-mark">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="28" height="28" rx="7" fill="#16A34A"/>
                    <path d="M7 8.5L11.5 14L7 19.5H10.5L14 15.2L17.5 19.5H21L16.5 14L21 8.5H17.5L14 12.8L10.5 8.5H7Z" fill="white"/>
                </svg>
            </div>
            <div class="xl-logo-text">
                <div class="xl-logo-name">
                    <span class="xl-logo-excel">Excel</span><span class="xl-logo-toolstack">ToolStack</span>
                </div>
                <span class="xl-logo-sub">AI SPREADSHEET WORKFLOWS</span>
            </div>
        </a>

        <div class="xl-navbar-links" id="xlNavLinks">
            <a href="/tools" class="xl-nav-link">Tools</a>
            <a href="/invoice-to-excel" class="xl-nav-link">Invoice → Excel</a>
            <a href="/templates" class="xl-nav-link">Templates</a>
            <a href="/blog" class="xl-nav-link">Blog</a>
