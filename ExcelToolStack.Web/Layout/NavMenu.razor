        </div>

        <div class="xl-navbar-actions">
            <ThemeToggle />
            <LoginDisplay />
            <button class="xl-hamburger" id="xlHamburger"
                onclick="document.getElementById('xlNavLinks').classList.toggle('open')"
                aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>
</nav>
