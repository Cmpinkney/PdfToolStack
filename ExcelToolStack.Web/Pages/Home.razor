                <div class="xl-crosssell-tool">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2250F4" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
