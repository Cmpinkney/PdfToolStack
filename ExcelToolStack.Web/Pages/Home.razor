@page "/"
@inject ProductBranding Branding

<PageTitle>@Branding.SiteName - AI Spreadsheet Workflows, Templates, and Tools</PageTitle>
<HeadContent>
    <meta name="description" content="ExcelToolStack is the upcoming AI-first workspace for spreadsheet workflows, Excel templates, everyday productivity tools, and practical how-to guides." />
    <link rel="canonical" href="@Branding.SiteUrl" />
    <meta property="og:title" content="@($"{Branding.SiteName} - AI Spreadsheet Workflows")" />
    <meta property="og:description" content="Plan AI spreadsheet workflows, templates, tools, and guides for everyday Excel productivity." />
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "FAQPage",
      "@@id": "@($"{Branding.SiteUrl}/#faq")",
      "mainEntity": [
        {
          "@@type": "Question",
          "name": "What is ExcelToolStack for?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "ExcelToolStack is positioned for AI spreadsheet workflows including formula generation, cleanup, templates, workbook review, and reporting operations."
          }
        },
        {
          "@@type": "Question",
          "name": "Does ExcelToolStack require an install?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "No. The public ExcelToolStack shell runs in the browser. Individual tool pages describe which workflows are live or planned."
          }
        },
        {
          "@@type": "Question",
          "name": "Can teams use ExcelToolStack?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "The product direction is built for operations, finance, reporting, and spreadsheet-heavy teams that need repeatable workbook workflows."
          }
        }
      ]
    }
    </script>
</HeadContent>

<section class="hero home-hero concept-hero">
    <div class="hero-copy">
        <p class="eyebrow">AI spreadsheet workflow platform</p>
        <h1>AI spreadsheet workflows, templates, and tools for <span class="text-highlight">teams.</span></h1>
        <p class="lead">
            @Branding.SiteName gives spreadsheet-heavy teams a premium workspace for generating formulas,
            cleaning data, packaging reports, and automating Excel workflows.
        </p>
        <div class="hero-actions">
            <a class="button button--primary" href="/ai-excel-formula-generator"><span aria-hidden="true">AI</span> Explore AI Tools</a>
            <a class="button button--secondary" href="/templates"><span aria-hidden="true">T</span> Browse Templates</a>
            <a class="button button--secondary" href="/pricing"><span aria-hidden="true">$</span> View Pricing</a>
        </div>
        <div class="hero-proof" aria-label="Product focus areas">
            <span>AI Powered</span>
            <span>Secure</span>
            <span>No Install</span>
            <span>Works in your browser</span>
        </div>
    </div>
    <ExcelWorkflowHeroVisual />
</section>

<section class="excel-command-center" id="workflows">
    <div class="section-heading section-heading--center">
        <p class="eyebrow">Command center</p>
        <h2>Start with the spreadsheet workflow in front of you.</h2>
        <p>Jump into formula generation, cleanup, conversion, templates, or workflow planning without hunting through a utility directory.</p>
    </div>
    <div class="command-search-shell" aria-label="Spreadsheet workflow search preview">
        <span aria-hidden="true">Search</span>
        <strong>formula for commission, clean CRM export, convert CSV, review workbook...</strong>
    </div>
    <div class="command-hints" aria-label="Popular spreadsheet workflows">
        <a href="/ai-excel-formula-generator">Formula Copilot</a>
        <a href="/clean-excel-data">Clean data</a>
        <a href="/csv-to-excel">CSV to Excel</a>
        <a href="/remove-duplicates-excel">Remove duplicates</a>
        <a href="/templates">Templates</a>
    </div>
</section>

<section class="trust-bar excel-trust-bar" aria-label="ExcelToolStack trust highlights">
    <div class="trust-item">Browser-first workflow previews</div>
    <div class="trust-divider"></div>
    <div class="trust-item">No install required</div>
    <div class="trust-divider"></div>
    <div class="trust-item">Built for workbook review</div>
