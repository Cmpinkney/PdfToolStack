@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>ExcelToolStack — AI Spreadsheet Tools for Teams</PageTitle>
<HeadContent>
    <meta name="description" content="Generate formulas, clean data, convert files, and review workbooks with AI. ExcelToolStack gives spreadsheet-heavy teams a faster, smarter workflow." />
    <meta name="keywords" content="excel formula generator, clean excel data, csv to excel, ai spreadsheet tools, excel workflow automation" />
    <link rel="canonical" href="https://exceltoolstack.com/" />
    <meta property="og:title" content="ExcelToolStack — AI Spreadsheet Tools for Teams" />
    <meta property="og:description" content="Generate formulas, clean data, convert files, and review workbooks with AI." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://exceltoolstack.com/" />
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "SoftwareApplication",
      "name": "ExcelToolStack",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "url": "https://exceltoolstack.com/",
      "description": "AI-powered spreadsheet tools for teams. Generate formulas, clean data, convert CSV files, and review workbooks.",
      "offers": { "@@type": "Offer", "price": "0", "priceCurrency": "USD" }
    }
    </script>
</HeadContent>

<section class="xl-hero-full">
    <div class="xl-hero-full-inner">
        <div class="xl-hero-full-content">
            <div class="xl-hero-pill">
                <span class="xl-hero-pill-dot"></span>
                AI-Powered Spreadsheet Platform
            </div>
            <h1 class="xl-hero-display">
                Stop fighting your
                <span class="xl-hero-display-accent">spreadsheets.</span>
            </h1>
            <p class="xl-hero-body">
                Generate formulas from plain English, clean messy exports,
                convert CSV files, and extract invoice data — without leaving
                your browser.
            </p>
            <div class="xl-hero-full-actions">
                <a href="/ai-excel-formula-generator" class="xl-cta-primary">
                    Try AI Formula Copilot — Free
                </a>
                <a href="/tools" class="xl-cta-ghost">
                    Browse all tools →
                </a>
            </div>
            <div class="xl-hero-trust-inline">
                <span>✓ No install</span>
                <span>✓ No signup for free tools</span>
                <span>✓ Files never stored</span>
            </div>
        </div>
        <div class="xl-hero-full-visual">
            <ExcelWorkflowHeroVisual />
        </div>
    </div>
</section>

<!-- Trust band -->
<div class="xl-trust-band">
    <div class="xl-trust-band-inner">
        <span class="xl-trust-label">Built for teams in</span>
        <div class="xl-trust-items">
            <span>Accounting</span>
            <span>Finance</span>
            <span>Operations</span>
            <span>Sales Ops</span>
            <span>HR</span>
            <span>Real Estate</span>
        </div>
    </div>
</div>

<!-- TOOLS GRID -->
<section class="xl-section xl-tools-section">
    <div class="xl-container">
        <div class="xl-section-header">
            <div class="xl-eyebrow">Core Tools</div>
            <h2>Everything your spreadsheet workflow needs.</h2>
            <p>Four tools that cover the most common — and most painful — parts of working with Excel and CSV files every day.</p>
        </div>
        <div class="xl-tools-grid">
            <a href="/ai-excel-formula-generator" class="xl-tool-card xl-tool-featured">
                <div class="xl-tool-badge">Live — Try it now</div>
                <h3>AI Formula Copilot</h3>
                <p>Describe what you need in plain English. Get the exact Excel or Google Sheets formula with a clear explanation of how it works.</p>
                <span class="xl-tool-link">Open Formula Copilot →</span>
            </a>
            <a href="/clean-excel-data" class="xl-tool-card">
                <h3>Clean Excel Data</h3>
                <p>Remove duplicates, fix formatting, normalize dates, and trim whitespace. Turn messy exports into dependable tables.</p>
                <span class="xl-tool-link">Preview cleanup →</span>
            </a>
            <a href="/csv-to-excel" class="xl-tool-card">
                <h3>CSV to Excel</h3>
                <p>Convert CSV exports from any source into properly structured Excel workbooks ready for analysis, reporting, or handoff.</p>
                <span class="xl-tool-link">Preview converter →</span>
            </a>
            <a href="/remove-duplicates-excel" class="xl-tool-card">
                <h3>Remove Duplicates</h3>
                <p>Identify and remove duplicate rows across any column combination. Preview matches before committing to changes.</p>
                <span class="xl-tool-link">Preview tool →</span>
            </a>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="xl-section xl-how-section">
    <div class="xl-container">
        <div class="xl-section-header">
            <div class="xl-eyebrow">How It Works</div>
            <h2>From messy workbook to clean output in minutes.</h2>
        </div>
        <div class="xl-steps">
            <div class="xl-step">
                <div class="xl-step-num">01</div>
                <h3>Upload or describe your problem</h3>
                <p>Upload an Excel or CSV file, or just describe what formula or transformation you need in plain English.</p>
            </div>
            <div class="xl-step-arrow">→</div>
            <div class="xl-step">
                <div class="xl-step-num">02</div>
                <h3>AI reviews and generates</h3>
                <p>The AI reads your file or prompt and produces the exact formula, cleaned data, or converted file you asked for.</p>
            </div>
            <div class="xl-step-arrow">→</div>
            <div class="xl-step">
                <div class="xl-step-num">03</div>
                <h3>Download and use immediately</h3>
                <p>Download your result as an Excel file or copy the formula directly. No setup, no account required for basic tools.</p>
            </div>
        </div>
    </div>
</section>

<!-- CROSS-SELL -->
