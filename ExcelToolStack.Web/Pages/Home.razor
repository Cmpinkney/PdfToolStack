@page "/"
@inject ProductBranding Branding

<PageTitle>@Branding.SiteName - AI Spreadsheet Workflows, Templates, and Tools</PageTitle>
<HeadContent>
    <meta name="description" content="ExcelToolStack is the upcoming AI-first workspace for spreadsheet workflows, Excel templates, everyday productivity tools, and practical how-to guides." />
    <link rel="canonical" href="@Branding.SiteUrl" />
    <meta property="og:title" content="@($"{Branding.SiteName} - AI Spreadsheet Workflows")" />
    <meta property="og:description" content="Plan AI spreadsheet workflows, templates, tools, and guides for everyday Excel productivity." />
</HeadContent>

<section class="hero">
    <div class="hero-copy">
        <p class="eyebrow">AI spreadsheet workflow platform</p>
        <h1>AI spreadsheet workflows, templates, and tools for modern teams.</h1>
        <p class="lead">
            @Branding.SiteName is being shaped as a premium Excel productivity shell for people who clean data,
            explain numbers, package reports, and keep spreadsheet-heavy work moving without losing rigor.
        </p>
        <div class="hero-actions">
            <a class="button button--primary" href="/ai-excel-formula-generator">Preview Formula Copilot</a>
            <a class="button button--secondary" href="/tools">Explore planned tools</a>
            <a class="button button--secondary" href="/templates">Browse templates</a>
        </div>
        <div class="hero-proof" aria-label="Product focus areas">
            <span>AI-assisted analysis</span>
            <span>Reusable templates</span>
            <span>Workbook quality workflows</span>
        </div>
    </div>
    <div class="workflow-preview" aria-label="AI spreadsheet workflow preview">
        <div class="sheet-toolbar">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div class="sheet-grid">
            @for (var i = 0; i < 36; i++)
            {
                <span class="cell @(i % 7 == 0 ? "cell--accent" : "") @(i is 9 or 10 or 11 or 25 ? "cell--active" : "")"></span>
            }
        </div>
        <div class="ai-panel">
            <p class="mini-label">Workflow draft</p>
            <strong>Quarterly forecast review</strong>
            <span>Normalize imported tabs</span>
            <span>Flag formula drift</span>
            <span>Draft variance commentary</span>
        </div>
    </div>
</section>

<section class="section-shell section-shell--tight">
    <div class="section-heading">
        <p class="eyebrow">Workflow preview</p>
        <h2>Built around the real rhythm of spreadsheet work.</h2>
        <p>
            The public shell sets up the product surface for future AI workflows without connecting processing,
            APIs, billing, or account behavior yet.
        </p>
    </div>
    <div class="workflow-steps">
        <article>
            <span>01</span>
            <h3>Bring structure to messy workbooks</h3>
            <p>Future workflows will focus on imports, inconsistent columns, duplicated tabs, and workbook prep.</p>
        </article>
        <article>
            <span>02</span>
            <h3>Use AI where judgment matters</h3>
            <p>Planned AI surfaces emphasize summaries, review prompts, explanations, and decision-ready notes.</p>
        </article>
        <article>
            <span>03</span>
            <h3>Package repeatable outputs</h3>
            <p>Templates and guides will help turn one-off analysis into repeatable reporting systems.</p>
        </article>
    </div>
</section>

<section class="section-shell">
    <div class="section-heading section-heading--split">
        <div>
            <p class="eyebrow">Future tool categories</p>
            <h2>Planned for everyday Excel productivity and higher-trust work.</h2>
        </div>
        <a class="text-link" href="/tools">View all planned tools</a>
    </div>
    <div class="category-grid">
        <article>
            <span class="category-kicker">Clean</span>
            <h3>Data cleanup workflows</h3>
            <p>Prepare imported sheets, normalize tables, identify duplicates, and make rough data usable.</p>
            <a href="/tools">Explore cleanup tools</a>
        </article>
        <article>
            <span class="category-kicker">Analyze</span>
            <h3>AI Formula Copilot</h3>
            <p>Preview the first tool landing page for generating, explaining, and debugging spreadsheet formulas.</p>
            <a href="/ai-excel-formula-generator">Preview Formula Copilot</a>
        </article>
        <article>
            <span class="category-kicker">Validate</span>
            <h3>Workbook quality checks</h3>
            <p>Future checks for broken formulas, inconsistent ranges, stale tabs, and review-ready handoffs.</p>
            <a href="/tools">Explore validation tools</a>
        </article>
    </div>
</section>

<section class="section-shell section-shell--accent">
    <div class="section-heading section-heading--split">
        <div>
            <p class="eyebrow">Templates</p>
            <h2>Reusable starting points for reporting, operations, and planning.</h2>
            <p>Templates will give teams a cleaner place to begin before automation arrives.</p>
        </div>
        <a class="button button--secondary" href="/templates">Browse templates</a>
    </div>
    <div class="template-strip">
        <article>
            <span>Reporting</span>
            <h3>Monthly KPI pack</h3>
        </article>
        <article>
            <span>Finance</span>
            <h3>Forecast assumptions tracker</h3>
        </article>
        <article>
            <span>Operations</span>
            <h3>Workbook review checklist</h3>
        </article>
    </div>
</section>

<section class="section-shell">
    <div class="section-heading section-heading--split">
        <div>
            <p class="eyebrow">How-to guides</p>
            <h2>Practical writing for people who live in workbooks.</h2>
        </div>
        <a class="text-link" href="/blog">Read the guide preview</a>
    </div>
    <div class="guide-grid">
        <article>
            <span>Guide</span>
            <h3>How to clean imported spreadsheet data before analysis</h3>
            <p>Patterns for turning pasted exports into dependable tables.</p>
            <a href="/blog">View guides</a>
        </article>
        <article>
            <span>Playbook</span>
            <h3>How to make monthly reporting less manual</h3>
            <p>Workflow ideas for repeatable summaries, commentary, and review.</p>
            <a href="/blog">View playbooks</a>
        </article>
    </div>
</section>

<section class="cta-section">
    <p class="eyebrow">Launch preview</p>
    <h2>Explore the public shell before the tools arrive.</h2>
    <p>
        See the planned tool categories, template library, guide structure, and pricing surface while the product
        stays anonymous and processing-free.
    </p>
    <div class="hero-actions">
        <a class="button button--primary" href="/tools">Review tools</a>
        <a class="button button--secondary" href="/pricing">See pricing preview</a>
    </div>
</section>

<section class="feature-band" aria-label="ExcelToolStack positioning">
    <article>
        <span>01</span>
        <h2>AI workflows</h2>
        <p>Positioned for analysis support, commentary, review, and repeatable spreadsheet operations.</p>
    </article>
    <article>
        <span>02</span>
        <h2>Everyday productivity</h2>
        <p>Useful for cleanup, reporting, validation, documentation, and workbook handoff habits.</p>
    </article>
    <article>
        <span>03</span>
        <h2>Templates and guides</h2>
        <p>Structured around reusable assets and practical how-to content, not a thin utility directory.</p>
    </article>
</section>
