@page "/authentication/{Action}"
@inject IConfiguration Configuration

<PageTitle>Authentication - ExcelToolStack</PageTitle>

@if (IsAuthConfigured)
{
    <RemoteAuthenticatorView Action="@Action">
        <LoggingIn>
            <div class="auth-route-shell">
                <div class="auth-route-spinner"></div>
                <p>Signing you in...</p>
            </div>
        </LoggingIn>

        <CompletingLoggingIn>
            <div class="auth-route-shell">
                <div class="auth-route-spinner"></div>
                <p>Completing sign in...</p>
            </div>
        </CompletingLoggingIn>

        <LogOut>
            <div class="auth-route-shell">
                <div class="auth-route-spinner"></div>
                <p>Signing you out...</p>
            </div>
        </LogOut>

        <CompletingLogOut>
            <div class="auth-route-shell">
                <div class="auth-route-spinner"></div>
                <p>Completing sign out...</p>
            </div>
        </CompletingLogOut>

        <LogOutSucceeded>
            <div class="auth-route-shell">
                <p>You have been signed out.</p>
                <a class="button button--primary" href="/">Return home</a>
            </div>
        </LogOutSucceeded>

        <LogInFailed>
            <div class="auth-route-shell">
                <p>Sorry, sign in failed.</p>
                <a class="button button--secondary" href="/">Return home</a>
            </div>
        </LogInFailed>

        <LogOutFailed>
            <div class="auth-route-shell">
                <p>Sorry, sign out failed.</p>
                <a class="button button--secondary" href="/">Return home</a>
            </div>
        </LogOutFailed>
    </RemoteAuthenticatorView>
}
else
{
    <section class="auth-route-shell auth-route-shell--static">
        <p class="eyebrow">Account preview</p>
        <h1>Sign in is not connected yet.</h1>
        <p>
            ExcelToolStack has the account shell ready, but Auth0 settings are not configured for this site.
            Public tools, templates, pricing, and guides remain available.
        </p>
        <div class="hero-actions">
            <a class="button button--primary" href="/account">View account preview</a>
            <a class="button button--secondary" href="/tools">Browse tools</a>
        </div>
    </section>
}

@code {
    [Parameter]
    public string? Action { get; set; }

    private bool IsAuthConfigured =>
        !string.IsNullOrWhiteSpace(Configuration["Auth0:Authority"]) &&
        !string.IsNullOrWhiteSpace(Configuration["Auth0:ClientId"]);
}
