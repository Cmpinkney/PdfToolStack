@page "/pricing"
@inject ProductBranding Branding

<PageTitle>Pricing Preview for AI Spreadsheet Workflows - @Branding.SiteName</PageTitle>
<HeadContent>
    <meta name="description" content="Preview future ExcelToolStack plans for AI spreadsheet workflows, Excel templates, productivity tools, and team-ready workbook operations." />
    <link rel="canonical" href="@($"{Branding.SiteUrl}/pricing")" />
    <meta property="og:title" content="@($"Pricing preview for AI spreadsheet workflows - {Branding.SiteName}")" />
    <meta property="og:description" content="A public pricing preview for planned Excel productivity tools, templates, guides, and team workflows." />
</HeadContent>

<section class="shell-page">
    <p class="eyebrow">Pricing</p>
    <h1>Plans are being prepared for AI-first spreadsheet work.</h1>
    <p class="lead">
        The pricing page is intentionally public and non-transactional for this shell. Checkout, subscriptions,
        account gates, and paid Excel workflows are not connected yet.
    </p>
    <div class="hero-actions">
        <a class="button button--primary" href="/tools">Explore planned tools</a>
        <a class="button button--secondary" href="/templates">Browse templates</a>
    </div>

    <div class="pricing-grid page-grid">
        <article>
            <span>Preview</span>
            <h2>Starter</h2>
            <p>Public guides, category previews, and launch positioning for spreadsheet productivity.</p>
            <a href="/blog">Read public guides</a>
        </article>
        <article class="pricing-plan--featured">
            <span>Planned</span>
            <h2>Pro</h2>
            <p>Future AI workflows, templates, productivity tools, and workbook review experiences.</p>
            <a href="/tools">Review planned tools</a>
        </article>
        <article>
            <span>Future</span>
            <h2>Teams</h2>
            <p>Reserved for shared spreadsheet operations, repeatable reporting, and team workflow support.</p>
            <a href="/templates">Review template library</a>
        </article>
    </div>

    <div class="note-band">
        <p>
            Launch state: anonymous public shell only. No authentication, billing, uploads, workbook processing,
            or API-backed Excel behavior has been added.
        </p>
        <a class="text-link" href="/">Back to product overview</a>
    </div>
</section>
