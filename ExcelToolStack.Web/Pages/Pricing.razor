@page "/pricing"
@inject ProductBranding Branding

<PageTitle>Pricing - @Branding.SiteName</PageTitle>
<HeadContent>
    <meta name="description" content="ExcelToolStack pricing is coming soon. The shell is public while tools and plans are prepared." />
    <link rel="canonical" href="@($"{Branding.SiteUrl}/pricing")" />
</HeadContent>

<section class="shell-page">
    <p class="eyebrow">Pricing</p>
    <h1>Plans are being prepared.</h1>
    <p class="lead">The public shell is live first. Checkout, subscriptions, and paid Excel workflows are not connected yet.</p>
    <div class="placeholder-grid">
        <article><h2>Starter</h2><p>Free public guides and launch previews.</p></article>
        <article><h2>Pro</h2><p>Future AI workflows and productivity tools.</p></article>
        <article><h2>Teams</h2><p>Future shared spreadsheet operations for teams.</p></article>
    </div>
</section>
