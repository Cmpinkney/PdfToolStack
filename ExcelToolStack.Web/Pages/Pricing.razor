@page "/pricing"
@inject ProductBranding Branding

<PageTitle>Pricing — ExcelToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="ExcelToolStack pricing. Free tools with no account required. Pro plan from $19/month unlocks AI Formula Copilot, batch processing, and more." />
    <link rel="canonical" href="@($"{Branding.SiteUrl}/pricing")" />
</HeadContent>

<section class="xl-page-hero">
    <div class="xl-container">
        <div class="xl-page-hero-inner">
            <div class="xl-eyebrow">Pricing</div>
            <h1>Start free. Upgrade when you need more.</h1>
            <p>Core tools work without any account. Pro unlocks AI tools, batch processing, and team features.</p>
        </div>
    </div>
</section>

<section class="xl-section xl-pricing-section">
    <div class="xl-container">
        <div class="xl-pricing-grid">

            <div class="xl-price-card">
                <div class="xl-price-tier">Free</div>
                <div class="xl-price-amount">$0<span>/month</span></div>
                <p class="xl-price-desc">Core tools, no account required.</p>
                <ul class="xl-price-features">
                    <li>CSV to Excel conversion</li>
                    <li>Excel to CSV export</li>
                    <li>Remove duplicates</li>
                    <li>Basic data cleaning</li>
                    <li>No signup required</li>
                    <li>Files processed securely</li>
                </ul>
                <a href="/tools" class="xl-btn-secondary xl-btn-full">Start for free</a>
            </div>

            <div class="xl-price-card xl-price-card--featured">
                <div class="xl-price-badge">Most popular</div>
                <div class="xl-price-tier">Pro</div>
                <div class="xl-price-amount">$19<span>/month</span></div>
                <p class="xl-price-desc">Everything you need for serious spreadsheet work.</p>
                <ul class="xl-price-features">
                    <li>Everything in Free</li>
                    <li>AI Formula Copilot (unlimited)</li>
                    <li>AI workbook review</li>
                    <li>Batch processing</li>
                    <li>Download history (30 days)</li>
                    <li>Priority processing</li>
                    <li>Cloud storage (Google Drive, Dropbox)</li>
                </ul>
                <a href="/pricing" class="xl-btn-primary xl-btn-full">Get Pro — $19/mo</a>
            </div>

            <div class="xl-price-card">
                <div class="xl-price-tier">Bundle</div>
                <div class="xl-price-amount">$29<span>/month</span></div>
                <p class="xl-price-desc">ExcelToolStack Pro + PdfToolStack Pro together.</p>
                <ul class="xl-price-features">
                    <li>Everything in Pro</li>
                    <li>PdfToolStack Pro included</li>
                    <li>AI invoice data extractor</li>
                    <li>AI contract reviewer</li>
                    <li>One subscription, two products</li>
                    <li>Best value for teams</li>
                </ul>
                <a href="/pricing" class="xl-btn-secondary xl-btn-full">Get Bundle — $29/mo</a>
            </div>

            <div class="xl-price-card">
                <div class="xl-price-tier">Teams</div>
                <div class="xl-price-amount">$39<span>/month</span></div>
                <p class="xl-price-desc">5 seats included, $6/mo per additional seat.</p>
                <ul class="xl-price-features">
                    <li>Everything in Bundle</li>
                    <li>5 seats included</li>
                    <li>Shared team workspace</li>
                    <li>Admin usage dashboard</li>
                    <li>Invoice & PO billing</li>
                    <li>Priority support</li>
                </ul>
                <a href="/pricing" class="xl-btn-secondary xl-btn-full">Get Teams — $39/mo</a>
            </div>

        </div>
    </div>
</section>

