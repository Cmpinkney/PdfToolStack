@page "/csv-to-excel"
@using ExcelToolStack.Web.Configuration
@using ExcelToolStack.Web.Services
@inject FormulaApiService ApiService
@inject IJSRuntime JS
@inject ProductBranding Branding

<PageTitle>CSV to Excel Converter — Convert CSV Files Online Free | ExcelToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Convert CSV files to Excel (.xlsx) online for free. Upload your CSV and download a formatted Excel workbook instantly. No signup required." />
    <link rel="canonical" href="https://exceltoolstack.com/csv-to-excel" />
</HeadContent>

<ExcelUpload Accept=".csv"
             ProcessButtonLabel="Convert to Excel"
             ProcessingMessage="Converting your CSV to Excel..."
             ReadyStateMessage="Drop in a CSV to see your Excel preview."
             ReadyStateSubMessage="Column headers are auto-detected and the first row is bolded automatically."
             Steps="@(new[] { "Upload", "Convert", "Process", "Download" })"
             CurrentStep="@_step"
             IsProcessing="@_isProcessing"
             Result="@_result"
             OutputFileName="@_outputFileName"
             OnFileReady="HandleFileReady"
             OnProcessClicked="ConvertAsync"
             OnReset="Reset">

    <SidebarContent>
        <p class="tool-panel__kicker">CONVERSION DETAILS</p>
        <h3 style="margin:0 0 12px;color:var(--text-primary);font-size:1.1rem;font-weight:900;">Smart CSV import</h3>
        <p style="margin:0 0 20px;color:var(--text-muted);font-size:0.9rem;line-height:1.6;">Your CSV is converted to a fully formatted Excel workbook with styled headers and auto-fitted columns.</p>
        <div style="display:grid;gap:12px;">
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Auto header detection</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">First row automatically styled as bold header</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Quoted fields supported</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Commas and line breaks inside quotes handled correctly</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Auto-fit columns</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Column widths adjusted to fit content automatically</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Up to 50MB</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Large CSV files with hundreds of thousands of rows supported</p>
                </div>
