        </div>
    </SidebarContent>

</ExcelUpload>

<section class="section-shell section-shell--accent">
    <div class="section-heading section-heading--center">
        <p class="eyebrow">Use Cases</p>
        <h2>When to convert CSV to Excel</h2>
    </div>
    <div class="workflow-steps">
        <article>
            <span>📊</span>
            <h3>Database exports</h3>
            <p>Turn raw database exports into formatted, sortable workbooks ready for analysis.</p>
        </article>
        <article>
            <span>📋</span>
            <h3>Report formatting</h3>
            <p>Convert flat CSV reports into Excel workbooks with proper column widths and header styling.</p>
        </article>
        <article>
            <span>🔄</span>
            <h3>System migrations</h3>
            <p>Move data between systems that export CSV into Excel-based workflows.</p>
        </article>
    </div>
</section>

<section class="section-shell">
    <div class="section-heading section-heading--center">
        <p class="eyebrow">FAQ</p>
        <h2>Common questions</h2>
    </div>
    <div class="faq-grid">
        <article>
            <h3>What CSV formats are supported?</h3>
            <p>Standard comma-delimited CSV files. Quoted fields, commas inside quotes, and multi-line values are all handled correctly.</p>
        </article>
        <article>
            <h3>Will my column headers be preserved?</h3>
            <p>Yes. The first row of your CSV becomes the header row in Excel, automatically bolded and highlighted.</p>
        </article>
        <article>
            <h3>Is there a file size limit?</h3>
            <p>Up to 50MB on the free tier. Large CSV files with hundreds of thousands of rows are supported.</p>
        </article>
        <article>
            <h3>Are my files stored?</h3>
            <p>No. Files are processed in memory and never stored on disk. Your data stays private.</p>
        </article>
    </div>
</section>

@code {
    private byte[]? _fileBytes;
    private string? _fileName;
    private byte[]? _result;
    private string? _outputFileName;
    private bool _isProcessing;
    private int _step = 1;

    private void HandleFileReady((byte[] Bytes, string FileName) args)
    {
        _fileBytes = args.Bytes;
        _fileName = args.FileName;
        _step = 2;
    }

    private async Task ConvertAsync()
    {
        if (_fileBytes is null || _fileName is null) return;

        _isProcessing = true;
        _step = 3;
        StateHasChanged();

        try
        {
            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(_fileBytes), "file", _fileName);
            var response = await ApiService.PostRawAsync("api/excel/csv-to-excel", content);

            if (response.IsSuccessStatusCode)
            {
                _result = await response.Content.ReadAsByteArrayAsync();
                _outputFileName = Path.GetFileNameWithoutExtension(_fileName) + ".xlsx";
                _step = 4;
            }
        }
        catch { }
        finally { _isProcessing = false; }
    }

    private void Reset()
    {
        _fileBytes = null;
        _fileName = null;
        _result = null;
        _outputFileName = null;
        _isProcessing = false;
        _step = 1;
    }
}
