@page "/clean-excel-data"
@using ExcelToolStack.Web.Configuration
@using ExcelToolStack.Web.Services
@inject FormulaApiService ApiService
@inject IJSRuntime JS
@inject ProductBranding Branding

<PageTitle>Clean Excel Data Online Free — Fix Messy Spreadsheets | ExcelToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Clean messy Excel data online for free. Trim whitespace, remove empty rows, and normalize formatting in any Excel or CSV file instantly." />
    <link rel="canonical" href="https://exceltoolstack.com/clean-excel-data" />
</HeadContent>

<ExcelUpload Accept=".xlsx,.xls,.csv"
             ProcessButtonLabel="Clean Data"
             ProcessingMessage="Cleaning your data..."
             ReadyStateMessage="Drop in a messy Excel or CSV file to clean it up."
             ReadyStateSubMessage="Trims whitespace, removes blank rows, and normalizes formatting in one click."
             Steps="@(new[] { "Upload", "Configure", "Clean", "Download" })"
             CurrentStep="@_step"
             IsProcessing="@_isProcessing"
             Result="@_result"
             OutputFileName="@_outputFileName"
             OnFileReady="HandleFileReady"
             OnProcessClicked="CleanAsync"
             OnReset="Reset">

    <ConfigContent>
        <div style="display:grid;gap:10px;">
            <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Cleaning options</p>
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;color:var(--text-muted);font-size:0.88rem;">
                <input type="checkbox" @bind="_trimWhitespace" style="width:16px;height:16px;accent-color:var(--brand-primary);" />
                Trim extra whitespace from all cells
            </label>
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;color:var(--text-muted);font-size:0.88rem;">
                <input type="checkbox" @bind="_removeEmptyRows" style="width:16px;height:16px;accent-color:var(--brand-primary);" />
                Remove completely empty rows
            </label>
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;color:var(--text-muted);font-size:0.88rem;">
                <input type="checkbox" @bind="_normalizeCase" style="width:16px;height:16px;accent-color:var(--brand-primary);" />
                Normalize text to sentence case
            </label>
        </div>
    </ConfigContent>

    <SidebarContent>
        <p class="tool-panel__kicker">WHAT GETS CLEANED</p>
        <h3 style="margin:0 0 12px;color:var(--text-primary);font-size:1.1rem;font-weight:900;">Data quality issues fixed</h3>
        <p style="margin:0 0 20px;color:var(--text-muted);font-size:0.9rem;line-height:1.6;">Common problems that break formulas, lookups, and reports — fixed automatically.</p>
        <div style="display:grid;gap:12px;">
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Whitespace trimming</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Leading and trailing spaces cause broken lookups — trimmed automatically</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Empty row removal</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Blank rows break sorting and pivot tables — removed cleanly</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Case normalization</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Inconsistent capitalization creates duplicate entries — normalized to sentence case</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Formulas untouched</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Only text cell values are cleaned — numbers, dates, formulas preserved</p>
                </div>
            </div>
        </div>
    </SidebarContent>

</ExcelUpload>

<section class="section-shell section-shell--accent">
    <div class="section-heading section-heading--center">
        <p class="eyebrow">Use Cases</p>
        <h2>When to clean your data</h2>
    </div>
    <div class="workflow-steps">
        <article>
            <span>📥</span>
            <h3>Before importing</h3>
            <p>Clean exports from CRMs, ERPs, and databases before importing into another system.</p>
        </article>
        <article>
            <span>📊</span>
            <h3>Before analysis</h3>
            <p>Inconsistent data breaks pivot tables and VLOOKUP. Clean first, analyze after.</p>
        </article>
        <article>
            <span>🤝</span>
            <h3>Before sharing</h3>
            <p>Clean up messy data before sending reports to clients or teammates.</p>
        </article>
    </div>
</section>

<section class="section-shell">
    <div class="section-heading section-heading--center">
        <p class="eyebrow">FAQ</p>
        <h2>Common questions</h2>
    </div>
    <div class="faq-grid">
        <article>
            <h3>Will my formulas be affected?</h3>
            <p>No. Only text cell values are cleaned. Formulas, numbers, and dates are untouched.</p>
        </article>
        <article>
            <h3>Does it work on CSV files too?</h3>
            <p>Yes. Upload a .csv file and get back a cleaned .csv with the same structure.</p>
        </article>
        <article>
            <h3>What does sentence case do?</h3>
            <p>Converts "john smith" or "JOHN SMITH" to "John smith". Useful for name and address columns.</p>
        </article>
        <article>
            <h3>Are my files stored?</h3>
            <p>No. Files are processed in memory and never stored. Your data stays private.</p>
        </article>
    </div>
</section>

@code {
    private byte[]? _fileBytes;
    private string? _fileName;
    private byte[]? _result;
    private string? _outputFileName;
    private bool _isProcessing;
    private int _step = 1;
    private bool _trimWhitespace = true;
    private bool _removeEmptyRows = true;
    private bool _normalizeCase;

    private void HandleFileReady((byte[] Bytes, string FileName) args)
    {
        _fileBytes = args.Bytes;
        _fileName = args.FileName;
        _step = 2;
    }

    private async Task CleanAsync()
    {
        if (_fileBytes is null || _fileName is null) return;

        _isProcessing = true;
        _step = 3;
        StateHasChanged();

        try
        {
            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(_fileBytes), "file", _fileName);
            var url = $"api/excel/clean-data?trimWhitespace={_trimWhitespace}&removeEmptyRows={_removeEmptyRows}&normalizeCase={_normalizeCase}";
            var response = await ApiService.PostRawAsync(url, content);

            if (response.IsSuccessStatusCode)
            {
                _result = await response.Content.ReadAsByteArrayAsync();
                var ext = _fileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase) ? ".csv" : ".xlsx";
                _outputFileName = Path.GetFileNameWithoutExtension(_fileName) + "_cleaned" + ext;
                _step = 4;
            }
        }
        catch { }
        finally { _isProcessing = false; }
    }

    private void Reset()
    {
        _fileBytes = null;
        _fileName = null;
        _result = null;
        _outputFileName = null;
        _isProcessing = false;
        _step = 1;
        _trimWhitespace = true;
        _removeEmptyRows = true;
        _normalizeCase = false;
    }
}
