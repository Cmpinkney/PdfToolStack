@page "/account"
@inject IConfiguration Configuration
@inject ProductBranding Branding

<PageTitle>Account - @Branding.SiteName</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex" />
</HeadContent>

<section class="account-shell">
    <AuthorizeView>
        <Authorized>
            @{
                var displayName = context.User.Identity?.Name ?? "ExcelToolStack user";
                var email = context.User.FindFirst("email")?.Value ?? "Signed in";
                var picture = context.User.FindFirst("picture")?.Value;
            }

            <div class="account-hero">
                <div>
                    <p class="eyebrow">ExcelToolStack dashboard</p>
                    <h1>Your spreadsheet workspace.</h1>
                    <p class="lead">
                        Account storage, billing, team management, and workbook history are placeholders until
                        the product services are connected.
                    </p>
                </div>

                <div class="account-profile-card">
                    @if (!string.IsNullOrWhiteSpace(picture))
                    {
                        <img src="@picture" alt="@displayName" />
                    }
                    else
                    {
                        <span>@GetInitials(displayName)</span>
                    }
                    <div>
                        <strong>@displayName</strong>
                        <small>@email</small>
                    </div>
                </div>
            </div>

            <div class="account-dashboard-grid">
                <article>
                    <span>Plan</span>
                    <h2>Free preview</h2>
                    <p>Billing is not connected in ExcelToolStack.Web. Pricing remains a public preview page.</p>
                    <a href="/pricing">View pricing</a>
                </article>
                <article>
                    <span>Usage</span>
                    <h2>Formula generation usage</h2>
                    <FormulaUsageMeter Title="Formula Copilot usage" />
                    <p>Usage is tracked locally until the Excel usage API is connected.</p>
                    <a href="/tools">Browse tools</a>
                </article>
                <article>
                    <span>Templates</span>
                    <h2>Template library</h2>
                    <p>Use templates and guides as the starting point for future spreadsheet workflows.</p>
                    <a href="/templates">Open templates</a>
                </article>
            </div>

            <div class="account-workflow-section">
                <div class="section-heading">
                    <p class="eyebrow">Quick actions</p>
                    <h2>Start a spreadsheet workflow.</h2>
                </div>
                <div class="account-workflow-grid">
                    <a href="/ai-excel-formula-generator">
                        <span>AI</span>
                        <strong>Formula Copilot</strong>
                        <small>Generate spreadsheet formulas from plain English.</small>
                    </a>
                    <a href="/clean-excel-data">
                        <span>Clean</span>
                        <strong>Clean Excel Data</strong>
                        <small>Preview cleanup, duplicates, formats, and blank checks.</small>
                    </a>
                    <a href="/csv-to-excel">
                        <span>CSV</span>
                        <strong>CSV to Excel</strong>
                        <small>Review the future file conversion workflow shell.</small>
                    </a>
                    <a href="/blog">
                        <span>Guide</span>
                        <strong>Spreadsheet guides</strong>
                        <small>Read practical workflow and formula guidance.</small>
                    </a>
                </div>
            </div>
        </Authorized>

        <NotAuthorized>
            <div class="account-signin-panel">
                <div class="account-signin-icon" aria-hidden="true">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                </div>
                <p class="eyebrow">Account preview</p>
                <h1>Sign in to view your ExcelToolStack account.</h1>
                @if (IsAuthConfigured)
                {
                    <p>
                        Authentication is available for this environment. Public pages stay anonymous and
                        are never redirected into login automatically.
                    </p>
                    <div class="hero-actions">
                        <a class="button button--primary" href="authentication/login">Sign in</a>
                        <a class="button button--secondary" href="/tools">Browse public tools</a>
                    </div>
                }
                else
                {
                    <p>
                        Auth0 settings are not configured for ExcelToolStack.Web yet. This page is a safe
                        placeholder shell; public tools, pricing, templates, and guides remain crawlable.
                    </p>
                    <div class="hero-actions">
                        <a class="button button--primary" href="/tools">Browse public tools</a>
                        <a class="button button--secondary" href="/pricing">View pricing preview</a>
                    </div>
                }
            </div>
        </NotAuthorized>
    </AuthorizeView>
</section>

@code {
    private bool IsAuthConfigured =>
        !string.IsNullOrWhiteSpace(Configuration["Auth0:Authority"]) &&
        !string.IsNullOrWhiteSpace(Configuration["Auth0:ClientId"]);

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        }

        return name.Length >= 2
            ? name[..2].ToUpperInvariant()
            : name.ToUpperInvariant();
    }
}
