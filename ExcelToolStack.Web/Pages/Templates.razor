@page "/templates"
@inject ProductBranding Branding

<PageTitle>Excel Templates — Reporting, Finance & Operations | ExcelToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Download free Excel templates for reporting, finance, forecasting, and operations. Clean starting points built for teams that work in spreadsheets every day." />
    <link rel="canonical" href="@($"{Branding.SiteUrl}/templates")" />
</HeadContent>

<section class="xl-page-hero">
    <div class="xl-container">
        <div class="xl-page-hero-inner">
            <div class="xl-eyebrow">Templates</div>
            <h1>Reusable starting points for reporting, finance, and operations.</h1>
            <p>Download and customize immediately. Built for teams that run the same workflows every month.</p>
            <div class="xl-hero-actions">
                <a href="/tools" class="xl-btn-primary">Browse all tools</a>
                <a href="/pricing" class="xl-btn-secondary">View Pro plan</a>
            </div>
        </div>
    </div>
</section>

<section class="xl-section" style="background: var(--surface, #fff);">
    <div class="xl-container">
        <div class="xl-section-header">
            <div class="xl-eyebrow">Template Library</div>
            <h2>Ready-to-use Excel templates.</h2>
            <p>Each template is a clean, structured starting point — not a bloated showcase file.</p>
        </div>
        <div class="xl-card-grid">

            <div class="xl-content-card xl-content-card--featured">
                <div class="xl-content-card-kicker">Finance</div>
                <h3>Invoice Tracker</h3>
                <p>Track outstanding invoices, payment status, due dates, and client totals. Built for freelancers and small teams billing 10–50 clients monthly.</p>
                <a href="/tools" class="xl-content-card-link">Download template →</a>
            </div>

            <div class="xl-content-card">
                <div class="xl-content-card-kicker">Reporting</div>
                <h3>Monthly KPI Pack</h3>
                <p>Revenue, pipeline, headcount, and operational metrics in one structured workbook. Designed for monthly reporting handoffs.</p>
                <a href="/tools" class="xl-content-card-link">Download template →</a>
            </div>

            <div class="xl-content-card">
                <div class="xl-content-card-kicker">Finance</div>
                <h3>Cash Flow Forecast</h3>
                <p>13-week rolling cash flow model with actuals vs forecast tracking. Clean enough to share with a CFO or board.</p>
                <a href="/tools" class="xl-content-card-link">Download template →</a>
            </div>

            <div class="xl-content-card">
                <div class="xl-content-card-kicker">Operations</div>
                <h3>Workbook Review Checklist</h3>
                <p>QA checklist for reviewing Excel files before sharing — covers formula consistency, broken references, stale data, and formatting.</p>
                <a href="/tools" class="xl-content-card-link">Download template →</a>
            </div>

            <div class="xl-content-card">
                <div class="xl-content-card-kicker">Planning</div>
                <h3>Forecast Assumptions Tracker</h3>
                <p>Document your model assumptions with owner, confidence level, last updated date, and linked cell reference. Keeps models auditable.</p>
                <a href="/tools" class="xl-content-card-link">Download template →</a>
            </div>

            <div class="xl-content-card">
                <div class="xl-content-card-kicker">AI</div>
                <h3>AI Formula Prompt Library</h3>
                <p>A curated set of plain-English prompts optimized for the AI Formula Copilot. Covers VLOOKUP replacements, conditional sums, date math, and more.</p>
                <a href="/ai-excel-formula-generator" class="xl-content-card-link">Open Formula Copilot →</a>
            </div>

            <div class="xl-content-card">
                <div class="xl-content-card-kicker">Operations</div>
                <h3>SaaS Metrics Dashboard</h3>
                <p>MRR, churn, LTV, CAC, and net revenue retention in one clean workbook. Built for founders and operators tracking monthly SaaS metrics.</p>
                <a href="/tools" class="xl-content-card-link">Download template →</a>
            </div>

        </div>
    </div>
</section>

<section class="xl-footer-cta">
    <div class="xl-container">
        <h2>Need a formula to go with your template?</h2>
        <p>Use the AI Formula Copilot to generate the exact formula your template needs — in plain English.</p>
        <a href="/ai-excel-formula-generator" class="xl-btn-primary xl-btn-large">Try AI Formula Copilot Free →</a>
    </div>
</section>
