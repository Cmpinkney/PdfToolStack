@page "/excel-to-csv"
@using ExcelToolStack.Web.Configuration
@using ExcelToolStack.Web.Services
@inject FormulaApiService ApiService
@inject IJSRuntime JS
@inject ProductBranding Branding

<PageTitle>Excel to CSV Converter — Export Excel to CSV Online Free | ExcelToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Convert Excel files to CSV online for free. Export any sheet from your .xlsx workbook to a clean CSV file instantly. No signup required." />
    <link rel="canonical" href="https://exceltoolstack.com/excel-to-csv" />
</HeadContent>

<ExcelUpload Accept=".xlsx,.xls"
             ProcessButtonLabel="Export to CSV"
             ProcessingMessage="Exporting your Excel sheet to CSV..."
             ReadyStateMessage="Drop in an Excel file to export it to CSV."
             ReadyStateSubMessage="Choose which sheet to export — defaults to the first sheet."
             Steps="@(new[] { "Upload", "Configure", "Export", "Download" })"
             CurrentStep="@_step"
             IsProcessing="@_isProcessing"
             Result="@_result"
             OutputFileName="@_outputFileName"
             OnFileReady="HandleFileReady"
             OnProcessClicked="ConvertAsync"
             OnReset="Reset">

    <ConfigContent>
        <div style="display:grid;gap:8px;">
            <label style="color:var(--text-primary);font-size:0.88rem;font-weight:850;">Sheet name (optional)</label>
            <input type="text" @bind="_sheetName" placeholder="Leave blank for first sheet"
                   style="width:100%;padding:10px 12px;border:1px solid var(--border-subtle);border-radius:8px;background:var(--surface);color:var(--text-primary);font:inherit;font-size:0.88rem;" />
            <p style="margin:0;color:var(--text-muted);font-size:0.8rem;">Leave blank to export the first sheet automatically.</p>
        </div>
    </ConfigContent>

    <SidebarContent>
        <p class="tool-panel__kicker">EXPORT DETAILS</p>
        <h3 style="margin:0 0 12px;color:var(--text-primary);font-size:1.1rem;font-weight:900;">Clean CSV export</h3>
        <p style="margin:0 0 20px;color:var(--text-muted);font-size:0.9rem;line-height:1.6;">Export any sheet from your Excel workbook to a clean, universally compatible CSV file.</p>
        <div style="display:grid;gap:12px;">
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Sheet selection</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Export any named sheet or default to the first</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Values preserved</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Formula results exported as values — no broken references</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">Proper CSV quoting</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Fields with commas or quotes are escaped correctly</p>
                </div>
            </div>
            <div style="display:flex;align-items:start;gap:10px;">
                <span style="display:inline-grid;place-items:center;width:22px;height:22px;border-radius:999px;background:var(--brand-primary-soft);color:var(--brand-primary-strong);font-size:0.7rem;font-weight:900;flex-shrink:0;margin-top:1px;">✓</span>
                <div>
                    <p style="margin:0;color:var(--text-primary);font-size:0.88rem;font-weight:850;">UTF-8 encoded</p>
                    <p style="margin:4px 0 0;color:var(--text-muted);font-size:0.82rem;line-height:1.45;">Compatible with all modern tools, databases, and APIs</p>
                </div>
            </div>
        </div>
    </SidebarContent>

</ExcelUpload>

<section class="section-shell section-shell--accent">
    <div class="section-heading section-heading--center">
        <p class="eyebrow">Use Cases</p>
        <h2>When to export Excel to CSV</h2>
    </div>
    <div class="workflow-steps">
        <article>
            <span>🗄️</span>
            <h3>Database imports</h3>
            <p>Most databases accept CSV for bulk imports. Export your Excel data and import it directly.</p>
        </article>
        <article>
            <span>🔌</span>
            <h3>API data feeds</h3>
            <p>Many APIs and integrations require CSV format. Convert your workbook for seamless data transfer.</p>
        </article>
        <article>
            <span>📱</span>
            <h3>Cross-platform sharing</h3>
            <p>CSV opens in any tool — Google Sheets, Numbers, or any text editor. No Excel required.</p>
        </article>
    </div>
</section>

<section class="section-shell">
    <div class="section-heading section-heading--center">
        <p class="eyebrow">FAQ</p>
        <h2>Common questions</h2>
    </div>
    <div class="faq-grid">
        <article>
            <h3>Which sheet gets exported?</h3>
            <p>By default the first sheet. Enter a sheet name in the field above to export a specific sheet.</p>
        </article>
        <article>
            <h3>Are formulas preserved?</h3>
            <p>CSV stores values only — formula results are preserved but not the formulas themselves.</p>
        </article>
        <article>
            <h3>What about formatting?</h3>
            <p>CSV is plain text — colors, fonts, and cell formatting are not carried over. Data values are always preserved.</p>
        </article>
        <article>
            <h3>Are my files stored?</h3>
            <p>No. Files are processed in memory and never stored. Your data stays private.</p>
        </article>
    </div>
</section>

@code {
    private byte[]? _fileBytes;
    private string? _fileName;
    private byte[]? _result;
    private string? _outputFileName;
    private bool _isProcessing;
    private int _step = 1;
    private string? _sheetName;

    private void HandleFileReady((byte[] Bytes, string FileName) args)
    {
        _fileBytes = args.Bytes;
        _fileName = args.FileName;
        _step = 2;
    }

    private async Task ConvertAsync()
    {
        if (_fileBytes is null || _fileName is null) return;

        _isProcessing = true;
        _step = 3;
        StateHasChanged();

        try
        {
            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(_fileBytes), "file", _fileName);
            var url = string.IsNullOrWhiteSpace(_sheetName)
                ? "api/excel/excel-to-csv"
                : $"api/excel/excel-to-csv?sheetName={Uri.EscapeDataString(_sheetName)}";
            var response = await ApiService.PostRawAsync(url, content);

            if (response.IsSuccessStatusCode)
            {
                _result = await response.Content.ReadAsByteArrayAsync();
                _outputFileName = Path.GetFileNameWithoutExtension(_fileName) + ".csv";
                _step = 4;
            }
        }
        catch { }
        finally { _isProcessing = false; }
    }

    private void Reset()
    {
        _fileBytes = null;
        _fileName = null;
        _result = null;
        _outputFileName = null;
        _isProcessing = false;
        _step = 1;
        _sheetName = null;
    }
}
