@page "/invoice-to-excel"
@inject InvoiceExtractApiService InvoiceApi
@inject IJSRuntime JS
@using System.Text.Json

<PageTitle>PDF Invoice to Excel — Extract Invoice Data | ExcelToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Upload a PDF invoice and get a clean Excel spreadsheet instantly. AI extracts vendor, amount, date, line items automatically. Free to try." />
    <link rel="canonical" href="https://exceltoolstack.com/invoice-to-excel" />
</HeadContent>

<div class="xl-tool-page">
    <div class="xl-container">

        <div class="xl-tool-header">
            <div class="xl-eyebrow">AI Tool</div>
            <h1>PDF Invoice to Excel</h1>
            <p>Upload a PDF invoice. AI extracts vendor name, invoice number, date, due date, line items, and totals — and outputs a clean Excel file instantly. Free — 3 extractions per day, no signup required.</p>
        </div>

        <div class="xl-tool-card-wrap">

            @if (_step == Step.Upload)
            {
                <div class="xl-upload-zone @(_isDragging ? "dragging" : "")"
                     @ondragover:preventDefault
                     @ondragenter="() => _isDragging = true"
                     @ondragleave="() => _isDragging = false"
                     @ondrop="HandleDrop"
                     @ondrop:preventDefault>
                    <InputFile OnChange="HandleFileSelected" accept=".pdf" id="invoiceFileInput" class="xl-file-input" />
                    <label for="invoiceFileInput" class="xl-upload-label">
                        <div class="xl-upload-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div class="xl-upload-text">
                            <strong>Drop your PDF invoice here</strong>
                            <span>or click to browse — up to 25MB</span>
                        </div>
                    </label>
                </div>

                @if (_selectedFile != null)
                {
                    <div class="xl-selected-file">
                        <span class="xl-file-name">@_selectedFile.Name</span>
                        <span class="xl-file-size">@FormatFileSize(_selectedFile.Size)</span>
                    </div>
                    <button class="xl-btn-primary xl-btn-full xl-btn-large" @onclick="ExtractInvoice" disabled="@_isProcessing">
                        @if (_isProcessing)
                        {
                            <span class="xl-spinner"></span>
                            <span>Extracting invoice data...</span>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                            <span>Extract to Excel</span>
                        }
                    </button>
                }
            }

            @if (_step == Step.Success)
            {
                <div class="xl-success-state">
                    <div class="xl-success-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <h3>Invoice extracted successfully</h3>
                    <p>Your Excel file is downloading now. It contains all extracted invoice fields ready for your spreadsheet.</p>
                    <button class="xl-btn-secondary" @onclick="Reset">Extract another invoice</button>
                </div>
            }

            @if (_step == Step.Error)
            {
                <div class="xl-error-state">
                    <p class="xl-error-msg">@_errorMessage</p>
                    <button class="xl-btn-secondary" @onclick="Reset">Try again</button>
                </div>
            }

        </div>

        <div class="xl-tool-features">
            <div class="xl-feature-item">
                <strong>What gets extracted</strong>
                <p>Vendor name, invoice number, invoice date, due date, line items with quantities and unit prices, subtotal, tax, and total amount.</p>
            </div>
            <div class="xl-feature-item">
                <strong>Works on any invoice format</strong>
                <p>The AI reads invoices the way a human would — it finds the relevant fields regardless of where they appear on the page or which vendor sent it.</p>
            </div>
            <div class="xl-feature-item">
                <strong>Privacy first</strong>
                <p>Your invoice is processed over an encrypted connection and deleted immediately after extraction. We never store or train on your documents.</p>
            </div>
        </div>

        <div class="xl-crosssell-banner">
            <div>
                <strong>Also need to work with PDF documents?</strong>
                <p>PdfToolStack handles the other side — compress, merge, sign, redact, and AI contract review.</p>
            </div>
            <a href="https://pdftoolstack.com/extract-invoice-data" class="xl-btn-outline" target="_blank">
                Try on PdfToolStack →
            </a>
        </div>

    </div>
</div>

@code {
    private enum Step { Upload, Success, Error }
    private Step _step = Step.Upload;
    private IBrowserFile? _selectedFile;
    private bool _isProcessing;
    private bool _isDragging;
    private string _errorMessage = string.Empty;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _errorMessage = string.Empty;
    }

    private void HandleDrop(DragEventArgs e)
    {
        _isDragging = false;
    }

    private async Task ExtractInvoice()
    {
        if (_selectedFile == null) return;

        _isProcessing = true;
        _errorMessage = string.Empty;

        try
        {
            var fileBytes = new byte[_selectedFile.Size];
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 26_214_400);
            await stream.ReadExactlyAsync(fileBytes);

            var response = await InvoiceApi.ExtractInvoiceToExcelAsync(
                fileBytes, _selectedFile.Name);

            if (response.IsSuccessStatusCode)
            {
                var excelBytes = await response.Content.ReadAsByteArrayAsync();
                var base64 = Convert.ToBase64String(excelBytes);
                var fileName = _selectedFile.Name.Replace(".pdf", "_extracted.xlsx");
                await JS.InvokeVoidAsync("downloadFile", fileName, base64);
                _step = Step.Success;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
            {
                _errorMessage = await ReadErrorMessageAsync(response)
                    ?? "You've used your 3 free invoice extractions for today. Try again tomorrow.";
                _step = Step.Error;
            }
            else
            {
                _errorMessage = await ReadErrorMessageAsync(response)
                    ?? "Extraction failed. Please check that your file is a readable PDF invoice and try again.";
                _step = Step.Error;
            }
        }
        catch (Exception)
        {
            _errorMessage = "Something went wrong. Please try again.";
            _step = Step.Error;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private static async Task<string?> ReadErrorMessageAsync(HttpResponseMessage response)
    {
        try
        {
            using var stream = await response.Content.ReadAsStreamAsync();
            var doc = await JsonDocument.ParseAsync(stream);
            return doc.RootElement.TryGetProperty("error", out var error)
                ? error.GetString()
                : null;
        }
        catch
        {
            return null;
        }
    }

    private void Reset()
    {
        _step = Step.Upload;
        _selectedFile = null;
        _errorMessage = string.Empty;
        _isProcessing = false;
    }

    private static string FormatFileSize(long bytes)
    {
        return bytes switch
        {
            < 1024 => $"{bytes} B",
            < 1048576 => $"{bytes / 1024.0:F1} KB",
            _ => $"{bytes / 1048576.0:F1} MB"
        };
    }
}

<style>
.xl-tool-page { padding: 3rem 0 5rem; background: var(--xl-bg, #eef0f8); min-height: 80vh; }

.xl-tool-header { text-align: center; margin-bottom: 2rem; }
.xl-tool-header h1 { font-family: 'Plus Jakarta Sans', Inter, sans-serif; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--xl-headline, #172033); letter-spacing: -0.03em; margin: 0.5rem 0 1rem; }
.xl-tool-header p { font-size: 1rem; color: var(--xl-body, #526173); line-height: 1.7; max-width: 560px; margin: 0 auto; }

.xl-tool-card-wrap { background: var(--xl-surface, #fff); border: 1px solid var(--xl-border-solid, #e2e8f0); border-radius: 20px; padding: clamp(1.5rem, 4vw, 2.5rem); max-width: 680px; margin: 0 auto 2rem; box-shadow: 0 8px 32px rgba(0,0,0,0.06); }

.xl-upload-zone { border: 2px dashed var(--xl-border-solid, #e2e8f0); border-radius: 14px; padding: 2.5rem 1.5rem; text-align: center; transition: border-color 0.15s, background 0.15s; cursor: pointer; position: relative; margin-bottom: 1.25rem; }
.xl-upload-zone:hover, .xl-upload-zone.dragging { border-color: #16A34A; background: #f0fdf4; }
.xl-file-input { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }
.xl-upload-label { display: flex; flex-direction: column; align-items: center; gap: 1rem; cursor: pointer; }
.xl-upload-icon { width: 64px; height: 64px; background: #dcfce7; border-radius: 16px; display: flex; align-items: center; justify-content: center; }
.xl-upload-text strong { display: block; font-size: 1rem; font-weight: 700; color: var(--xl-headline, #172033); margin-bottom: 0.25rem; }
.xl-upload-text span { font-size: 0.875rem; color: var(--xl-body, #526173); }

.xl-selected-file { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; margin-bottom: 1rem; }
.xl-file-name { font-size: 0.875rem; font-weight: 600; color: var(--xl-headline, #172033); }
.xl-file-size { font-size: 0.8rem; color: var(--xl-body, #526173); }

.xl-spinner { width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: xl-spin 0.7s linear infinite; }
@@keyframes xl-spin { to { transform: rotate(360deg); } }

.xl-success-state, .xl-error-state { text-align: center; padding: 2rem 1rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
.xl-success-icon { width: 72px; height: 72px; background: #dcfce7; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.xl-success-state h3 { font-family: 'Plus Jakarta Sans', Inter, sans-serif; font-size: 1.25rem; font-weight: 700; color: var(--xl-headline, #172033); margin: 0; }
.xl-success-state p { font-size: 0.9rem; color: var(--xl-body, #526173); margin: 0; max-width: 400px; }
.xl-error-msg { font-size: 0.9rem; color: #dc2626; background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: 0.75rem 1rem; margin: 0; }

.xl-tool-features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; max-width: 900px; margin: 0 auto 2rem; }
.xl-feature-item { background: var(--xl-surface, #fff); border: 1px solid var(--xl-border-solid, #e2e8f0); border-radius: 14px; padding: 1.25rem; }
.xl-feature-item strong { display: block; font-size: 0.9rem; font-weight: 700; color: var(--xl-headline, #172033); margin-bottom: 0.375rem; }
.xl-feature-item p { font-size: 0.84rem; color: var(--xl-body, #526173); line-height: 1.6; margin: 0; }

.xl-crosssell-banner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; background: #EEF2FF; border: 1px solid #C7D2FE; border-radius: 14px; padding: 1.25rem 1.75rem; max-width: 900px; margin: 0 auto; flex-wrap: wrap; }
.xl-crosssell-banner strong { display: block; font-size: 0.9rem; font-weight: 700; color: #172033; margin-bottom: 0.25rem; }
.xl-crosssell-banner p { font-size: 0.84rem; color: #526173; margin: 0; }

@@media (max-width: 720px) {
    .xl-tool-features { grid-template-columns: 1fr; }
    .xl-crosssell-banner { flex-direction: column; text-align: center; }
}
</style>
