@page "/tools"
@inject ProductBranding Branding

<PageTitle>Excel Tools — AI Spreadsheet Workflows | ExcelToolStack</PageTitle>
<HeadContent>
    <meta name="description" content="Generate Excel formulas, clean data, convert CSV files, remove duplicates, and review workbooks with AI. Free tools, no signup required." />
    <link rel="canonical" href="@($"{Branding.SiteUrl}/tools")" />
    <meta property="og:title" content="Excel Tools — AI Spreadsheet Workflows | ExcelToolStack" />
    <meta property="og:description" content="Generate Excel formulas, clean data, convert CSV files, and remove duplicates. Free tools, no signup required." />
</HeadContent>

<section class="xl-tools-hero">
    <div class="xl-container">
        <div class="xl-tools-hero-inner">
            <div class="xl-tools-hero-content">
                <div class="xl-eyebrow">Excel Tools</div>
                <h1>Every tool your spreadsheet workflow needs.</h1>
                <p>Generate formulas, clean messy data, convert files, and review workbooks — all in your browser. Free to start, no signup required for core tools.</p>
                <div class="xl-hero-actions">
                    <a class="xl-btn-primary" href="/ai-excel-formula-generator">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                        Try AI Formula Copilot
                    </a>
                    <a class="xl-btn-secondary" href="/pricing">View pricing</a>
                </div>
            </div>
            <div class="xl-tools-hero-links">
                <div class="xl-workflow-map">
                    <span class="xl-workflow-step">Import</span>
                    <span class="xl-workflow-arrow">→</span>
                    <span class="xl-workflow-step">Clean</span>
                    <span class="xl-workflow-arrow">→</span>
                    <span class="xl-workflow-step xl-workflow-step--active">Formula</span>
                    <span class="xl-workflow-arrow">→</span>
                    <span class="xl-workflow-step">Review</span>
                    <span class="xl-workflow-arrow">→</span>
                    <span class="xl-workflow-step">Report</span>
                </div>
                <div class="xl-quick-links">
                    <a href="/ai-excel-formula-generator">Formula Copilot</a>
                    <a href="/clean-excel-data">Clean Data</a>
                    <a href="/remove-duplicates-excel">Remove Duplicates</a>
                    <a href="/csv-to-excel">CSV to Excel</a>
                    <a href="/excel-to-csv">Excel to CSV</a>
                    <a href="/blog">Guides</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="xl-section xl-tools-grid-section">
    <div class="xl-container">
        <div class="xl-section-header">
            <div class="xl-eyebrow">All Tools</div>
            <h2>Built for the work you actually do in spreadsheets.</h2>
        </div>
        <div class="xl-tools-directory-grid">

            <a href="/ai-excel-formula-generator" class="xl-dir-card xl-dir-card--featured">
                <div class="xl-dir-card-badge">Live — Try it free</div>
                <div class="xl-dir-card-kicker">AI · Formula</div>
                <h3>AI Formula Copilot</h3>
                <p>Describe what you need in plain English. Get the exact Excel or Google Sheets formula with a clear explanation.</p>
                <span class="xl-dir-card-link">Open Formula Copilot →</span>
            </a>

            <a href="/invoice-to-excel" class="xl-dir-card xl-dir-card--featured">
                <div class="xl-dir-card-badge">New — AI Powered</div>
                <div class="xl-dir-card-kicker">AI · Extract</div>
                <h3>PDF Invoice to Excel</h3>
                <p>Upload a PDF invoice. AI extracts vendor, amount, date, and line items — outputs a clean Excel file instantly. Works on any invoice format.</p>
                <span class="xl-dir-card-link">Extract invoice data →</span>
            </a>

            <a href="/clean-excel-data" class="xl-dir-card">
                <div class="xl-dir-card-kicker">Clean</div>
                <h3>Clean Excel Data</h3>
                <p>Remove duplicates, fix formatting, normalize dates, trim whitespace, and handle missing values. Turn messy exports into dependable tables.</p>
                <span class="xl-dir-card-link">Open Clean Data →</span>
            </a>

            <a href="/remove-duplicates-excel" class="xl-dir-card">
                <div class="xl-dir-card-kicker">Deduplicate</div>
                <h3>Remove Duplicates</h3>
                <p>Identify and remove duplicate rows across any column combination. Works for customer lists, CRM exports, SKUs, and email lists.</p>
                <span class="xl-dir-card-link">Open Remove Duplicates →</span>
            </a>

            <a href="/csv-to-excel" class="xl-dir-card">
                <div class="xl-dir-card-kicker">Convert</div>
                <h3>CSV to Excel</h3>
                <p>Convert CSV exports from any source into properly structured Excel workbooks ready for analysis, reporting, or handoff.</p>
                <span class="xl-dir-card-link">Open CSV to Excel →</span>
            </a>

            <a href="/excel-to-csv" class="xl-dir-card">
                <div class="xl-dir-card-kicker">Export</div>
                <h3>Excel to CSV</h3>
                <p>Export Excel workbooks to CSV for database imports, CRM feeds, ecommerce platforms, analytics tools, and lightweight sharing.</p>
                <span class="xl-dir-card-link">Open Excel to CSV →</span>
            </a>

            <a href="/blog" class="xl-dir-card">
                <div class="xl-dir-card-kicker">AI · Analyze</div>
                <h3>AI Workbook Review</h3>
                <p>AI-powered summaries, variance explanations, assumption review, and decision-ready notes for your workbooks. Coming soon.</p>
                <span class="xl-dir-card-link">Read AI guides →</span>
            </a>

            <a href="/templates" class="xl-dir-card">
                <div class="xl-dir-card-kicker">Templates</div>
                <h3>Excel Templates</h3>
                <p>Reporting, finance, and operations templates as clean starting points for recurring work. Download and customize immediately.</p>
                <span class="xl-dir-card-link">Browse templates →</span>
            </a>

            <a href="/pricing" class="xl-dir-card">
                <div class="xl-dir-card-kicker">Pro</div>
                <h3>AI Tools — Pro Plan</h3>
                <p>Unlock AI Formula Copilot, AI workbook review, batch processing, and download history. From $19/month.</p>
                <span class="xl-dir-card-link">View Pro plan →</span>
            </a>

        </div>
    </div>
</section>

<section class="xl-footer-cta">
    <div class="xl-container">
        <h2>Start with the tool in front of you.</h2>
        <p>Free tools work without any account. AI tools and batch processing require Pro.</p>
        <a href="/ai-excel-formula-generator" class="xl-btn-primary xl-btn-large">
            Try AI Formula Copilot Free →
        </a>
    </div>
</section>

<style>
.xl-tools-hero {
    background: linear-gradient(135deg, #eef0f8 0%, #e8f5e9 50%, #eef0f8 100%);
    background-size: 400% 400%;
    animation: xl-gradient-shift 8s ease infinite;
    padding: 2rem 1.5rem 3rem;
}

.xl-tools-hero-inner {
    background: #ffffff;
    border-radius: 24px;
    box-shadow: 0 24px 64px rgba(15, 23, 42, 0.08);
    padding: clamp(2rem, 5vw, 3.5rem) clamp(2rem, 6vw, 5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
}

.xl-tools-hero-content h1 {
    font-family: 'Plus Jakarta Sans', Inter, sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: #172033;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0.5rem 0 1rem;
    border: none !important;
    outline: none !important;
    -webkit-text-stroke: 0 !important;
}

.xl-tools-hero-content p {
    font-size: 0.95rem;
    color: #526173;
    line-height: 1.7;
    margin: 0 0 1.5rem;
}

.xl-workflow-map {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.875rem 1rem;
    margin-bottom: 1rem;
}

.xl-workflow-step {
    font-size: 0.78rem;
    font-weight: 600;
    color: #526173;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
}

.xl-workflow-step--active {
    background: #dcfce7;
    color: #16A34A;
    font-weight: 700;
}

.xl-workflow-arrow {
    font-size: 0.75rem;
    color: #94a3b8;
}

.xl-quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.xl-quick-links a {
    font-size: 0.8rem;
    font-weight: 600;
    color: #526173;
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 99px;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
}

.xl-quick-links a:hover {
    color: #16A34A;
    border-color: #16A34A;
    background: #f0fdf4;
}

.xl-tools-grid-section { background: #ffffff; }

.xl-tools-directory-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
}

.xl-dir-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    position: relative;
}

.xl-dir-card:hover {
    border-color: #16A34A;
    box-shadow: 0 8px 32px rgba(22, 163, 74, 0.1);
    transform: translateY(-2px);
}

.xl-dir-card--featured {
    border-color: #16A34A;
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    grid-column: span 1;
}

.xl-dir-card-badge {
    display: inline-flex;
    width: fit-content;
    background: #16A34A;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 99px;
    margin-bottom: 0.25rem;
}

.xl-dir-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
    flex-shrink: 0;
}

.xl-dir-card-icon--ai { background: #dcfce7; color: #16A34A; }
.xl-dir-card-icon--clean { background: #fef9c3; color: #ca8a04; }
.xl-dir-card-icon--convert { background: #eff6ff; color: #2563eb; }
.xl-dir-card-icon--validate { background: #f3e8ff; color: #9333ea; }
.xl-dir-card-icon--template { background: #fff7ed; color: #ea580c; }

.xl-dir-card-kicker {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94a3b8;
}

.xl-dir-card h3 {
    font-family: 'Plus Jakarta Sans', Inter, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #172033;
    margin: 0;
    line-height: 1.3;
}

.xl-dir-card p {
    font-size: 0.84rem;
    color: #526173;
    line-height: 1.6;
    margin: 0;
    flex: 1;
}

.xl-dir-card-link {
    font-size: 0.82rem;
    font-weight: 700;
    color: #16A34A;
    margin-top: 0.5rem;
}

@@media (max-width: 900px) {
    .xl-tools-hero-inner {
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .xl-tools-directory-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@@media (max-width: 580px) {
    .xl-tools-directory-grid {
        grid-template-columns: 1fr;
    }

    .xl-tools-hero {
        padding: 1.5rem 1rem 2rem;
    }
}
</style>
