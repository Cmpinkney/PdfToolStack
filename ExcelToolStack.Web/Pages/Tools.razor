@page "/tools"
@inject ProductBranding Branding

<PageTitle>Tools - @Branding.SiteName</PageTitle>
<HeadContent>
    <meta name="description" content="ExcelToolStack tools are planned for AI-assisted spreadsheet cleanup, analysis, validation, and workbook workflows." />
    <link rel="canonical" href="@($"{Branding.SiteUrl}/tools")" />
</HeadContent>

<section class="shell-page">
    <p class="eyebrow">Tools</p>
    <h1>Excel tools are not wired yet.</h1>
    <p class="lead">This shell reserves the future tool surface without adding processing code or API behavior.</p>
    <div class="placeholder-grid">
        <article><h2>Clean</h2><p>Future workflows for formatting, columns, duplicates, and broken imports.</p></article>
        <article><h2>Analyze</h2><p>Future AI-assisted summaries, variance explanations, and checks.</p></article>
        <article><h2>Package</h2><p>Future export, documentation, and team handoff flows.</p></article>
    </div>
</section>
