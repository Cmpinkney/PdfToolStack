@inject IConfiguration Configuration
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <div class="profile-menu-wrap">
            <button class="nav-user-chip"
                    type="button"
                    @onclick="ToggleMenu"
                    aria-expanded="@_menuOpen"
                    aria-haspopup="true">
                @if (!string.IsNullOrWhiteSpace(Picture))
                {
                    <img src="@Picture" alt="@DisplayName" class="nav-user-avatar-img" />
                }
                else
                {
                    <span class="nav-user-avatar">@Initials</span>
                }
                <span class="nav-user-name">@FirstName</span>
                <svg class="nav-user-chevron-svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    @if (_menuOpen)
                    {
                        <polyline points="18,15 12,9 6,15" />
                    }
                    else
                    {
                        <polyline points="6,9 12,15 18,9" />
                    }
                </svg>
            </button>

            @if (_menuOpen)
            {
                <div class="profile-dropdown" @onclick:stopPropagation="true">
                    <div class="profile-dropdown-header">
                        @if (!string.IsNullOrWhiteSpace(Picture))
                        {
                            <img src="@Picture" alt="@DisplayName" class="profile-dropdown-avatar" />
                        }
                        else
                        {
                            <div class="profile-dropdown-initials">@Initials</div>
                        }
                        <div class="profile-dropdown-info">
                            <span class="profile-dropdown-name">@DisplayName</span>
                            <span class="profile-dropdown-email">@Email</span>
                        </div>
                    </div>

                    <div class="profile-dropdown-divider"></div>

                    <button class="profile-menu-item" type="button" @onclick='() => NavigateTo("/account")'>
                        <span class="profile-menu-icon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </span>
                        Account
                    </button>

                    <button class="profile-menu-item" type="button" @onclick='() => NavigateTo("/pricing")'>
                        <span class="profile-menu-icon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
                                <line x1="1" y1="10" x2="23" y2="10" />
                            </svg>
                        </span>
                        Pricing
                    </button>

                    <button class="profile-menu-item" type="button" @onclick='() => NavigateTo("/tools")'>
                        <span class="profile-menu-icon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <path d="M3 9h18" />
                                <path d="M9 3v18" />
                            </svg>
                        </span>
                        Spreadsheet tools
                    </button>

                    <div class="profile-dropdown-divider"></div>

                    <button class="profile-menu-item profile-menu-signout" type="button" @onclick="BeginLogout">
                        <span class="profile-menu-icon" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <polyline points="16,17 21,12 16,7" />
                                <line x1="21" y1="12" x2="9" y2="12" />
                            </svg>
                        </span>
                        Sign out
                    </button>
                </div>

                <div class="profile-menu-backdrop" @onclick="CloseMenu"></div>
            }
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="auth-buttons">
            <a href="@SignInHref" class="login-btn">Sign in</a>
            <a href="/account" class="signup-btn">Account</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _menuOpen;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private ClaimsPrincipal? User { get; set; }

    private bool IsAuthConfigured =>
        !string.IsNullOrWhiteSpace(Configuration["Auth0:Authority"]) &&
        !string.IsNullOrWhiteSpace(Configuration["Auth0:ClientId"]);

    private string SignInHref => IsAuthConfigured
        ? "authentication/login"
        : "/account";

    private string DisplayName => User?.Identity?.Name ?? "Account";

    private string FirstName => string.IsNullOrWhiteSpace(DisplayName)
        ? "Account"
        : DisplayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "Account";

    private string Email => User?.FindFirst("email")?.Value ?? "Signed in";

    private string? Picture => User?.FindFirst("picture")?.Value;

    private string Initials => GetInitials(DisplayName);

    protected override async Task OnParametersSetAsync()
    {
        if (AuthenticationStateTask is null)
        {
            return;
        }

        var authState = await AuthenticationStateTask;
        User = authState.User;
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private void CloseMenu() => _menuOpen = false;

    private void NavigateTo(string url)
    {
        CloseMenu();
        Navigation.NavigateTo(url);
    }

    private void BeginLogout()
    {
        CloseMenu();
        Navigation.NavigateTo("authentication/logout");
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        }

        return name.Length >= 2
            ? name[..2].ToUpperInvariant()
            : name.ToUpperInvariant();
    }
}
