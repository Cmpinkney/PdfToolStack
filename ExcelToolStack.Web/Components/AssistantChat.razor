@using Microsoft.JSInterop
@inject FormulaApiService Api
@inject IJSRuntime JS
@inject ILogger<AssistantChat> Logger
@inject ProductBranding Branding

<div class="xl-chat-wrap">

    @if (_open)
    {
        <div class="xl-chat-window">
            <div class="xl-chat-header">
                <div class="xl-chat-header-info">
                    <div class="xl-chat-avatar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" />
                            <path d="M3 9h18M9 21V9" />
                        </svg>
                    </div>
                    <div>
                        <div class="xl-chat-name">Excel Assistant</div>
                        <div class="xl-chat-status">
                            <span class="xl-chat-status-dot"></span>
                            Tell me what you want to do — I'll take you there.
                        </div>
                    </div>
                </div>
                <button class="xl-chat-close" @onclick="Toggle">✕</button>
            </div>

            <div class="xl-chat-messages" id="xlChatMessages">
                @foreach (var msg in _messages)
                {
                    <div class="xl-chat-msg @(msg.IsUser ? "xl-chat-msg-user" : "xl-chat-msg-ai")">
                        @if (!msg.IsUser)
                        {
                            <div class="xl-chat-msg-avatar">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="18" height="18" rx="2" />
                                    <path d="M3 9h18M9 21V9" />
                                </svg>
                            </div>
                        }
                        <div class="xl-chat-msg-bubble">@msg.Text</div>
                    </div>
                }
                @if (_thinking)
                {
                    <div class="xl-chat-msg xl-chat-msg-ai">
                        <div class="xl-chat-msg-avatar">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <path d="M3 9h18M9 21V9" />
                            </svg>
                        </div>
                        <div class="xl-chat-msg-bubble xl-chat-msg-thinking">
                            <span class="chat-dot"></span>
                            <span class="chat-dot"></span>
                            <span class="chat-dot"></span>
                        </div>
                    </div>
                }
            </div>

            @if (_messages.Count == 1 && !_thinking)
            {
                <div class="xl-chat-suggestions">
                    <div class="xl-chat-suggestions-label">Popular workflows</div>
                    <a class="xl-chat-suggestion-btn xl-chat-action-chip" href="/ai-formula-copilot">Generate a formula with AI →</a>
                    <a class="xl-chat-suggestion-btn xl-chat-action-chip" href="/csv-to-excel">Convert CSV to Excel →</a>
                    <a class="xl-chat-suggestion-btn xl-chat-action-chip" href="/remove-duplicates-excel">Remove duplicate rows →</a>
                    <a class="xl-chat-suggestion-btn xl-chat-action-chip" href="/clean-excel-data">Clean messy data →</a>
                    <a class="xl-chat-suggestion-btn xl-chat-action-chip" href="/templates">Browse templates →</a>
                </div>
            }

            <div class="xl-chat-footer">
                Can't find your answer?
                <a href="@SupportMailTo">Email support</a>
            </div>

            <form class="xl-chat-input-row" @onsubmit="Send" @onsubmit:preventDefault="true">
                <input class="xl-chat-input"
                       type="text"
                       placeholder="What do you want to do with your spreadsheet?"
                       @bind="_messageText"
                       @bind:event="oninput"
                       disabled="@_thinking" />
                <button class="xl-chat-send"
                        type="submit"
                        disabled="@(_thinking || string.IsNullOrWhiteSpace(_messageText))">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13" />
                        <polygon points="22,2 15,22 11,13 2,9" />
                    </svg>
                </button>
            </form>
        </div>
    }

    <button class="xl-chat-bubble @(_open ? "open" : "")"
            @onclick="Toggle"
            aria-label="Excel Assistant">
        @if (_open)
        {
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        }
        else
        {
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M3 9h18M9 21V9" />
            </svg>
            @if (_unread > 0)
            {
                <span class="xl-chat-unread">@_unread</span>
            }
        }
    </button>

</div>

@code {
    private bool _open = false;
    private bool _thinking = false;
    private string _messageText = string.Empty;
    private int _unread = 0;
    private List<ChatMsg> _messages = new()
    {
        new("Hi! Tell me what you want to do with your spreadsheet and I'll point you to the right workflow.", false)
    };
    private List<HistoryMsg> _history = new();

    private void Toggle()
    {
        _open = !_open;
        if (_open)
            _unread = 0;
        else
            _thinking = false;
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_messageText) || _thinking) return;

        var msg = _messageText.Trim();
        _messageText = string.Empty;
        _messages.Add(new(msg, true));
        _history.Add(new("user", msg));
        _thinking = true;
        StateHasChanged();

        await Task.Delay(50);
        try { await JS.InvokeVoidAsync("scrollToBottom", "xlChatMessages"); } catch { }

        try
        {
            var requestBody = new SupportChatRequest(
                msg,
                _history.SkipLast(1)
                    .Select(h => new SupportHistoryEntry(h.Role, h.Content))
                    .ToList());

            var result = await Api.PostAsync<SupportChatRequest, SupportResponse>(
                "api/ai/support", requestBody);

            string answer = result?.Answer
                ?? "Sorry, I couldn't process that. Please try again.";

            _messages.Add(new(answer, false));
            _history.Add(new("assistant", answer));

            if (!_open) _unread++;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Excel assistant chat request failed");
            _messages.Add(new(
                $"Something went wrong. Please email {Branding.SupportEmail} for help.",
                false));
        }
        finally
        {
            _thinking = false;
            StateHasChanged();
            try { await JS.InvokeVoidAsync("scrollToBottom", "xlChatMessages"); } catch { }
        }
    }

    private record ChatMsg(string Text, bool IsUser);
    private record HistoryMsg(string Role, string Content);
    private class SupportResponse { public string Answer { get; set; } = string.Empty; }
    private string SupportMailTo => $"mailto:{Branding.SupportEmail}";

    private record SupportChatRequest(string Message, List<SupportHistoryEntry> History);
    private record SupportHistoryEntry(string Role, string Content);
}
