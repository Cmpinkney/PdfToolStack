<div class="hero-visual excel-workflow-hero" aria-label="AI spreadsheet workflow visualization">
    <div class="excel-flow-shell">
        <div class="excel-flow-ambient" aria-hidden="true"></div>

        <nav class="excel-flow-steps" aria-label="Workflow steps">
            <span>Import data</span>
            <span class="is-active">AI review</span>
            <span>Clean workbook</span>
            <span>Package report</span>
        </nav>

        <div class="excel-flow-stage">
            <svg class="excel-flow-connectors" viewBox="0 0 616 554" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                <defs>
                    <filter id="excelFlowLineGlow" x="-20%" y="-80%" width="140%" height="260%" color-interpolation-filters="sRGB">
                        <feGaussianBlur stdDeviation="1.3" result="blur" />
                        <feMerge>
                            <feMergeNode in="blur" />
                            <feMergeNode in="SourceGraphic" />
                        </feMerge>
                    </filter>
                    <filter id="excelFlowDotGlow" x="-160%" y="-160%" width="420%" height="420%" color-interpolation-filters="sRGB">
                        <feGaussianBlur stdDeviation="1.4" result="blur" />
                        <feMerge>
                            <feMergeNode in="blur" />
                            <feMergeNode in="SourceGraphic" />
                        </feMerge>
                    </filter>
                    <marker id="excelFlowArrowFormula" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="excel-flow-arrowhead excel-flow-arrowhead--formula" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                    <marker id="excelFlowArrowClean" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="excel-flow-arrowhead excel-flow-arrowhead--clean" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                    <marker id="excelFlowArrowTemplate" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="excel-flow-arrowhead excel-flow-arrowhead--template" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                    <marker id="excelFlowArrowReport" viewBox="0 0 8 8" refX="7.1" refY="4" markerWidth="8" markerHeight="8" markerUnits="userSpaceOnUse" orient="auto" overflow="visible">
                        <path class="excel-flow-arrowhead excel-flow-arrowhead--report" d="M1.2 1.25 L7 4 L1.2 6.75 Z" />
                    </marker>
                </defs>

                <path class="excel-flow-line excel-flow-line--formula" id="excelFlowPathFormula" d="M244 187 C286 187 308 147 356 147" marker-end="url(#excelFlowArrowFormula)" />
                <path class="excel-flow-line excel-flow-line--clean" id="excelFlowPathClean" d="M244 258 C286 258 308 256 356 256" marker-end="url(#excelFlowArrowClean)" />
                <path class="excel-flow-line excel-flow-line--template" id="excelFlowPathTemplate" d="M244 328 C286 328 308 364 356 364" marker-end="url(#excelFlowArrowTemplate)" />
                <path class="excel-flow-line excel-flow-line--report" id="excelFlowPathReport" d="M244 392 C286 392 306 470 356 472" marker-end="url(#excelFlowArrowReport)" />

                <g filter="url(#excelFlowDotGlow)">
                    <circle class="excel-flow-source-dot excel-flow-source-dot--formula" cx="244" cy="187" r="3" />
                    <circle class="excel-flow-source-dot excel-flow-source-dot--clean" cx="244" cy="258" r="3" />
                    <circle class="excel-flow-source-dot excel-flow-source-dot--template" cx="244" cy="328" r="3" />
                    <circle class="excel-flow-source-dot excel-flow-source-dot--report" cx="244" cy="392" r="3" />
                </g>
            </svg>

            <article class="excel-source-card" aria-label="Uploaded workbook preview">
                <div class="excel-source-header">
                    <span class="excel-file-mark" aria-hidden="true">XLS</span>
                    <span class="excel-status">AI checking</span>
                </div>

                <div class="excel-sheet-preview" aria-hidden="true">
                    <div class="excel-sheet-row excel-sheet-row--head">
                        <span>Dept</span>
                        <span>Revenue</span>
                        <span>Status</span>
                    </div>
                    @for (var i = 0; i < 5; i++)
                    {
                        <div class="excel-sheet-row">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    }
                    <div class="excel-scan-line"></div>
                </div>

                <div class="excel-file-meta">
                    <strong>Ops_Report_May.xlsx</strong>
                    <span>18 tabs</span>
                </div>
                <p>Rows, formulas, duplicates, and reporting notes reviewed before handoff.</p>
                <div class="excel-source-progress" aria-hidden="true"><span></span></div>
            </article>

            <div class="excel-output-stack">
                <article class="excel-output-card excel-output-card--formula">
                    <span class="excel-output-icon" aria-hidden="true">fx</span>
                    <div>
                        <span>Formula logic</span>
                        <strong>=SUMIFS by region</strong>
                        <i aria-hidden="true"></i>
                    </div>
                    <span class="excel-output-meter" aria-hidden="true"></span>
                </article>

                <article class="excel-output-card excel-output-card--clean">
                    <span class="excel-output-icon" aria-hidden="true">OK</span>
                    <div>
                        <span>Clean data</span>
                        <strong>42 duplicates flagged</strong>
                        <i aria-hidden="true"></i>
                    </div>
                    <span class="excel-output-meter" aria-hidden="true"></span>
                </article>

                <article class="excel-output-card excel-output-card--template">
                    <span class="excel-output-icon" aria-hidden="true">KPI</span>
                    <div>
                        <span>Template pack</span>
                        <strong>Monthly report ready</strong>
                        <i aria-hidden="true"></i>
                    </div>
                    <span class="excel-output-meter" aria-hidden="true"></span>
                </article>

                <article class="excel-output-card excel-output-card--report">
                    <span class="excel-output-icon" aria-hidden="true">AI</span>
                    <div>
                        <span>Review notes</span>
                        <strong>5 variance flags found</strong>
                        <i aria-hidden="true"></i>
                    </div>
                    <span class="excel-output-meter" aria-hidden="true"></span>
                </article>
            </div>
        </div>
    </div>
</div>

<style>
    .excel-workflow-hero {
        width: 100%;
        min-width: 0;
        min-height: 0;
        --excel-flow-formula: #0f5b3d;
        --excel-flow-clean: #06b6d4;
        --excel-flow-template: #f59e0b;
        --excel-flow-report: #2563eb;
        --excel-flow-ink: var(--text-primary, #0b1220);
        --excel-flow-muted: var(--text-muted, #53617a);
        --excel-flow-line: rgba(148, 163, 184, 0.22);
    }

    .excel-flow-shell {
        position: relative;
        width: min(616px, 100%);
        aspect-ratio: 616 / 554;
        min-height: 0;
        margin-inline: auto;
        overflow: hidden;
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 8px;
        background:
            radial-gradient(circle at 72% 16%, rgba(6, 182, 212, 0.12), transparent 34%),
            radial-gradient(circle at 31% 45%, rgba(34, 197, 94, 0.14), transparent 34%),
            linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(246, 252, 248, 0.9) 52%, rgba(247, 251, 255, 0.96));
        box-shadow: 0 28px 74px rgba(15, 91, 61, 0.14);
        isolation: isolate;
    }

    .excel-flow-shell::before {
        position: absolute;
        inset: 74px 30px 28px;
        z-index: -1;
        background-image: radial-gradient(circle, rgba(15, 91, 61, 0.18) 1px, transparent 1.2px);
        background-size: 18px 18px;
        content: "";
        mask-image: linear-gradient(180deg, transparent, #000 18%, #000 88%, transparent);
        pointer-events: none;
    }

    .excel-flow-ambient {
        position: absolute;
        left: 130px;
        top: 92px;
        z-index: -1;
        width: 390px;
        height: 390px;
        border-radius: 999px;
        background:
            radial-gradient(circle at 42% 42%, rgba(34, 197, 94, 0.18), transparent 38%),
            radial-gradient(circle at 66% 62%, rgba(6, 182, 212, 0.12), transparent 44%);
        filter: blur(8px);
        opacity: 0.8;
        animation: excelFlowAmbient 12s ease-in-out infinite alternate;
        pointer-events: none;
    }

    .excel-flow-steps {
        position: absolute;
        top: 14px;
        left: 22px;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0;
        width: calc(100% - 44px);
        min-height: 42px;
        margin: 0;
        padding: 5px 18px;
        border: 1px solid rgba(226, 232, 240, 0.88);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
        backdrop-filter: blur(18px);
    }

    .excel-flow-steps span {
        position: relative;
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0.32rem 0.46rem;
        border-radius: 999px;
        color: #475569;
        font-size: 0.73rem;
        font-weight: 850;
        white-space: nowrap;
    }

    .excel-flow-steps span:not(:last-child) {
        margin-right: 28px;
    }

    .excel-flow-steps span:not(:last-child)::after {
        position: absolute;
        top: 50%;
        right: -20px;
        color: #64748b;
        content: "->";
        font-size: 0.74rem;
        font-weight: 900;
        opacity: 0.74;
        transform: translateY(-52%);
    }

    .excel-flow-steps .is-active {
        border: 1px solid rgba(15, 91, 61, 0.18);
        background: rgba(232, 244, 238, 0.94);
        color: var(--excel-flow-formula);
        box-shadow: 0 0 0 1px rgba(15, 91, 61, 0.08), 0 10px 28px rgba(15, 91, 61, 0.14);
        animation: excelFlowStepPulse 3.2s ease-in-out infinite;
    }

    .excel-flow-stage {
        position: absolute;
        inset: 0;
        z-index: 2;
        width: 100%;
        height: 100%;
    }

    .excel-flow-connectors {
        position: absolute;
        inset: 0;
        z-index: 4;
        width: 100% !important;
        height: 100% !important;
        overflow: visible;
        pointer-events: none;
    }

    .excel-flow-line {
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 2;
        stroke-dasharray: 3.5 8;
        opacity: 0.86;
        filter: url(#excelFlowLineGlow);
        animation: excelFlowLineTravel 4.8s linear infinite;
    }

    .excel-flow-line--formula,
    .excel-flow-arrowhead--formula { stroke: var(--excel-flow-formula); }
    .excel-flow-line--clean,
    .excel-flow-arrowhead--clean { stroke: var(--excel-flow-clean); animation-delay: -0.6s; }
    .excel-flow-line--template,
    .excel-flow-arrowhead--template { stroke: var(--excel-flow-template); animation-delay: -1.2s; }
    .excel-flow-line--report,
    .excel-flow-arrowhead--report { stroke: var(--excel-flow-report); animation-delay: -1.8s; }

    .excel-flow-arrowhead {
        stroke: none;
    }

    .excel-flow-arrowhead--formula,
    .excel-flow-source-dot--formula { fill: var(--excel-flow-formula); }
    .excel-flow-arrowhead--clean,
    .excel-flow-source-dot--clean { fill: var(--excel-flow-clean); }
    .excel-flow-arrowhead--template,
    .excel-flow-source-dot--template { fill: var(--excel-flow-template); }
    .excel-flow-arrowhead--report,
    .excel-flow-source-dot--report { fill: var(--excel-flow-report); }

    .excel-source-card,
    .excel-output-card {
        border: 1px solid rgba(226, 232, 240, 0.8);
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 20px 44px rgba(15, 23, 42, 0.09), inset 0 1px 0 rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(18px) saturate(135%);
    }

    .excel-source-card {
        position: absolute;
        left: 4.2%;
        top: 27.1%;
        z-index: 3;
        width: 35%;
        min-width: 0;
        height: 61.2%;
        padding: 22px 16px 20px;
        border-radius: 8px;
        animation: excelFlowFloat 7.2s ease-in-out infinite;
    }

    .excel-source-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 18px;
    }

    .excel-file-mark {
        display: grid;
        place-items: center;
        width: 32px;
        height: 38px;
        border-radius: 6px;
        background: linear-gradient(135deg, #22c55e 0%, #0f5b3d 100%);
        box-shadow: 0 10px 20px rgba(15, 91, 61, 0.22);
        color: #fff;
        font-size: 0.58rem;
        font-weight: 950;
    }

    .excel-status {
        display: inline-flex;
        align-items: center;
        min-height: 25px;
        padding: 0.22rem 0.5rem;
        border: 1px solid rgba(6, 182, 212, 0.18);
        border-radius: 999px;
        background: rgba(236, 254, 255, 0.9);
        color: #0e7490;
        font-size: 0.66rem;
        font-weight: 850;
        white-space: nowrap;
        animation: excelFlowStatusPulse 3.6s ease-in-out infinite;
    }

    .excel-sheet-preview {
        position: relative;
        display: grid;
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: 8px;
        background: rgba(248, 250, 252, 0.9);
    }

    .excel-sheet-row {
        display: grid;
        grid-template-columns: 0.85fr 1fr 0.75fr;
    }

    .excel-sheet-row span {
        min-height: 21px;
        border-right: 1px solid rgba(148, 163, 184, 0.2);
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        background:
            linear-gradient(90deg, rgba(226, 232, 240, 0.74), rgba(226, 232, 240, 0.34));
        color: transparent;
    }

    .excel-sheet-row span:last-child {
        border-right: 0;
    }

    .excel-sheet-row--head span {
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        padding-inline: 5px;
        background: rgba(232, 244, 238, 0.92);
        color: #0f5b3d;
        font-size: 0.48rem;
        font-weight: 950;
    }

    .excel-sheet-row:nth-child(3) span:nth-child(2),
    .excel-sheet-row:nth-child(5) span:nth-child(3) {
        background: rgba(245, 158, 11, 0.18);
    }

    .excel-scan-line {
        position: absolute;
        left: 0;
        right: 0;
        top: -28%;
        height: 38px;
        border-top: 1px solid rgba(6, 182, 212, 0.2);
        border-bottom: 1px solid rgba(34, 197, 94, 0.18);
        background:
            linear-gradient(180deg, transparent, rgba(6, 182, 212, 0.1), transparent),
            linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.62), transparent);
        animation: excelFlowScan 4.2s ease-in-out infinite;
    }

    .excel-file-meta {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 4px;
        align-items: baseline;
        margin-top: 12px;
    }

    .excel-file-meta strong {
        min-width: 0;
        overflow: hidden;
        color: var(--excel-flow-ink);
        font-size: 0.68rem;
        line-height: 1.25;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .excel-file-meta span {
        color: var(--excel-flow-muted);
        font-size: 0.54rem;
        font-weight: 850;
        white-space: nowrap;
    }

    .excel-source-card p {
        margin: 7px 0 0;
        color: var(--excel-flow-muted);
        font-size: 0.68rem;
        line-height: 1.55;
    }

    .excel-source-progress {
        height: 5px;
        overflow: hidden;
        margin-top: 12px;
        border-radius: 999px;
        background: rgba(226, 232, 240, 0.88);
    }

    .excel-source-progress span {
        display: block;
        width: 72%;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--excel-flow-formula), var(--excel-flow-clean), var(--excel-flow-template));
        transform-origin: left center;
        animation: excelFlowProgress 4.4s ease-in-out infinite;
    }

    .excel-output-stack {
        position: absolute;
        top: 18%;
        right: 3.1%;
        z-index: 3;
        display: grid;
        align-content: start;
        gap: 14px;
        width: 40.3%;
    }

    .excel-output-card {
        --accent: var(--excel-flow-formula);
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr) 30px;
        align-items: center;
        gap: 14px;
        min-width: 0;
        min-height: 94px;
        padding: 16px 14px;
        border-radius: 8px;
    }

    .excel-output-card--clean {
        --accent: var(--excel-flow-clean);
    }

    .excel-output-card--template {
        --accent: var(--excel-flow-template);
    }

    .excel-output-card--report {
        --accent: var(--excel-flow-report);
    }

    .excel-output-icon {
        display: grid;
        place-items: center;
        width: 42px;
        height: 42px;
        border-radius: 8px;
        background: color-mix(in srgb, var(--accent) 11%, white);
        color: var(--accent);
        font-size: 0.66rem;
        font-weight: 950;
    }

    .excel-output-card div {
        min-width: 0;
    }

    .excel-output-card div > span {
        display: block;
        color: #475569;
        font-size: 0.62rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .excel-output-card strong {
        display: block;
        margin-top: 4px;
        color: var(--excel-flow-ink);
        font-size: 0.78rem;
        line-height: 1.24;
        overflow-wrap: anywhere;
    }

    .excel-output-card i {
        display: block;
        height: 4px;
        overflow: hidden;
        margin-top: 9px;
        border-radius: 999px;
        background: rgba(226, 232, 240, 0.86);
    }

    .excel-output-card i::before {
        display: block;
        width: 42%;
        height: 100%;
        border-radius: inherit;
        background: var(--accent);
        content: "";
        opacity: 0.34;
        animation: excelFlowLoader 3.4s ease-in-out infinite;
    }

    .excel-output-meter {
        position: relative;
        display: grid;
        place-items: center;
        width: 30px;
        height: 30px;
        border-radius: 999px;
        background: conic-gradient(var(--accent) 0 78%, rgba(226, 232, 240, 0.92) 78% 100%);
        animation: excelFlowMeterSpin 8.5s linear infinite;
    }

    .excel-output-meter::before {
        position: absolute;
        inset: 5px;
        border-radius: inherit;
        background: rgba(255, 255, 255, 0.96);
        content: "";
    }

    .excel-output-meter::after {
        position: relative;
        z-index: 1;
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 8px var(--accent);
        content: "";
        animation: excelFlowMeterPulse 2.6s ease-in-out infinite;
    }

    @@keyframes excelFlowAmbient {
        0% { opacity: 0.62; transform: translate3d(-1%, -1%, 0) scale(0.98); }
        100% { opacity: 0.88; transform: translate3d(1%, 1%, 0) scale(1.02); }
    }

    @@keyframes excelFlowStepPulse {
        0%, 100% { box-shadow: 0 0 0 1px rgba(15, 91, 61, 0.08), 0 10px 24px rgba(15, 91, 61, 0.12); }
        50% { box-shadow: 0 0 0 1px rgba(15, 91, 61, 0.14), 0 12px 32px rgba(15, 91, 61, 0.2); }
    }

    @@keyframes excelFlowLineTravel {
        to { stroke-dashoffset: -46; }
    }

    @@keyframes excelFlowFloat {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }

    @@keyframes excelFlowStatusPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.12), 0 0 0 rgba(6, 182, 212, 0); }
        50% { box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.08), 0 0 14px rgba(6, 182, 212, 0.16); }
    }

    @@keyframes excelFlowScan {
        0% { opacity: 0; transform: translateY(-14px); }
        18%, 74% { opacity: 1; }
        100% { opacity: 0; transform: translateY(190px); }
    }

    @@keyframes excelFlowProgress {
        0%, 100% { opacity: 0.72; transform: scaleX(0.68); }
        50% { opacity: 1; transform: scaleX(1); }
    }

    @@keyframes excelFlowLoader {
        0% { transform: translateX(-110%); }
        55%, 100% { transform: translateX(245%); }
    }

    @@keyframes excelFlowMeterPulse {
        0%, 100% { opacity: 0.62; transform: scale(0.86); }
        50% { opacity: 1; transform: scale(1.15); }
    }

    @@keyframes excelFlowMeterSpin {
        to { transform: rotate(360deg); }
    }

    [data-theme="dark"] .excel-flow-shell {
        border-color: rgba(148, 163, 184, 0.18);
        background:
            radial-gradient(circle at 76% 17%, rgba(6, 182, 212, 0.16), transparent 35%),
            radial-gradient(circle at 31% 46%, rgba(34, 197, 94, 0.2), transparent 36%),
            linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(17, 35, 32, 0.88) 52%, rgba(13, 31, 42, 0.94));
        box-shadow: 0 28px 72px rgba(2, 8, 23, 0.28);
    }

    [data-theme="dark"] .excel-flow-shell::before {
        background-image: radial-gradient(circle, rgba(187, 247, 208, 0.16) 1px, transparent 1.2px);
        opacity: 0.72;
    }

    [data-theme="dark"] .excel-flow-steps,
    [data-theme="dark"] .excel-source-card,
    [data-theme="dark"] .excel-output-card {
        border-color: rgba(148, 163, 184, 0.16);
        background: rgba(15, 23, 42, 0.76);
        box-shadow: 0 18px 42px rgba(2, 8, 23, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    }

    [data-theme="dark"] .excel-flow-steps span,
    [data-theme="dark"] .excel-output-card div > span,
    [data-theme="dark"] .excel-file-meta span,
    [data-theme="dark"] .excel-source-card p {
        color: #b7c6da;
    }

    [data-theme="dark"] .excel-flow-steps .is-active {
        border-color: rgba(34, 197, 94, 0.26);
        background: rgba(17, 55, 38, 0.86);
        color: #86efac;
    }

    [data-theme="dark"] .excel-sheet-preview,
    [data-theme="dark"] .excel-output-card i,
    [data-theme="dark"] .excel-source-progress {
        border-color: rgba(148, 163, 184, 0.16);
        background: rgba(15, 23, 42, 0.42);
